load "common.pk";
load "ohdr_msgs.pk";

var ohdr_msg_failures = 0;

fun expect_ohdr_msg = (string name, int cond) void:
{
    if (cond)
        printf("PASS %s\n", name);
    else
        {
            printf("FAIL %s\n", name);
            ohdr_msg_failures = ohdr_msg_failures + 1;
        }
}

/* Keep the payloads compact while still exercising file-width handling. */
set_global_sizeof_offsets(4UB);
set_global_sizeof_lengths(4UB);

/* Hard links omit the link-type byte and end in an object-header address. */
var hard_blob = [1UB, 0UB, 1UB, 104UB,
                 120UB, 86UB, 52UB, 18UB];
var hard_ios = open("*unit-ohdr-link-hard*");
byte[hard_blob'length] @ hard_ios : 0#B = hard_blob;
var hard_link = oh_msg_link @ hard_ios : 0#B;
expect_ohdr_msg("link_hard_payload",
                hard_link'size/#B == hard_blob'length
                && hard_link.lnk_name'length == 1
                && hard_link.lnk_name[0] == 'h'
                && bytes_to_u64_le(hard_link.ohdr_addr_raw) == 0x12345678UL);
close(hard_ios);

/* Soft links carry a uint16 length and a non-null-terminated target. */
var soft_blob = [1UB, 8UB, 1UB, 1UB, 120UB,
                 3UB, 0UB, 97UB, 98UB, 99UB];
var soft_ios = open("*unit-ohdr-link-soft*");
byte[soft_blob'length] @ soft_ios : 0#B = soft_blob;
var soft_link = oh_msg_link @ soft_ios : 0#B;
expect_ohdr_msg("link_soft_payload",
                soft_link'size/#B == soft_blob'length
                && soft_link.lnk_type == LNK_TYPE_SOFT
                && soft_link.soft_len == 3UH
                && soft_link.soft_name'length == 3
                && soft_link.soft_name[0] == 'a'
                && soft_link.soft_name[2] == 'c');
close(soft_ios);

/* External links use link type 64 and store their encoded value in ud_data. */
var external_blob = [1UB, 8UB, 64UB, 1UB, 120UB,
                     4UB, 0UB, 0UB, 102UB, 0UB, 0UB];
var external_ios = open("*unit-ohdr-link-external*");
byte[external_blob'length] @ external_ios : 0#B = external_blob;
var external_link = oh_msg_link @ external_ios : 0#B;
expect_ohdr_msg("link_external_payload",
                external_link'size/#B == external_blob'length
                && external_link.lnk_type == LNK_TYPE_EXT
                && external_link.ud_len == 4UH
                && external_link.ud_data'length == 4
                && external_link.ud_data[1] == 'f');
close(external_ios);

/* Values above 64 are user-defined links and share the ud_data layout. */
var user_blob = [1UB, 8UB, 65UB, 1UB, 117UB,
                 2UB, 0UB, 65UB, 66UB];
var user_ios = open("*unit-ohdr-link-user-defined*");
byte[user_blob'length] @ user_ios : 0#B = user_blob;
var user_link = oh_msg_link @ user_ios : 0#B;
expect_ohdr_msg("link_user_defined_payload",
                user_link'size/#B == user_blob'length
                && user_link.lnk_type == 65UB
                && user_link.ud_len == 2UH
                && user_link.ud_data'length == 2
                && user_link.ud_data[0] == 'A'
                && user_link.ud_data[1] == 'B');
close(user_ios);

/* A v1 dataspace stores one maximum dimension per declared dimension. */
var dspace_max_blob =
    [1UB, 2UB, 1UB, 0UB, 0UB, 0UB, 0UB, 0UB,
     3UB, 0UB, 0UB, 0UB, 4UB, 0UB, 0UB, 0UB,
     5UB, 0UB, 0UB, 0UB, 6UB, 0UB, 0UB, 0UB];
var dspace_max_ios = open("*unit-ohdr-dspace-v1-max*");
byte[dspace_max_blob'length] @ dspace_max_ios : 0#B = dspace_max_blob;
var dspace_max = oh_msg_sdspace @ dspace_max_ios : 0#B;
expect_ohdr_msg("dataspace_v1_max_array",
                dspace_max'size/#B == dspace_max_blob'length
                && dspace_max.space.v1.ndims == 2UB
                && dspace_max.space.v1.dim_size'length == 2
                && bytes_to_u64_le(dspace_max.space.v1.dim_size[1]) == 4UL
                && dspace_max.space.v1.max'length == 2
                && bytes_to_u64_le(dspace_max.space.v1.max[0]) == 5UL
                && bytes_to_u64_le(dspace_max.space.v1.max[1]) == 6UL);
close(dspace_max_ios);

/* The deprecated permutation vector has the same ndims cardinality, even
   though current libhdf5 versions do not emit it. */
var dspace_perm_blob =
    [1UB, 2UB, 2UB, 0UB, 0UB, 0UB, 0UB, 0UB,
     3UB, 0UB, 0UB, 0UB, 4UB, 0UB, 0UB, 0UB,
     7UB, 0UB, 0UB, 0UB, 8UB, 0UB, 0UB, 0UB];
var dspace_perm_ios = open("*unit-ohdr-dspace-v1-perm*");
byte[dspace_perm_blob'length] @ dspace_perm_ios : 0#B = dspace_perm_blob;
var dspace_perm = oh_msg_sdspace @ dspace_perm_ios : 0#B;
expect_ohdr_msg("dataspace_v1_perm_array",
                dspace_perm'size/#B == dspace_perm_blob'length
                && dspace_perm.space.v1.ndims == 2UB
                && dspace_perm.space.v1.perm'length == 2
                && bytes_to_u64_le(dspace_perm.space.v1.perm[0]) == 7UL
                && bytes_to_u64_le(dspace_perm.space.v1.perm[1]) == 8UL);
close(dspace_perm_ios);

/* When both flags are set, max precedes perm and each vector has ndims
   entries.  Pinning the final values also pins the second vector's offset. */
var dspace_max_perm_blob =
    [1UB, 2UB, 3UB, 0UB, 0UB, 0UB, 0UB, 0UB,
     3UB, 0UB, 0UB, 0UB, 4UB, 0UB, 0UB, 0UB,
     5UB, 0UB, 0UB, 0UB, 6UB, 0UB, 0UB, 0UB,
     7UB, 0UB, 0UB, 0UB, 8UB, 0UB, 0UB, 0UB];
var dspace_max_perm_ios = open("*unit-ohdr-dspace-v1-max-perm*");
byte[dspace_max_perm_blob'length] @ dspace_max_perm_ios : 0#B =
    dspace_max_perm_blob;
var dspace_max_perm = oh_msg_sdspace @ dspace_max_perm_ios : 0#B;
expect_ohdr_msg("dataspace_v1_max_and_perm_arrays",
                dspace_max_perm'size/#B == dspace_max_perm_blob'length
                && dspace_max_perm.space.v1.max'length == 2
                && bytes_to_u64_le(dspace_max_perm.space.v1.max[1]) == 6UL
                && dspace_max_perm.space.v1.perm'length == 2
                && bytes_to_u64_le(dspace_max_perm.space.v1.perm[1]) == 8UL);
close(dspace_max_perm_ios);

/* Version 0 uses the legacy strategy byte and omits manager addresses unless
   the strategy is ALL_PERSIST (1). */
var fsinfo_v0_blob = [0UB, 2UB, 16UB, 0UB, 0UB, 0UB];
var fsinfo_v0_ios = open("*unit-ohdr-fsinfo-v0*");
byte[fsinfo_v0_blob'length] @ fsinfo_v0_ios : 0#B = fsinfo_v0_blob;
var fsinfo_v0 = oh_msg_fsinfo @ fsinfo_v0_ios : 0#B;
expect_ohdr_msg("fsinfo_v0_without_addresses",
                fsinfo_v0'size/#B == fsinfo_v0_blob'length
                && fsinfo_v0.info.v0.strategy == 2UB
                && bytes_to_u64_le(fsinfo_v0.info.v0.threshold) == 16UL);
close(fsinfo_v0_ios);

/* ALL_PERSIST version 0 messages carry one address for each of the six
   legacy allocation types, with no small/large split. */
var fsinfo_v0_persist_blob =
    [0UB, 1UB, 16UB, 0UB, 0UB, 0UB,
     1UB, 0UB, 0UB, 0UB, 2UB, 0UB, 0UB, 0UB,
     3UB, 0UB, 0UB, 0UB, 4UB, 0UB, 0UB, 0UB,
     5UB, 0UB, 0UB, 0UB, 6UB, 0UB, 0UB, 0UB];
var fsinfo_v0_persist_ios = open("*unit-ohdr-fsinfo-v0-persist*");
byte[fsinfo_v0_persist_blob'length] @ fsinfo_v0_persist_ios : 0#B =
    fsinfo_v0_persist_blob;
var fsinfo_v0_persist = oh_msg_fsinfo @ fsinfo_v0_persist_ios : 0#B;
expect_ohdr_msg("fsinfo_v0_with_addresses",
                fsinfo_v0_persist'size/#B == fsinfo_v0_persist_blob'length
                && fsinfo_v0_persist.info.v0.fs_addr'length == 6
                && bytes_to_u64_le(
                       fsinfo_v0_persist.info.v0.fs_addr[0]) == 1UL
                && bytes_to_u64_le(
                       fsinfo_v0_persist.info.v0.fs_addr[5]) == 6UL);
close(fsinfo_v0_persist_ios);

/* Version 1 always carries page/EOA fields but omits all twelve manager
   addresses when persistence is disabled. */
var fsinfo_v1_blob =
    [1UB, 1UB, 0UB,
     16UB, 0UB, 0UB, 0UB,
     0UB, 16UB, 0UB, 0UB,
     32UB, 0UB,
     52UB, 18UB, 0UB, 0UB];
var fsinfo_v1_ios = open("*unit-ohdr-fsinfo-v1*");
byte[fsinfo_v1_blob'length] @ fsinfo_v1_ios : 0#B = fsinfo_v1_blob;
var fsinfo_v1 = oh_msg_fsinfo @ fsinfo_v1_ios : 0#B;
expect_ohdr_msg("fsinfo_v1_without_addresses",
                fsinfo_v1'size/#B == fsinfo_v1_blob'length
                && fsinfo_v1.info.v1.strategy == 1UB
                && fsinfo_v1.info.v1.persist == 0UB
                && bytes_to_u64_le(fsinfo_v1.info.v1.page_size) == 4096UL
                && bytes_to_u64_le(fsinfo_v1.info.v1.eoa) == 0x1234UL);
close(fsinfo_v1_ios);

/* Persistent version 1 messages append six small-allocation and six
   large-allocation manager addresses. */
var fsinfo_v1_persist_blob =
    [1UB, 0UB, 1UB,
     16UB, 0UB, 0UB, 0UB,
     0UB, 16UB, 0UB, 0UB,
     32UB, 0UB,
     52UB, 18UB, 0UB, 0UB,
     1UB, 0UB, 0UB, 0UB, 2UB, 0UB, 0UB, 0UB,
     3UB, 0UB, 0UB, 0UB, 4UB, 0UB, 0UB, 0UB,
     5UB, 0UB, 0UB, 0UB, 6UB, 0UB, 0UB, 0UB,
     7UB, 0UB, 0UB, 0UB, 8UB, 0UB, 0UB, 0UB,
     9UB, 0UB, 0UB, 0UB, 10UB, 0UB, 0UB, 0UB,
     11UB, 0UB, 0UB, 0UB, 12UB, 0UB, 0UB, 0UB];
var fsinfo_v1_persist_ios = open("*unit-ohdr-fsinfo-v1-persist*");
byte[fsinfo_v1_persist_blob'length] @ fsinfo_v1_persist_ios : 0#B =
    fsinfo_v1_persist_blob;
var fsinfo_v1_persist = oh_msg_fsinfo @ fsinfo_v1_persist_ios : 0#B;
expect_ohdr_msg("fsinfo_v1_with_addresses",
                fsinfo_v1_persist'size/#B == fsinfo_v1_persist_blob'length
                && fsinfo_v1_persist.info.v1.small_fs_addr'length == 6
                && fsinfo_v1_persist.info.v1.large_fs_addr'length == 6
                && bytes_to_u64_le(
                       fsinfo_v1_persist.info.v1.small_fs_addr[5]) == 6UL
                && bytes_to_u64_le(
                       fsinfo_v1_persist.info.v1.large_fs_addr[0]) == 7UL
                && bytes_to_u64_le(
                       fsinfo_v1_persist.info.v1.large_fs_addr[5]) == 12UL);
close(fsinfo_v1_persist_ios);

if (ohdr_msg_failures != 0)
    {
        printf("UNIT OHDR MESSAGES: %i32d failure(s)\n", ohdr_msg_failures);
        exit(1);
    }
printf("UNIT OHDR MESSAGES: all passed\n");

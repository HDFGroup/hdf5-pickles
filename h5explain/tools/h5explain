#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  h5explain [OPTIONS] FILE [OFFSET]
  h5explain -h|--help

Arguments:
  FILE       HDF5 file to open with GNU poke
  OFFSET     Optional starting byte offset, decimal or hexadecimal (0x...)

Options:
  -h, --help           show this help
  -n, --non-strict     use non-strict poke mapping to keep exploring
  -c, --command CMD    run CMD after startup; may be repeated
  -b, --batch          run commands and exit instead of entering the REPL
  -q, --quiet          suppress the startup banner
      --policy         load the h5policy pickles (check, check_all, profile)
      --no-policy      do not load them, even if the commands look like they need them

The policy pickles roughly double startup, so they load only when the session
may use them: always when interactive, and in batch only when the commands
mention a policy command.  Use --policy if a batch session reaches check
indirectly, or --no-policy to keep a scripted sweep as fast as possible.

Commands come from --command options, or, when none are given and standard
input is not a terminal, from standard input.  Either source implies --batch
and --quiet, so a scripted session works without extra flags:

  printf 'root\nls\n' | h5explain file.h5
  h5explain -c root -c ls file.h5

Batch mode exits with poke's status.  Note that poke reports an unhandled
exception on stderr and continues, so scripted callers should assert on
output rather than on the exit status alone.
EOF
}

source_path=${BASH_SOURCE[0]}
while [[ -L "$source_path" ]]; do
    source_dir="$(cd -- "$(dirname -- "$source_path")" && pwd)"
    source_path="$(readlink -- "$source_path")"
    [[ "$source_path" == /* ]] || source_path="$source_dir/$source_path"
done
script_dir="$(cd -- "$(dirname -- "$source_path")" && pwd)"
h5explain_dir="$(cd -- "$script_dir/.." && pwd)"
repo_dir="$(cd -- "$h5explain_dir/.." && pwd)"

# escape_poke_string, escape_poke_file_arg, and h5_export_load_path live here.
source "$repo_dir/tools/lib/h5common.sh"

non_strict=0
batch=0
quiet=0
load_policy=-1        # -1 = decide from the session; 0/1 = forced by --policy
commands=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -n|--non-strict)
            non_strict=1
            shift
            ;;
        -b|--batch)
            batch=1
            shift
            ;;
        -q|--quiet)
            quiet=1
            shift
            ;;
        --policy)
            load_policy=1
            shift
            ;;
        --no-policy)
            load_policy=0
            shift
            ;;
        -c|--command)
            if [[ $# -lt 2 ]]; then
                printf 'h5explain: %s requires an argument\n\n' "$1" >&2
                usage >&2
                exit 2
            fi
            commands+=("$2")
            shift 2
            ;;
        --command=*)
            commands+=("${1#--command=}")
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            printf 'h5explain: unknown option: %s\n\n' "$1" >&2
            usage >&2
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -lt 1 || $# -gt 2 ]]; then
    usage >&2
    exit 2
fi

file=$1
offset=${2:-}

if [[ ! -e "$file" ]]; then
    printf 'h5explain: file not found: %s\n' "$file" >&2
    exit 1
fi

if [[ "$file" == *$'\n'* ]]; then
    printf 'h5explain: file names containing newlines are not supported\n' >&2
    exit 1
fi

if [[ -n "$offset" && ! "$offset" =~ ^([0-9]+|0[xX][0-9A-Fa-f]+)$ ]]; then
    printf 'h5explain: OFFSET must be decimal or hexadecimal (0x...): %s\n' "$offset" >&2
    exit 2
fi

# Commands come from --command options, or failing that from a piped stdin.
# poke reads its own stdin as the REPL, so a scripted session has to be
# collected here and replayed through the startup script instead.  Only drain
# stdin when no --command was given: a caller that passed --command may leave
# stdin open forever, and draining it would hang the session.
if [[ ${#commands[@]} -eq 0 && ! -t 0 ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        commands+=("$line")
    done
fi

if [[ ${#commands[@]} -gt 0 ]]; then
    batch=1
    quiet=1
fi

# Loading the h5policy pickles roughly doubles startup (~0.3s), and a session
# that never checks anything pays it for nothing -- which for a scripted sweep
# over many files is the whole cost.  poke forbids `load` inside a function, so
# check cannot pull its own implementation in on demand; the decision has to be
# made here, before poke starts.
#
# An interactive session always loads: the user can type check at any prompt.
# A batch session has all of its commands up front, and reaching any policy
# command means naming it, so the text is authoritative.  Matching is
# deliberately loose -- a false positive costs 0.3s, a false negative costs an
# undefined-variable error -- and --policy forces the issue either way.
if [[ $load_policy -lt 0 ]]; then
    if [[ $batch -eq 0 ]]; then
        load_policy=1
    elif printf '%s\n' "${commands[@]}" | grep -qiE 'check|policy|profile|reach'; then
        load_policy=1
    else
        load_policy=0
    fi
fi

policy_dir="$repo_dir/h5policy/pickles"
h5_export_load_path "$h5explain_dir/pickles" "$policy_dir" "$repo_dir/pickles"

cmd_file=$(mktemp "${TMPDIR:-/tmp}/h5explain.XXXXXX")
trap 'rm -f "$cmd_file"' EXIT

{
    printf '.file %s\n' "$(escape_poke_file_arg "$file")"
    printf '.set pretty-print yes\n'
    printf '.set omode tree\n'
    printf 'load h5explain\n'
    if [[ $load_policy -eq 1 ]]; then
        # Must follow h5explain: loading the policy pickles rebinds the shared
        # format globals, and h5explain's decoding has to keep the binding it
        # primes.  See the header of h5explain_check.pk.
        printf 'load h5explain_check\n'
    fi
    printf 'h5explain_non_strict = %d\n' "$non_strict"
    printf 'h5explain_quiet = %d\n' "$quiet"
    if [[ -n "$offset" ]]; then
        printf 'h5explain_start ("%s")\n' "$(escape_poke_string "$offset")"
    else
        printf 'h5explain_start\n'
    fi
    if [[ ${#commands[@]} -gt 0 ]]; then
        printf '%s\n' "${commands[@]}"
    fi
    # poke keeps reading its stdin as a REPL once the startup script ends, so
    # batch mode has to close the session explicitly.
    if [[ $batch -eq 1 ]]; then
        printf '.exit\n'
    fi
} >"$cmd_file"

exec poke --quiet -s "$cmd_file"

def cmd_init(args):
    if not os.path.exists(args.poc):
        die(f"no such PoC file: {args.poc}")
    cdir = os.path.join(CASES_ROOT, args.id)
    if os.path.exists(cdir) and not args.force:
        die(f"case exists: {cdir} (use --force to overwrite)")
    os.makedirs(cdir, exist_ok=True)

    shutil.copy(args.poc, os.path.join(cdir, "input.h5"))
    digest = sha256(os.path.join(cdir, "input.h5"))
    with open(os.path.join(cdir, "input.sha256"), "w") as f:
        f.write(f"{digest}  input.h5\n")


# -------------------------------------------------------------- triage --------

def cmd_census(args):
    files = sorted(glob.glob(os.path.join(os.path.abspath(args.root), "**", "*.h5"), recursive=True))
    counts = {}
    for inp in files:
        rep, rc = run_json([H5POLICY, "--profile", "untrusted-strict", "--json", inp], timeout=60)
        key = rep.get("findings", [{}])[0].get("code") if rep.get("findings") else rep.get("decision", "error")
        counts[key] = counts.get(key, 0) + 1
    print(json.dumps({"root": os.path.abspath(args.root), "specimens": len(files), "by_primary_finding": counts}, indent=2, sort_keys=True))
    return 0


def cmd_matrix(args):
    """Run registry-selected canaries for the expected-fixture matrix."""
    findings = yaml.safe_load(open(FINDINGS_YML)).get("findings", {})
    policy = yaml.safe_load(open(args.policy)) if args.policy else {"defaults": {}}
    defaults = policy.get("defaults", {}).get("allowed_statuses", [])
    overrides = policy.get("fixture_overrides", {})
    rows = []
    for path in sorted(glob.glob(os.path.join(EXPECTED_DIR, "*.yml"))):
        expected = yaml.safe_load(open(path)) or {}
        if expected.get("allow_missing_file"):
            continue
        codes = expected.get("required_findings", []) or []
        fixture_policy = expected.get("h5cve", {}) or {}
        entry = next((findings.get(c) for c in codes if findings.get(c)), None)
        # The matrix has no finding message to resolve a shared code with, so an
        # ambiguous entry supplies no default family; such a fixture must name
        # its family explicitly or be reported as a coverage gap.
        default_record = None if (entry or {}).get("ambiguous") \
            else (entry.get("record") if entry else None)
        # Registry association alone selects a diagnostic candidate, not an
        # allowed verification result.  A fixture must state its family and
        # permitted status explicitly before the exact-build canary is allowed
        # to claim exercised coverage.
        if not fixture_policy:
            rows.append({"expectation": os.path.basename(path),
                         "fixture": expected.get("file"), "record": default_record,
                         "status": "coverage_gap", "h5cve_policy": fixture_policy})
            continue
        requested = fixture_policy.get("families", [fixture_policy.get("family", default_record)])
        if not isinstance(requested, list):
            requested = [requested]
        if not entry and not any(requested):
            rows.append({"expectation": os.path.basename(path), "fixture": expected.get("file"),
                         "status": "coverage_gap",
                         "h5cve_policy": fixture_policy})
            continue
        fixture = os.path.join(REPO, "h5policy", "tests", expected["file"])
        for record in requested:
            per_family = fixture_policy.get("family_policies", {}).get(record, {})
            effective_policy = {**fixture_policy, **per_family}
            effective_policy.pop("family_policies", None)
            exercise = CANARY_BY_RECORD.get(record)
            if not exercise:
                rows.append({"expectation": os.path.basename(path), "fixture": expected["file"], "record": record,
                             "status": "coverage_gap", "h5cve_policy": effective_policy})
                continue
            rep, _ = _probe(fixture, args.baseline, exercise)
            canary = _canary_summary(rep, None, exercise)
            alignment = _oracle_alignment(rep, expected.get("expected_decision"))
            if effective_policy.get("require_oracle_alignment") and alignment == "divergent":
                canary["status"] = "violation"
            rows.append({"expectation": os.path.basename(path), "fixture": expected["file"], "record": record,
                         "exercise": exercise, "oracle_alignment": alignment,
                         "h5cve_policy": effective_policy, **canary})
    for row in rows:
        fixture_policy = row.pop("h5cve_policy", {})
        permitted = fixture_policy.get("allowed_statuses",
                    overrides.get(row.get("fixture"), {}).get("allowed_statuses", defaults))
        row["allowed"] = row["status"] in permitted
    report = {"policy": args.policy, "rows": rows}
    rendered = json.dumps(report, indent=2, sort_keys=True)
    if args.output:
        with open(args.output, "w") as f:
            f.write(rendered + "\n")
    else:
        print(rendered)
    return 0 if all(r["allowed"] for r in rows) else 2

# ------------------------------------------------------------- evidence -------

# What the exact-build matrix lets us conclude about libhdf5 per record family.
# Only `reject_corrupt` specimens are comparable: reject_resource and
# reject_policy are decisions about the selected PROFILE, which libhdf5 has no
# equivalent of.  `unmeasured` is a visible outcome, never a stand-in for
# `enforced`.
EVIDENCE_VERDICTS = ("enforced", "partial", "diverges", "unmeasured")


def _evidence_for_rows(rows, expectations):
    """Derive per-record libhdf5 evidence from matrix rows."""
    by_record = {}
    for row in rows:
        record = row.get("record")
        if not record or not row.get("exercise"):
            continue
        by_record.setdefault(record, []).append(row)

    out = {}
    for record, rs in sorted(by_record.items()):
        enforced, diverges, activation, crashes = [], [], [], []
        for r in rs:
            name = r["expectation"]
            decision = (expectations.get(name) or {}).get("expected_decision")
            viol = r.get("violations") or []
            if "crash" in viol:
                crashes.append(name)
            elif viol:
                activation.append({"fixture": name, "events": sorted(viol)})
            # Only reject_corrupt is a claim about the FILE that libhdf5 can
            # agree or disagree with.
            if decision != "reject_corrupt":
                continue
            reached = len(r.get("entry_points_exercised") or []) > 1
            if r.get("oracle_alignment") == "divergent":
                diverges.append(name)
            elif r.get("oracle_alignment") == "aligned" and reached:
                enforced.append(name)

        if diverges and enforced:
            verdict = "partial"
        elif diverges:
            verdict = "diverges"
        elif enforced:
            verdict = "enforced"
        else:
            verdict = "unmeasured"

        entry = {"verdict": verdict,
                 "enforced_on": sorted(enforced),
                 "diverges_on": sorted(diverges)}
        # Activation and crashes do not change the ENFORCEMENT verdict -- a
        # build can enforce an invariant and still crash reaching it -- so they
        # are reported separately rather than folded in.
        if activation:
            entry["activation_observed"] = sorted(activation,
                                                  key=lambda a: a["fixture"])
        if crashes:
            entry["crashes_on"] = sorted(crashes)
        out[record] = entry
    return out


def cmd_evidence(args):
    """Write the measured libhdf5 evidence derived from a matrix artifact.

    The manifest's `validators.hdf5` stays hand-maintained; this file is the
    measurement, and check_registry.py gates the two against each other. Keeping
    them separate is deliberate: an asserted value must not be able to overwrite
    itself with a generated one and call that agreement.
    """
    if args.matrix:
        report = json.load(open(args.matrix))
    else:
        import tempfile
        fd, tmp = tempfile.mkstemp(suffix=".json")
        os.close(fd)
        argv = argparse.Namespace(baseline=args.baseline, output=tmp,
                                  policy=os.path.join(REPO, "registry",
                                                      "h5cve-matrix-policy.yml"))
        cmd_matrix(argv)
        report = json.load(open(tmp))
        os.unlink(tmp)

    expectations = {}
    for path in glob.glob(os.path.join(EXPECTED_DIR, "*.yml")):
        expectations[os.path.basename(path)] = yaml.safe_load(open(path)) or {}

    rows = report.get("rows", [])
    build = next((r.get("build") for r in rows if r.get("build")), None)
    doc = {
        "schema_version": 1,
        "generated_by": "h5cve evidence",
        "libhdf5_version": args.libhdf5_version,
        "records": _evidence_for_rows(rows, expectations),
    }
    header = (
        "# GENERATED by `h5cve evidence` -- do not hand-edit.\n"
        "#\n"
        "# The measured behaviour of the selected libhdf5 build, per record\n"
        "# family, derived from the exact-build canary matrix.\n"
        "#\n"
        "# validation-coverage.yml's `validators.hdf5` is the HAND-MAINTAINED\n"
        "# claim; this file is the measurement. check_registry.py gates the two\n"
        "# against each other so a claim cannot drift from what was observed.\n"
        "#\n"
        "# verdict, over `reject_corrupt` specimens only (reject_resource and\n"
        "# reject_policy are profile decisions libhdf5 has no equivalent of):\n"
        "#   enforced   every comparable specimen reaching the family surface is\n"
        "#              rejected by libhdf5\n"
        "#   partial    some rejected, some accepted\n"
        "#   diverges   libhdf5 accepts every comparable specimen\n"
        "#   unmeasured no comparable specimen reaches the family surface\n"
        "#\n"
        "# activation_observed and crashes_on are reported separately: a build\n"
        "# can enforce an invariant and still crash or activate reaching it.\n")
    with open(args.output, "w") as f:
        f.write(header)
        yaml.safe_dump(doc, f, sort_keys=False, default_flow_style=False)
    counts = {}
    for e in doc["records"].values():
        counts[e["verdict"]] = counts.get(e["verdict"], 0) + 1
    print(f"evidence: {len(doc['records'])} records -> "
          f"{os.path.relpath(args.output)}")
    for v in EVIDENCE_VERDICTS:
        if counts.get(v):
            print(f"  {v:11} {counts[v]}")
    return 0


# ---------------------------------------------------- §12 verification --------

# Strategy-doc §12 lists eleven verification requirements every migrated record
# family should meet.  This derives, per family, which are demonstrably met from
# the artifacts in the tree.  Statuses are deliberately four-valued:
#
#   met           mechanically demonstrated, with the evidence listed
#   partial       demonstrated for some of the requirement's parts, not all
#   absent        mechanically demonstrated to be MISSING
#   not_assessed  cannot be determined from artifacts; needs classification
#
# `not_assessed` is not a soft `met`.  Requirements 2, 3 and 4 are marked that
# way rather than guessed at from finding-code names: inferring a family's
# boundary-value or overflow coverage from code spelling is exactly the kind of
# confident-but-wrong attribution the `contexts` mechanism exists to prevent.

# Reviewed mapping from invariant id to the §12 requirement-5 categories
# (self-reference, overlap, duplicate-reference, structure-specific cycle).
# Hand-reviewed against the invariant semantics, not pattern-matched.
REFERENCE_SEMANTICS = {
    "continuation.no_source_overlap": "self_reference",
    "continuation.no_chunk_alias": "overlap",
    "continuation.unique_counting": "duplicate_reference",
    "chunk.no_cycle": "cycle",
    "sohm.no_cycle": "cycle",
    "dense.unique_name_ids": "duplicate_reference",
    "heap.global_progress": "cycle",
}

VERIFICATION_REQUIREMENTS = [
    "truncation_every_byte_boundary",
    "count_and_extent_boundaries",
    "integer_overflow_and_allocation_budget",
    "deep_nesting_and_non_progress",
    "reference_semantics_cases",
    "stable_finding_and_offset_assertions",
    "no_activation_on_validation_failure",
    "differential_vs_legacy_on_valid_inputs",
    "in_memory_fuzz_targets",
    "full_file_cve_and_ossfuzz",
    "lazy_validation_performance",
]


def _req(status, note, evidence=None):
    entry = {"status": status, "note": note}
    if evidence:
        entry["evidence"] = sorted(evidence)
    return entry


def _verification_for_record(record, exps, evidence, truncation, lazy):
    """Derive the §12 status block for one record family."""
    name = record["record"]
    # A contract may name one family or several; both forms must be honoured or
    # a multi-family fixture silently stops counting for every family it covers.
    def covers(e):
        h = e.get("h5cve") or {}
        return name == h.get("family") or name in (h.get("families") or [])
    fam = {n: e for n, e in exps.items() if covers(e)}
    accepts = [n for n, e in fam.items()
               if str(e.get("expected_decision", "")).startswith("accept")]
    cve = [n for n, e in fam.items() if str(e.get("file", "")).startswith("cve/")]
    with_findings = [n for n, e in fam.items() if e.get("required_findings")]
    with_offsets = [n for n, e in fam.items()
                    if e.get("expected_finding_evidence_locations")]
    ev = evidence.get(name, {})

    out = {}

    swept = {s["seed"]: s for s in truncation.get("seeds", [])}
    fam_seeds = [("h5policy/tests/" + e["file"]) for e in fam.values()
                 if str(e.get("expected_decision", "")).startswith("accept")]
    exhaustive = [s for s in fam_seeds
                  if swept.get(s, {}).get("coverage") == "exhaustive"
                  and not swept.get(s, {}).get("violations")]
    sampled = [s for s in fam_seeds if swept.get(s, {}).get("coverage") == "sampled"]
    if exhaustive:
        out["truncation_every_byte_boundary"] = _req(
            "met",
            "h5policy-truncate walks every byte boundary of a seed contracted to "
            "this family, with no escape, internal error or hang.", exhaustive)
    elif sampled:
        out["truncation_every_byte_boundary"] = _req(
            "partial",
            "The family's seed exceeds the sweep budget, so boundaries were "
            "strided rather than exhausted. A sampled sweep is not the "
            "every-boundary coverage this requires.", sampled)
    else:
        out["truncation_every_byte_boundary"] = _req(
            "absent",
            "No accepting fixture contracted to this family appears in "
            "registry/truncation-sweep.json.")

    out["count_and_extent_boundaries"] = _req(
        "not_assessed",
        "Requires classifying each fixture as a zero/max/N-1/N/N+1 case. Not "
        "derivable from the corpus as it stands.")

    out["integer_overflow_and_allocation_budget"] = _req(
        "not_assessed",
        "Budget coverage is partly visible via reject_resource fixtures, but "
        "integer-overflow coverage cannot be separated without classifying "
        "fixtures. Deliberately not inferred from finding-code spelling.")

    out["deep_nesting_and_non_progress"] = _req(
        "not_assessed",
        "Same: depth and non-progress fixtures exist for some families but are "
        "not distinguishable from the corpus without classification.")

    cats = sorted({REFERENCE_SEMANTICS[i["id"]]
                   for i in record.get("invariants", [])
                   if i.get("id") in REFERENCE_SEMANTICS})
    if not cats:
        out["reference_semantics_cases"] = _req(
            "not_assessed",
            "No invariant in this family maps to a reviewed self-reference / "
            "overlap / duplicate-reference / cycle category. That may be "
            "correct for a non-reference-bearing family, or the mapping may be "
            "incomplete.")
    else:
        missing = {"self_reference", "overlap", "duplicate_reference", "cycle"} - set(cats)
        out["reference_semantics_cases"] = _req(
            "met" if not missing else "partial",
            f"Categories covered: {', '.join(cats)}."
            + (f" Not covered: {', '.join(sorted(missing))}." if missing else ""),
            cats)

    if with_findings and with_offsets:
        out["stable_finding_and_offset_assertions"] = _req(
            "met", "Fixtures assert both finding codes and evidence locations.",
            with_offsets)
    elif with_findings:
        out["stable_finding_and_offset_assertions"] = _req(
            "partial",
            "Finding codes are asserted; no fixture pins an evidence location "
            "(expected_finding_evidence_locations).", with_findings)
    else:
        out["stable_finding_and_offset_assertions"] = _req(
            "absent", "No contracted fixture asserts a finding code.")

    activating = [a["fixture"] for a in ev.get("activation_observed", [])
                  if (exps.get(a["fixture"]) or {}).get("expected_decision")
                  == "reject_corrupt"]
    crashes = ev.get("crashes_on", [])
    if activating or crashes:
        out["no_activation_on_validation_failure"] = _req(
            "partial",
            "The probe forbids activation and the family is exercised, but a "
            "rejecting fixture still activates or crashes the build under test.",
            activating + crashes)
    elif ev.get("enforced_on") or ev.get("diverges_on"):
        out["no_activation_on_validation_failure"] = _req(
            "met",
            "Exact-build probe drives this family with external_open, "
            "plugin_load, write, network and crash forbidden; no rejecting "
            "fixture triggers one.")
    else:
        out["no_activation_on_validation_failure"] = _req(
            "not_assessed", "No measured rejecting specimen for this family.")

    out["differential_vs_legacy_on_valid_inputs"] = _req(
        "met" if accepts else "absent",
        "h5policy-diff cross-checks every corpus file against libhdf5; this "
        "family has an accepting fixture in that set."
        if accepts else
        "No accepting fixture is contracted to this family, so the differential "
        "harness proves nothing about it specifically.", accepts)

    ft = record.get("fuzz_targets") or {}
    out["in_memory_fuzz_targets"] = _req(
        "met" if ft.get("recipes") else "absent",
        f"{len(ft.get('recipes', []))} typed mutation recipes."
        if ft.get("recipes") else
        "No fuzz_targets declared. h5policy-fuzz mutates whole-file seeds "
        "generically; this requires a dedicated target for the family.",
        [ft.get("seed")] if ft.get("seed") else None)

    out["full_file_cve_and_ossfuzz"] = _req(
        "partial" if cve else "absent",
        "Full-file CVE fixture present; OSS-Fuzz integration does not exist in "
        "this repository." if cve else
        "No full-file cve/ fixture, and no OSS-Fuzz integration.", cve)

    if lazy.get("total_violations") == 0 and lazy.get("ladders"):
        data = lazy["ladders"].get("data", [])
        growth = (data[-1]["physical_bytes"] / max(1, data[0]["physical_bytes"])
                  if len(data) > 1 else 0)
        out["lazy_validation_performance"] = _req(
            "partial",
            f"h5policy-lazy shows validation cost flat while raw data grows "
            f"{growth:.0f}x, with a sensitivity control proving the counters "
            f"respond to real metadata growth. Measured on the oracle as a "
            f"whole, not per family, so it does not yet discharge this "
            f"requirement family by family.")
    elif lazy.get("ladders"):
        out["lazy_validation_performance"] = _req(
            "absent",
            f"h5policy-lazy reports {lazy['total_violations']} violation(s); "
            f"validation cost is not demonstrably independent of data volume.")
    else:
        out["lazy_validation_performance"] = _req(
            "absent",
            "No performance measurement present; run `h5policy-lazy --output "
            "registry/lazy-validation.json`.")

    return out


def cmd_verification(args):
    """Write the §12 per-family verification status."""
    coverage = yaml.safe_load(open(COVERAGE_YML))["records"]
    exps = {}
    for path in glob.glob(os.path.join(EXPECTED_DIR, "*.yml")):
        exps[os.path.basename(path)] = yaml.safe_load(open(path)) or {}
    ev_path = os.path.join(REPO, "registry", "libhdf5-evidence.yml")
    evidence = ((yaml.safe_load(open(ev_path)) or {}).get("records", {})
                if os.path.exists(ev_path) else {})

    tr_path = os.path.join(REPO, "registry", "truncation-sweep.json")
    truncation = json.load(open(tr_path)) if os.path.exists(tr_path) else {}
    lz_path = os.path.join(REPO, "registry", "lazy-validation.json")
    lazy = json.load(open(lz_path)) if os.path.exists(lz_path) else {}
    records = {r["record"]: _verification_for_record(r, exps, evidence,
                                                     truncation, lazy)
               for r in coverage}
    doc = {"schema_version": 1, "generated_by": "h5cve verification",
           "requirements": VERIFICATION_REQUIREMENTS, "records": records}
    header = (
        "# GENERATED by `h5cve verification` -- do not hand-edit.\n"
        "#\n"
        "# Strategy-doc §12 per record family: which of the eleven verification\n"
        "# requirements are demonstrably met by the artifacts in this tree.\n"
        "#\n"
        "#   met           mechanically demonstrated, evidence listed\n"
        "#   partial       demonstrated for some of the requirement, not all\n"
        "#   absent        mechanically demonstrated to be MISSING\n"
        "#   not_assessed  not determinable from artifacts; needs classification\n"
        "#\n"
        "# `not_assessed` is NOT a soft `met`. Requirements 2-4 are marked that\n"
        "# way rather than inferred from finding-code spelling, which would be\n"
        "# a confident guess rather than a measurement.\n")
    with open(args.output, "w") as f:
        f.write(header)
        yaml.safe_dump(doc, f, sort_keys=False, default_flow_style=False)

    tally = {}
    for rec in records.values():
        for req, e in rec.items():
            tally.setdefault(req, {}).setdefault(e["status"], 0)
            tally[req][e["status"]] += 1
    print(f"verification: {len(records)} records -> {os.path.relpath(args.output)}")
    for req in VERIFICATION_REQUIREMENTS:
        parts = ", ".join(f"{k}={v}" for k, v in sorted(tally[req].items()))
        print(f"  {req:42} {parts}")
    return 0


def _primary_finding(report):
    """The finding that best names the defect: the first corrupt one, else the
    first finding at all."""
    findings = report.get("findings", [])
    for f in findings:
        if f.get("class") == "corrupt" or f.get("severity") == "corrupt":
            return f
    return findings[0] if findings else None


def resolve_finding(code, message, findings_reg):
    """Map an emitted finding to its record/invariant using its message.

    Twenty catalogued codes are emitted by more than one walker (a checksum or
    an out-of-file address means something different in a chunk index than in an
    object header), so the catalog's top-level record/invariant names only ONE
    of a code's roles.  Those entries carry `ambiguous: true` plus an ordered
    `contexts` list matched against the finding message -- the only per-
    occurrence discriminator h5policy reports, since messages are composed at
    the emission site.

    Returns a mapping with a `confidence`:
      exact       a context matched; record (and invariant, when catalogued)
      default     the code is unambiguous; the top-level mapping applies
      ambiguous   ambiguous code, no context matched -- nothing is asserted and
                  `candidates` lists the roles the catalog knows about
      uncatalogued  the code is not in findings.yml at all

    An ambiguous code with no matching context yields NO record/invariant on
    purpose: an unnamed invariant is a visible gap, a wrong one is a wrong fix.
    """
    entry = findings_reg.get(code)
    if not entry:
        return {"confidence": "uncatalogued", "record": None, "invariant": None,
                "scope": None, "candidates": [], "matched_context": None}
    if not entry.get("ambiguous"):
        return {"confidence": "default", "record": entry.get("record"),
                "invariant": entry.get("invariant"), "scope": entry.get("scope"),
                "candidates": [], "matched_context": None}

    contexts = entry.get("contexts") or []
    for ctx in contexts:
        if message and ctx.get("match") and ctx["match"] in message:
            # When the context names the same role the catalog entry describes,
            # the entry's other fields apply; otherwise only what the context
            # states is trustworthy.
            same_role = ctx.get("record") == entry.get("record")
            return {
                "confidence": "exact",
                "record": ctx.get("record"),
                "invariant": ctx.get("invariant") or
                             (entry.get("invariant") if same_role else None),
                "scope": ctx.get("scope") or
                         (entry.get("scope") if same_role else None),
                "candidates": [],
                "matched_context": ctx.get("match"),
                "evidence": ctx.get("evidence"),
            }

    candidates = sorted({c.get("record") for c in contexts if c.get("record")} |
                        ({entry.get("record")} if entry.get("record") else set()))
    return {"confidence": "ambiguous", "record": None, "invariant": None,
            "scope": None, "candidates": candidates, "matched_context": None}


def cmd_triage(args):
    cdir = case_dir(args.case)
    case = load_case(cdir)
    inp = os.path.join(cdir, "input.h5")

    forensic, _ = run_json([H5POLICY, "--profile", "forensic", "--json", inp])
    strict, _ = run_json([H5POLICY, "--profile", "untrusted-strict", "--json", inp])
    json.dump(forensic, open(os.path.join(cdir, "h5policy-forensic.json"), "w"), indent=2)
    json.dump(strict, open(os.path.join(cdir, "h5policy-strict.json"), "w"), indent=2)

    # markers.json (optional: the census binary must be built)
    if os.path.exists(H5MARKERS):
        try:
            out = subprocess.run([H5MARKERS, inp], capture_output=True,
                                 text=True, timeout=60).stdout
            markers = []
            for line in out.splitlines():
                parts = line.split()
                if len(parts) >= 2 and parts[1].startswith("0x"):
                    markers.append({"marker": parts[0], "offset": int(parts[1], 16)})
            json.dump({"markers": markers},
                      open(os.path.join(cdir, "markers.json"), "w"), indent=2)
        except Exception as e:
            json.dump({"error": str(e)},
                      open(os.path.join(cdir, "markers.json"), "w"))
    else:
        json.dump({"skipped": "h5markers not built"},
                  open(os.path.join(cdir, "markers.json"), "w"))

    # explain-transcript.txt (best-effort structural navigation)
    prim = _primary_finding(strict)
    offset = prim.get("offset") if prim else None
    with open(os.path.join(cdir, "explain-transcript.txt"), "w") as tf:
        tf.write(f"# h5explain transcript for input.h5\n")
        tf.write(f"# primary finding offset: {offset}\n\n")
        if os.path.exists(H5EXPLAIN):
            try:
                cmds = ["-b", "-q", "-c", "root", "-c", "ls"]
                p = subprocess.run([H5EXPLAIN] + cmds + [inp],
                                   capture_output=True, text=True, timeout=90)
                tf.write(p.stdout)
                if p.stderr:
                    tf.write("\n# stderr:\n" + p.stderr)
            except Exception as e:
                tf.write(f"# h5explain failed: {e}\n")
        else:
            tf.write("# h5explain not found\n")

    # --- map the primary finding to the registry --------------------------------
    findings_reg = yaml.safe_load(open(FINDINGS_YML)).get("findings", {}) \
        if os.path.exists(FINDINGS_YML) else {}
    coverage = yaml.safe_load(open(COVERAGE_YML)).get("records", []) \
        if os.path.exists(COVERAGE_YML) else []

    code = prim.get("code") if prim else None
    msg = prim.get("message") if prim else None
    case["oracle"] = {
        "profile": "untrusted-strict",
        "decision": strict.get("decision"),
        "primary_finding": code,
        # The message is what disambiguates a shared code, so the case records
        # the exact text the mapping was resolved from.
        "primary_finding_message": msg,
        "object_path": prim.get("object") if prim else None,
        "offset": offset,
    }

    case["reproducers"]["assertions"]["stable_finding"] = code is not None
    entry = findings_reg.get(code)
    mapping = resolve_finding(code, msg, findings_reg)
    case["mapping"] = mapping

    if mapping["record"]:
        case["record"] = mapping["record"]
        case["versions"] = entry.get("versions", []) if entry else []
        case["violated_invariant"] = mapping["invariant"]
        case["root_cause_classification"] = SCOPE_TO_CLASS.get(mapping["scope"],
                                                               mapping["scope"])
        # semantic boundary + closure hint from the coverage manifest
        for rec in coverage:
            if rec.get("record") == mapping["record"]:
                case["systemic"]["semantic_boundary"] = rec.get("semantic_boundary")
                case["validation_closure"] = rec.get("semantic_boundary")
                break
        if mapping["invariant"]:
            case["coverage_manifest_change"] = \
                f"{mapping['record']} already covered " \
                f"(invariant {mapping['invariant']})"
            note = (f"mapped {code} -> {mapping['invariant']} "
                    f"[{mapping['scope']}] via registry "
                    f"({mapping['confidence']})")
        else:
            # Family resolved, invariant not catalogued: still enough to select
            # the right exact-build canary, and it names the registry gap.
            case["coverage_manifest_change"] = \
                f"TODO: {mapping['record']} has no catalogued invariant for " \
                f"{code} in this context ({msg!r})"
            note = (f"mapped {code} -> record {mapping['record']} "
                    f"(no catalogued invariant for this context; "
                    f"add one to validation-coverage.yml)")
    elif mapping["confidence"] == "ambiguous":
        case["coverage_manifest_change"] = \
            f"TODO: add a `contexts` entry for {code} matching {msg!r}"
        note = (f"finding {code} is emitted by more than one walker and no "
                f"`contexts` rule matches {msg!r}; candidates: "
                f"{', '.join(mapping['candidates']) or 'none'}. "
                "Invariant deliberately left unset -- add a contexts rule to "
                "registry/findings.yml rather than assuming the default.")
    else:
        note = (f"finding {code!r} is not catalogued in registry/findings.yml; "
                "triage fields left for manual completion (registry coverage gap)")

    # --- every family the file implicates, not just the primary's ---------------
    #
    # The strict profile stops at the FIRST rejection, so `record` above names
    # one family even when the file carries several unrelated defects -- and
    # verify then runs exactly one canary.  On GHSA-3hmr-6c9r-mqq9/3.h5 that
    # meant the primary (an out-of-file driver-info address, address_space_bounds)
    # got a `verified` canary while a second forensic finding, a corrupt local-
    # heap free list, was never exercised at all: its family surface is only
    # reached by the heap_structures canary.  A `verified` canary is therefore
    # not a statement about the file, only about one finding in it.
    #
    # The forensic profile continues after rejection, so its finding list is the
    # superset.  Resolve every one of them and record the families here; verify
    # runs a canary for each.
    case["family_coverage"] = _family_coverage(forensic, findings_reg)

    save_case(cdir, case)
    print(f"triage: decision={case['oracle']['decision']} "
          f"finding={code} ({os.path.relpath(cdir)})")
    print(f"  {note}")
    extra = [f for f in case["family_coverage"]
             if f["record"] and f["record"] != case.get("record")]
    if extra:
        print(f"  forensic implicates {len(extra)} further "
              f"{'family' if len(extra) == 1 else 'families'}; verify will "
              "exercise each:")
        for f in extra:
            print(f"    {f['record']:<28} from {f['code']}"
                  + ("" if f["exercise"] else "  (no canary: coverage_gap)"))
    unmapped = [f for f in case["family_coverage"] if not f["record"]]
    if unmapped:
        print(f"  {len(unmapped)} forensic finding(s) map to no family: "
              + ", ".join(sorted({f["code"] for f in unmapped})))
    print("next: h5cve verify " + case["id"] + " --baseline <bindir>")
    return 0


def _family_coverage(report, findings_reg):
    """Every record family implicated by a report's findings, in order, deduped.

    One entry per family, tagged with the finding that named it, so a reader can
    see WHY a canary was selected.  An unmapped finding is kept with a null
    record rather than dropped: a family that cannot be named is a visible gap,
    the same principle the primary mapping follows.
    """
    coverage, seen = [], set()
    for f in report.get("findings", []):
        code, msg = f.get("code"), f.get("message")
        mapping = resolve_finding(code, msg, findings_reg)
        record = mapping["record"]
        key = record or f"<unmapped:{code}>"
        if key in seen:
            continue
        seen.add(key)
        coverage.append({
            "record": record,
            "code": code,
            "message": msg,
            "confidence": mapping["confidence"],
            "exercise": CANARY_BY_RECORD.get(record) if record else None,
        })
    return coverage


# -------------------------------------------------------------- verify --------

CANARY_BY_RECORD = {
    "datatypes": "datatype",
    "dataspace_dimension": "dataspace",
    "dataset_layout_filter_fill": "dataset_layout",
    "btree_heap_index": "btree",
    "address_space_bounds": "address_space",
    # Free-space managers are loaded lazily: neither a plain open nor an object
    # walk decodes FSHD/FSSE, so only the free_space canary (H5Fget_free_sections)
    # reaches this family.  Without the mapping every validation_controls case
    # fell back to the generic exercise and reported a misleading "accepted".
    "validation_controls": "free_space",
    "chunk_index": "chunk_index",
    "dense_index": "dense_index",
    "heap_structures": "heap_structures",
    "shared_messages_legacy": "shared_messages_legacy",
    "cache_image_dependency_graph": "cache_image",
    "message_envelope": "message_envelope",
    # Continuation chunks are decoded as part of object-header materialization,
    # which is exactly what the message_envelope exercise drives; the family had
    # no canary at all before, so its fixtures could only ever report
    # coverage_gap.  validation_controls deliberately has none: it is a controls
    # family (budgets, base address, free-space managers, profile validity) with
    # no single traversal surface to exercise.
    "object_header_continuation": "message_envelope",
    "external_link": "external_link",
    "external_file_list": "external_file_list",
    "virtual_dataset": "virtual_dataset",
}


def _probe(inp, bindir, exercise="generic"):
    cmd = [H5PROBE, inp, "--json", "--forbid",
           "external_open,plugin_load,write,network,crash"]
    if bindir:
        cmd += ["--hdf5-bindir", bindir]
    cmd += ["--exercise", exercise]
    rep, rc = run_json(cmd, timeout=180)
    return rep, rc


def _family_probe(inp, cdir, bindir, exercise, tag, oracle_decision):
    """One canary run, summarised the same way the primary probe is."""
    rep, _ = _probe(inp, bindir, exercise)
    json.dump(rep, open(os.path.join(cdir, f"{tag}-result-{exercise}.json"), "w"),
              indent=2)
    summary = _probe_summary(rep)
    summary["oracle_alignment"] = _oracle_alignment(rep, oracle_decision)
    canary = _canary_summary(rep, None, exercise)
    summary["canary"] = canary
    summary["status"] = canary["status"]
    summary["entry_points_exercised"] = canary["entry_points_exercised"]
    _qualify_outcome(summary, canary)
    return summary


def _family_probes(cdir, case, inp, args, primary_record):
    """Run a canary for every non-primary family the forensic profile named.

    A family with no canary is recorded as an explicit `coverage_gap` row rather
    than omitted: "we did not look" and "we looked and saw nothing" are
    different results, and conflating them is what made a bare `accepted`
    misleading in the first place.
    """
    out = {}
    oracle_decision = case.get("oracle", {}).get("decision")
    for fam in case.get("family_coverage") or []:
        record = fam.get("record")
        if not record or record == primary_record or record in out:
            continue
        exercise = CANARY_BY_RECORD.get(record)
        if not exercise:
            out[record] = {"status": "coverage_gap",
                           "from_finding": fam.get("code"),
                           "reason": f"no canary exercise is mapped to {record}"}
            continue
        row = _family_probe(inp, cdir, args.baseline, exercise, "baseline",
                            oracle_decision)
        row["from_finding"] = fam.get("code")
        if args.candidate:
            row["candidate"] = _family_probe(inp, cdir, args.candidate, exercise,
                                             "candidate", oracle_decision)
        out[record] = row
    return out


def cmd_verify(args):
    cdir = case_dir(args.case)
    case = load_case(cdir)
    inp = os.path.join(cdir, "input.h5")

    record = case.get("record")
    exercise = CANARY_BY_RECORD.get(record)
    canary_status = "coverage_gap" if not exercise else None
    exercise = exercise or "generic"
    base, base_rc = _probe(inp, args.baseline, exercise)
    json.dump(base, open(os.path.join(cdir, "baseline-result.json"), "w"), indent=2)
    result = {"baseline": _probe_summary(base)}
    oracle_decision = case.get("oracle", {}).get("decision")
    result["baseline"]["oracle_alignment"] = _oracle_alignment(base, oracle_decision)
    if args.candidate:
        cand, cand_rc = _probe(inp, args.candidate, exercise)
        json.dump(cand, open(os.path.join(cdir, "candidate-result.json"), "w"), indent=2)
        result["candidate"] = _probe_summary(cand)
        result["candidate"]["oracle_alignment"] = _oracle_alignment(cand, oracle_decision)

    result["canary"] = _canary_summary(base, canary_status, exercise)
    result["baseline"]["status"] = result["canary"]["status"]
    result["baseline"]["entry_points_exercised"] = result["canary"]["entry_points_exercised"]
    _qualify_outcome(result["baseline"], result["canary"])
    if args.candidate:
        result["candidate"]["canary"] = _canary_summary(cand, canary_status, exercise)
        result["candidate"]["status"] = result["candidate"]["canary"]["status"]
        result["candidate"]["entry_points_exercised"] = result["candidate"]["canary"]["entry_points_exercised"]
        _qualify_outcome(result["candidate"], result["candidate"]["canary"])
        result["comparison"] = _comparison_verdict(result["baseline"],
                                                     result["candidate"])
    # The probe above covers the PRIMARY family only.  A file with several
    # defects implicates several families, and a family surface no canary
    # touches reports nothing at all -- see _family_coverage in cmd_triage.
    result["family_probes"] = _family_probes(cdir, case, inp, args, record)
    case["verification"] = {"exact_build_probe": result}

    # Fold the OS-observable assertions into the reproducer block from the
    # baseline probe (the build under test).
    act = base.get("activation", {})
    mat = (base.get("probe") or {}).get("materialization", {})
    safe = base.get("outcome") not in ("crashed", "timeout")
    a = case["reproducers"]["assertions"]
    a["no_external_open"] = act.get("external_open", {}).get("count", 1) == 0
    a["no_plugin_load"] = act.get("plugin_load", {}).get("count", 1) == 0
    a["no_decompression"] = act.get("plugin_load", {}).get("count", 1) == 0 \
        and mat.get("data_reads", 1) == 0
    a["fails_before_materialization"] = safe and mat.get("objects", 1) == 0
    # no_user_callback / no_legacy_fallback are not OS-observable here.
    case["activation_before_validation"] = _merge_activation(
        case.get("activation_before_validation"), base)
    # The raw --forbid tokens are evidence too, but they are a different
    # vocabulary; keep them in their own field instead of overloading the enum.
    case["probe_reported_violations"] = base.get("violations") or []

    save_case(cdir, case)
    v = base.get("violations") or []
    # Report the QUALIFIED outcome, not the raw probe verdict: see _qualify_outcome.
    print(f"verify: baseline outcome={result['baseline']['outcome']} "
          f"violations={v or 'none'}")
    if result["baseline"].get("outcome_note"):
        print(f"        WARNING: {result['baseline']['outcome_note']}")
    if args.candidate:
        print(f"        candidate outcome={result['candidate']['outcome']} "
              f"violations={result['candidate']['violations'] or 'none'}")
        if result["candidate"].get("outcome_note"):
            print(f"        WARNING: {result['candidate']['outcome_note']}")
    fam_violations = []
    for record, row in (result.get("family_probes") or {}).items():
        if row.get("status") == "coverage_gap" and "outcome" not in row:
            print(f"        {record}: coverage_gap ({row['reason']})")
            continue
        print(f"        {record}: outcome={row['outcome']} "
              f"exercise={row['exercise']} status={row['status']} "
              f"violations={row['violations'] or 'none'}")
        if row.get("outcome_note"):
            print(f"          WARNING: {row['outcome_note']}")
        fam_violations += row.get("violations") or []
        cand = row.get("candidate") or {}
        if cand:
            print(f"          candidate outcome={cand['outcome']} "
                  f"violations={cand['violations'] or 'none'}")
            fam_violations += cand.get("violations") or []
    # A forbidden activation is evidence wherever it shows up, so a secondary
    # family's violation has to fail the command too -- otherwise widening the
    # coverage would have no effect on the exit status.
    return 2 if (v or fam_violations) else 0


# cve-case.yml `activation_before_validation` vocabulary (strategy §11.5).
ACTIVATION_KINDS = ("native_construction", "cache_publication", "public_id",
                    "index_init", "plugin_load", "decompression", "callback",
                    "external_open", "none")
# The subset the exact-build probe can actually OBSERVE, as OS-level events.
# Everything else in the enum -- native construction, cache publication, ID
# registration, index init, user callbacks -- needs internal counters the probe
# does not have, so those values are source-derived and must survive a re-run.
PROBE_OBSERVABLE_ACTIVATION = ("external_open", "plugin_load")


def _merge_activation(previous, base):
    """Re-measure what the probe can see; preserve what only a human can.

    This field used to be assigned straight from `base["violations"]`, which is
    the wrong vocabulary: those are --forbid tokens (crash, write, network, ...),
    not activation kinds, so a crashing case recorded `[crash]` -- not a member
    of the enum.  It also clobbered hand-curated triage on every re-run.

    So: drop tokens that are not activation kinds, refresh the two the probe
    genuinely observes, and keep any non-observable kind already recorded.
    """
    act = base.get("activation", {})
    observed = [k for k in PROBE_OBSERVABLE_ACTIVATION
                if act.get(k, {}).get("count", 0) > 0]
    kept = [k for k in (previous or [])
            if k in ACTIVATION_KINDS and k != "none"
            and k not in PROBE_OBSERVABLE_ACTIVATION]
    merged = kept + [k for k in observed if k not in kept]
    return merged or ["none"]


def _qualify_outcome(summary, canary):
    """Refuse to report a bare `accepted` the exercise did not earn.

    When the record family has no canary exercise, `_probe` silently falls back
    to `generic` -- a read-only open plus object walk.  Any structure that walk
    does not decode (free-space managers being the motivating case) is never put
    in front of the library, so `accepted` means "nothing looked", not "the build
    is safe".  On GHSA-r856-frmw-wwvr that false negative masked a live SIGSEGV.

    A crash or a rejection is real evidence whatever the exercise was, so only
    the affirmative verdict is downgraded.  The original is kept verbatim.
    """
    if canary.get("status") == "coverage_gap" and summary.get("outcome") == "accepted":
        summary["probe_outcome"] = "accepted"
        summary["outcome"] = "unverified_coverage_gap"
        summary["outcome_note"] = (
            "libhdf5 did not reject the file, but the record family has no canary "
            "exercise so the generic read-only open never decoded it. This is NOT "
            "evidence of safety; add an exercise for this family before relying on it.")
    return summary


def _probe_summary(rep):
    summary = {
        "outcome": rep.get("outcome"),
        "exercise": (rep.get("probe") or {}).get("exercise"),
        "libhdf5_version": rep.get("build", {}).get("libhdf5_version"),
        "linked_library": rep.get("build", {}).get("linked_library"),
        "settings_sha256": rep.get("build", {}).get("settings_sha256"),
        "sanitizers": rep.get("build", {}).get("sanitizers") or [],
        "activation": {k: v.get("count") for k, v in
                       rep.get("activation", {}).items()},
        "violations": rep.get("violations", []),
        "post_open_call_errors": (rep.get("probe") or {}).get(
            "materialization", {}).get("call_errors", 0),
        "entry_points": [e.get("name") for e in
                         (rep.get("probe") or {}).get("entry_points", [])],
    }
    # A sanitizer report is the hard evidence a stock-build crash can't give;
    # keep it in the case summary (not just the raw probe JSON) so the faulting
    # invariant survives into the record.
    if rep.get("asan"):
        summary["asan"] = rep["asan"]
    return summary


def _canary_summary(rep, forced_status=None, exercise=None):
    """Classify activation independently from the generic open outcome."""
    if rep.get("outcome") == "build_unavailable":
        status = "build_unavailable"
    elif rep.get("violations"):
        status = "violation"
    else:
        eps = (rep.get("probe") or {}).get("entry_points", [])
        exercised = [e.get("name") for e in eps if e.get("calls", 0)]
        succeeded = {e.get("name") for e in eps if e.get("successes", 0)}
        required = {"external_link": ("H5Lvisit2", "H5Oopen"),
                    "external_file_list": ("H5Dread", "H5Dwrite"),
                    "virtual_dataset": ("H5Dread",),
                    "datatype": ("H5Tget_size", "H5Tget_class",
                                  "H5Tget_nmembers"),
                    "dataspace": ("H5Sget_simple_extent_npoints", "H5Dread"),
                    "dataset_layout": ("H5Dget_create_plist", "H5Dread"),
                    "btree": ("H5Lvisit2", "H5Oopen"),
                    "address_space": ("H5Fopen", "H5Fget_create_plist", "H5Pget_userblock",
                                      "H5Fget_eoa", "H5Fget_filesize", "H5Ovisit3"),
                    "free_space": ("H5Fopen", "H5Fget_filesize",
                                   "H5Fget_free_sections", "H5Ovisit3"),
                    "chunk_index": ("H5Ovisit3", "H5Dopen2", "H5Sselect_elements", "H5Dread"),
                    "dense_index": ("H5Lvisit2",),
                    "heap_structures": ("H5Ovisit3", "H5Aopen_by_idx", "H5Aread"),
                    "shared_messages_legacy": ("H5Ovisit3", "H5Aopen_by_idx", "H5Aget_type"),
                    "message_envelope": ("H5Ovisit3", "H5Oopen",
                                          "H5Gget_create_plist"),
                    "legacy_messages": ("H5Ovisit3", "H5Gget_info"),
                    "cache_image": ("H5Fget_mdc_image_info", "H5Fget_mdc_size",
                                    "H5Fget_filesize", "H5Ovisit3")}.get(exercise, ())
        traversal_modes = {"btree", "chunk_index", "dense_index",
                           "heap_structures", "shared_messages_legacy", "cache_image",
                           "message_envelope", "legacy_messages"}
        traversed = (rep.get("probe") or {}).get("materialization", {}).get(
            "traversal_calls", 0)
        family_completed = (rep.get("probe") or {}).get(
            "family_exercise", {}).get("completed", 0)
        # A generic successful open is not evidence: the selected family mode
        # and every required traversal entry point must have been called.
        selected = (rep.get("probe") or {}).get("exercise")
        if exercise and selected != exercise:
            return {"status": "unexercised", "entry_points_exercised": exercised,
                    "violations": rep.get("violations", [])}
        status = forced_status or ("verified" if all(x in succeeded for x in required)
                                   and (exercise not in traversal_modes or traversed > 0)
                                   and (exercise in (None, "generic") or family_completed > 0)
                                   else "unexercised")
    return {"status": status,
            "family_exercise": (rep.get("probe") or {}).get("family_exercise", {}),
            "entry_points_exercised": [e.get("name") for e in
                (rep.get("probe") or {}).get("entry_points", [])
                if e.get("calls", 0)],
            "violations": rep.get("violations", [])}


def _comparison_verdict(baseline, candidate):
    """A conservative release verdict; unknown evidence never becomes a pass."""
    blocked = {"unexercised", "coverage_gap", "build_unavailable"}
    before, after = baseline["status"], candidate["status"]
    if baseline.get("oracle_alignment") == "divergent" and \
       candidate.get("oracle_alignment") == "aligned":
        return "fixed"
    if candidate.get("oracle_alignment") == "divergent":
        return "regression"
    if before in blocked or after in blocked:
        return "inconclusive"
    if before == "violation" and after == "verified":
        return "fixed"
    if before != "violation" and after == "violation":
        return "regression"
    if before == after:
        return "unchanged"
    return "inconclusive"


def _oracle_alignment(rep, oracle_decision):
    """Compare the oracle's decision with what the build under test did.

    Only `reject_corrupt` is a claim ABOUT THE FILE that libhdf5 can agree or
    disagree with.  `reject_resource` and `reject_policy` are decisions about
    the selected PROFILE -- a traversal budget or a denied feature -- and
    libhdf5 has no equivalent, so it accepting such a file is expected by design
    and must not be reported as a divergence.
    """
    if not oracle_decision:
        return "unknown"
    if oracle_decision == "accept":
        return "aligned" if rep.get("outcome") == "accepted" else "divergent"
    if oracle_decision == "reject_corrupt":
        return "aligned" if rep.get("outcome") != "accepted" else "divergent"
    if oracle_decision.startswith("reject_"):
        return "not_comparable"
    return "unknown"


# ------------------------------------------------ minimize / variants ---------

def cmd_deferred(args, what, change):
    cdir = case_dir(args.case)
    print(f"h5cve {what}: deferred -- the {what} engine is roadmap change #{change}.")
    print(f"  bundle: {os.path.relpath(cdir)}")
    print(f"  for now, hand-{what} and drop artifacts into the bundle.")
    return 0


def cmd_variants(args):
    """Generate typed semantic variants with h5mutate.  The seed is a VALID
    neighbor (mutated into invariant-violating variants), not the malformed PoC:
    default to the PoC when it still parses as a continuation chain, else require
    an explicit --seed."""
    cdir = case_dir(args.case)
    case = load_case(cdir)
    seed = args.seed or case.get("fuzz_seed") or os.path.join(cdir, "input.h5")
    vdir = os.path.join(cdir, "variants")
    p = subprocess.run([H5MUTATE, "family", "--seed", seed,
                        "--out-dir", vdir, "--verify"],
                       capture_output=True, text=True)
    sys.stdout.write(p.stdout)
    if p.returncode != 0 and "not parseable" in (p.stdout + p.stderr) \
            or "supported" in p.stderr:
        print("h5cve variants: seed is not a continuation chain; pass a valid "
              "neighbor with --seed (the mutator slice covers the continuation "
              "family; other families are roadmap change #5 follow-ups).")
        return 0
    # record the produced variants in the case
    variants = []
    if os.path.isdir(vdir):
        for f in sorted(os.listdir(vdir)):
            if f.endswith(".recipe.yml"):
                sc = yaml.safe_load(open(os.path.join(vdir, f)))
                variants.append({"recipe": sc["recipe"],
                                 "intended_invariant": sc["intended_invariant"],
                                 "intended_finding": sc["intended_finding"]})
    case["variants"] = {"seed": seed, "engine": "h5mutate", "generated": variants}
    case["fuzz_seed"] = seed
    save_case(cdir, case)
    if not variants:
        print("variants: 0 applicable -- the seed has no continuation chain to "
              "mutate. The mutator slice covers the object-header continuation "
              "family; pass a continuation-bearing --seed, or this family is a "
              "roadmap change #5 follow-up.")
    else:
        print(f"variants: {len(variants)} recorded in "
              f"{os.path.relpath(cdir)}/variants/")
    return p.returncode


# ------------------------------------------------------------- promote --------

def cmd_promote(args):
    cdir = case_dir(args.case)
    case = load_case(cdir)
    prim = case.get("oracle", {}).get("primary_finding")
    decision = case.get("oracle", {}).get("decision")
    if not prim or not decision:
        die("run `h5cve triage` before promote (no oracle finding recorded)")

    exit_map = {"reject_corrupt": 2, "reject_resource": 4, "reject_policy": 3,
                "accept": 0}
    slug = case["id"].lower().replace("-", "_")
    exp_name = f"cve-{slug}.yml"
    expectation = {
        "file": f"cve/{slug}.h5",
        "profile": "untrusted-strict",
        "expected_decision": decision,
        "expected_exit": exit_map.get(decision, 2),
        "required_findings": [prim],
        "forbidden": ["crash", "timeout", "external_open", "plugin_load", "write"],
    }
    out_exp = os.path.join(cdir, "expected.yml")
    with open(out_exp, "w") as f:
        f.write(f"# Promotion draft for {case['id']}. Review, then copy to\n")
        f.write(f"# h5policy/tests/expected/{exp_name} and add the fixture.\n")
        yaml.safe_dump(expectation, f, sort_keys=False)

    # curated registry case (flat YAML alongside the hand-written ones)
    reg_case = os.path.join(cdir, f"registry-case-{slug}.yml")
    with open(reg_case, "w") as f:
        f.write(f"# Promotion draft: review and move to registry/cases/{slug}.yml\n")
        yaml.safe_dump(case, f, sort_keys=False, default_flow_style=False)

    print(f"promote: drafted {os.path.relpath(out_exp)} and "
          f"{os.path.relpath(reg_case)}")
    print("  manual steps (kept deliberate, not auto-committed):")
    print(f"    1. add a deterministic generator/seed for cve/{slug}.h5")
    print(f"    2. move expected.yml -> h5policy/tests/expected/{exp_name}")
    print(f"    3. move the registry case -> registry/cases/{slug}.yml")
    print(f"    4. add invariant/finding rows to registry/*.yml if new")
    return 0


def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("census", help="read-only oracle census of an HDF5 tree")
    p.add_argument("root")
    p.set_defaults(fn=cmd_census)

    p = sub.add_parser("matrix", help="run registry canaries for expected fixtures")
    p.add_argument("--baseline", help="bindir of the build under test")
    p.add_argument("--policy", default=os.path.join(REPO, "registry", "h5cve-matrix-policy.yml"))
    p.add_argument("--output", help="write the JSON matrix artifact to this path")
    p.set_defaults(fn=cmd_matrix)

    p = sub.add_parser("evidence", help="write measured libhdf5 evidence per record")
    p.add_argument("--matrix", help="matrix JSON artifact (default: run the matrix)")
    p.add_argument("--baseline", help="bindir of the build under test")
    p.add_argument("--libhdf5-version", help="version string to record")
    p.add_argument("--output", default=os.path.join(REPO, "registry",
                                                    "libhdf5-evidence.yml"))
    p.set_defaults(fn=cmd_evidence)

    p = sub.add_parser("verification", help="write the §12 per-family status")
    p.add_argument("--output", default=os.path.join(REPO, "registry",
                                                    "verification-coverage.yml"))
    p.set_defaults(fn=cmd_verification)

    p = sub.add_parser("init", help="new case bundle from a PoC")
    p.add_argument("id"); p.add_argument("--poc", required=True)
    p.add_argument("--force", action="store_true")
    p.set_defaults(fn=cmd_init)

    p = sub.add_parser("triage", help="oracle + census + registry mapping")
    p.add_argument("case"); p.set_defaults(fn=cmd_triage)

    p = sub.add_parser("verify", help="exact-build probe(s)")
    p.add_argument("case")
    p.add_argument("--baseline", help="bindir of the baseline build")
    p.add_argument("--candidate", help="bindir of the candidate build")
    p.set_defaults(fn=cmd_verify)

    p = sub.add_parser("minimize", help="[deferred: roadmap change #5]")
    p.add_argument("case")
    p.set_defaults(fn=lambda a: cmd_deferred(a, "minimize", 5))

    p = sub.add_parser("variants", help="typed semantic variants via h5mutate")
    p.add_argument("case")
    p.add_argument("--seed", help="valid neighbor to mutate (default: the PoC if "
                   "it still parses as a continuation chain, else required)")
    p.set_defaults(fn=cmd_variants)

    p = sub.add_parser("promote", help="draft the tests expectation + registry case")
    p.add_argument("case"); p.set_defaults(fn=cmd_promote)

    args = ap.parse_args()
    return args.fn(args)


if __name__ == "__main__":
    sys.exit(main())

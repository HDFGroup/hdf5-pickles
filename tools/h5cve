def die(msg):
    sys.exit(f"h5cve: {msg}")


def sha256(path):
    return hashlib.sha256(open(path, "rb").read()).hexdigest()


def git_commit():
    try:
        return subprocess.run(["git", "-C", REPO, "rev-parse", "--short", "HEAD"],
                              capture_output=True, text=True).stdout.strip() or None
    except Exception:
        return None


def poke_version():
    try:
        out = subprocess.run(["poke", "--version"], capture_output=True,
                             text=True, timeout=10).stdout
        return out.splitlines()[0] if out else None
    except Exception:
        return None


def case_dir(case):
    """Resolve a case argument to its bundle directory: an explicit path, or an
    id under cases/."""
    if os.path.isdir(case):
        return os.path.abspath(case)
    cand = os.path.join(CASES_ROOT, case)
    if os.path.isdir(cand):
        return cand
    die(f"no such case: {case} (looked for a dir and cases/{case})")


def load_case(cdir):
    p = os.path.join(cdir, "case.yml")
    if not os.path.exists(p):
        die(f"{p} not found; run `h5cve init` first")
    return yaml.safe_load(open(p))


def save_case(cdir, case):
    p = os.path.join(cdir, "case.yml")
    with open(p, "w") as f:
        f.write("# Generated by h5cve; edit fields marked TODO before promotion.\n")
        yaml.safe_dump(case, f, sort_keys=False, default_flow_style=False)


def run_json(cmd, timeout=120):
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return json.loads(p.stdout), p.returncode
    except (subprocess.TimeoutExpired, json.JSONDecodeError, OSError) as e:
        return {"error": str(e)}, -1



        "status": "draft",
        "disclosure": "TODO",
        "record": None,
        "versions": [],
        "entry_points": ["h5policy (oracle)", "TODO: libhdf5 entry points"],
        "root_cause_classification": None,
        "violated_invariant": None,
        "validation_closure": None,
        "activation_before_validation": ["TODO: run `h5cve verify`"],
        "oracle": {"profile": None, "decision": None, "primary_finding": None,
                   "object_path": None, "offset": None},
        "containment": {"status": "planned", "description": "TODO"},
        "systemic": {"semantic_boundary": None, "status": "planned", "owner": "TODO"},
        "backports": [],
        "reproducers": {
            "integration_poc": "TODO",
            "direct_fixture": "input.h5",
            "generator": "TODO",
            "assertions": {"stable_finding": None,
                           "fails_before_materialization": "unverified",
                           "no_plugin_load": "unverified",
                           "no_decompression": "unverified",
                           "no_external_open": "unverified",
                           "no_user_callback": "unverified",
                           "no_legacy_fallback": "unverified"},
        },
        "sibling_audit": "TODO",
        "fuzz_seed": None,

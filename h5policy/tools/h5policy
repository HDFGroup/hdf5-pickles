set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  h5policy [--profile PROFILE] [--max-walk-seconds N] [MODE FLAGS] FILE
  h5policy -h|--help

Output is JSON (the only format; --json is accepted but no longer required).

Profiles (see main.pdf Table 5):
  legacy           compatibility bias; unlimited budgets, all features allowed
  trusted-fast     normal validation, generous budgets, features allowed
  untrusted-strict strict validation, tight budgets, features denied (default)
  forensic         non-strict mapping, report anomalies, never follow refs

Mode flags (independent of the profile; default to the profile's behavior):
  --strict / --non-strict        force strict (@) or non-strict (@!) mapping
  --continue-after-rejection     keep walking after any rejecting finding
                                 (e.g. untrusted-strict --continue-after-rejection
                                  applies strict policy but reports all issues)

Resource overrides:
  --max-walk-seconds N           override the profile's internal walk deadline;
                                 the wrapper hard timeout becomes N + 30 seconds

Policy boundary:
  metadata-only, read-only, no libhdf5, no plugins, no decompression,
  no external file opens, no repair, no writes, no application deserialization.

Exit codes:
  0  accept
  1  accept_with_warnings
  2  reject_corrupt
  3  reject_policy
  4  reject_resource
  5  unsupported_coverage_gap
  70 internal_error
EOF
}

source_path=${BASH_SOURCE[0]}
while [[ -L "$source_path" ]]; do
    source_dir="$(cd -- "$(dirname -- "$source_path")" && pwd)"
    source_path="$(readlink -- "$source_path")"
    [[ "$source_path" == /* ]] || source_path="$source_dir/$source_path"
done
script_dir="$(cd -- "$(dirname -- "$source_path")" && pwd)"
overlay_dir="$(cd -- "$script_dir/.." && pwd)"
repo_dir="$(cd -- "$overlay_dir/.." && pwd)"

# escape_poke_string, escape_json_string, and h5_export_load_path live here.
source "$repo_dir/tools/lib/h5common.sh"

profile="untrusted_strict"
mapping_arg=""
continue_arg=""
max_walk_seconds=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --json)
            # JSON is the default (and only) output format; the flag is
            # accepted as a no-op for backward compatibility.
            shift
            ;;
        --profile)
            if [[ $# -lt 2 ]]; then
                printf 'h5policy: --profile requires an argument\n\n' >&2
                usage >&2
                exit 2
            fi
            case "$2" in
                legacy)
                    profile="legacy"
                    ;;
                trusted-fast|trusted_fast)
                    profile="trusted_fast"
                    ;;
                untrusted-strict|untrusted_strict)
                    profile="untrusted_strict"
                    ;;
                forensic)
                    profile="forensic"
                    ;;
                *)
                    printf 'h5policy: unsupported profile: %s\n\n' "$2" >&2
                    usage >&2
                    exit 2
                    ;;
            esac
            shift 2
            ;;
        --max-walk-seconds)
            if [[ $# -lt 2 ]]; then
                printf 'h5policy: --max-walk-seconds requires an argument\n\n' >&2
                usage >&2
                exit 2
            fi
            if [[ ! "$2" =~ ^[1-9][0-9]*$ \
                  || ${#2} -gt 10 \
                  || ( ${#2} -eq 10 && "$2" > "2147483647" ) ]]; then
                printf 'h5policy: --max-walk-seconds must be an integer between 1 and 2147483647\n' >&2
                exit 2
            fi
            max_walk_seconds=$2
            shift 2
            ;;
        --strict)
            mapping_arg="strict"
            shift
            ;;
        --non-strict)
            mapping_arg="non_strict"
            shift
            ;;
        --continue-after-rejection)
            continue_arg="yes"
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            printf 'h5policy: unknown option: %s\n\n' "$1" >&2
            usage >&2
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -ne 1 ]]; then
    usage >&2
    exit 2
fi

file=$1

if [[ ! -e "$file" ]]; then
    printf 'h5policy: file not found: %s\n' "$file" >&2
    exit 1
fi

if [[ "$file" == *$'\n'* ]]; then
    printf 'h5policy: file names containing newlines are not supported\n' >&2
    exit 1
fi

h5_export_load_path "$overlay_dir/pickles" "$repo_dir/pickles"

cmd_file=$(mktemp "${TMPDIR:-/tmp}/h5policy.XXXXXX")
trap 'rm -f "$cmd_file"' EXIT

{
    printf 'load h5_policy\n'
    printf 'h5policy_profile_name = "%s"\n' "$(escape_poke_string "$profile")"
    printf 'h5policy_file_name = "%s"\n' "$(escape_poke_string "$file")"
    printf 'h5policy_mapping_arg = "%s"\n' "$(escape_poke_string "$mapping_arg")"
    printf 'h5policy_continue_arg = "%s"\n' "$(escape_poke_string "$continue_arg")"
    if [[ -n "$max_walk_seconds" ]]; then
        printf 'h5policy_max_walk_seconds_override = %sUL\n' "$max_walk_seconds"
    fi
    printf 'h5policy_run\n'
    printf '.exit 0\n'
} >"$cmd_file"

# Hard wall-clock backstop.  Parts of the reachable-metadata walk still use
# linear-scan de-dup sets; the pickle enforces a soft per-profile deadline, but
# a single long-running poke operation can run between those checks.  A process
# timeout guarantees the preflight always terminates.  Kept above the pickle's
# own max_walk_seconds so the clean in-pickle coverage-gap fires first when it can.
case "$profile" in
    forensic)             wall=50 ;;
    legacy)               wall=90 ;;
    trusted_fast|trusted-fast) wall=35 ;;
    *)                    wall=20 ;;
esac
if [[ -n "$max_walk_seconds" ]]; then
    wall=$((max_walk_seconds + 30))
fi

poke_status=0
if command -v timeout >/dev/null 2>&1; then
    poke_output=$(timeout "${wall}s" poke --quiet -s "$cmd_file" 2>&1) || poke_status=$?
else
    poke_output=$(poke --quiet -s "$cmd_file" 2>&1) || poke_status=$?
fi

# timeout(1) exits 124 when it kills the child: emit a coverage-gap and stop.
if [[ $poke_status -eq 124 ]]; then
    continue_json=false
    if [[ "$continue_arg" == yes || "$profile" == forensic ]]; then
        continue_json=true
    fi
    mapping_mode=strict
    if [[ "$mapping_arg" == non_strict \
          || ( -z "$mapping_arg" && "$profile" == forensic ) ]]; then
        mapping_mode=non_strict
    fi
    physical_bytes=null
    if physical_candidate=$(stat -c '%s' -- "$file" 2>/dev/null) \
       && [[ "$physical_candidate" =~ ^[0-9]+$ ]]; then
        physical_bytes=$physical_candidate
    fi
    json_file=$(escape_json_string "$file")
    printf '{\n  "schema_version": 1,\n'
    printf '  "decision": "unsupported_coverage_gap",\n'
    printf '  "profile": "%s",\n  "file": "%s",\n' "$profile" "$json_file"
    printf '  "mapping_mode": "%s",\n  "phase": "0-4",\n' "$mapping_mode"
    printf '  "geometry": {"physical_bytes":%s,"declared_eoa":null,"effective_ceiling":null,"trailing_bytes":null},\n' "$physical_bytes"
    printf '  "analysis": {"complete":false,"walk_started":true,"walk_completed":false,"stop_reason":"wall_timeout","continue_after_rejection":%s,"findings_truncated":false},\n' "$continue_json"
    printf '  "boundary": {"libhdf5":false,"plugins":false,"decompression":false,"external_file_opens":false,"repair":false,"writes":false,"application_deserialization":false},\n'
    printf '  "features": {},\n  "metrics": {},\n'
    printf '  "findings": [ { "code": "H5_UNSUPPORTED_WALK_TIMEOUT", "class": "unsupported", "severity": "warning", "has_location": false, "object": "metadata", "offset": 0, "message": "analysis exceeded the %ss wall-clock limit; file too large or complex to fully vet" } ]\n' "$wall"
    printf '}\n'
    exit 5
fi

exit_code=
report=""
while IFS= read -r line; do
    case "$line" in
        __H5POLICY_EXIT_CODE=*)
            exit_code=${line#__H5POLICY_EXIT_CODE=}
            ;;
        *)
            report+="$line"$'\n'
            ;;
    esac
done <<<"$poke_output"

if [[ -z "$exit_code" ]]; then
    printf '%s' "$poke_output" >&2
    if [[ $poke_status -ne 0 ]]; then
        exit "$poke_status"
    fi
    exit 70
fi

printf '%s' "$report"
exit "$exit_code"

def _make_bad_null_message_gap(path, base_path):
    """Object-header NIL message no longer covers the chunk's remaining free
    space.  The repaired checksum lets the object-header free-space rule fire."""
    raw = bytearray(open(base_path, "rb").read())
    off = -1
    ohdr = -1
    remaining = 0
    for i in range(len(raw) - 4):
        if raw[i] == 0 and struct.unpack_from("<H", raw, i + 1)[0] >= 32 \
                and raw[i + 3] == 0:
            candidate_ohdr = raw.rfind(b"OHDR", 0, i)
            if candidate_ohdr >= 0:
                flags = raw[candidate_ohdr + 5]
                cur = candidate_ohdr + 6 + (16 if flags & (1 << 5) else 0) \
                    + (4 if flags & (1 << 4) else 0)
                size_width = 1 << (flags & 3)
                chunk_size = int.from_bytes(raw[cur:cur + size_width], "little")
                chunk_off = cur + size_width
                candidate_remaining = chunk_size - (i - chunk_off) - 4
                if struct.unpack_from("<H", raw, i + 1)[0] == candidate_remaining:
                    off = i
                    ohdr = candidate_ohdr
                    remaining = candidate_remaining
                    break
    if off < 0:
        raise RuntimeError("could not locate a terminal NIL message")
    struct.pack_into("<H", raw, off + 1, remaining - 1)
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_adjacent_null_messages(path, base_path):
    """Split one terminal v2 NIL message into two adjacent NIL messages.

    libhdf5 accepts adjacent NIL messages as long as they collectively leave no
    chunk gap.  This guards h5policy against requiring each NIL to cover the
    entire remainder of its chunk.
    """
    raw = bytearray(open(base_path, "rb").read())
    off = -1
    ohdr = -1
    remaining = 0
    for i in range(len(raw) - 4):
        if raw[i] == 0 and struct.unpack_from("<H", raw, i + 1)[0] >= 32 \
                and raw[i + 3] == 0:
            candidate_ohdr = raw.rfind(b"OHDR", 0, i)
            if candidate_ohdr >= 0:
                flags = raw[candidate_ohdr + 5]
                cur = candidate_ohdr + 6 + (16 if flags & (1 << 5) else 0) \
                    + (4 if flags & (1 << 4) else 0)
                size_width = 1 << (flags & 3)
                chunk_size = int.from_bytes(raw[cur:cur + size_width], "little")
                chunk_off = cur + size_width
                candidate_remaining = chunk_size - (i - chunk_off) - 4
                if struct.unpack_from("<H", raw, i + 1)[0] == candidate_remaining \
                        and candidate_remaining >= 24:
                    off = i
                    ohdr = candidate_ohdr
                    remaining = candidate_remaining
                    break
    if off < 0:
        raise RuntimeError("could not locate a splittable terminal NIL message")

    first_size = remaining - 12
    second_size = 8
    struct.pack_into("<H", raw, off + 1, first_size)
    second_off = off + 4 + first_size
    raw[second_off] = 0
    struct.pack_into("<H", raw, second_off + 1, second_size)
    raw[second_off + 3] = 0
    for j in range(second_size):
        raw[second_off + 4 + j] = 0

    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_message_count_compat(path):
    """v1 object header with the historic bad-message-count compatibility bug.

    Upstream HDF5 ships tbad_msg_count.h5, generated by a special build that
    stores one fewer message than the object header really contains.  Normal
    libhdf5 accepts it unless built with H5_STRICT_FORMAT_CHECKS because the
    under-count happens after chunk 0, in continuation messages.
    """
    base = path + ".base"
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with h5py.File(base, "w", libver="earliest") as h:
        g = h.create_group("Group")
        group_ohdr = h5py.h5o.get_info(g.id).addr
        g.attrs.create("Attribute #1", np.array(0, dtype="i4"))
        g.attrs.create("Attribute #2", np.array(0, dtype="i4"))

    raw = bytearray(open(base, "rb").read())
    os.unlink(base)
    if raw[group_ohdr] != 1:
        raise RuntimeError("expected a v1 group object header")
    nmessages = struct.unpack_from("<H", raw, group_ohdr + 2)[0]
    chunk0_size = struct.unpack_from("<I", raw, group_ohdr + 8)[0]
    first_msg_type = struct.unpack_from("<H", raw, group_ohdr + 16)[0]
    if nmessages < 2 or chunk0_size < 8 or first_msg_type != 0x10:
        raise RuntimeError("expected a continuation-only first object-header chunk")
    struct.pack_into("<H", raw, group_ohdr + 2, nmessages - 1)
    _patch(path, bytes(raw))



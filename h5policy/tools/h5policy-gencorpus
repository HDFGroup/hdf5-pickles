def _make_bad_link_info_max_corder(path):
    """Tracked-order compact group whose link-info message has a negative
    signed max creation order.  libhdf5 rejects this in H5O__linfo_decode."""
    def _build(h):
        g = h.create_group("g", track_order=True)
        g.create_group("a")
        g.create_group("b")
    raw = _base_bytes(_build, libver="earliest")

    # Link-info payload for the tracked/indexed group:
    # version(0), flags(track+index), max_corder(2), then three undef addresses.
    payload = b"\x00\x03" + struct.pack("<Q", 2) + (b"\xff" * 24)
    off = raw.find(payload)
    if off < 0:
        raise RuntimeError("could not locate the tracked link-info payload")
    struct.pack_into("<Q", raw, off + 2, 0x8000_0000_0000_0000)

    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate the containing object header")
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_link_info_trailing_bytes(path, base_path):
    """Root link-info message whose size is inflated to swallow following
    object-header messages.  The repaired checksum lets the malformed payload
    reach semantic validation."""
    raw = bytearray(open(base_path, "rb").read())
    # v2 message prefix: type=link-info(0x02), size=18, flags=0, payload
    # version=0, flags=0, then two undefined addresses.
    pat = b"\x02\x12\x00\x00\x00\x00" + (b"\xff" * 16)
    off = raw.find(pat)
    if off < 0:
        raise RuntimeError("could not locate the root link-info message")
    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate containing object header")
    raw[off + 1] = 0x62                           # swallow following messages
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _find_root_group_info(raw):
    pat = b"\x0a\x02\x00\x01\x00\x00"  # v2 prefix + payload: version=0, flags=0
    off = raw.find(pat)
    if off < 0:
        raise RuntimeError("could not locate the root group-info message")
    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate containing object header")
    return off, ohdr


def _make_bad_group_info_version(path, base_path):

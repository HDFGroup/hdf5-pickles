        raise RuntimeError("could not locate the dataspace message prefix")
    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate containing object header")
    raw[off + 6] = 0                              # max dimensions not present
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))



def _make_bad_ext_address(path):
    """v2/v3 superblock whose extension address is a defined 0 (the address of
    the superblock itself) rather than HADDR_UNDEF.  libhdf5 tries to read an
    object header there and rejects; h5policy used to treat 0 as "no extension".
    Found by the structure-aware fuzzer (super strategy)."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4"), track_times=False))
    assert raw[8] in (2, 3) and raw[9] == 8, "expected a v3 superblock, 8-byte offsets"
    struct.pack_into("<Q", raw, 12 + 1 * 8, 0)     # extension address := 0 (defined)
    _fix_sb_checksum(raw)
    _patch(path, bytes(raw))


def _make_bad_btree_key(path):
    """Old-style group whose group v1 B-tree first key (a local-heap name offset)
    points past the heap data segment.  libhdf5: 'unable to offset into local
    heap data block'.  h5policy validated SNOD name offsets but not the B-tree
    keys.  Found by the structure-aware fuzzer (bitflip)."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    tree = raw.find(b"TREE")
    if tree < 0:
        raise RuntimeError("could not locate the group v1 B-tree node")
    soff = raw[13]                                 # v0 superblock: size of offsets
    # node header (sig 4 + type 1 + level 1 + entries 2 + 2 sibling offsets),
    # then key0 (a sizeof_lengths byte offset into the group's local heap).
    key0 = tree + 8 + 2 * soff
    struct.pack_into("<Q", raw, key0, 0x1000)      # key well past any small heap
    _patch(path, bytes(raw))


def _make_bad_group_btree_declared_size(path, base_path):
    """Old-style group whose superblock group-B-tree K value makes the root
    B-tree node's declared allocation run past EOA.  h5policy used to size the
    node from entries_used only; libhdf5 sizes it from the superblock K."""
    raw = bytearray(open(base_path, "rb").read())
    if raw[8] != 0:
        raise RuntimeError("expected a v0 superblock fixture")
    # v0 superblock bytes 18..19 are the symbol-table internal-node K.
    struct.pack_into("<H", raw, 18, 0x0210)
    _patch(path, bytes(raw))


def _make_bad_group_btree_child_address(path, base_path):
    """Old-style group whose type-0 B-tree child pointer is a high-bit address.

    The address is outside the file, but converting it to a poke offset before
    range-checking used to raise an internal overflow instead of reporting the
    corrupt pointer field.
    """
    raw = bytearray(open(base_path, "rb").read())
    if raw[8] != 0:
        raise RuntimeError("expected a v0 superblock fixture")
    tree = raw.find(b"TREE")
    if tree < 0:
        raise RuntimeError("could not locate the group v1 B-tree node")
    off_size = raw[13]
    len_size = raw[14]
    child0 = tree + 8 + (2 * off_size) + len_size
    struct.pack_into("<Q", raw, child0, 0x2000_0000_0000_0430)
    _patch(path, bytes(raw))


def _make_bad_compound(path):
    """Compound datatype patched to declare zero members (libhdf5: 'invalid
    number of members: 0').  Built on a v1 object header (no checksum) so the
    edit needs no checksum fix-up."""
    raw = _base_bytes(
        lambda h: h.create_dataset(
            "d", shape=(2,),
            dtype=np.dtype([("aa", np.int32), ("bb", np.int32)])),
        libver="earliest")
    # Compound datatype header: byte0 low nibble = class 6, bytes 1-2 = number
    # of members (LE), bytes 4-7 = datatype size.  Locate the 2-member, 8-byte
    # compound and zero its member count.
    for i in range(len(raw) - 8):
        if ((raw[i] & 0x0F) == 6
                and struct.unpack_from("<H", raw, i + 1)[0] == 2
                and struct.unpack_from("<I", raw, i + 4)[0] == 8):
            struct.pack_into("<H", raw, i + 1, 0)
            break
    else:
        raise RuntimeError("could not locate the compound datatype header")
    _patch(path, bytes(raw))


def _v1_compound_array_member(elem_size, dims, base_size, base_precision):
    """Bytes of a version-1 compound datatype with a single member "a" that uses
    the legacy embedded-array encoding.  `dims` is the 4-slot dimension vector
    (unused slots are zero and never read past the declared rank)."""
    ndim = sum(1 for d in dims if d)  # number of leading non-zero dims
    dt = bytes([0x16]) + b"\x01\x00\x00" + struct.pack("<I", elem_size)  # compound v1, 1 member
    name = b"a\x00"
    name += b"\x00" * ((8 - len(name) % 8) % 8)                          # name padded to 8
    dt += name + struct.pack("<I", 0)                                    # member name + byte offset
    dt += bytes([ndim]) + b"\x00" * 3                                    # dimensionality + reserved
    dt += struct.pack("<I", 0) + struct.pack("<I", 0)                   # permutation + reserved
    for d in dims:
        dt += struct.pack("<I", d)                                      # 4 dimension-size slots
    dt += bytes([0x10]) + b"\x00" * 3 + struct.pack("<I", base_size) \
        + struct.pack("<H", 0) + struct.pack("<H", base_precision)      # integer base type
    return dt


def _splice_compact_datatype(path, dt_bytes, elem_size):
    """Splice a hand-built datatype message into a compact dataset's object
    header, so the on-disk element size matches `elem_size` (keeping the compact
    data consistent) and no data address shifts on the resize.  Grows chunk 0
    and repairs the object-header and superblock checksums.  Used for legacy
    encodings modern libhdf5 no longer writes."""
    def _build(h):
        space = h5py.h5s.create_simple((1,))
        dcpl = h5py.h5p.create(h5py.h5p.DATASET_CREATE)
        dcpl.set_layout(h5py.h5d.COMPACT)      # data inline: no address shifts on resize
        opaque = h5py.h5t.create(h5py.h5t.OPAQUE, elem_size)
        dsid = h5py.h5d.create(h.id, b"dset", opaque, space, dcpl)
        dsid.write(h5py.h5s.ALL, h5py.h5s.ALL, np.zeros((1,), dtype=f"V{elem_size}"))
    raw = _base_bytes(_build)

    ohdr = msg_start = old_size = body = size_off = size_w = None
    for o in range(len(raw) - 4):
        if raw[o:o + 4] != b"OHDR" or raw[o + 4] != 2:
            continue
        flags = raw[o + 5]
        cur = o + 6 + (16 if flags & (1 << 5) else 0) + (4 if flags & (1 << 4) else 0)
        size_w = 1 << (flags & 3)
        chunk0 = int.from_bytes(raw[cur:cur + size_w], "little")
        size_off = cur
        p = cur + size_w
        while p < cur + size_w + chunk0 - 3:
            mtype = raw[p]
            msize = struct.unpack_from("<H", raw, p + 1)[0]
            mbody = p + 4 + (2 if flags & 0x04 else 0)
            if mtype == 3:
                ohdr, msg_start, old_size, body = o, p, msize, mbody
                break
            p = mbody + msize
        if ohdr is not None:
            break
    if ohdr is None:
        raise RuntimeError("could not locate the dataset datatype message")

    delta = len(dt_bytes) - old_size
    new = bytearray(raw[:body] + dt_bytes + raw[body + old_size:])
    struct.pack_into("<H", new, msg_start + 1, len(dt_bytes))    # datatype message size
    chunk0 = int.from_bytes(new[size_off:size_off + size_w], "little")
    new[size_off:size_off + size_w] = (chunk0 + delta).to_bytes(size_w, "little")
    _fix_v2_ohdr_checksum(new, ohdr)
    struct.pack_into("<Q", new, 12 + 2 * new[9], len(new))       # declared EOF := new size
    _fix_sb_checksum(new)
    _patch(path, bytes(new))


def _make_compound_member_array_nelem_overflow(path):
    """A version-1 compound whose member uses the legacy embedded-array encoding
    with dimensions whose product overflows 64 bits.

    libhdf5 later scales that element count by the base type size
    (H5T__array_create), so an overflowing product wraps and underflows the
    array type's size -- consumers that build the type overflow (h5py: "dtype
    size in bytes must fit into a C int").  Modern libhdf5 only ever writes the
    newer *nested* array-datatype form, so this legacy member encoding is
    synthesized by splicing a hand-built datatype into a compact object header."""
    # dims [65537,65536,65536,65536] -> product 2**64 + 2**48; base H5T_STD_U32LE.
    dt = _v1_compound_array_member(4, (65537, 65536, 65536, 65536), 4, 32)
    _splice_compact_datatype(path, dt, 4)


def _make_compound_member_array_bounds(path):
    """A version-1 compound whose legacy embedded-array member overruns the
    compound element.

    The member is a [262144] array of H5T_STD_U8LE -- 262144 bytes -- inside a
    compound element declared as only 16 bytes.  libhdf5 reads base_size *
    element_count bytes per element, so the member extends far past the element
    storage: an out-of-bounds read (h5py refuses the type; h5dump prints past
    the 16 real bytes).  h5policy must reject the member as extending outside its
    parent type.  Built by splicing a hand-built v1 compound datatype whose
    element size matches the compact dataset's."""
    # A single 262144-element u8 array in a 16-byte compound element.
    dt = _v1_compound_array_member(16, (262144, 0, 0, 0), 1, 8)
    _splice_compact_datatype(path, dt, 16)


def _v1_compound_plain_member(elem_size, member_off, base_size, base_precision):
    """Bytes of a version-1 compound datatype with a single *plain* member "a"
    (rank-0 legacy array block) placed at byte offset `member_off`.  Unlike
    `_v1_compound_array_member` this fixes the member footprint at one base type
    and instead lets the caller drive the member's byte offset -- used to stress
    the offset side of the member-bounds check (a member that starts past the
    parent element)."""
    dt = bytes([0x16]) + b"\x01\x00\x00" + struct.pack("<I", elem_size)  # compound v1, 1 member
    name = b"a\x00"
    name += b"\x00" * ((8 - len(name) % 8) % 8)                          # name padded to 8
    dt += name + struct.pack("<I", member_off)                          # member name + byte offset
    dt += bytes([0]) + b"\x00" * 3                                       # rank 0 + reserved
    dt += struct.pack("<I", 0) + struct.pack("<I", 0)                   # permutation + reserved
    dt += struct.pack("<I", 0) * 4                                       # 4 dimension-size slots
    dt += bytes([0x10]) + b"\x00" * 3 + struct.pack("<I", base_size) \
        + struct.pack("<H", 0) + struct.pack("<H", base_precision)      # integer base type
    return dt


def _make_compound_member_offset_oob(path):
    """A version-1 compound whose single member starts at a byte offset far past
    the compound element.

    The member "a" (a 4-byte integer) declares byte offset 0xFFFFFF00 inside a
    compound element of only 16 bytes.  libhdf5 accumulates member offset + size
    and, on a 32-bit size_t, 0xFFFFFF00 + 4 wraps back below the element size --
    the classic integer-overflow path to a member landing outside the element
    (any conversion or access to it is an out-of-bounds heap write).  h5policy
    reasons about the raw on-disk offset in 64 bits and guards `member_off >
    elm_size` before subtracting, so it rejects the member as extending outside
    its parent type regardless of target pointer size.  Built by splicing a
    hand-built v1 compound datatype into a compact dataset of matching element
    size (modern libhdf5 no longer writes this legacy member encoding)."""
    dt = _v1_compound_plain_member(16, 0xFFFFFF00, 4, 32)
    _splice_compact_datatype(path, dt, 16)


def _scaleoffset_cd_patch(path, cd_index, value):
    """Build a chunked scale-offset dataset (4-element chunk of i4) and overwrite
    cd_values[cd_index] in its v2 filter pipeline message, repairing the object-
    header checksum.  Shared by the element-count and element-size fixtures.

    The pipeline payload is: version(1) nfilters(1); then the descriptor id(2)
    flags(2) cd_nelmts(2), followed by the 32-bit client-data words, so
    cd_values[i] lives at mbody + 8 + 4*i."""
    def _build(h):
        h.create_dataset("d", data=np.arange(8, dtype="i4"),
                         chunks=(4,), scaleoffset=0, track_times=False)
    raw = _base_bytes(_build)

    for o in range(len(raw) - 4):
        if raw[o:o + 4] != b"OHDR" or raw[o + 4] != 2:
            continue
        flags = raw[o + 5]
        cur = o + 6 + (16 if flags & (1 << 5) else 0) + (4 if flags & (1 << 4) else 0)
        size_w = 1 << (flags & 3)
        chunk0 = int.from_bytes(raw[cur:cur + size_w], "little")
        p = cur + size_w
        end = cur + size_w + chunk0
        while p < end - 3:
            mtype = raw[p]
            msize = struct.unpack_from("<H", raw, p + 1)[0]
            mbody = p + 4 + (2 if flags & 0x04 else 0)
            if (mtype == 0x0b and raw[mbody] == 2 and raw[mbody + 1] == 1
                    and struct.unpack_from("<H", raw, mbody + 2)[0] == 6):
                struct.pack_into("<I", raw, mbody + 8 + 4 * cd_index, value)
                _fix_v2_ohdr_checksum(raw, o)
                _patch(path, bytes(raw))
                return
            p = mbody + msize
    raise RuntimeError("could not locate the scale-offset filter descriptor")


def _make_scaleoffset_nelmts_mismatch(path):
    """A chunked dataset whose scale-offset filter declares a chunk element count
    (cd_values[2], H5Z_SCALEOFFSET_PARM_NELMTS) larger than the real chunk.

    libhdf5 auto-derives cd_values[2] from the chunk dataspace in
    H5Z__set_local_scaleoffset; its decompressor then sizes the per-chunk output
    buffer as cd_values[2] * element_size.  Inflating that count (here 4 -> 65537
    for a 4-element chunk) makes the decompressor write past the buffer sized from
    the real chunk -- and on a 32-bit size_t the 65537 * element_size product
    wraps and under-allocates, the classic filter integer-overflow OOB write.
    n-bit (filter 5) shares the identical cd_values[2] convention and code path;
    scale-offset is used here only because h5py can write it directly."""
    _scaleoffset_cd_patch(path, 2, 65537)


def _make_scaleoffset_size_mismatch(path):
    """A chunked dataset whose scale-offset filter declares a per-element size
    (cd_values[4], H5Z_SCALEOFFSET_PARM_SIZE) larger than the real datatype.

    cd_values[4] is the second factor libhdf5 multiplies into the decompressed
    buffer (nelmts * size).  Leaving the element count consistent and inflating
    only the size (here 4 -> 131073 for an i4 datatype) still overflows that
    product on a 32-bit size_t (131073 * 131073 wraps below the real chunk),
    driving the same out-of-bounds write.  h5policy rejects it because the
    declared element size disagrees with the dataset's datatype size."""
    _scaleoffset_cd_patch(path, 4, 131073)


def _make_chunk_size_uint32_wrap(path):
    """A v4 chunked layout whose encoded chunk dimensions multiply to a byte size
    of 2**32 + 256.  Vulnerable libhdf5 versions store the per-chunk byte size in
    a uint32_t (H5O_layout_chunk_t.size), so the product wraps to 256 and can
    under-allocate the read buffer; newer versions reject the oversized legacy
    chunk.  No valid file reaches this state -- H5Pset_chunk rejects chunks >=
    4 GiB at creation -- so build a single-chunk dataset whose chunk dimension
    needs four encoded bytes (2**24, no data written -> tiny file) and patch that
    dimension to 0x40000040, repairing the object-header checksum."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", shape=(1 << 24,), chunks=(1 << 24,),
                                   dtype="i4"))
    for o in range(len(raw) - 4):
        if raw[o:o + 4] != b"OHDR" or raw[o + 4] != 2:
            continue
        flags = raw[o + 5]
        cur = o + 6 + (16 if flags & (1 << 5) else 0) + (4 if flags & (1 << 4) else 0)
        size_w = 1 << (flags & 3)
        chunk0 = int.from_bytes(raw[cur:cur + size_w], "little")
        p = cur + size_w
        end = cur + size_w + chunk0
        while p < end - 3:
            mtype = raw[p]
            msize = struct.unpack_from("<H", raw, p + 1)[0]
            mbody = p + 4 + (2 if flags & 0x04 else 0)
            # Data Layout (0x08), version 4, class 2 (chunked): dims follow
            # version/class/flags/dimensionality/enc_bytes_per_dim.
            if mtype == 0x08 and raw[mbody] == 4 and raw[mbody + 1] == 2:
                enc = raw[mbody + 4]
                if enc < 4:
                    raise RuntimeError(
                        "chunk dim encoding too narrow to patch a wrapping value")
                struct.pack_into("<I", raw, mbody + 5, 0x40000040)
                _fix_v2_ohdr_checksum(raw, o)
                _patch(path, bytes(raw))
                return
            p = mbody + msize
    raise RuntimeError("could not locate the v4 chunked layout message")


def _make_bad_reference_datatype_version(path):
    """Datatype header patched to class reference with an unsupported version.

    Found by h5policy-fuzz: dictionary-splicing ``GCOL`` over a compound
    datatype header made a version-4 reference datatype that libhdf5 rejects and
    h5policy used to accept.
    """
    raw = _base_bytes(
        lambda h: h.create_dataset(
            "d", shape=(2,),
            dtype=np.dtype([("aa", np.int32), ("bb", np.int32)])),
        libver="earliest")
    for i in range(len(raw) - 8):
        if ((raw[i] & 0x0F) == 6
                and struct.unpack_from("<H", raw, i + 1)[0] == 2
                and struct.unpack_from("<I", raw, i + 4)[0] == 8):
            raw[i:i + 4] = b"GCOL"
            break
    else:
        raise RuntimeError("could not locate the compound datatype header")
    _patch(path, bytes(raw))


def _make_bad_offset(path):
    """Old-style group whose first symbol-table entry has a link-name offset
    past the end of the local heap data segment (libhdf5: 'unable to offset
    into local heap data block')."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    snod = raw.find(b"SNOD")
    if snod < 0:
        raise RuntimeError("could not locate the symbol table node")
    # First symbol-table entry's link-name offset (sizeof_offsets bytes at
    # SNOD+8) -> a value well past any small heap's data segment.
    struct.pack_into("<Q", raw, snod + 8, 0x1000)
    _patch(path, bytes(raw))


def _make_bad_unused_bits(path):
    """Fixed-point datatype whose size (65525 bytes) vastly exceeds its
    precision (32 bits) -- libhdf5: 'unusually large # of unused bits'."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    # Fixed-point datatype header: byte0 low nibble = class 0, bytes 4-7 = size,
    # bytes 8-9 = bit offset, bytes 10-11 = bit precision.  Find the int32
    # (size 4, precision 32, offset 0) and blow up its size.
    for i in range(len(raw) - 12):
        if ((raw[i] & 0x0F) == 0
                and struct.unpack_from("<I", raw, i + 4)[0] == 4
                and struct.unpack_from("<H", raw, i + 8)[0] == 0
                and struct.unpack_from("<H", raw, i + 10)[0] == 32):
            struct.pack_into("<I", raw, i + 4, 65525)
            break
    else:
        raise RuntimeError("could not locate the int32 datatype header")
    _patch(path, bytes(raw))


def _jenkins_lookup3():
    """Borrow the vetted Jenkins lookup3 from the CVE seed builder, so the
    superblock-field fixtures below can repair the v2/v3 superblock checksum."""
    import importlib.machinery
    import importlib.util
    here = os.path.dirname(os.path.realpath(__file__))
    path = os.path.normpath(
        os.path.join(here, "..", "tests", "cve", "make_cve_2020_10812.py"))
    loader = importlib.machinery.SourceFileLoader("cve_builder_gc", path)
    spec = importlib.util.spec_from_loader("cve_builder_gc", loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod.jenkins_lookup3


def _make_dtype_compound_recursion(path, levels=5000):
    """A single-member compound datatype nested ``levels`` deep in the modern
    (version-3) encoding: each level is a compound with one 1-char-named member
    whose type is the next compound, bottoming out in a fixed-point leaf.  This
    is the datatype-recursion CVE in its compound form -- libhdf5's
    H5O__dtype_decode_helper recurses once per level and overflows the stack.
    h5policy caps nesting at profile.resources.max_datatype_recursion_depth and
    rejects it as reject_resource (H5_RESOURCE_DATATYPE_RECURSION_DEPTH).

    Companion to the single-child VLen sibling (dtype_unbounded_recursion.h5):
    h5policy's cheap linear-depth preflight recognises a single-member compound
    as a one-child chain too, so both are rejected from the datatype prefix alone
    without descending the whole depth or checksumming the giant object header --
    the crisp resource rejection lands well inside the tightest wall-clock
    regardless of how deep the file claims to nest.

    Assembled from scratch (superblock + dataset object header + root-group
    object header) rather than byte-patched, because no libhdf5 writes a type this
    deep.  The fixed message encodings mirror the VLen sibling's envelope; both
    Jenkins checksums are recomputed for the compound datatype's length.
    """
    jenkins = _jenkins_lookup3()

    # Fixed envelope pieces, byte-identical to the known-good VLen recursion
    # fixture (superblock header, the dataset's dataspace/fill/layout messages,
    # and the root-group object header whose link points at the dataset OH @0x30).
    sb_head = bytes.fromhex("894844460d0a1a0a02080800")           # sig + v2 + 8B off/len + flags
    dataspace_msg = bytes.fromhex("0104000002000002")             # dataspace message (hdr + body)
    ds_trailer = bytes.fromhex("0502000003060804000003000000")    # fill-value + data-layout messages
    root_group_oh = bytes.fromhex(
        "4f484452020030021200000000ffffffffffffffffffffffffffffffff"
        "0a020000000006100000010005706f6331363000000000000000d7543402")

    # One version-3 compound level: header (class 6, version 3, 1 member, element
    # size 1 -> 1-byte member-offset field), the 1-char member name "a", and the
    # member's byte offset.  The member type is the next compound (11 bytes/level).
    wrapper = bytes.fromhex("3601000001000000") + b"a\x00" + b"\x00"
    leaf = bytes.fromhex("100000000100000000000800")              # fixed-point leaf, size 1
    dtype_data = wrapper * levels + leaf

    dtype_msg = bytes([0x03]) + struct.pack("<H", len(dtype_data)) + b"\x00" + dtype_data
    chunk0 = dataspace_msg + dtype_msg + ds_trailer
    dataset_oh = b"OHDR" + bytes([2, 1]) + struct.pack("<H", len(chunk0)) + chunk0
    dataset_oh += struct.pack("<I", jenkins(dataset_oh))

    root_addr = 48 + len(dataset_oh)                              # the superblock is 48 bytes
    eof = root_addr + len(root_group_oh)
    sb = (sb_head + struct.pack("<Q", 0) + b"\xff" * 8
          + struct.pack("<Q", eof) + struct.pack("<Q", root_addr))
    sb += struct.pack("<I", jenkins(sb))

    _patch(path, sb + dataset_oh + root_group_oh)


def _make_vds_nentries_overflow(path, base_path):
    """Make the VDS mapping count allocation/multiplication overflow shape.

    Preserve the valid GCOL and VDS object geometry, replace only the mapping
    count with an impossible value, and repair the VDS object's own checksum so
    the count/extent invariant is what rejects the file.
    """
    raw = bytearray(open(base_path, "rb").read())
    # create_virtual_dataset can't set track_times=False, so pin the object
    # header timestamps to keep this tracked cve/ seed byte-reproducible.
    _pin_ohdr_times(raw)
    gcol = raw.find(b"GCOL")
    if gcol < 0:
        raise RuntimeError("generated VDS fixture has no global heap")
    # Generated latest-format fixtures use 8-byte lengths.  GCOL header and
    # object header are each align8(8 + sizeof_lengths) == 16 bytes.
    data = gcol + 32
    obj_size = struct.unpack_from("<Q", raw, gcol + 24)[0]
    if obj_size < 13 or data + obj_size > len(raw):
        raise RuntimeError("generated VDS heap object geometry changed")
    struct.pack_into("<Q", raw, data + 1, 0x2000000000000000)
    checksum = data + obj_size - 4
    struct.pack_into("<I", raw, checksum,
                     _jenkins_lookup3()(bytes(raw[data:checksum])))
    _patch(path, raw)


def _fix_sb_checksum(raw):
    """Recompute the v2/v3 superblock's trailing Jenkins checksum in place."""
    assert raw[8] in (2, 3), "not a v2/v3 superblock"
    soff = raw[9]
    chksum_off = 12 + 4 * soff
    struct.pack_into("<I", raw, chksum_off,
                     _jenkins_lookup3()(bytes(raw[:chksum_off])))


def _fix_v2_ohdr_checksum(raw, ohdr_off):
    """Recompute a v2 object header's trailing Jenkins checksum in place."""
    assert raw[ohdr_off:ohdr_off + 4] == b"OHDR", "not a v2 object header"
    assert raw[ohdr_off + 4] == 2, "object header is not version 2"
    flags = raw[ohdr_off + 5]
    cursor = ohdr_off + 6
    if flags & (1 << 5):
        cursor += 16
    if flags & (1 << 4):
        cursor += 4
    size_width = 1 << (flags & 3)
    chunk_size = int.from_bytes(raw[cursor:cursor + size_width], "little")
    chksum_off = cursor + size_width + chunk_size
    struct.pack_into("<I", raw, chksum_off,
                     _jenkins_lookup3()(bytes(raw[ohdr_off:chksum_off])))


def _pin_ohdr_times(raw):
    """Zero the timestamp block of every v2 object header (and repair its
    checksum), making an h5py-written fixture byte-reproducible.

    h5py's create_virtual_dataset cannot disable time tracking the way
    create_dataset's ``track_times=False`` does, so a VDS fixture otherwise
    embeds the wall-clock time and drifts on every regeneration.  Each candidate
    header's stored checksum is verified before editing so incidental ``OHDR``
    bytes in data are never touched."""
    jenkins = _jenkins_lookup3()
    pos = 0
    while True:
        o = raw.find(b"OHDR", pos)
        if o < 0:
            break
        pos = o + 4
        if raw[o + 4] != 2:
            continue
        flags = raw[o + 5]
        cursor = o + 6 + (16 if flags & (1 << 5) else 0) + (4 if flags & (1 << 4) else 0)
        size_width = 1 << (flags & 3)
        chksum_off = cursor + size_width + int.from_bytes(raw[cursor:cursor + size_width], "little")
        if chksum_off + 4 > len(raw):
            continue
        if struct.unpack_from("<I", raw, chksum_off)[0] != jenkins(bytes(raw[o:chksum_off])):
            continue                              # not a genuine v2 object header
        if flags & (1 << 5):                      # times-present flag: zero the block
            raw[o + 6:o + 6 + 16] = b"\x00" * 16
            _fix_v2_ohdr_checksum(raw, o)


def _bytes_for_bits(nbits):
    return (nbits + 7) // 8


def _floor_log2(value):
    return value.bit_length() - 1 if value > 0 else 0


def _bt2_nrec_bytes(node_size, record_size, offset_size):
    nbytes = 1
    prev = 0
    while nbytes != prev:
        prev = nbytes
        ptr_size = offset_size + nbytes
        if node_size < 10 + ptr_size or record_size + ptr_size == 0:
            return nbytes
        max_nrec = (node_size - 10 - ptr_size) // (record_size + ptr_size)
        nbytes = 1
        thresh = 256
        while max_nrec >= thresh:
            nbytes += 1
            thresh *= 256
    return nbytes


def _bt2_subtree_bytes(node_size, record_size, level, offset_size):
    if level == 0 or record_size == 0 or node_size < 10:
        return 0
    nrec_bytes = _bt2_nrec_bytes(node_size, record_size, offset_size)
    cum_max = (node_size - 10) // record_size
    subtree_bytes = 0
    for _ in range(1, level + 1):
        ptr_size = offset_size + nrec_bytes + subtree_bytes
        if node_size < 10 + ptr_size or record_size + ptr_size == 0:
            return subtree_bytes
        max_int = (node_size - 10 - ptr_size) // (record_size + ptr_size)
        cum_max = ((max_int + 1) * cum_max) + max_int
        subtree_bytes = 1
        thresh = 256
        while cum_max >= thresh:
            if subtree_bytes >= 8:
                return 8
            subtree_bytes += 1
            thresh *= 256
    return subtree_bytes


def _dense_frhp_info(raw):
    off_size = raw[9]
    len_size = raw[10]
    frhp = raw.find(b"FRHP")
    if frhp < 0:
        raise RuntimeError("could not locate dense fractal heap header")
    filter_len = struct.unpack_from("<H", raw, frhp + 7)[0]
    flags = raw[frhp + 9]
    dtable = frhp + 14 + (10 * len_size) + (2 * off_size)
    width = struct.unpack_from("<H", raw, dtable)[0]
    start = int.from_bytes(raw[dtable + 2:dtable + 2 + len_size], "little")
    max_direct = int.from_bytes(
        raw[dtable + 2 + len_size:dtable + 2 + 2 * len_size], "little")
    max_heap_bits = struct.unpack_from("<H", raw, dtable + 2 + 2 * len_size)[0]
    root = int.from_bytes(
        raw[dtable + 6 + 2 * len_size:dtable + 6 + 2 * len_size + off_size],
        "little")
    curr_rows = struct.unpack_from(
        "<H", raw, dtable + 6 + 2 * len_size + off_size)[0]
    header_body = 14 + (2 * off_size) + (10 * len_size) \
        + (8 + 2 * len_size + off_size)
    if filter_len:
        header_body += len_size + 4 + filter_len
    return dict(off_size=off_size, len_size=len_size, frhp=frhp,
                filter_len=filter_len, flags=flags, width=width, start=start,
                max_direct=max_direct, max_heap_bits=max_heap_bits, root=root,
                curr_rows=curr_rows, heap_off_size=_bytes_for_bits(max_heap_bits),
                frhp_checksum=frhp + header_body)


def _dense_iblock_size(info, nrows):
    max_direct_rows = _floor_log2(info["max_direct"]) \
        - _floor_log2(info["start"]) + 2
    width = info["width"]
    if nrows <= max_direct_rows:
        ndir = nrows * width
        nindir = 0
    else:
        ndir = max_direct_rows * width
        nindir = (nrows - max_direct_rows) * width
    dir_entry = info["off_size"] if info["filter_len"] == 0 \
        else info["off_size"] + info["len_size"] + 4
    return 5 + info["off_size"] + info["heap_off_size"] \
        + ndir * dir_entry + nindir * info["off_size"] + 4


def _dense_bthd_info(raw):
    off_size = raw[9]
    len_size = raw[10]
    bthd = raw.find(b"BTHD")
    if bthd < 0:
        raise RuntimeError("could not locate dense v2 B-tree header")
    node_size = struct.unpack_from("<I", raw, bthd + 6)[0]
    record_size = struct.unpack_from("<H", raw, bthd + 10)[0]
    depth = struct.unpack_from("<H", raw, bthd + 12)[0]
    root = int.from_bytes(raw[bthd + 16:bthd + 16 + off_size], "little")
    nroot = struct.unpack_from("<H", raw, bthd + 16 + off_size)[0]
    return dict(off_size=off_size, len_size=len_size, bthd=bthd,
                node_size=node_size, record_size=record_size, depth=depth,
                root=root, nroot=nroot,
                checksum=bthd + 22 + off_size + len_size - 4)


def _dense_checksum_offset(raw, block):
    if block == "FRHP":
        return _dense_frhp_info(raw)["frhp_checksum"]
    if block == "FHDB":
        info = _dense_frhp_info(raw)
        fhdb = raw.find(b"FHDB")
        if fhdb < 0:
            raise RuntimeError("could not locate dense fractal heap direct block")
        return fhdb + 5 + info["off_size"] + info["heap_off_size"]
    if block == "FHIB":
        info = _dense_frhp_info(raw)
        fhib = raw.find(b"FHIB")
        if fhib < 0:
            raise RuntimeError("could not locate dense fractal heap indirect block")
        return fhib + _dense_iblock_size(info, info["curr_rows"]) - 4
    bt = _dense_bthd_info(raw)
    if block == "BTHD":
        return bt["checksum"]
    if block == "BTLF":
        btlf = raw.find(b"BTLF")
        if btlf < 0:
            raise RuntimeError("could not locate dense v2 B-tree leaf")
        return btlf + 6 + bt["nroot"] * bt["record_size"]
    if block == "BTIN":
        if raw[bt["root"]:bt["root"] + 4] != b"BTIN":
            raise RuntimeError("dense v2 B-tree root is not an internal node")
        nrec_bytes = _bt2_nrec_bytes(bt["node_size"], bt["record_size"],
                                     bt["off_size"])
        sub_bytes = _bt2_subtree_bytes(bt["node_size"], bt["record_size"],
                                       bt["depth"] - 1, bt["off_size"]) \
            if bt["depth"] > 1 else 0
        ptr_size = bt["off_size"] + nrec_bytes + sub_bytes
        return bt["root"] + 6 + bt["nroot"] * bt["record_size"] \
            + (bt["nroot"] + 1) * ptr_size
    raise RuntimeError(f"unknown dense checksum block {block}")


def _make_bad_dense_checksum(path, block):
    """Flip one stored checksum byte in dense link/attribute metadata."""
    root = os.path.dirname(os.path.dirname(path))
    base_name = "dense_attribute.h5" if block == "BTIN" else "dense_links.h5"
    raw = bytearray(open(os.path.join(root, "valid", base_name), "rb").read())
    off = _dense_checksum_offset(raw, block)
    raw[off] ^= 0x01
    _patch(path, bytes(raw))


def _make_bad_dense_attr_btree_deep(path, base_path):
    """Dense-attribute B-tree with a checksum-valid, absurd declared depth.

    The depth stays below the forensic profile cap so the dense v2-B-tree
    subtree-width helper is exercised.  Without saturating at 8-byte counters,
    the helper can spend unbounded time growing its threshold.
    """
    raw = bytearray(open(base_path, "rb").read())
    bt = _dense_bthd_info(raw)
    struct.pack_into("<H", raw, bt["bthd"] + 12, 120)
    struct.pack_into("<I", raw, bt["checksum"],
                     _jenkins_lookup3()(bytes(raw[bt["bthd"]:bt["checksum"]])))
    _patch(path, bytes(raw))


def _make_zero_v2_btree_record_size(path, base_path):
    """Dense-link name index with a checksum-valid zero record width.

    libhdf5's H5B2__hdr_init computes leaf capacity by dividing usable node
    bytes by this field, so h5dump and h5py receive SIGFPE before they can
    reject the malformed tree.
    """
    raw = bytearray(open(base_path, "rb").read())
    bt = _dense_bthd_info(raw)
    struct.pack_into("<H", raw, bt["bthd"] + 10, 0)
    struct.pack_into("<I", raw, bt["checksum"],
                     _jenkins_lookup3()(bytes(raw[bt["bthd"]:bt["checksum"]])))
    _patch(path, bytes(raw))


def _filtered_frhp_rewrite(base_path, pipeline, clear_checksum_flag):
    """Rewrite a valid unfiltered dense-link FRHP header into a filtered one.

    Inserts the filtered-header fields (size of the filtered root direct block,
    the I/O filter mask, and `pipeline`), sets the I/O filter length to the
    declared pipeline length, optionally clears the "direct blocks are
    checksummed" header flag, and repairs the FRHP and superblock checksums.
    h5policy returns at the filtered-heap branch before reading the doubling
    table, root block, or B-tree, so the now-stale trailing metadata (which
    still keeps libhdf5 from enumerating the group) needs no address fixups.

    `pipeline` is the raw filter-pipeline message; its declared length is used
    verbatim, so a descriptor extending past it stays a genuine overrun.
    """
    raw = bytearray(open(base_path, "rb").read())
    info = _dense_frhp_info(raw)
    assert info["filter_len"] == 0, "base heap is already filtered"
    frhp = info["frhp"]
    len_size = info["len_size"]
    # Fields up to and including "current rows in root indirect block".
    body_end = frhp + 14 + (2 * info["off_size"]) + (10 * len_size) \
        + (8 + 2 * len_size + info["off_size"])
    assert body_end == info["frhp_checksum"], "unexpected unfiltered header size"

    filtered_fields = bytearray()
    filtered_fields += int(info["start"]).to_bytes(len_size, "little")  # filt. dblock size
    filtered_fields += struct.pack("<I", 0)                             # I/O filter mask
    filtered_fields += pipeline

    new = bytearray(raw[:body_end])
    new += filtered_fields
    chksum_off = len(new)
    new += struct.pack("<I", 0)          # placeholder for the FRHP checksum
    new += raw[info["frhp_checksum"] + 4:]

    struct.pack_into("<H", new, frhp + 7, len(pipeline))  # I/O filters' encoded length
    if clear_checksum_flag:
        new[frhp + 9] &= ~0x02                            # clear checksum-dblocks flag
    struct.pack_into("<I", new, chksum_off,
                     _jenkins_lookup3()(bytes(new[frhp:chksum_off])))

    # Declared EOF must cover the enlarged header for h5policy's ceiling.
    soff = new[9]
    struct.pack_into("<Q", new, 12 + 2 * soff, len(new))
    _fix_sb_checksum(new)
    return bytes(new)


def _make_filtered_dense_link_no_dblock_checksum(path, base_path):
    """Dense-link fractal heap that declares an I/O filter pipeline but clears
    the "direct blocks are checksummed" header flag.

    libhdf5 always writes dense link/attribute heaps with that flag set, so the
    combination is malformed -- and a memory-safety hazard.  With the flag
    clear, H5HF__cache_dblock_verify_chksum short-circuits and never allocates
    the direct-block buffer, so H5HF__cache_dblock_deserialize then memcpy()s
    the reverse-filtered bytes into a NULL block and libhdf5 segfaults
    (H5HFcache.c).  h5policy validates the FRHP header and its filter pipeline,
    then must reject this rather than report a bare fractal-heap coverage gap.
    """
    # Minimal, structurally valid v2 filter pipeline: one scale-offset filter
    # (id 6) with no client data.  h5policy only needs the descriptor to parse.
    pipeline = struct.pack("<BB", 2, 1) + struct.pack("<HHH", 6, 0, 0)
    _patch(path, _filtered_frhp_rewrite(base_path, pipeline,
                                        clear_checksum_flag=True))


def _make_filtered_dense_link_pipeline_overrun(path, base_path):
    """Dense-link fractal heap whose filter pipeline descriptor runs past the
    declared I/O filter length.

    A version-1 descriptor declaring two client-data values is placed in a
    pipeline whose encoded length leaves no room for them, so the descriptor
    extent overruns the message -- the shape a "wrong decode buffer length"
    fuzz seed takes.  h5policy must reject it with
    H5_CORRUPT_FILTER_PIPELINE_OVERRUNS_MESSAGE rather than trust the pipeline
    and fall through to a coverage gap.  The checksum-dblocks flag is left set
    so the overrun is the sole finding.
    """
    # v1 pipeline: version, nfilters, 6 reserved, then a descriptor for a core
    # filter (shuffle, id 2) with no name but cd_nelmts=2 -- 8 bytes of client
    # data that the 16-byte declared length cannot hold (overruns by 8).
    pipeline = struct.pack("<BB", 1, 1) + b"\x00" * 6 \
        + struct.pack("<HHHH", 2, 0, 0, 2)
    assert len(pipeline) == 16
    _patch(path, _filtered_frhp_rewrite(base_path, pipeline,
                                        clear_checksum_flag=False))


def _make_gheap_infinite_loop(path, base_path):
    """Append an orphaned, malformed global heap collection to a valid file.

    The collection's free-space object (heap index 0) is encoded with a zero
    length.  libhdf5's H5HG__cache_heap_deserialize advances the parse cursor by
    obj[0].size for index 0, so a zero there never moves it and any consumer
    that loads the collection loops forever (h5debug hangs on it).  Nothing
    references the collection, so the reachability walk never sees it and
    libhdf5's normal open ignores it; only the forensic profile's GCOL
    signature sweep catches it, reporting a resource (DoS) hazard.
    """
    raw = bytearray(open(base_path, "rb").read())
    assert raw[8] in (2, 3), "expected a v2/v3 superblock"
    len_size = raw[10]
    align8 = lambda n: (n + 7) & ~7

    csize = 4096                                  # aligned collection size
    coll = bytearray(csize)                        # zero-filled body
    coll[0:4] = b"GCOL"
    coll[4] = 1                                    # version
    struct.pack_into("<" + {2: "H", 4: "I", 8: "Q"}[len_size], coll, 8, csize)
    # The first object sits at the aligned header and is left all-zero: heap
    # index 0 with a zero length -- the non-advancing free-space object.
    assert align8(4 + 1 + 3 + len_size) == 16 and coll[16:16 + 2 + len_size] == b"\x00" * (2 + len_size)

    raw += coll
    # Declared EOF must cover the appended collection for h5policy's ceiling.
    soff = raw[9]
    struct.pack_into("<Q", raw, 12 + 2 * soff, len(raw))
    _fix_sb_checksum(raw)
    _patch(path, bytes(raw))


def _make_bad_base_address(path):
    """v2/v3 superblock whose base address does not equal the superblock's own
    location (0 with no userblock).  libhdf5 measures the EOA relative to base,
    so a wrong base shifts every address -- 'actual len exceeds EOA'."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4"), track_times=False))
    assert raw[8] in (2, 3) and raw[9] == 8, "expected a v3 superblock, 8-byte offsets"
    struct.pack_into("<Q", raw, 12, 0x8)          # base address 8, superblock at 0
    _fix_sb_checksum(raw)
    _patch(path, bytes(raw))


def _make_eof_past_metadata(path):
    """v2/v3 superblock whose declared EOF equals the root object header address,
    so the root header lies at/after the declared end-of-file.  libhdf5 rejects
    any address >= EOA; h5policy must use the declared EOF (not the physical
    size) as its address ceiling."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4"), track_times=False))
    assert raw[8] in (2, 3) and raw[9] == 8, "expected a v3 superblock, 8-byte offsets"
    root = struct.unpack_from("<Q", raw, 12 + 3 * 8)[0]
    struct.pack_into("<Q", raw, 12 + 2 * 8, root)  # EOF := root addr (root now >= EOF)
    _fix_sb_checksum(raw)
    _patch(path, bytes(raw))


def _make_eof_truncates_data(path):
    """v4 contiguous dataset whose declared EOF is one byte below the end of the
    dataset's contiguous data.  libhdf5 rejects it ("invalid dataset size");
    h5policy must bounds-check the contiguous data extent against the EOF ceiling
    (the v4 layout branch used to skip this).  Found by the structure-aware
    fuzzer (super/eof on a v4-contiguous dataset)."""
    # No chunks/filter -> contiguous layout; data is the last allocated block.
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(64, dtype="i4"), track_times=False))
    assert raw[8] in (2, 3) and raw[9] == 8, "expected a v3 superblock, 8-byte offsets"
    struct.pack_into("<Q", raw, 12 + 2 * 8, len(raw) - 1)  # EOF := physical - 1
    _fix_sb_checksum(raw)
    _patch(path, bytes(raw))


def _make_inflated_eoa_ext_addr(path):
    """v2/v3 superblock that inflates the declared end-of-file above an
    out-of-file superblock extension address.

    This is the end-of-allocation bypass: a naive `addr < declared EOA` bounds
    check would accept the extension address, since it sits below the inflated
    EOA -- but it is far past the physical image.  h5policy checks superblock
    addresses against the physical file size and caps its walk ceiling at
    min(declared EOF, physical), so an attacker cannot buy address space past
    the file image by lying in the superblock; the address is still rejected.
    libhdf5 likewise refuses the file at open (declared EOA beyond the image)."""
    raw = _base_bytes(lambda h: None)           # valid, empty root group
    assert raw[8] in (2, 3) and raw[9] == 8, "expected a v3 superblock, 8-byte offsets"
    physical = len(raw)
    ext_addr = 0x10_0000                         # 1 MiB: far past the physical image
    declared_eof = 0x20_0000                     # 2 MiB: inflated ABOVE the ext addr
    assert physical < ext_addr < declared_eof
    struct.pack_into("<Q", raw, 12 + 1 * 8, ext_addr)      # superblock extension addr
    struct.pack_into("<Q", raw, 12 + 2 * 8, declared_eof)  # declared EOF / EOA
    _fix_sb_checksum(raw)
    _patch(path, bytes(raw))


def _make_bad_snod_cache_type(path):
    """Old-style group whose first symbol-table entry declares an unknown cache
    type (>2); libhdf5: 'unknown symbol table entry cache type'."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    snod = raw.find(b"SNOD")
    if snod < 0:
        raise RuntimeError("could not locate the symbol table node")
    soff = raw[13]                                 # v0 superblock: size of offsets
    # Entry 0 cache type is 4 bytes after the 8-byte SNOD header + name + address.
    struct.pack_into("<I", raw, snod + 8 + 2 * soff, 0x10)   # cache type -> 16
    _patch(path, bytes(raw))


def _make_bad_snod_version(path):
    """Old-style group whose symbol-table node has an unsupported version.

    Found by h5policy-fuzz: flipping SNOD version 1 -> 0 made libhdf5 reject the
    file while h5policy accepted it.
    """
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    snod = raw.find(b"SNOD")
    if snod < 0:
        raise RuntimeError("could not locate the symbol table node")
    raw[snod + 4] = 0                             # SNOD version must be 1
    _patch(path, bytes(raw))


def _make_bad_snod_empty_name(path):
    """Old-style group whose first SNOD entry points into the heap at an empty
    link name.  libhdf5 rejects this as an invalid link name."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    snod = raw.find(b"SNOD")
    if snod < 0:
        raise RuntimeError("could not locate the symbol table node")
    # The generated heap stores "d\0" at offset 8; offset 12 is inside the
    # zero-filled heap area and decodes as an empty name.
    struct.pack_into("<Q", raw, snod + 8, 12)
    _patch(path, bytes(raw))


def _make_bad_heap_segment(path):
    """Old-style group whose local heap declares a ~1 TB data-segment size, far
    past the file; libhdf5 rejects the oversized heap segment."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    heap = raw.find(b"HEAP")
    if heap < 0:
        raise RuntimeError("could not locate the local heap")
    # HEAP(4) + version(1) + reserved(3) then the data-segment size (a length).
    struct.pack_into("<Q", raw, heap + 8, 0x0000_0100_0000_0000)
    _patch(path, bytes(raw))


def _make_bad_heap_free_list(path):
    """Old-style group whose local heap free-list head points outside the heap
    data segment; libhdf5 rejects this while initializing the local heap."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", data=np.arange(4, dtype="i4")),
        libver="earliest")
    heap = raw.find(b"HEAP")
    if heap < 0:
        raise RuntimeError("could not locate the local heap")
    # HEAP(4) + version(1) + reserved(3) + data-segment size(length), then the
    # free-list head offset(length).  Point it well past the small data segment.
    struct.pack_into("<Q", raw, heap + 16, 0x1000)
    _patch(path, bytes(raw))


def _make_bad_duplicate_dataspace_message(path, base_path):
    """Dataset object header whose layout message type is rewritten as
    dataspace, with the v2 object-header checksum repaired.

    The payload is still a layout payload, so libhdf5 rejects it while decoding
    the duplicate dataspace message's version byte.  Found by the
    checksum-repairing `struct` mutator.
    """
    raw = bytearray(open(base_path, "rb").read())
    # v2 message prefix: type=layout(0x08), size=22, flags=0, then layout v4
    # payload: version=4, class=chunked, ndims=3.
    pat = b"\x08\x16\x00\x00\x04\x02\x00\x03"
    off = raw.find(pat)
    if off < 0:
        raise RuntimeError("could not locate the layout message prefix")
    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate containing object header")
    raw[off] = 0x01                                # layout -> dataspace
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_ext_array_without_unlimited_dim(path, base_path):

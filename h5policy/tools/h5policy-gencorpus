    raw = bytearray(open(base, "rb").read())
    os.unlink(base)
    # v1 object-header message prefix: type(2), size(2), flags(1), reserved(3).
    prefix = struct.pack("<HHB", 0x11, 16, 0)  # symbol-table message, no flags
    off = raw.find(prefix)
    if off < 0:
        raise RuntimeError("could not locate the symbol-table message prefix")
    raw[off + 4] = 0x20                         # WAS_UNKNOWN without MARK_IF_UNKNOWN
    _patch(path, bytes(raw))


def _make_bad_link_info_max_corder(path):
    """Tracked-order compact group whose link-info message has a negative
    signed max creation order.  libhdf5 rejects this in H5O__linfo_decode."""
    base = path + ".base"
    with h5py.File(base, "w", libver="earliest") as h:
        g = h.create_group("g", track_order=True)
        g.create_group("a")
        g.create_group("b")
    raw = bytearray(open(base, "rb").read())
    os.unlink(base)

    # Link-info payload for the tracked/indexed group:
    # version(0), flags(track+index), max_corder(2), then three undef addresses.
    payload = b"\x00\x03" + struct.pack("<Q", 2) + (b"\xff" * 24)
    off = raw.find(payload)
    if off < 0:
        raise RuntimeError("could not locate the tracked link-info payload")
    struct.pack_into("<Q", raw, off + 2, 0x8000_0000_0000_0000)

    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate the containing object header")
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_link_info_trailing_bytes(path, base_path):
    """Root link-info message whose size is inflated to swallow following
    object-header messages.  The repaired checksum lets the malformed payload
    reach semantic validation."""
    raw = bytearray(open(base_path, "rb").read())
    # v2 message prefix: type=link-info(0x02), size=18, flags=0, payload
    # version=0, flags=0, then two undefined addresses.
    pat = b"\x02\x12\x00\x00\x00\x00" + (b"\xff" * 16)
    off = raw.find(pat)
    if off < 0:
        raise RuntimeError("could not locate the root link-info message")
    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate containing object header")
    raw[off + 1] = 0x62                           # swallow following messages
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _find_root_group_info(raw):
    pat = b"\x0a\x02\x00\x01\x00\x00"  # v2 prefix + payload: version=0, flags=0
    off = raw.find(pat)
    if off < 0:
        raise RuntimeError("could not locate the root group-info message")
    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate containing object header")
    return off, ohdr


def _make_bad_group_info_version(path, base_path):
    """Group-info payload version byte mutated away from zero.  libhdf5 rejects
    this while decoding the root group creation info."""
    raw = bytearray(open(base_path, "rb").read())
    off, ohdr = _find_root_group_info(raw)
    raw[off + 4] = 8
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_group_info_trailing_bytes(path, base_path):
    """Group-info message size inflated so the following message bytes become
    bogus trailing payload.  Found by h5policy-fuzz against a v2 root header."""
    raw = bytearray(open(base_path, "rb").read())
    off, ohdr = _find_root_group_info(raw)
    struct.pack_into("<H", raw, off + 1, 52)
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_null_message_gap(path, base_path):
    """Object-header NIL message no longer covers the chunk's remaining free
    space.  The repaired checksum lets the object-header free-space rule fire."""
    raw = bytearray(open(base_path, "rb").read())
    off = -1
    ohdr = -1
    remaining = 0
    for i in range(len(raw) - 4):
        if raw[i] == 0 and struct.unpack_from("<H", raw, i + 1)[0] >= 32 \
                and raw[i + 3] == 0:
            candidate_ohdr = raw.rfind(b"OHDR", 0, i)
            if candidate_ohdr >= 0:
                flags = raw[candidate_ohdr + 5]
                cur = candidate_ohdr + 6 + (16 if flags & (1 << 5) else 0) \
                    + (4 if flags & (1 << 4) else 0)
                size_width = 1 << (flags & 3)
                chunk_size = int.from_bytes(raw[cur:cur + size_width], "little")
                chunk_off = cur + size_width
                candidate_remaining = chunk_size - (i - chunk_off) - 4
                if struct.unpack_from("<H", raw, i + 1)[0] == candidate_remaining:
                    off = i
                    ohdr = candidate_ohdr
                    remaining = candidate_remaining
                    break
    if off < 0:
        raise RuntimeError("could not locate a terminal NIL message")
    struct.pack_into("<H", raw, off + 1, remaining - 1)
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))



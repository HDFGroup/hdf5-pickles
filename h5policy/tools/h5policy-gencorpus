        off = raw.find(prefix, off + 1)
    if off < 0:
        raise RuntimeError("could not locate the rank-1 dataspace message")
    struct.pack_into("<H", raw, off + 2, 64)
    _patch(path, bytes(raw))


def _make_bad_datatype_precision_bounds(path):
    """Fixed-point datatype whose bit offset + precision exceeds its storage
    size.  Found by h5policy-fuzz; libhdf5 reports integer
    offset+precision-out-of-bounds when opening the dataset."""
    raw = _base_bytes(
        lambda h: h.create_dataset(
            "d", data=np.arange(100, dtype="i4").reshape(10, 10), chunks=(5, 5)),
        libver="earliest")
    for i in range(len(raw) - 12):
        if ((raw[i] & 0x0F) == 0
                and struct.unpack_from("<I", raw, i + 4)[0] == 4
                and struct.unpack_from("<H", raw, i + 8)[0] == 0
                and struct.unpack_from("<H", raw, i + 10)[0] == 32):
            struct.pack_into("<H", raw, i + 10, 0x4020)
            break
    else:
        raise RuntimeError("could not locate the int32 datatype header")
    _patch(path, bytes(raw))


def _make_bad_dataspace_maxdim(path):
    """Dataset whose current dataspace dimension is larger than the encoded
    maximum dimension; libhdf5 rejects this when opening the dataspace."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", shape=(10,), maxshape=(10,), dtype="i4"),
        libver="earliest")
    prefix = struct.pack("<HHB3x", 0x01, 24, 0)
    off = raw.find(prefix)
    while off >= 0 and raw[off + 8:off + 11] != b"\x01\x01\x01":
        off = raw.find(prefix, off + 1)
    if off < 0:
        raise RuntimeError("could not locate the max-dimension dataspace")
    struct.pack_into("<Q", raw, off + 24, 5)
    _patch(path, bytes(raw))


def _make_dataspace_nelem_overflow(path):
    """Compact 2-D dataset whose dimensions multiply to more than 2**64.

    libhdf5 stores the element count in hsize_t, so the product wraps to a
    small value and it under-sizes the inline compact buffer -- an
    out-of-bounds read in H5D__compact_readvv.  h5policy rejects the
    unrepresentable dataspace as corrupt, distinct from a
    representable-but-oversized dataset (a resource shape)."""
    def _build(h):
        space = h5py.h5s.create_simple((2, 8))
        dcpl = h5py.h5p.create(h5py.h5p.DATASET_CREATE)
        dcpl.set_layout(h5py.h5d.COMPACT)
        dt = h5py.h5t.py_create(np.dtype("u1"))
        dsid = h5py.h5d.create(h.id, b"dset", dt, space, dcpl)
        dsid.write(h5py.h5s.ALL, h5py.h5s.ALL,
                   np.arange(16, dtype="u1").reshape(2, 8))
    raw = _base_bytes(_build)

    # v2 dataspace: version(1) rank(1) flags(1=maxdims) type(1), then dims,
    # then maxdims.  Overwrite dim0 and maxdim0 together so the only defect is
    # the overflowing product (dim never exceeds its own maximum).
    hdr = struct.pack("<BBBB", 2, 2, 1, 1) + struct.pack("<QQ", 2, 8)
    ds = raw.find(hdr)
    if ds < 0:
        raise RuntimeError("could not locate the 2-D dataspace message")
    dims = ds + 4
    big = (1 << 62) + 1                          # (2**62+1) * 8 = 2**65 + 8
    struct.pack_into("<Q", raw, dims, big)       # dim0
    struct.pack_into("<Q", raw, dims + 16, big)  # maxdim0

    ohdr = raw.rfind(b"OHDR", 0, ds)
    if ohdr < 0:
        raise RuntimeError("could not locate the dataset object header")
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_external_link_info(path):
    """External link whose user-data length is smaller than the minimum
    external-link encoding.  libhdf5 rejects this before link traversal policy
    is relevant."""
    raw = _base_bytes(
        lambda h: h.__setitem__("ext", h5py.ExternalLink("other.h5", "/x")))

    payload = b"\x01\x08\x40\x03ext\x0d\x00\x00other.h5\x00/x\x00"
    off = raw.find(payload)
    if off < 0:
        raise RuntimeError("could not locate the external link payload")
    struct.pack_into("<H", raw, off + 7, 0)

    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate the containing object header")
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_external_link_unterminated(path):
    """External link whose value contains no NUL terminator, so the target file
    name never ends inside the value.  libhdf5's H5L__extern_traverse runs
    strlen() over it and reads past the value -- the out-of-bounds read the seed
    is named for.  h5policy rejects the malformed value structurally under every
    profile, independent of the external-reference policy."""
    raw = _base_bytes(
        lambda h: h.__setitem__("ext", h5py.ExternalLink("other.h5", "/x")))

    payload = b"\x01\x08\x40\x03ext\x0d\x00\x00other.h5\x00/x\x00"
    off = raw.find(payload)
    if off < 0:
        raise RuntimeError("could not locate the external link payload")
    # The value follows the 2-byte user-data length at off+7, starting with its
    # own version/flags byte at off+9.  Overwrite every NUL after that byte so
    # neither the file name nor the object path terminates inside the value.
    val = off + 9
    ext_len = struct.unpack_from("<H", raw, off + 7)[0]
    for k in range(1, ext_len):
        if raw[val + k] == 0:
            raw[val + k] = 0x41                  # 'A'

    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate the containing object header")
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _efl_payload(raw):
    """Return (payload offset, containing v2 object-header offset) for the
    single-slot, 8-byte-width EFL fixture generated above."""
    marker = b"\x07\x28\x00\x01\x01\x00\x00\x00\x01\x00\x01\x00"
    prefix = raw.find(marker)
    if prefix < 0:
        raise RuntimeError("could not locate the external file list message")
    payload = prefix + 4
    ohdr = raw.rfind(b"OHDR", 0, prefix)
    if ohdr < 0:
        raise RuntimeError("could not locate the EFL object header")
    return payload, ohdr


def _patch_efl(path, base_path, mutate):
    raw = bytearray(open(base_path, "rb").read())
    payload, ohdr = _efl_payload(raw)
    mutate(raw, payload)
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_efl_slot_count(path, base_path):
    """An EFL with one used slot but no allocated slots."""
    _patch_efl(path, base_path,
               lambda raw, off: struct.pack_into("<H", raw, off + 4, 0))


def _make_truncated_efl_slots(path, base_path):
    """An EFL declaring two slots while its message contains only one."""
    def mutate(raw, off):
        struct.pack_into("<H", raw, off + 4, 2)
        struct.pack_into("<H", raw, off + 6, 2)
    _patch_efl(path, base_path, mutate)


def _make_bad_efl_heap_address(path, base_path):
    """An EFL whose filename local-heap address lies outside the file."""
    _patch_efl(path, base_path,
               lambda raw, off: struct.pack_into("<Q", raw, off + 8,
                                                  0x7fff_ffff_ffff_ff00))


def _make_bad_efl_name_offset(path, base_path):
    """An EFL slot whose filename offset lies outside its local heap."""
    _patch_efl(path, base_path,
               lambda raw, off: struct.pack_into("<Q", raw, off + 16,
                                                  0x1000))


def _make_overflowing_efl_segment(path, base_path):
    """An EFL slot whose external-file offset plus size wraps uint64."""
    _patch_efl(path, base_path,
               lambda raw, off: struct.pack_into("<Q", raw, off + 24,
                                                  0xffff_ffff_ffff_fff8))


def _make_bad_dataset_storage_overflow(path):
    """Contiguous dataset whose dataspace element count overflows when
    multiplied by the datatype size.  libhdf5 rejects this while initializing
    the dataset's storage."""
    raw = _base_bytes(
        lambda h: h.create_dataset("d", shape=(4,), dtype="i8"),
        libver="earliest")

    # v1 object-header dataspace message: prefix(8), then version/rank/header,
    # then current and max dimensions as 8-byte lengths.
    prefix = struct.pack("<HHB3x", 0x01, 24, 0)
    off = raw.find(prefix)
    while off >= 0 and raw[off + 8:off + 10] != b"\x01\x01":
        off = raw.find(prefix, off + 1)
    if off < 0:
        raise RuntimeError("could not locate the dataspace message prefix")
    huge_dim = 0x4000_0000_0000_0000
    struct.pack_into("<Q", raw, off + 16, huge_dim)
    struct.pack_into("<Q", raw, off + 24, huge_dim)
    _patch(path, bytes(raw))


def _make_bad_compact_layout_overrun(path):
    """A scaleoffset filter-pipeline message retagged as a legacy compact
    layout message.  The filter descriptor bytes become a bogus compact
    inline-data size, and libhdf5 rejects the object while decoding layout."""
    raw = _base_bytes(
        lambda h: h.create_dataset(
            "d", data=np.arange(42, dtype="f4").reshape(7, 6),
            chunks=(4, 3), scaleoffset=3),
        libver="earliest")

    off = -1
    for i in range(len(raw) - 16):
        mtype, size, flags = struct.unpack_from("<HHB", raw, i)
        if (mtype == 0x0b and size == 112 and flags == 1
                and raw[i + 8:i + 16] == b"\x01\x01\x00\x00\x00\x00\x00\x00"):
            off = i
            break
    if off < 0:
        raise RuntimeError("could not locate the scaleoffset filter pipeline")

    # v1 object headers have no checksum; only the message ID changes.
    struct.pack_into("<H", raw, off, 0x08)
    _patch(path, bytes(raw))


def _patch(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "wb") as f:
        f.write(data)



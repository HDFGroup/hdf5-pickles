def _make_bad_external_link_info(path):
    """External link whose user-data length is smaller than the minimum
    external-link encoding.  libhdf5 rejects this before link traversal policy
    is relevant."""
    base = path + ".base"
    with h5py.File(base, "w", libver="latest") as h:
        h["ext"] = h5py.ExternalLink("other.h5", "/x")
    raw = bytearray(open(base, "rb").read())
    os.unlink(base)

    payload = b"\x01\x08\x40\x03ext\x0d\x00\x00other.h5\x00/x\x00"
    off = raw.find(payload)
    if off < 0:
        raise RuntimeError("could not locate the external link payload")
    struct.pack_into("<H", raw, off + 7, 0)

    ohdr = raw.rfind(b"OHDR", 0, off)
    if ohdr < 0:
        raise RuntimeError("could not locate the containing object header")
    _fix_v2_ohdr_checksum(raw, ohdr)
    _patch(path, bytes(raw))


def _make_bad_dataset_storage_overflow(path):
    """Contiguous dataset whose dataspace element count overflows when
    multiplied by the datatype size.  libhdf5 rejects this while initializing
    the dataset's storage."""
    base = path + ".base"
    with h5py.File(base, "w", libver="earliest") as h:
        h.create_dataset("d", shape=(4,), dtype="i8")
    raw = bytearray(open(base, "rb").read())
    os.unlink(base)

    # v1 object-header dataspace message: prefix(8), then version/rank/header,
    # then current and max dimensions as 8-byte lengths.
    prefix = struct.pack("<HHB3x", 0x01, 24, 0)
    off = raw.find(prefix)
    while off >= 0 and raw[off + 8:off + 10] != b"\x01\x01":
        off = raw.find(prefix, off + 1)
    if off < 0:
        raise RuntimeError("could not locate the dataspace message prefix")
    huge_dim = 0x4000_0000_0000_0000
    struct.pack_into("<Q", raw, off + 16, huge_dim)
    struct.pack_into("<Q", raw, off + 24, huge_dim)
    _patch(path, bytes(raw))


def _make_bad_compact_layout_overrun(path):
    """A scaleoffset filter-pipeline message retagged as a legacy compact
    layout message.  The filter descriptor bytes become a bogus compact
    inline-data size, and libhdf5 rejects the object while decoding layout."""
    base = path + ".base"
    with h5py.File(base, "w", libver="earliest") as h:
        h.create_dataset("d", data=np.arange(42, dtype="f4").reshape(7, 6),
                         chunks=(4, 3), scaleoffset=3)
    raw = bytearray(open(base, "rb").read())
    os.unlink(base)

    off = -1
    for i in range(len(raw) - 16):
        mtype, size, flags = struct.unpack_from("<HHB", raw, i)
        if (mtype == 0x0b and size == 112 and flags == 1
                and raw[i + 8:i + 16] == b"\x01\x01\x00\x00\x00\x00\x00\x00"):
            off = i
            break
    if off < 0:
        raise RuntimeError("could not locate the scaleoffset filter pipeline")

    # v1 object headers have no checksum; only the message ID changes.
    struct.pack_into("<H", raw, off, 0x08)
    _patch(path, bytes(raw))


def _patch(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "wb") as f:
        f.write(data)



    _patch(path, bytes(raw))


def _make_bad_snod_empty_name(path):
    """Old-style group whose first SNOD entry points into the heap at an empty
    link name.  libhdf5 rejects this as an invalid link name."""
    base = path + ".base"
    with h5py.File(base, "w", libver="earliest") as h:

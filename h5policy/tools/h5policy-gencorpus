        raise RuntimeError("could not locate the symbol-table message prefix")
    ohdr = off - 16
    if ohdr < 0 or raw[ohdr] != 1:
        raise RuntimeError("expected a v1 root object header")
    struct.pack_into("<I", raw, ohdr + 8, 2)
    _patch(path, bytes(raw))


def _make_bad_layout_rank_mismatch(path):
    """Old chunked dataset whose v1 dataspace rank does not match the legacy

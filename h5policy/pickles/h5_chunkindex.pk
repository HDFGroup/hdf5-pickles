/* Chunk indexes can be large and deeply nested, so this file validates enough
   structure to count chunks, enforce resource limits, and reject out-of-file
   chunk addresses without reading or decompressing chunk payloads.  */

/* Walk a v1 (type-1, raw-data-chunk) B-tree chunk index: count chunks against
   max_chunk_count, verify each chunk's address+size lies in the file, and bound
   recursion by max_btree_depth and a visited set.  `ndims` is the chunk
   dimensionality from the layout message (dataset rank + 1); a type-1 key is
   chunk_size(4) + filter_mask(4) + ndims 8-byte offsets.  This validates the
   index structure under budget; it does not read chunk contents.  */
fun h5policy_walk_chunk_btree = (int ios, H5PolicyProfile profile, H5WalkContext ctx,
                                 uint<64> btree_addr, uint<64> ndims,
                                 string object, uint<64> btree_depth) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var file_size = h5policy_ceiling(ios);

    /* A previous leaf has already proved that the file-wide chunk ceiling was
       exceeded.  The resource decision is established, so do not chase more
       of this recursively encoded index. */
    if (ctx.chunk_count_exceeded != 0UB)
        return ctx;

    /* The recursive v1 B-tree walker is the only chunk-index path that follows
       arbitrary tree depth today.  The profile depth limit and visited set
       bound both normal nesting and corrupt cycles.  */
    if (btree_depth > profile.resources.max_btree_depth)
        {
            h5policy_emit_error("H5_RESOURCE_BTREE_DEPTH", "resource",
                                btree_addr#B, object,
                                "chunk B-tree depth exceeds the selected profile limit");
            return ctx;
        }

    /* A repeated node address means either a cycle or shared child in a place
       where the on-disk B-tree should be a tree.  Stop at the first repeat to
       keep traversal bounded and avoid double-counting chunks.  */
    if (!h5policy_mark_visited_btree(btree_addr))
        return ctx;

    var hdr = 8UL + (2UL * o);
    if (!h5policy_checked_addr_range(btree_addr, hdr, file_size,
                                     "chunk B-tree node outside file",
                                     btree_addr#B, object))
        return ctx;

    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL) != H5_FORMAT_TREE_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, object,
                                "chunk B-tree signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(btree_addr, "TREE");

    var node_type = h5policy_msg_u64_at(ios, profile, btree_addr#B + 4#B, 1UL);
    if (node_type != 1UL)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, object,
                                "expected a raw-data-chunk (type 1) v1 B-tree node");
            return ctx;
        }

    var node_level = h5policy_msg_u64_at(ios, profile, btree_addr#B + 5#B, 1UL);
    var entries_used = h5policy_msg_u64_at(ios, profile, btree_addr#B + 6#B, 2UL);
    /* Type-1 v1 B-tree keys start with chunk byte size and filter mask, then
       one 64-bit chunk offset per chunk dimension.  */
    var offs_bytes = h5policy_checked_mul_u64(ndims, 8UL, 0xffffffffffffffffUL,
                                              "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                              btree_addr#B, object,
                                              "chunk B-tree key size overflow");
    var key_size = h5policy_checked_add_u64(8UL, offs_bytes, 0xffffffffffffffffUL,
                                            "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                            btree_addr#B, object,
                                            "chunk B-tree key size overflow");
    var pair = key_size + o;
    var capacity = h5policy_checked_mul_u64(2UL, h5policy_super_indexed_internal_k,
                                            0xffffffffffffffffUL,
                                            "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                            btree_addr#B, object,
                                            "chunk B-tree node capacity overflow");
    var entry_count_valid = 1;
    if (entries_used > capacity)
        {
            h5policy_emit_error("H5_CORRUPT_BTREE_NODE_ENTRY_COUNT", "corrupt",
                                btree_addr#B, object,
                                "chunk B-tree node uses more entries than its superblock K permits");
            entry_count_valid = 0;
        }
    var body = h5policy_checked_mul_u64(capacity, pair, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        btree_addr#B, object,
                                        "chunk B-tree node size overflow");
    body = h5policy_checked_add_u64(body, key_size, 0xffffffffffffffffUL,
                                    "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                    btree_addr#B, object,
                                    "chunk B-tree node size overflow");
    var total = h5policy_checked_add_u64(hdr, body, 0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                         btree_addr#B, object,
                                         "chunk B-tree node size overflow");
    if (!h5policy_checked_addr_range(btree_addr, total, file_size,
                                     "chunk B-tree node body outside file",
                                     btree_addr#B, object))
        return ctx;

    ctx = h5policy_account_metadata(ctx, profile, total, btree_addr#B, object);

    /* Preserve capacity-sized node bounds and metadata accounting above, but
       do not turn a corrupt entry count into a resource claim or use it to
       iterate beyond the validated body. */
    if (!entry_count_valid)
        return ctx;

    if (node_level == 0UL)
        {
            /* A validated leaf header proves how many chunk records it holds.
               Claim them in one operation so a leaf that crosses the exact
               ceiling cannot disappear behind an equality early return.  Only
               inspect the entries within the remaining resource allowance. */
            var inspect_entries = entries_used;
            var limit = profile.resources.max_chunk_count;
            if (ctx.accounted_chunk_count >= limit)
                inspect_entries = 0UL;
            else if (inspect_entries > limit - ctx.accounted_chunk_count)
                inspect_entries = limit - ctx.accounted_chunk_count;

            ctx = h5policy_count_chunks(
                ctx, profile, entries_used, btree_addr#B, object,
                "chunk count exceeds the selected profile limit");

            var i = 0UL;
            while (i < inspect_entries)
                {
                    var key_off = btree_addr + hdr + (i * pair);
                    var child_raw = h5policy_msg_bytes(ios, profile,
                                                       (key_off + key_size)#B, o);
                    var child_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(child_raw));
                    var chunk_size = h5policy_msg_u64_at(ios, profile,
                                                         key_off#B, 4UL);
                    if (!h5policy_msg_addr_is_undef(child_raw))
                        {
                            var ok = h5policy_checked_addr_range(
                                child_addr, chunk_size, file_size,
                                "chunk data outside file", key_off#B, object);
                        }
                    i = i + 1UL;
                }

            return ctx;
        }

    /* Internal nodes do not reveal subtree record totals.  At exact equality,
       continue through validated child nodes until either the tree ends (the
       count was exactly the ceiling) or a nonempty leaf proves overflow. */
    var i = 0UL;
    while (i < entries_used)
        {
            if (ctx.chunk_count_exceeded != 0UB)
                return ctx;

            var key_off = btree_addr + hdr + (i * pair);
            var child_raw = h5policy_msg_bytes(ios, profile,
                                               (key_off + key_size)#B, o);
            var child_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(child_raw));

            if (!h5policy_msg_addr_is_undef(child_raw))
                {
                    if (child_addr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                            "corrupt",
                                            (key_off + key_size)#B, object,
                                            "chunk B-tree child address outside file");
                    else
                        ctx = h5policy_walk_chunk_btree(ios, profile, ctx,
                                                        child_addr, ndims,
                                                        object, btree_depth + 1UL);
                }
            i = i + 1UL;
        }

    return ctx;
}

/* All v2 B-tree clients use the same node-capacity initialization.  In
   libhdf5 that calculation divides the usable node bytes by record_size, so a
   zero record width is corrupt even for an otherwise empty tree.  Keep this
   check before every client-specific early return. */
fun h5policy_validate_v2_btree_geometry = (uint<64> node_size,
                                           uint<64> record_size,
                                           off64 loc,
                                           string object) int:
{
    if (record_size == 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_SIZE", "corrupt",
                                loc, object,
                                "v2 B-tree record size is zero");
            return 0;
        }
    if (node_size < 10UL || record_size > node_size - 10UL)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_SIZE", "corrupt",
                                loc, object,
                                "v2 B-tree node cannot hold one record");
            return 0;
        }
    return 1;
}

/* Test whether charging BYTES would cross the selected metadata ceiling.  The
   ordinary accounting helper still performs the charge and emits/saturates the
   public metric; this predicate tells recursive walkers not to follow another
   attacker-controlled edge after that refusal has been established. */
fun h5policy_chunkindex_metadata_would_exceed = (H5WalkContext ctx,
                                                 H5PolicyProfile profile,
                                                 uint<64> bytes) int:
{
    var limit = profile.resources.max_accounted_metadata_bytes;
    if (bytes > limit)
        return 1;
    return ctx.metadata_seen > limit - bytes;
}

/* Verify a chunk-index structure whose checksum is the final four bytes of its
   used image.  A v2 B-tree node may reserve a larger fixed node_size; callers
   pass only the used prefix through the checksum field, matching libhdf5. */
fun h5policy_chunkindex_verify_trailing_checksum = (int ios, H5PolicyProfile profile,
                                                     uint<64> addr, uint<64> total_size,
                                                     uint<64> file_size, string object,
                                                     string what) int:
{
    if (total_size < 4UL)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                                addr#B, object, what + " checksum field outside block");
            return 0;
        }
    if (!h5policy_checked_addr_range(addr, total_size, file_size,
                                     what + " outside file",
                                     addr#B, object))
        return 0;

    var body_size = total_size - 4UL;
    var body = h5policy_msg_bytes(ios, profile, addr#B, body_size);
    var stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                   addr#B + body_size#B, 4UL));
    if (lookup3_hashlittle(body, 0) != stored)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                                addr#B, object, what + " checksum mismatch");
            return 0;
        }
    return 1;
}

/* Number of bytes used for the records-in-child counter in every v2 B-tree
   pointer.  libhdf5 derives this from the maximum LEAF capacity, not from the
   smaller internal-node capacity. */
fun h5policy_chunk_bt2_nrec_bytes = (uint<64> node_size,
                                     uint<64> record_size) uint<64>:
{
    var max_nrec = (node_size - 10UL) / record_size;
    var bytes = 1UL;
    var threshold = 256UL;
    while (max_nrec >= threshold)
        {
            bytes = bytes + 1UL;
            threshold = threshold * 256UL;
        }
    return bytes;
}

/* Width of the records-in-subtree counter for a child pointer.  LEVEL is the
   child's depth (zero for a leaf).  This is H5B2's cumulative maximum
   recurrence, with saturation before any uint64 multiplication can wrap. */
fun h5policy_chunk_bt2_subtree_bytes = (uint<64> node_size,
                                        uint<64> record_size,
                                        uint<64> level) uint<64>:
{
    if (level == 0UL)
        return 0UL;

    var o = global_sizeof_offsets as uint<64>;
    var nrec_bytes = h5policy_chunk_bt2_nrec_bytes(node_size, record_size);
    var cum_max = (node_size - 10UL) / record_size;
    var subtree_bytes = 0UL;
    var u64_max = 0xffffffffffffffffUL;
    var current = 1UL;
    while (current <= level)
        {
            var ptr_size = o + nrec_bytes + subtree_bytes;
            if (node_size < 10UL + ptr_size)
                return subtree_bytes;
            var max_internal = (node_size - 10UL - ptr_size)
                               / (record_size + ptr_size);
            if (max_internal != 0UL
                && cum_max > (u64_max - max_internal) / (max_internal + 1UL))
                return 8UL;
            cum_max = ((max_internal + 1UL) * cum_max) + max_internal;
            subtree_bytes = 1UL;
            var threshold = 256UL;
            while (cum_max >= threshold)
                {
                    if (subtree_bytes >= 8UL
                        || threshold > u64_max / 256UL)
                        return 8UL;
                    subtree_bytes = subtree_bytes + 1UL;
                    threshold = threshold * 256UL;
                }
            current = current + 1UL;
        }
    return subtree_bytes;
}

/* Validate the address-bearing part of each type-10/type-11 chunk record.
   Internal-node records are real chunks too, so this is used for every node,
   not only leaves. */
fun h5policy_validate_v2_chunk_records = (int ios, H5PolicyProfile profile,
                                          uint<64> records_addr, uint<64> nrec,
                                          uint<64> record_type,
                                          uint<64> record_size,
                                          uint<64> chunk_rank,
                                          uint<64> chunk_byte_size,
                                          uint<64> file_size,
                                          string object) void:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var scaled_bytes = h5policy_checked_mul_u64(
        chunk_rank, 8UL, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", records_addr#B, object,
        "v2 B-tree chunk-record dimensionality overflow");
    var filtered_size_len = 0UL;
    if (record_type == 10UL)
        {
            if (record_size != o + scaled_bytes)
                {
                    h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_LAYOUT",
                                        "corrupt", records_addr#B, object,
                                        "unfiltered v2 B-tree chunk record size does not match the dataset rank");
                    return;
                }
        }
    else
        {
            if (record_size <= o + 4UL + scaled_bytes)
                {
                    h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_LAYOUT",
                                        "corrupt", records_addr#B, object,
                                        "filtered v2 B-tree chunk record has no encoded chunk-size field");
                    return;
                }
            filtered_size_len = record_size - o - 4UL - scaled_bytes;
            if (filtered_size_len > el)
                {
                    h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_LAYOUT",
                                        "corrupt", records_addr#B, object,
                                        "filtered v2 B-tree chunk-size field is wider than the file length encoding");
                    return;
                }
        }

    var i = 0UL;
    while (i < nrec)
        {
            var rec_addr = records_addr + (i * record_size);
            var chunk_raw = h5policy_msg_bytes(ios, profile, rec_addr#B, o);
            var chunk_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(chunk_raw));
            if (!h5policy_msg_addr_is_undef(chunk_raw))
                {
                    var stored_size = chunk_byte_size;
                    if (record_type == 11UL)
                        stored_size = h5policy_msg_u64_at(
                            ios, profile, rec_addr#B + o#B, filtered_size_len);
                    if (stored_size != 0xffffffffffffffffUL)
                        {
                            var ok = h5policy_checked_addr_range(
                                chunk_addr, stored_size, file_size,
                                "chunk data outside file", rec_addr#B, object);
                        }
                }
            i = i + 1UL;
        }
}

/* Recursively validate one v2 B-tree chunk-index node.  The declared node_size
   bounds every read and is charged once; the checksum covers only the used
   prefix.  Depth, a visited set, the metadata ceiling, the chunk ceiling, and
   the global operation/time budgets independently bound descent. */
fun h5policy_walk_v2_btree_chunk_node = (
    int ios, H5PolicyProfile profile, H5WalkContext ctx,
    uint<64> node_addr, uint<64> node_depth, uint<64> nrec,
    uint<64> node_size, uint<64> record_size, uint<64> record_type,
    uint<64> chunk_rank, uint<64> chunk_byte_size,
    uint<64> file_size, string object) H5WalkContext:
{
    if (ctx.metadata_count_exceeded != 0UB)
        return ctx;

    if (node_depth > profile.resources.max_btree_depth)
        {
            h5policy_emit_error("H5_RESOURCE_BTREE_DEPTH", "resource",
                                node_addr#B, object,
                                "chunk v2 B-tree depth exceeds the selected profile limit");
            return ctx;
        }

    if (!h5policy_mark_visited_btree(node_addr))
        {
            h5policy_emit_error("H5_CORRUPT_CHUNK_INDEX_CYCLE", "corrupt",
                                node_addr#B, object,
                                "v2 B-tree chunk index repeats a node address");
            return ctx;
        }

    if (!h5policy_checked_addr_range(node_addr, node_size, file_size,
                                     "v2 B-tree node outside file",
                                     node_addr#B, object))
        return ctx;

    var o = global_sizeof_offsets as uint<64>;
    var nrec_bytes = h5policy_chunk_bt2_nrec_bytes(node_size, record_size);
    var subtree_bytes = node_depth > 1UL
                        ? h5policy_chunk_bt2_subtree_bytes(
                              node_size, record_size, node_depth - 1UL)
                        : 0UL;
    var ptr_size = o + nrec_bytes + subtree_bytes;
    var capacity = (node_size - 10UL) / record_size;
    if (node_depth > 0UL)
        {
            if (node_size < 10UL + ptr_size)
                capacity = 0UL;
            else
                capacity = (node_size - 10UL - ptr_size)
                           / (record_size + ptr_size);
        }
    if (nrec > capacity)
        {
            h5policy_emit_error("H5_CORRUPT_BTREE_NODE_ENTRY_COUNT", "corrupt",
                                node_addr#B, object,
                                "v2 B-tree chunk node record count exceeds its capacity");
            return ctx;
        }

    var rec_bytes = h5policy_checked_mul_u64(
        nrec, record_size, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        "v2 B-tree chunk node record bytes overflow");
    var used_size = h5policy_checked_add_u64(
        6UL, rec_bytes, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        "v2 B-tree chunk node size overflow");
    if (node_depth > 0UL)
        {
            var ptr_bytes = h5policy_checked_mul_u64(
                nrec + 1UL, ptr_size, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
                "v2 B-tree chunk child-pointer bytes overflow");
            used_size = h5policy_checked_add_u64(
                used_size, ptr_bytes, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
                "v2 B-tree chunk node size overflow");
        }
    used_size = h5policy_checked_add_u64(
        used_size, 4UL, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        "v2 B-tree chunk node checksum offset overflow");
    if (used_size > node_size)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_SIZE", "corrupt",
                                node_addr#B, object,
                                "v2 B-tree chunk node contents exceed the declared node size");
            return ctx;
        }

    var expected_sig = node_depth == 0UL
                       ? H5_FORMAT_BTLF_SIGNATURE : H5_FORMAT_BTIN_SIGNATURE;
    if (h5policy_msg_bytes(ios, profile, node_addr#B, 4UL) != expected_sig)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                node_addr#B, object,
                                node_depth == 0UL
                                ? "v2 B-tree chunk leaf signature mismatch"
                                : "v2 B-tree chunk internal-node signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(node_addr, node_depth == 0UL ? "BTLF" : "BTIN");
    var version = h5policy_msg_u64_at(ios, profile, node_addr#B + 4#B, 1UL);
    var found_type = h5policy_msg_u64_at(ios, profile, node_addr#B + 5#B, 1UL);
    if (version != 0UL || found_type != record_type)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_HEADER", "corrupt",
                                node_addr#B, object,
                                "v2 B-tree chunk node version or record type does not match the header");
            return ctx;
        }

    var metadata_over = h5policy_chunkindex_metadata_would_exceed(
        ctx, profile, node_size);
    ctx = h5policy_account_metadata(ctx, profile, node_size,
                                    node_addr#B, object);
    if (metadata_over)
        return ctx;
    if (!h5policy_chunkindex_verify_trailing_checksum(
            ios, profile, node_addr, used_size, file_size, object,
            node_depth == 0UL
            ? "v2 B-tree chunk leaf" : "v2 B-tree chunk internal node"))
        return ctx;

    h5policy_validate_v2_chunk_records(
        ios, profile, node_addr + 6UL, nrec, record_type, record_size,
        chunk_rank, chunk_byte_size, file_size, object);

    if (node_depth == 0UL || ctx.chunk_count_exceeded != 0UB)
        return ctx;

    var ptr_base = node_addr + 6UL + rec_bytes;
    var i = 0UL;
    while (i < nrec + 1UL)
        {
            if (ctx.metadata_count_exceeded != 0UB)
                return ctx;
            var ptr_addr = ptr_base + (i * ptr_size);
            var child_raw = h5policy_msg_bytes(ios, profile, ptr_addr#B, o);
            var child_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(child_raw));
            var child_nrec = h5policy_msg_u64_at(
                ios, profile, ptr_addr#B + o#B, nrec_bytes);
            if (h5policy_msg_addr_is_undef(child_raw))
                h5policy_emit_error("H5_CORRUPT_CHUNK_INDEX_CHILD_ADDRESS",
                                    "corrupt", ptr_addr#B, object,
                                    "v2 B-tree chunk internal node has an undefined child address");
            else if (child_addr >= file_size)
                h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                    ptr_addr#B, object,
                                    "v2 B-tree chunk child address outside file");
            else
                ctx = h5policy_walk_v2_btree_chunk_node(
                    ios, profile, ctx, child_addr, node_depth - 1UL,
                    child_nrec, node_size, record_size, record_type,
                    chunk_rank, chunk_byte_size, file_size, object);
            i = i + 1UL;
        }

    return ctx;
}

/* Validate a version-2 B-tree chunk index (v4 layout index type 5).  The
   checksummed header supplies the total chunk count; after enforcing that
   budget, descend every reachable internal/leaf node within the independent
   depth, visited-node, metadata-byte, operation, and wall-clock ceilings. */
fun h5policy_walk_v2_btree_chunks = (int ios, H5PolicyProfile profile,
                                     H5WalkContext ctx, uint<64> hdr_addr,
                                     uint<64> chunk_rank,
                                     uint<64> chunk_byte_size,
                                     off64 loc, string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    var hdr_size = 22UL + o + el;

    if (!h5policy_checked_addr_range(hdr_addr, hdr_size, file_size,
                                     "v2 B-tree header outside file", loc, object))
        return ctx;

    if (h5policy_msg_bytes(ios, profile, hdr_addr#B, 4UL) != H5_FORMAT_BTHD_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree header signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(hdr_addr, "BTHD");
    var hdr_version = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 4#B, 1UL);
    if (hdr_version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_V2_BTREE_VERSION",
                                "corrupt", hdr_addr#B, object,
                                "v2 B-tree header has an unsupported version");
            return ctx;
        }

    var hdr_body = h5policy_msg_bytes(ios, profile, hdr_addr#B,
                                      hdr_size - 4UL);
    var hdr_stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                       hdr_addr#B + (hdr_size - 4UL)#B,
                                                       4UL));
    if (lookup3_hashlittle(hdr_body, 0) != hdr_stored)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree header checksum mismatch");
            return ctx;
        }

    var record_type = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 5#B, 1UL);
    var node_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 6#B, 4UL);
    var record_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 10#B, 2UL);
    var depth = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 12#B, 2UL);
    var root_raw = h5policy_msg_bytes(ios, profile, hdr_addr#B + 16#B, o);
    var root_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(root_raw));
    var num_root = h5policy_msg_u64_at(ios, profile, hdr_addr#B + (16UL + o)#B, 2UL);
    var total_nrec = h5policy_msg_u64_at(ios, profile, hdr_addr#B + (18UL + o)#B, el);

    if (!h5policy_validate_v2_btree_geometry(node_size, record_size,
                                              hdr_addr#B, object))
        return ctx;

    /* Chunk-index v2 B-trees use specific record types for filtered and
       unfiltered chunk records.  Other record types may be valid H5B2 users,
       but they are not dataset chunk indexes.  */
    if (record_type != 10UL && record_type != 11UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNKNOWN_CHUNK_INDEX_TYPE", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree chunk index has an unexpected record type");
            return ctx;
        }

    var split_percent = h5policy_msg_u64_at(ios, profile,
                                             hdr_addr#B + 14#B, 1UL);
    var merge_percent = h5policy_msg_u64_at(ios, profile,
                                             hdr_addr#B + 15#B, 1UL);
    if (split_percent == 0UL || split_percent > 100UL
        || merge_percent == 0UL || merge_percent >= split_percent / 2UL)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_SPLIT_MERGE", "corrupt",
                                hdr_addr#B + 14#B, object,
                                "v2 B-tree split/merge percentages are inconsistent");
            return ctx;
        }

    /* Reject a rank/record-width mismatch before any node record can be
       interpreted at the wrong stride. */
    var scaled_bytes = h5policy_checked_mul_u64(
        chunk_rank, 8UL, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", hdr_addr#B, object,
        "v2 B-tree chunk-record dimensionality overflow");
    if ((record_type == 10UL && record_size != o + scaled_bytes)
        || (record_type == 11UL && record_size <= o + 4UL + scaled_bytes)
        || (record_type == 11UL
            && record_size - o - 4UL - scaled_bytes > el))
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_LAYOUT", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree chunk record size does not match the dataset rank");
            return ctx;
        }

    /* Total record count == chunk count: enforce the resource budget. */
    ctx = h5policy_count_chunks(
        ctx, profile, total_nrec, hdr_addr#B, object,
        "chunk count exceeds the selected profile limit");

    var metadata_over = h5policy_chunkindex_metadata_would_exceed(
        ctx, profile, hdr_size);
    ctx = h5policy_account_metadata(ctx, profile, hdr_size,
                                    hdr_addr#B, object);
    if (metadata_over)
        return ctx;

    if (h5policy_msg_addr_is_undef(root_raw))
        {
            if (num_root != 0UL || total_nrec != 0UL)
                h5policy_emit_error("H5_CORRUPT_V2_BTREE_ROOT_COUNT", "corrupt",
                                    hdr_addr#B + (16UL + o)#B, object,
                                    "v2 B-tree has records but no root node");
            return ctx;
        }
    if (root_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                hdr_addr#B + 16#B, object,
                                "v2 B-tree root node outside file");
            return ctx;
        }

    if (depth == 0UL && total_nrec != num_root)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_ROOT_COUNT", "corrupt",
                                hdr_addr#B + (18UL + o)#B, object,
                                "leaf-root v2 B-tree total record count differs from its root count");
            return ctx;
        }

    return h5policy_walk_v2_btree_chunk_node(
        ios, profile, ctx, root_addr, depth, num_root,
        node_size, record_size, record_type, chunk_rank,
        chunk_byte_size, file_size, object);
}

/* Fixed arrays are simple when unpaged: one data block, one element per chunk.
   Paged arrays add an initialization bitmap and per-page checksums, so only
   initialized pages should be inspected for chunk addresses.  */
/* Validate a fixed-array chunk index (v4 layout index type 3), used by chunked
   datasets with fixed dimensions.  The checksummed header gives the element
   count (= chunk count) and data-block address; the data block holds one
   element per chunk whose leading offset-sized field is the chunk address.
   Paged data blocks use an initialization bitmap and per-page checksums. */
fun h5policy_walk_fixed_array_chunks = (int ios, H5PolicyProfile profile, H5WalkContext ctx,
                                        uint<64> hdr_addr, off64 loc,
                                        string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    var hdr_size = 12UL + el + o;

    if (!h5policy_checked_addr_range(hdr_addr, hdr_size, file_size,
                                     "fixed array header outside file", loc, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, hdr_addr#B, 4UL) != H5_FORMAT_FAHD_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", hdr_addr#B, object,
                                "fixed array header signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(hdr_addr, "FAHD");
    var hdr_version = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 4#B, 1UL);
    if (hdr_version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FIXED_ARRAY_VERSION",
                                "corrupt", hdr_addr#B, object,
                                "fixed array header has an unsupported version");
            return ctx;
        }
    var client_id = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 5#B, 1UL);
    if (client_id > 1UL)
        {
            h5policy_emit_error("H5_CORRUPT_FIXED_ARRAY_CLIENT_ID",
                                "corrupt", hdr_addr#B, object,
                                "fixed array chunk index has an unsupported client ID");
            return ctx;
        }

    var hdr_body = h5policy_msg_bytes(ios, profile, hdr_addr#B, hdr_size - 4UL);
    var hdr_stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                       hdr_addr#B + (hdr_size - 4UL)#B, 4UL));
    if (lookup3_hashlittle(hdr_body, 0) != hdr_stored)
        h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt", hdr_addr#B, object,
                            "fixed array header checksum mismatch");

    var raw_elmt_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 6#B, 1UL);
    var page_bits = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 7#B, 1UL);
    var nelmts = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 8#B, el);
    var dblk_raw = h5policy_msg_bytes(ios, profile, hdr_addr#B + (8UL + el)#B, o);
    var dblk_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(dblk_raw));

    /* Fixed-array element count is the chunk count.  Count it from the header
       before deciding whether individual chunk addresses are inline or paged. */
    ctx = h5policy_count_chunks(
        ctx, profile, nelmts, hdr_addr#B, object,
        "chunk count exceeds the selected profile limit");
    ctx = h5policy_account_metadata(ctx, profile, hdr_size, hdr_addr#B, object);

    if (h5policy_msg_addr_is_undef(dblk_raw))
        return ctx;
    if (dblk_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", hdr_addr#B, object,
                                "fixed array data block outside file");
            return ctx;
        }

    var is_paged = page_bits > 0UL && page_bits < 48UL
                   && nelmts > (1UL <<. page_bits);

    /* Extremely large page_bits values are treated as unpaged here because the
       shift itself would no longer describe a sane in-file page geometry.  */
    /* Unpaged arrays are a single contiguous data block after a fixed prefix;
       every element's leading offset-sized field is the chunk address.  */
    if (!is_paged)
        {
            /* Elements stored inline in a single data block. */
            var db_prefix = 6UL + o;
            var elems = h5policy_checked_mul_u64(nelmts, raw_elmt_size, 0xffffffffffffffffUL,
                                                 "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                 dblk_addr#B, object,
                                                 "fixed array data block size overflow");
            var db_need = h5policy_checked_add_u64(db_prefix + 4UL, elems, 0xffffffffffffffffUL,
                                                   "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                   dblk_addr#B, object,
                                                   "fixed array data block size overflow");
            if (!h5policy_checked_addr_range(dblk_addr, db_need, file_size,
                                             "fixed array data block body outside file",
                                             dblk_addr#B, object))
                return ctx;
            if (h5policy_msg_bytes(ios, profile, dblk_addr#B, 4UL) != H5_FORMAT_FADB_SIGNATURE)
                {
                    h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", dblk_addr#B, object,
                                        "fixed array data block signature mismatch");
                    return ctx;
                }
            h5policy_mark_reached(dblk_addr, "FADB");
            var dblk_version = h5policy_msg_u64_at(ios, profile, dblk_addr#B + 4#B, 1UL);
            if (dblk_version != 0UL)
                {
                    h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FIXED_ARRAY_VERSION",
                                        "corrupt", dblk_addr#B, object,
                                        "fixed array data block has an unsupported version");
                    return ctx;
                }
            h5policy_chunkindex_verify_trailing_checksum(ios, profile, dblk_addr,
                                                         db_need, file_size, object,
                                                         "fixed array data block");

            var i = 0UL;
            while (i < nelmts)
                {
                    var elem_off = dblk_addr + db_prefix + (i * raw_elmt_size);
                    var caddr_raw = h5policy_msg_bytes(ios, profile, elem_off#B, o);
                    var caddr = hdf5_addr_to_file_u64(bytes_to_u64_le(caddr_raw));
                    if (!h5policy_msg_addr_is_undef(caddr_raw) && caddr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", elem_off#B, object,
                                            "chunk data address outside file");
                    i = i + 1UL;
                }

            return ctx;
        }

    /* Paged data block: prefix (+page-init bitmap +prefix checksum) followed by
       one page per group of dblk_page_nelmts elements (last page shorter), each
       with its own checksum.  Only pages flagged initialized carry chunks.  */
    var page_nelmts = 1UL <<. page_bits;
    var npages = (nelmts + page_nelmts - 1UL) / page_nelmts;
    var last_page_nelmts = nelmts - ((npages - 1UL) * page_nelmts);
    var page_init_size = (npages + 7UL) / 8UL;
    var db_prefix = 6UL + o + page_init_size + 4UL;
    var full_page_bytes =
        h5policy_checked_add_u64(h5policy_checked_mul_u64(page_nelmts, raw_elmt_size,
                                                          0xffffffffffffffffUL,
                                                          "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                          dblk_addr#B, object,
                                                          "fixed array page size overflow"),
                                 4UL, 0xffffffffffffffffUL,
                                 "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                 dblk_addr#B, object, "fixed array page size overflow");
    var all_pages = h5policy_checked_mul_u64(npages, full_page_bytes, 0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                             dblk_addr#B, object,
                                             "fixed array data block size overflow");
    if (!h5policy_checked_addr_range(dblk_addr, db_prefix + all_pages, file_size,
                                     "fixed array paged data block outside file",
                                     dblk_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, dblk_addr#B, 4UL) != H5_FORMAT_FADB_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", dblk_addr#B, object,
                                "fixed array data block signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(dblk_addr, "FADB");
    var dblk_version = h5policy_msg_u64_at(ios, profile, dblk_addr#B + 4#B, 1UL);
    if (dblk_version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FIXED_ARRAY_VERSION",
                                "corrupt", dblk_addr#B, object,
                                "fixed array data block has an unsupported version");
            return ctx;
        }
    h5policy_chunkindex_verify_trailing_checksum(ios, profile, dblk_addr,
                                                 db_prefix, file_size, object,
                                                 "fixed array data block prefix");

    var p = 0UL;
    while (p < npages)
        {
            /* The page-init bitmap tells which pages have real elements.  Skip
               uninitialized pages because their bytes are not chunk records.  */
            var page_start = dblk_addr + db_prefix + (p * full_page_bytes);
            var pn = (p == npages - 1UL) ? last_page_nelmts : page_nelmts;
            var bmap = h5policy_msg_u64_at(ios, profile,
                                           dblk_addr#B + (6UL + o + (p / 8UL))#B, 1UL);
            if (((bmap .>> (p % 8UL)) & 1UL) != 0UL)   /* page initialized */
                {
                    var page_body =
                        h5policy_checked_mul_u64(pn, raw_elmt_size,
                                                  0xffffffffffffffffUL,
                                                  "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                  page_start#B, object,
                                                  "fixed array page size overflow");
                    var page_need =
                        h5policy_checked_add_u64(page_body, 4UL,
                                                 0xffffffffffffffffUL,
                                                 "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                 page_start#B, object,
                                                 "fixed array page size overflow");
                    h5policy_chunkindex_verify_trailing_checksum(ios, profile,
                                                                 page_start,
                                                                 page_need,
                                                                 file_size, object,
                                                                 "fixed array data block page");
                    var j = 0UL;
                    while (j < pn)
                        {
                            var elem_off = page_start + (j * raw_elmt_size);
                            var caddr_raw = h5policy_msg_bytes(ios, profile, elem_off#B, o);
                            var caddr = hdf5_addr_to_file_u64(bytes_to_u64_le(caddr_raw));
                            if (!h5policy_msg_addr_is_undef(caddr_raw) && caddr >= file_size)
                                h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                                    elem_off#B, object,
                                                    "chunk data address outside file");
                            j = j + 1UL;
                        }
                }
            p = p + 1UL;
        }

    return ctx;
}

/* Immutable geometry decoded from an EAHD.  Keeping it in a value passed to
   child walkers avoids the mutable global geometry used by the interactive
   earray pickle and makes nested file validation deterministic. */
type H5PolicyEAConfig = struct
{
    uint<64> hdr_addr;
    uint<64> client_id;
    uint<64> raw_elmt_size;
    uint<64> arr_off_size;
    uint<64> idx_blk_elmts;
    uint<64> data_blk_min_elmts;
    uint<64> iblk_nsblks;
    uint<64> ndblk_addrs;
    uint<64> nsblk_addrs;
    uint<64> page_nelmts;
    uint<64> chunk_byte_size;
};

fun h5policy_ea_is_power_of_two = (uint<64> value) int:
{
    return value != 0UL && (value & (value - 1UL)) == 0UL;
}

fun h5policy_ea_log2 = (uint<64> value) uint<64>:
{
    var result = 0UL;
    var v = value;
    while (v > 1UL)
        {
            v = v .>> 1UL;
            result = result + 1UL;
        }
    return result;
}

/* EA index/super/data blocks form a tree even though only the B-tree formats
   use that name.  A repeated child address is invalid sharing or a cycle; use
   the common visited set to bound it and make the corruption explicit. */
fun h5policy_ea_mark_block = (uint<64> addr, string object,
                              string what) int:
{
    if (h5policy_mark_visited_btree(addr))
        return 1;
    h5policy_emit_error("H5_CORRUPT_CHUNK_INDEX_CYCLE", "corrupt",
                        addr#B, object, what + " repeats a metadata-block address");
    return 0;
}

/* Validate address-bearing EA elements.  Client 0 stores only a chunk address;
   client 1 also stores the post-filter byte count before its four-byte mask. */
fun h5policy_validate_ea_elements = (int ios, H5PolicyProfile profile,
                                     uint<64> elem_addr, uint<64> count,
                                     H5PolicyEAConfig cfg,
                                     uint<64> file_size,
                                     string object) void:
{
    var o = global_sizeof_offsets as uint<64>;
    var size_width = cfg.client_id == 1UL
                     ? cfg.raw_elmt_size - o - 4UL : 0UL;
    var i = 0UL;
    while (i < count)
        {
            var current = elem_addr + (i * cfg.raw_elmt_size);
            var raw = h5policy_msg_bytes(ios, profile, current#B, o);
            var addr = hdf5_addr_to_file_u64(bytes_to_u64_le(raw));
            if (!h5policy_msg_addr_is_undef(raw))
                {
                    var stored_size = cfg.chunk_byte_size;
                    if (cfg.client_id == 1UL)
                        stored_size = h5policy_msg_u64_at(
                            ios, profile, current#B + o#B, size_width);
                    if (stored_size == 0UL)
                        h5policy_emit_error("H5_CORRUPT_CHUNK_STORED_SIZE",
                                            "corrupt", current#B, object,
                                            "extensible-array chunk record has a zero stored size");
                    else if (stored_size != 0xffffffffffffffffUL)
                        {
                            var ok = h5policy_checked_addr_range(
                                addr, stored_size, file_size,
                                "extensible-array chunk data outside file",
                                current#B, object);
                        }
                }
            i = i + 1UL;
        }
}

/* Validate one EADB and, when paged, each initialized page selected by the
   owning EASB's bitmap.  The entire contiguous allocation is range-checked and
   metadata-accounted; uninitialized pages are not interpreted as records. */
fun h5policy_walk_ea_dblock = (int ios, H5PolicyProfile profile,
                               H5WalkContext ctx, uint<64> dblock_addr,
                               uint<64> dblock_nelmts,
                               uint<64> expected_block_off,
                               uint<64> page_init_addr,
                               uint<8> has_page_init,
                               H5PolicyEAConfig cfg,
                               uint<64> file_size,
                               string object) H5WalkContext:
{
    if (ctx.metadata_count_exceeded != 0UB)
        return ctx;
    if (!h5policy_ea_mark_block(dblock_addr, object,
                                "extensible-array data block"))
        return ctx;

    var o = global_sizeof_offsets as uint<64>;
    var prefix_body = 6UL + o + cfg.arr_off_size;
    var prefix_size = prefix_body + 4UL;
    var paged = dblock_nelmts > cfg.page_nelmts;
    var npages = 0UL;
    if (paged)
        {
            if (cfg.page_nelmts == 0UL
                || (dblock_nelmts % cfg.page_nelmts) != 0UL)
                {
                    h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_GEOMETRY",
                                        "corrupt", dblock_addr#B, object,
                                        "extensible-array data-block page geometry is inconsistent");
                    return ctx;
                }
            npages = dblock_nelmts / cfg.page_nelmts;
            if (has_page_init == 0UB)
                {
                    h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_GEOMETRY",
                                        "corrupt", dblock_addr#B, object,
                                        "paged extensible-array data block has no page-init bitmap");
                    return ctx;
                }
        }

    var elem_bytes = h5policy_checked_mul_u64(
        dblock_nelmts, cfg.raw_elmt_size, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", dblock_addr#B, object,
        "extensible-array data block size overflow");
    var page_checksums = h5policy_checked_mul_u64(
        npages, 4UL, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", dblock_addr#B, object,
        "extensible-array page checksum bytes overflow");
    var total_size = h5policy_checked_add_u64(
        prefix_size, elem_bytes, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", dblock_addr#B, object,
        "extensible-array data block size overflow");
    total_size = h5policy_checked_add_u64(
        total_size, page_checksums, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", dblock_addr#B, object,
        "extensible-array data block size overflow");
    if (!h5policy_checked_addr_range(
            dblock_addr, total_size, file_size,
            "extensible-array data block outside file",
            dblock_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, dblock_addr#B, 4UL)
        != H5_FORMAT_EADB_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                dblock_addr#B, object,
                                "extensible-array data block signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(dblock_addr, "EADB");
    var version = h5policy_msg_u64_at(ios, profile,
                                       dblock_addr#B + 4#B, 1UL);
    var client = h5policy_msg_u64_at(ios, profile,
                                      dblock_addr#B + 5#B, 1UL);
    var owner = h5policy_msg_addr_at(ios, profile,
                                     dblock_addr#B + 6#B, o);
    var block_off = h5policy_msg_u64_at(
        ios, profile, dblock_addr#B + (6UL + o)#B, cfg.arr_off_size);
    if (version != 0UL || client != cfg.client_id)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BLOCK_HEADER",
                                "corrupt", dblock_addr#B, object,
                                "extensible-array data-block version or client differs from its header");
            return ctx;
        }
    if (owner != cfg.hdr_addr)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BACKPOINTER",
                                "corrupt", dblock_addr#B + 6#B, object,
                                "extensible-array data block points at the wrong header");
            return ctx;
        }
    if (block_off != expected_block_off)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BLOCK_OFFSET",
                                "corrupt", dblock_addr#B + (6UL + o)#B, object,
                                "extensible-array data-block logical offset is inconsistent");
            return ctx;
        }

    var metadata_over = h5policy_chunkindex_metadata_would_exceed(
        ctx, profile, total_size);
    ctx = h5policy_account_metadata(ctx, profile, total_size,
                                    dblock_addr#B, object);
    if (metadata_over)
        return ctx;

    if (!paged)
        {
            if (!h5policy_chunkindex_verify_trailing_checksum(
                    ios, profile, dblock_addr, total_size, file_size, object,
                    "extensible-array data block"))
                return ctx;
            h5policy_validate_ea_elements(
                ios, profile, dblock_addr + prefix_body,
                dblock_nelmts, cfg, file_size, object);
            return ctx;
        }

    if (!h5policy_chunkindex_verify_trailing_checksum(
            ios, profile, dblock_addr, prefix_size, file_size, object,
            "extensible-array data-block prefix"))
        return ctx;

    var page_elem_bytes = h5policy_checked_mul_u64(
        cfg.page_nelmts, cfg.raw_elmt_size, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", dblock_addr#B, object,
        "extensible-array data-block page size overflow");
    var page_size = page_elem_bytes + 4UL;
    var p = 0UL;
    while (p < npages)
        {
            var bitmap = h5policy_msg_u64_at(
                ios, profile, (page_init_addr + (p / 8UL))#B, 1UL);
            if (((bitmap .>> (p % 8UL)) & 1UL) != 0UL)
                {
                    var page_addr = dblock_addr + prefix_size + (p * page_size);
                    h5policy_mark_reached(page_addr, "EAPG");
                    if (h5policy_chunkindex_verify_trailing_checksum(
                            ios, profile, page_addr, page_size,
                            file_size, object,
                            "extensible-array data-block page"))
                        h5policy_validate_ea_elements(
                            ios, profile, page_addr, cfg.page_nelmts,
                            cfg, file_size, object);
                }
            p = p + 1UL;
        }
    return ctx;
}

/* Validate an EASB, then follow each defined data-block address with the page
   bitmap slice belonging to that block. */
fun h5policy_walk_ea_sblock = (int ios, H5PolicyProfile profile,
                               H5WalkContext ctx, uint<64> sblock_addr,
                               uint<64> sblock_index,
                               uint<64> expected_block_off,
                               H5PolicyEAConfig cfg,
                               uint<64> file_size,
                               string object) H5WalkContext:
{
    if (ctx.metadata_count_exceeded != 0UB)
        return ctx;
    if (!h5policy_ea_mark_block(sblock_addr, object,
                                "extensible-array secondary block"))
        return ctx;

    var o = global_sizeof_offsets as uint<64>;
    var ndblks = 1UL <<. (sblock_index / 2UL);
    var dblock_factor = 1UL <<. ((sblock_index + 1UL) / 2UL);
    var dblock_nelmts = h5policy_checked_mul_u64(
        dblock_factor, cfg.data_blk_min_elmts, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", sblock_addr#B, object,
        "extensible-array secondary-block geometry overflow");
    var npages = dblock_nelmts > cfg.page_nelmts
                 ? dblock_nelmts / cfg.page_nelmts : 0UL;
    var page_init_size = npages > 0UL ? (npages + 7UL) / 8UL : 0UL;
    var all_page_init = h5policy_checked_mul_u64(
        ndblks, page_init_size, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", sblock_addr#B, object,
        "extensible-array page-init bitmap size overflow");
    var address_bytes = h5policy_checked_mul_u64(
        ndblks, o, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", sblock_addr#B, object,
        "extensible-array secondary-block address table overflow");
    var base_size = 6UL + o + cfg.arr_off_size;
    var total_size = h5policy_checked_add_u64(
        base_size, all_page_init, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", sblock_addr#B, object,
        "extensible-array secondary-block size overflow");
    total_size = h5policy_checked_add_u64(
        total_size, address_bytes, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", sblock_addr#B, object,
        "extensible-array secondary-block size overflow");
    total_size = h5policy_checked_add_u64(
        total_size, 4UL, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", sblock_addr#B, object,
        "extensible-array secondary-block size overflow");
    if (!h5policy_checked_addr_range(
            sblock_addr, total_size, file_size,
            "extensible-array secondary block outside file",
            sblock_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, sblock_addr#B, 4UL)
        != H5_FORMAT_EASB_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                sblock_addr#B, object,
                                "extensible-array secondary block signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(sblock_addr, "EASB");
    var version = h5policy_msg_u64_at(ios, profile,
                                       sblock_addr#B + 4#B, 1UL);
    var client = h5policy_msg_u64_at(ios, profile,
                                      sblock_addr#B + 5#B, 1UL);
    var owner = h5policy_msg_addr_at(ios, profile,
                                     sblock_addr#B + 6#B, o);
    var block_off = h5policy_msg_u64_at(
        ios, profile, sblock_addr#B + (6UL + o)#B, cfg.arr_off_size);
    if (version != 0UL || client != cfg.client_id)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BLOCK_HEADER",
                                "corrupt", sblock_addr#B, object,
                                "extensible-array secondary-block version or client differs from its header");
            return ctx;
        }
    if (owner != cfg.hdr_addr)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BACKPOINTER",
                                "corrupt", sblock_addr#B + 6#B, object,
                                "extensible-array secondary block points at the wrong header");
            return ctx;
        }
    if (block_off != expected_block_off)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BLOCK_OFFSET",
                                "corrupt", sblock_addr#B + (6UL + o)#B, object,
                                "extensible-array secondary-block logical offset is inconsistent");
            return ctx;
        }

    var metadata_over = h5policy_chunkindex_metadata_would_exceed(
        ctx, profile, total_size);
    ctx = h5policy_account_metadata(ctx, profile, total_size,
                                    sblock_addr#B, object);
    if (metadata_over)
        return ctx;
    if (!h5policy_chunkindex_verify_trailing_checksum(
            ios, profile, sblock_addr, total_size, file_size, object,
            "extensible-array secondary block"))
        return ctx;

    var page_init_base = sblock_addr + base_size;
    var address_base = page_init_base + all_page_init;
    var i = 0UL;
    while (i < ndblks)
        {
            if (ctx.metadata_count_exceeded != 0UB)
                return ctx;
            var ptr_addr = address_base + (i * o);
            var raw = h5policy_msg_bytes(ios, profile, ptr_addr#B, o);
            var addr = hdf5_addr_to_file_u64(bytes_to_u64_le(raw));
            if (!h5policy_msg_addr_is_undef(raw))
                {
                    if (addr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                            "corrupt", ptr_addr#B, object,
                                            "extensible-array data-block address outside file");
                    else
                        ctx = h5policy_walk_ea_dblock(
                            ios, profile, ctx, addr, dblock_nelmts,
                            expected_block_off + (i * dblock_nelmts),
                            page_init_base + (i * page_init_size),
                            (page_init_size > 0UL) as uint<8>,
                            cfg, file_size, object);
                }
            i = i + 1UL;
        }
    return ctx;
}

/* Validate an extensible-array chunk index (v4 layout index type 4), used by
   datasets with one unlimited dimension.  Every defined EAIB, direct EADB,
   EASB, nested EADB, and initialized page is followed under independent chunk,
   metadata-byte, visited-node, operation, and wall-clock budgets. */
fun h5policy_walk_ext_array_chunks = (int ios, H5PolicyProfile profile,
                                      H5WalkContext ctx, uint<64> hdr_addr,
                                      uint<64> chunk_byte_size,
                                      off64 loc, string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    var hdr_size = 16UL + (6UL * el) + o;

    if (!h5policy_checked_addr_range(hdr_addr, hdr_size, file_size,
                                     "extensible array header outside file", loc, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, hdr_addr#B, 4UL) != H5_FORMAT_EAHD_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", hdr_addr#B, object,
                                "extensible array header signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(hdr_addr, "EAHD");
    var hdr_version = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 4#B, 1UL);
    if (hdr_version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_EXTENSIBLE_ARRAY_VERSION",
                                "corrupt", hdr_addr#B, object,
                                "extensible array header has an unsupported version");
            return ctx;
        }
    var client_id = h5policy_msg_u64_at(ios, profile,
                                         hdr_addr#B + 5#B, 1UL);
    if (client_id > 1UL)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_CLIENT_ID",
                                "corrupt", hdr_addr#B, object,
                                "extensible array chunk index has an unsupported client ID");
            return ctx;
        }

    var hdr_body = h5policy_msg_bytes(ios, profile, hdr_addr#B, hdr_size - 4UL);
    var hdr_stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                       hdr_addr#B + (hdr_size - 4UL)#B, 4UL));
    if (lookup3_hashlittle(hdr_body, 0) != hdr_stored)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                                hdr_addr#B, object,
                                "extensible array header checksum mismatch");
            return ctx;
        }

    var raw_elmt_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 6#B, 1UL);
    var max_nelmts_bits = h5policy_msg_u64_at(ios, profile,
                                               hdr_addr#B + 7#B, 1UL);
    var idx_blk_elmts = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 8#B, 1UL);
    var data_blk_min_elmts = h5policy_msg_u64_at(ios, profile,
                                                  hdr_addr#B + 9#B, 1UL);
    var sup_blk_min_data_ptrs = h5policy_msg_u64_at(ios, profile,
                                                     hdr_addr#B + 10#B, 1UL);
    var page_bits = h5policy_msg_u64_at(ios, profile,
                                         hdr_addr#B + 11#B, 1UL);
    var nelmts = h5policy_msg_u64_at(ios, profile, hdr_addr#B + (12UL + (5UL * el))#B, el);
    var idx_raw = h5policy_msg_bytes(ios, profile, hdr_addr#B + (12UL + (6UL * el))#B, o);
    var idx_blk_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(idx_raw));

    var geometry_ok = 1;
    if ((client_id == 0UL && raw_elmt_size != o)
        || (client_id == 1UL
            && (raw_elmt_size <= o + 4UL || raw_elmt_size > o + 4UL + el)))
        geometry_ok = 0;
    if (max_nelmts_bits == 0UL || max_nelmts_bits > 64UL
        || !h5policy_ea_is_power_of_two(data_blk_min_elmts)
        || h5policy_ea_log2(data_blk_min_elmts) > max_nelmts_bits
        || sup_blk_min_data_ptrs < 2UL
        || !h5policy_ea_is_power_of_two(sup_blk_min_data_ptrs)
        || page_bits == 0UL || page_bits > max_nelmts_bits
        || page_bits >= 64UL)
        geometry_ok = 0;
    if (!geometry_ok)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_GEOMETRY",
                                "corrupt", hdr_addr#B, object,
                                "extensible-array header geometry is invalid");
            return ctx;
        }

    var data_min_bits = h5policy_ea_log2(data_blk_min_elmts);
    var nsblks = 1UL + max_nelmts_bits - data_min_bits;
    var iblk_nsblks = 2UL * h5policy_ea_log2(sup_blk_min_data_ptrs);
    if (iblk_nsblks > nsblks)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_GEOMETRY",
                                "corrupt", hdr_addr#B, object,
                                "extensible-array index-block group count exceeds the array geometry");
            return ctx;
        }
    var ndblk_addrs = 2UL * (sup_blk_min_data_ptrs - 1UL);
    var nsblk_addrs = nsblks - iblk_nsblks;
    var page_nelmts = 1UL <<. page_bits;
    var first_sblock_factor = 1UL <<. ((iblk_nsblks + 1UL) / 2UL);
    var first_sblock_nelmts = h5policy_checked_mul_u64(
        first_sblock_factor, data_blk_min_elmts,
        0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", hdr_addr#B, object,
        "extensible-array first secondary-block geometry overflow");
    if (page_nelmts < idx_blk_elmts
        || page_nelmts < first_sblock_nelmts)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_GEOMETRY",
                                "corrupt", hdr_addr#B, object,
                                "extensible-array page capacity is inconsistent with its index geometry");
            return ctx;
        }

    var cfg = H5PolicyEAConfig
    {
        hdr_addr = hdr_addr,
        client_id = client_id,
        raw_elmt_size = raw_elmt_size,
        arr_off_size = (max_nelmts_bits + 7UL) / 8UL,
        idx_blk_elmts = idx_blk_elmts,
        data_blk_min_elmts = data_blk_min_elmts,
        iblk_nsblks = iblk_nsblks,
        ndblk_addrs = ndblk_addrs,
        nsblk_addrs = nsblk_addrs,
        page_nelmts = page_nelmts,
        chunk_byte_size = chunk_byte_size
    };

    /* The extensible-array header's realized-element count is a conservative
       pre-traversal chunk budget for all inline and allocated child blocks. */
    ctx = h5policy_count_chunks(
        ctx, profile, nelmts, hdr_addr#B, object,
        "chunk count exceeds the selected profile limit");
    var metadata_over = h5policy_chunkindex_metadata_would_exceed(
        ctx, profile, hdr_size);
    ctx = h5policy_account_metadata(ctx, profile, hdr_size,
                                    hdr_addr#B, object);
    if (metadata_over)
        return ctx;

    if (h5policy_msg_addr_is_undef(idx_raw))
        {
            if (nelmts != 0UL)
                h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_INDEX_ADDRESS",
                                    "corrupt", hdr_addr#B, object,
                                    "extensible array has realized elements but no index block");
            return ctx;
        }
    if (idx_blk_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", hdr_addr#B, object,
                                "extensible array index block outside file");
            return ctx;
        }

    if (!h5policy_ea_mark_block(idx_blk_addr, object,
                                "extensible-array index block"))
        return ctx;

    var ib_prefix = 6UL + o;
    var inline = h5policy_checked_mul_u64(idx_blk_elmts, raw_elmt_size, 0xffffffffffffffffUL,
                                          "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                          idx_blk_addr#B, object,
                                          "extensible array index block size overflow");
    var direct_addr_bytes = h5policy_checked_mul_u64(
        ndblk_addrs, o, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B, object,
        "extensible-array direct-block address table overflow");
    var secondary_addr_bytes = h5policy_checked_mul_u64(
        nsblk_addrs, o, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B, object,
        "extensible-array secondary-block address table overflow");
    var ib_size = h5policy_checked_add_u64(
        ib_prefix, inline, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B, object,
        "extensible array index block size overflow");
    ib_size = h5policy_checked_add_u64(
        ib_size, direct_addr_bytes, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B, object,
        "extensible array index block size overflow");
    ib_size = h5policy_checked_add_u64(
        ib_size, secondary_addr_bytes, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B, object,
        "extensible array index block size overflow");
    ib_size = h5policy_checked_add_u64(
        ib_size, 4UL, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B, object,
        "extensible array index block size overflow");
    if (!h5policy_checked_addr_range(idx_blk_addr, ib_size, file_size,
                                     "extensible array index block body outside file",
                                     idx_blk_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, idx_blk_addr#B, 4UL) != H5_FORMAT_EAIB_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", idx_blk_addr#B, object,
                                "extensible array index block signature mismatch");
            return ctx;
        }
    h5policy_mark_reached(idx_blk_addr, "EAIB");
    var ib_version = h5policy_msg_u64_at(ios, profile, idx_blk_addr#B + 4#B, 1UL);
    var ib_client = h5policy_msg_u64_at(ios, profile,
                                         idx_blk_addr#B + 5#B, 1UL);
    var ib_owner = h5policy_msg_addr_at(ios, profile,
                                        idx_blk_addr#B + 6#B, o);
    if (ib_version != 0UL || ib_client != client_id)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_EXTENSIBLE_ARRAY_VERSION",
                                "corrupt", idx_blk_addr#B, object,
                                "extensible array index-block version or client differs from its header");
            return ctx;
        }
    if (ib_owner != hdr_addr)
        {
            h5policy_emit_error("H5_CORRUPT_EXTENSIBLE_ARRAY_BACKPOINTER",
                                "corrupt", idx_blk_addr#B + 6#B, object,
                                "extensible-array index block points at the wrong header");
            return ctx;
        }

    metadata_over = h5policy_chunkindex_metadata_would_exceed(
        ctx, profile, ib_size);
    ctx = h5policy_account_metadata(ctx, profile, ib_size,
                                    idx_blk_addr#B, object);
    if (metadata_over)
        return ctx;
    if (!h5policy_chunkindex_verify_trailing_checksum(
            ios, profile, idx_blk_addr, ib_size, file_size, object,
            "extensible-array index block"))
        return ctx;

    h5policy_validate_ea_elements(
        ios, profile, idx_blk_addr + ib_prefix,
        idx_blk_elmts, cfg, file_size, object);

    if (ctx.chunk_count_exceeded != 0UB)
        return ctx;

    var direct_base = idx_blk_addr + ib_prefix + inline;
    var secondary_base = direct_base + direct_addr_bytes;
    var dblock_index = 0UL;
    var group_start = 0UL;
    var group = 0UL;
    while (group < iblk_nsblks)
        {
            var ndblks = 1UL <<. (group / 2UL);
            var factor = 1UL <<. ((group + 1UL) / 2UL);
            var dblock_nelmts = h5policy_checked_mul_u64(
                factor, data_blk_min_elmts, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B,
                object, "extensible-array direct data-block geometry overflow");
            var i = 0UL;
            while (i < ndblks)
                {
                    if (ctx.metadata_count_exceeded != 0UB)
                        return ctx;
                    var ptr_addr = direct_base + (dblock_index * o);
                    var raw = h5policy_msg_bytes(ios, profile, ptr_addr#B, o);
                    var addr = hdf5_addr_to_file_u64(bytes_to_u64_le(raw));
                    if (!h5policy_msg_addr_is_undef(raw))
                        {
                            if (addr >= file_size)
                                h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                                    "corrupt", ptr_addr#B, object,
                                                    "extensible-array direct data-block address outside file");
                            else
                                ctx = h5policy_walk_ea_dblock(
                                    ios, profile, ctx, addr, dblock_nelmts,
                                    /* Direct-block offsets use the absolute
                                       slot in EAIB's direct-address table;
                                       secondary blocks restart at slot zero. */
                                    group_start
                                    + (dblock_index * dblock_nelmts),
                                    0UL, 0UB, cfg, file_size, object);
                        }
                    dblock_index = dblock_index + 1UL;
                    i = i + 1UL;
                }
            var group_span = h5policy_checked_mul_u64(
                ndblks, dblock_nelmts, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B,
                object, "extensible-array group span overflow");
            group_start = h5policy_checked_add_u64(
                group_start, group_span, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B,
                object, "extensible-array group offset overflow");
            group = group + 1UL;
        }

    var s = 0UL;
    while (s < nsblk_addrs)
        {
            if (ctx.metadata_count_exceeded != 0UB)
                return ctx;
            group = iblk_nsblks + s;
            var ptr_addr = secondary_base + (s * o);
            var raw = h5policy_msg_bytes(ios, profile, ptr_addr#B, o);
            var addr = hdf5_addr_to_file_u64(bytes_to_u64_le(raw));
            if (!h5policy_msg_addr_is_undef(raw))
                {
                    if (addr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                            "corrupt", ptr_addr#B, object,
                                            "extensible-array secondary-block address outside file");
                    else
                        ctx = h5policy_walk_ea_sblock(
                            ios, profile, ctx, addr, group, group_start,
                            cfg, file_size, object);
                }
            var ndblks = 1UL <<. (group / 2UL);
            var factor = 1UL <<. ((group + 1UL) / 2UL);
            var dblock_nelmts = h5policy_checked_mul_u64(
                factor, data_blk_min_elmts, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B,
                object, "extensible-array secondary group geometry overflow");
            var group_span = h5policy_checked_mul_u64(
                ndblks, dblock_nelmts, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B,
                object, "extensible-array secondary group span overflow");
            group_start = h5policy_checked_add_u64(
                group_start, group_span, 0xffffffffffffffffUL,
                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", idx_blk_addr#B,
                object, "extensible-array secondary group offset overflow");
            s = s + 1UL;
        }
    return ctx;
}

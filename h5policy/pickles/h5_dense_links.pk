/* Dense link storage is the modern group representation: a link-info message
   points to a fractal heap of serialized link messages and a name-indexed v2
   B-tree of records whose heap IDs locate those messages.  The code here
   resolves enough of that graph to validate and enqueue hard links while
   preserving h5policy's metadata-only boundary.  */

/* Compact link messages and dense-heap link objects share the same payload
   layout.  Hard links enqueue object headers; soft links are only bounds
   checked; external and user-defined links become policy findings.  */
fun h5policy_utf8_cont_byte = (uint<64> b) int:
{
    return b >= 0x80UL && b <= 0xbfUL;
}

fun h5policy_emit_bad_link_charset = (off64 loc, string object,
                                      string message) void:
{
    h5policy_emit_error("H5_CORRUPT_LINK_NAME_CHARSET",
                        "corrupt", loc, object, message);
}

fun h5policy_validate_link_name_charset = (int ios,
                                           H5PolicyProfile profile,
                                           offset<uint<64>,B> name_off,
                                           uint<64> name_len,
                                           uint<64> charset,
                                           string object) void:
{
    if (charset > 1UL)
        {
            h5policy_emit_bad_link_charset(name_off, object,
                                           "link name has an unknown character set");
            return;
        }

    var i = 0UL;
    while (i < name_len)
        {
            var b0 = h5policy_msg_u64_at(ios, profile, name_off + i#B, 1UL);

            if (charset == 0UL)
                {
                    if (b0 > 0x7fUL)
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "ASCII link name contains a non-ASCII byte");
                            return;
                        }
                    i = i + 1UL;
                }
            else if (b0 <= 0x7fUL)
                i = i + 1UL;
            else if (b0 >= 0xc2UL && b0 <= 0xdfUL)
                {
                    if (i + 1UL >= name_len)
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "UTF-8 link name is truncated");
                            return;
                        }
                    var b1 = h5policy_msg_u64_at(ios, profile,
                                                  name_off + (i + 1UL)#B, 1UL);
                    if (!h5policy_utf8_cont_byte(b1))
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "UTF-8 link name has an invalid continuation byte");
                            return;
                        }
                    i = i + 2UL;
                }
            else if (b0 >= 0xe0UL && b0 <= 0xefUL)
                {
                    if (i + 2UL >= name_len)
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "UTF-8 link name is truncated");
                            return;
                        }
                    var e1 = h5policy_msg_u64_at(ios, profile,
                                                  name_off + (i + 1UL)#B, 1UL);
                    var e2 = h5policy_msg_u64_at(ios, profile,
                                                  name_off + (i + 2UL)#B, 1UL);
                    if ((b0 == 0xe0UL && (e1 < 0xa0UL || e1 > 0xbfUL))
                        || (b0 == 0xedUL && (e1 < 0x80UL || e1 > 0x9fUL))
                        || (b0 != 0xe0UL && b0 != 0xedUL
                            && !h5policy_utf8_cont_byte(e1))
                        || !h5policy_utf8_cont_byte(e2))
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "UTF-8 link name has an invalid byte sequence");
                            return;
                        }
                    i = i + 3UL;
                }
            else if (b0 >= 0xf0UL && b0 <= 0xf4UL)
                {
                    if (i + 3UL >= name_len)
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "UTF-8 link name is truncated");
                            return;
                        }
                    var f1 = h5policy_msg_u64_at(ios, profile,
                                                  name_off + (i + 1UL)#B, 1UL);
                    var f2 = h5policy_msg_u64_at(ios, profile,
                                                  name_off + (i + 2UL)#B, 1UL);
                    var f3 = h5policy_msg_u64_at(ios, profile,
                                                  name_off + (i + 3UL)#B, 1UL);
                    if ((b0 == 0xf0UL && (f1 < 0x90UL || f1 > 0xbfUL))
                        || (b0 == 0xf4UL && (f1 < 0x80UL || f1 > 0x8fUL))
                        || (b0 != 0xf0UL && b0 != 0xf4UL
                            && !h5policy_utf8_cont_byte(f1))
                        || !h5policy_utf8_cont_byte(f2)
                        || !h5policy_utf8_cont_byte(f3))
                        {
                            h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                           "UTF-8 link name has an invalid byte sequence");
                            return;
                        }
                    i = i + 4UL;
                }
            else
                {
                    h5policy_emit_bad_link_charset(name_off + i#B, object,
                                                   "UTF-8 link name has an invalid leading byte");
                    return;
                }
        }
}

/* Offset (relative to `off`) of the first NUL byte within `len` bytes, or the
   all-ones sentinel when the range holds no terminator.  External link target
   strings must terminate inside the link value: libhdf5 runs strlen() over
   them, so a missing NUL is an out-of-bounds read.  */
fun h5policy_scan_nul = (int ios, H5PolicyProfile profile,
                         offset<uint<64>,B> off, uint<64> len) uint<64>:
{
    var i = 0UL;
    while (i < len)
        {
            if (h5policy_msg_u64_at(ios, profile, off + i#B, 1UL) == 0UL)
                return i;
            i = i + 1UL;
        }
    return 0xffffffffffffffffUL;
}

/* Classify an external link's *target file name* for path-safety hazards from
   the stored bytes alone.  h5policy never resolves or opens the target, so this
   is a syntactic best-effort signal, not a resolved-path guarantee: it cannot
   know the consumer's base directory or whether a plain name is itself a
   symlink.  Mirrors the external-storage (h5_external.pk) and VDS (h5_vds.pk)
   source-path advisories and, like them, emits only when the profile permits the
   feature -- a denied profile already rejects the link with H5_POLICY_EXTERNAL_-
   LINK, so the advisory would be redundant there.  `off`/`len` cover the
   NUL-free, in-bounds target file name (the object path is validated
   separately).  */
fun h5policy_classify_external_link_target = (int ios, H5PolicyProfile profile,
                                              off64 off, uint<64> len,
                                              string object) void:
{
    if (profile.features.allow_external_links == 0UB || len == 0UL)
        return;

    var first = 0UL; var second = 0UL; var third = 0UL;
    var parent = 0; var component_start = 1;
    var i = 0UL;
    while (i < len)
        {
            var ch = h5policy_msg_u64_at(ios, profile, off + i#B, 1UL);
            if (i == 0UL) first = ch;
            if (i == 1UL) second = ch;
            if (i == 2UL) third = ch;
            if (component_start && ch == ('.' as uint<64>) && i + 1UL < len)
                {
                    var next = h5policy_msg_u64_at(ios, profile,
                                                   off + (i + 1UL)#B, 1UL);
                    if (next == ('.' as uint<64>))
                        {
                            var after = 0UL;
                            if (i + 2UL < len)
                                after = h5policy_msg_u64_at(ios, profile,
                                                            off + (i + 2UL)#B, 1UL);
                            if (after == 0UL
                                || after == ('/' as uint<64>)
                                || after == ('\\' as uint<64>))
                                parent = 1;
                        }
                }
            component_start = ch == ('/' as uint<64>) || ch == ('\\' as uint<64>);
            i = i + 1UL;
        }

    var absolute = first == ('/' as uint<64>)
                   || first == ('\\' as uint<64>)
                   || (second == (':' as uint<64>)
                       && (third == ('/' as uint<64>)
                           || third == ('\\' as uint<64>)));
    if (parent)
        h5policy_emit_warning("H5_ADVISORY_EXTERNAL_LINK_PARENT_PATH",
                              off, object,
                              "external link target path contains a parent-directory component and can direct a consumer to open a file outside the expected directory");
    else if (absolute)
        h5policy_emit_warning("H5_ADVISORY_EXTERNAL_LINK_ABSOLUTE_PATH",
                              off, object,
                              "external link uses an absolute target path and can direct a consumer to open that file");
    else
        h5policy_emit_warning("H5_ADVISORY_EXTERNAL_LINK_RELATIVE_PATH",
                              off, object,
                              "external link uses a relative target path whose resolved file depends on consumer path resolution");
}

/* A link is encoded identically whether it is a compact link MESSAGE in an
   object header (h5_dispatch.pk, message type 0x06) or a link RECORD inside a
   dense index's fractal heap (h5policy_walk_dense_links below) -- so one
   decoder serves both.  They are different record families, though, so `role`
   names which one this call is, exactly as h5policy_dense_corder_role does for
   the creation-order walker.  Without it a link-message defect in an object
   header was catalogued against dense_index.

   A parameter rather than a global here: this function IS the entry point, so
   the compiler can enforce that every call site names its role.  The phrasing
   has to match the `contexts` rules in registry/findings.yml, and it prefixes
   the WHOLE message, so every message below reads "<role> link ...".  */
fun h5policy_validate_link_payload = (int ios,
                                      H5PolicyProfile profile,
                                      offset<uint<64>,B> payload_off,
                                      uint<64> msg_size,
                                      string object,
                                      string role) void:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                   "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   role + " link message is too small"))
        return;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
    var flags = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var cur = 2UL;
    var link_type = 0UL;
    var charset = 0UL;

    /* Optional fields are controlled by flag bits: type, creation order,
       character set, then a variable-width name length.  `cur` tracks the next
       unread payload byte and every skip is guarded before later reads.  */
    if (version != 1UL)
        h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_LINK_VERSION",
                            "corrupt", payload_off, object,
                            role + " unsupported link message version");

    if ((flags & 8UL) != 0UL)
        {
            if (!h5policy_payload_range_ok(msg_size, cur, 1UL,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           role + " link type byte is missing"))
                return;
            link_type = h5policy_msg_u64_at(ios, profile,
                                            payload_off + cur#B, 1UL);
            cur = cur + 1UL;
        }

    if ((flags & 4UL) != 0UL)
        cur = cur + 8UL;
    if ((flags & 16UL) != 0UL)
        {
            if (!h5policy_payload_range_ok(msg_size, cur, 1UL,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           role + " link character set byte is missing"))
                return;
            charset = h5policy_msg_u64_at(ios, profile, payload_off + cur#B, 1UL);
            cur = cur + 1UL;
        }

    var len_width = 1UL <<. (flags & 3UL);
    if (!h5policy_payload_range_ok(msg_size, cur, len_width,
                                   "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                   payload_off + cur#B, object,
                                   role + " link name length field is missing"))
        return;

    var name_len = h5policy_msg_u64_at(ios, profile,
                                       payload_off + cur#B, len_width);
    cur = cur + len_width;
    var name_off = payload_off + cur#B;

    if (name_len == 0UL)
        h5policy_emit_error("H5_CORRUPT_LINK_NAME_EMPTY",
                            "corrupt", payload_off + cur#B, object,
                            role + " link name is empty");

    if (!h5policy_payload_range_ok(msg_size, cur, name_len,
                                   "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                   payload_off + cur#B, object,
                                   role + " link name overruns the link message"))
        return;

    /* The compact link name is stored as exactly `name_len` bytes with no NUL
       terminator, so an embedded NUL truncates the C-string libhdf5 decodes --
       a leading NUL yields an empty name, which libhdf5 rejects outright.  No
       valid file stores a NUL inside a link name, so flagging one here closes a
       soundness gap (h5policy would otherwise accept a file libhdf5 refuses)
       without risking an over-strict rejection of a legitimate name.  */
    var name_nul = 0UL;
    while (name_nul < name_len)
        {
            if (h5policy_msg_u64_at(ios, profile,
                                    name_off + name_nul#B, 1UL) == 0UL)
                {
                    h5policy_emit_error("H5_CORRUPT_LINK_NAME_EMPTY",
                                        "corrupt", name_off + name_nul#B, object,
                                        role + " link name contains a NUL byte");
                    break;
                }
            name_nul = name_nul + 1UL;
        }

    cur = cur + name_len;
    var link_name = h5policy_string_from_payload(ios, profile,
                                                 name_off, name_len);
    if (link_name == "")
        link_name = "<unnamed>";
    h5policy_validate_link_name_charset(ios, profile, name_off, name_len,
                                        charset, object);

    if (link_type == 0UL)
        {
            /* Hard links are the only link kind that extends the reachable
               metadata graph.  The target address is queued rather than walked
               immediately so breadth-first traversal and depth budgets remain
               centralized.  */
            if (!h5policy_payload_range_ok(msg_size, cur,
                                           global_sizeof_offsets as uint<64>,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           role + " hard link target address is missing"))
                return;

            var target_raw = h5policy_msg_bytes(ios, profile,
                                                payload_off + cur#B,
                                                global_sizeof_offsets as uint<64>);
            var target = hdf5_addr_to_file_u64(bytes_to_u64_le(target_raw));
            if (!h5policy_msg_addr_is_undef(target_raw))
                {
                    var ok = h5policy_checked_addr_range(target, 1UL,
                                                         h5policy_ceiling(ios),
                                                         role + " hard link target address outside file",
                                                         payload_off + cur#B,
                                                         object);
                    if (ok)
                        h5policy_enqueue_ohdr(profile, target,
                                              h5policy_current_object_depth + 1UL,
                                              h5policy_join_path(object, link_name),
                                              payload_off + cur#B,
                                              object);
                }
        }
    else if (link_type == 1UL)
        {
            /* Soft links carry a target path string.  h5policy validates the
               envelope but does not resolve the path because doing so would
               require HDF5 name lookup semantics rather than metadata reach.  */
            if (!h5policy_payload_range_ok(msg_size, cur, 2UL,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           role + " soft link length is missing"))
                return;
            var soft_len = h5policy_msg_u64_at(ios, profile,
                                               payload_off + cur#B, 2UL);
            if (!h5policy_payload_range_ok(msg_size, cur + 2UL, soft_len,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           role + " soft link target overruns the link message"))
                return;
        }
    else if (link_type == 64UL)
        {
            /* External links can cause consumers to open other files.  The
               payload is still bounds checked even if the active profile will
               reject the feature.  */
            h5policy_note_external_link;
            if (!h5policy_payload_range_ok(msg_size, cur, 2UL,
                                           "H5_CORRUPT_EXTERNAL_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           role + " external link value length is missing"))
                return;
            var ext_len = h5policy_msg_u64_at(ios, profile,
                                              payload_off + cur#B, 2UL);
            if (ext_len < 3UL)
                h5policy_emit_error("H5_CORRUPT_EXTERNAL_LINK_INFO_TOO_SMALL",
                                    "corrupt", payload_off + cur#B, object,
                                    role + " external link information length is too small");
            else if (!h5policy_payload_range_ok(msg_size, cur + 2UL, ext_len,
                                                "H5_CORRUPT_EXTERNAL_LINK_MESSAGE_TOO_SMALL",
                                                payload_off + cur#B, object,
                                                role + " external link value overruns the link message"))
                return;
            else
                {
                    /* The value is a version/flags byte, then a NUL-terminated
                       target file name and a NUL-terminated target object path.
                       libhdf5 runs strlen() over each, so a string that does not
                       terminate inside the value is an out-of-bounds read.  This
                       is structural corruption under every profile, independent
                       of the external-reference policy applied below.  */
                    var val_off = payload_off + (cur + 2UL)#B;
                    var fname_nul = h5policy_scan_nul(ios, profile,
                                                      val_off + 1#B, ext_len - 1UL);
                    if (fname_nul == 0xffffffffffffffffUL)
                        h5policy_emit_error("H5_CORRUPT_EXTERNAL_LINK_VALUE_NOT_TERMINATED",
                                            "corrupt", val_off, object,
                                            role + " external link target file name is not terminated within the link value");
                    else
                        {
                            h5policy_classify_external_link_target(
                                ios, profile, val_off + 1#B, fname_nul, object);
                            var obj_rel = fname_nul + 2UL;   /* past fname + its NUL */
                            if (obj_rel >= ext_len
                                || h5policy_scan_nul(ios, profile,
                                                     val_off + obj_rel#B,
                                                     ext_len - obj_rel) == 0xffffffffffffffffUL)
                                h5policy_emit_error("H5_CORRUPT_EXTERNAL_LINK_VALUE_NOT_TERMINATED",
                                                    "corrupt", val_off, object,
                                                    role + " external link target object path is not terminated within the link value");
                        }
                }
            if (profile.features.allow_external_links == 0UB)
                h5policy_emit_error("H5_POLICY_EXTERNAL_LINK", "policy",
                                    payload_off, object,
                                    role + " external link encountered; profile denies external references");
        }
    else
        {
            h5policy_emit_error("H5_POLICY_USER_DEFINED_LINK", "policy",
                                payload_off, object,
                                role + " user-defined link encountered; profile denies user-defined links");
        }
}

var h5policy_dense_checksummed_blocks = uint<64>[]();

/* Fractal heap blocks can be reached by both dense-link and dense-attribute
   paths.  Remember which block checksums have already been verified so shared
   references do not multiply checksum work in forensic walks.  */
fun h5policy_dense_mark_checksummed = (uint<64> addr) int:
{
    if (h5policy_seen_u64(h5policy_dense_checksummed_blocks, addr))
        return 0;
    h5policy_dense_checksummed_blocks += [addr];
    return 1;
}

/* Small integer-width helpers for fractal heap IDs.  Heap object offsets are
   sized by the maximum heap address bits; object lengths are the minimum bytes
   needed for the maximum managed object size.  */
fun h5policy_bytes_for_bits = (uint<64> nbits) uint<64>:
{
    return (nbits + 7UL) / 8UL;
}

fun h5policy_bytes_for_limit = (uint<64> limit) uint<64>:
{
    var nbytes = 1UL;
    var max = 0xffUL;
    while (nbytes < 8UL && limit > max)
        {
            nbytes = nbytes + 1UL;
            max = (max <<. 8UL) | 0xffUL;
        }
    return nbytes;
}

/* Poke has no built-in integer log2 helper in this style, and fractal heap row
   geometry is specified in powers of two.  */
fun h5policy_floor_log2 = (uint<64> value) uint<64>:
{
    var v = value;
    var n = 0UL;
    while ((v .>> 1UL) > 0UL)
        {
            v = v .>> 1UL;
            n = n + 1UL;
        }
    return n;
}

/* Verify a structure whose checksum is the final four bytes over all preceding
   bytes.  Several dense-storage structures share this convention.  */
fun h5policy_dense_verify_trailing_checksum = (int ios, H5PolicyProfile profile,
                                               uint<64> addr, uint<64> total_size,
                                               uint<64> file_size, string object,
                                               string what) int:
{
    if (total_size < 4UL)
        {
            h5policy_emit_error("H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                addr#B, object, what + " checksum field outside block");
            return 0;
        }
    if (!h5policy_checked_addr_range(addr, total_size, file_size,
                                     what + " outside file", addr#B, object))
        return 0;
    if (!h5policy_dense_mark_checksummed(addr))
        return 1;

    var body_size = total_size - 4UL;
    var body = h5policy_msg_bytes(ios, profile, addr#B, body_size);
    var stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                   addr#B + body_size#B, 4UL));
    if (lookup3_hashlittle(body, 0) != stored)
        h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                            addr#B, object, what + " checksum mismatch");
    return 1;
}

/* Compute the on-disk fractal heap header size, including optional filter
   pipeline bytes and the trailing checksum.  This routine only sizes the
   header; filtered heaps are rejected by the dense walkers before traversal.  */
fun h5policy_frhp_header_size = (uint<64> filter_len, off64 loc,
                                 string object) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var body = 14UL + (2UL * o) + (10UL * el) + (8UL + (2UL * el) + o);
    if (filter_len != 0UL)
        body = h5policy_checked_add_u64(body, el + 4UL + filter_len,
                                        0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        loc, object,
                                        "fractal heap header size overflow");
    return h5policy_checked_add_u64(body, 4UL, 0xffffffffffffffffUL,
                                    "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                    loc, object,
                                    "fractal heap header checksum size overflow");
}

/* A filtered fractal-heap header stores the compressed root-direct-block size
   and filter mask immediately before an ordinary encoded filter pipeline.
   Its data blocks remain outside h5policy's metadata-only coverage, but the
   pipeline descriptor itself can be validated without executing any filter. */
fun h5policy_frhp_filter_pipeline_off = (uint<64> fheap_addr) offset<uint<64>,B>:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var unfiltered_body = 14UL + (2UL * o) + (10UL * el)
                          + (8UL + (2UL * el) + o);
    return (fheap_addr + unfiltered_body + el + 4UL)#B;
}

/* Size a fractal heap indirect block from its doubling-table geometry.  Direct
   entries appear until max_direct_size is reached; remaining rows hold child
   indirect-block pointers.  */
fun h5policy_frhp_iblock_size = (uint<64> nrows, uint<64> table_width,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> off_size, uint<64> filter_len,
                                 off64 loc, string object) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var max_direct_rows = h5policy_floor_log2(max_direct_size)
                          - h5policy_floor_log2(start_size) + 2UL;
    var ndir = nrows <= max_direct_rows
               ? nrows * table_width
               : max_direct_rows * table_width;
    var nindir = nrows > max_direct_rows
                 ? (nrows - max_direct_rows) * table_width
                 : 0UL;
    var dir_entry_size = filter_len == 0UL ? o : o + el + 4UL;
    var prefix = 5UL + o + off_size;
    var dir_bytes = h5policy_checked_mul_u64(ndir, dir_entry_size,
                                             0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW",
                                             "corrupt", loc, object,
                                             "fractal heap indirect block size overflow");
    var indir_bytes = h5policy_checked_mul_u64(nindir, o,
                                               0xffffffffffffffffUL,
                                               "H5_CORRUPT_LENGTH_OVERFLOW",
                                               "corrupt", loc, object,
                                               "fractal heap indirect block size overflow");
    var total = h5policy_checked_add_u64(prefix, dir_bytes,
                                         0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW",
                                         "corrupt", loc, object,
                                         "fractal heap indirect block size overflow");
    total = h5policy_checked_add_u64(total, indir_bytes,
                                     0xffffffffffffffffUL,
                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                     "corrupt", loc, object,
                                     "fractal heap indirect block size overflow");
    return h5policy_checked_add_u64(total, 4UL, 0xffffffffffffffffUL,
                                    "H5_CORRUPT_LENGTH_OVERFLOW",
                                    "corrupt", loc, object,
                                    "fractal heap indirect block checksum size overflow");
}

/* Verify an indirect block enough to trust its row table.  The caller supplies
   the expected geometry from the heap header or parent descent.  */
fun h5policy_verify_frhp_iblock = (int ios, H5PolicyProfile profile,
                                   uint<64> iblock_addr, uint<64> nrows,
                                   uint<64> table_width, uint<64> start_size,
                                   uint<64> max_direct_size, uint<64> off_size,
                                   uint<64> filter_len, uint<64> file_size,
                                   string object) int:
{
    var total = h5policy_frhp_iblock_size(nrows, table_width, start_size,
                                          max_direct_size, off_size, filter_len,
                                          iblock_addr#B, object);
    if (!h5policy_dense_verify_trailing_checksum(ios, profile, iblock_addr,
                                                 total, file_size, object,
                                                 "fractal heap indirect block"))
        return 0;
    if (h5policy_msg_bytes(ios, profile, iblock_addr#B, 4UL) != H5_FORMAT_FHIB_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                iblock_addr#B, object,
                                "fractal heap indirect block signature mismatch");
            return 0;
        }
    h5policy_mark_reached(iblock_addr, "FHIB");
    var version = h5policy_msg_u64_at(ios, profile, iblock_addr#B + 4#B, 1UL);
    if (version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FRACTAL_HEAP_VERSION",
                                "corrupt", iblock_addr#B, object,
                                "fractal heap indirect block has an unsupported version");
            return 0;
        }
    return 1;
}

/* Direct blocks store heap object bytes.  When the heap asks for direct-block
   checksums, the checksum field is in the block prefix rather than at the end;
   HDF5 computes it with that field zeroed, so h5policy mirrors that layout.  */
fun h5policy_verify_frhp_dblock = (int ios, H5PolicyProfile profile,
                                   uint<64> dblock_addr, uint<64> block_size,
                                   uint<64> off_size, uint<8> checksum_dblocks,
                                   uint<64> file_size, string object) int:
{
    if (!h5policy_checked_addr_range(dblock_addr, block_size, file_size,
                                     "fractal heap direct block outside file",
                                     dblock_addr#B, object))
        return 0;
    /* A direct block cannot be smaller than its own prefix -- signature (4),
       version (1), heap-header address, and block offset.  The heap header
       declares this size (start_block_size doubling per row) and nothing floors
       it, so a declared 1 makes libhdf5 allocate one byte and then read the
       checksum at the prefix offset: heap-buffer-overflow in
       H5HF__cache_dblock_verify_chksum (GHSA-7ggx-c45p-66ph/61, confirmed under
       ASAN -- "16 bytes after 1-byte region").

       Checked BEFORE the signature, for two reasons: libhdf5 verifies the
       checksum before it deserializes, so this is the failure it actually hits;
       and reading a 4-byte signature out of a 1-byte block would itself look
       past the declared extent.  Checked INDEPENDENTLY of checksum_dblocks --
       the prefix exists either way.  The floor used to be a side effect of the
       checksum-position check below, which sits after an early return for heaps
       that do not checksum direct blocks, so a tiny block in such a heap was
       ACCEPTED outright. */
    var prefix_bytes = 5UL + (global_sizeof_offsets as uint<64>) + off_size;
    if (block_size < prefix_bytes)
        {
            h5policy_emit_error("H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                dblock_addr#B, object,
                                "fractal heap direct block is smaller than its own prefix");
            return 0;
        }
    if (h5policy_msg_bytes(ios, profile, dblock_addr#B, 4UL) != H5_FORMAT_FHDB_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                dblock_addr#B, object,
                                "fractal heap direct block signature mismatch");
            return 0;
        }
    h5policy_mark_reached(dblock_addr, "FHDB");
    var version = h5policy_msg_u64_at(ios, profile, dblock_addr#B + 4#B, 1UL);
    if (version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FRACTAL_HEAP_VERSION",
                                "corrupt", dblock_addr#B, object,
                                "fractal heap direct block has an unsupported version");
            return 0;
        }
    if (checksum_dblocks == 0UB || !h5policy_dense_mark_checksummed(dblock_addr))
        return 1;

    var o = global_sizeof_offsets as uint<64>;
    var checksum_rel = 5UL + o + off_size;
    if (block_size < checksum_rel + 4UL)
        {
            h5policy_emit_error("H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                dblock_addr#B, object,
                                "fractal heap direct block checksum field outside block");
            return 0;
        }

    var before = h5policy_msg_bytes(ios, profile, dblock_addr#B, checksum_rel);
    var after_len = block_size - checksum_rel - 4UL;
    var after = h5policy_msg_bytes(ios, profile,
                                   dblock_addr#B + (checksum_rel + 4UL)#B,
                                   after_len);
    var stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                   dblock_addr#B + checksum_rel#B,
                                                   4UL));
    var checksum_bytes = before + [0UB, 0UB, 0UB, 0UB] + after;
    if (lookup3_hashlittle(checksum_bytes, 0) != stored)
        h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                            dblock_addr#B, object,
                            "fractal heap direct block checksum mismatch");
    return 1;
}

/* File offset of a fractal-heap managed object, from its heap offset.  Mirrors
   H5HF__man_dblock_locate (and the single-root-direct-block shortcut).  Returns
   the undef sentinel when the lookup escapes the block geometry (corruption or
   a heap id from another heap).  Bounded by a fixed descent guard.  */
fun h5policy_frhp_locate = (int ios, H5PolicyProfile profile,
                            uint<64> root_addr, uint<64> curr_root_rows,
                            uint<64> start_size, uint<64> max_direct_size,
                            uint<64> width, uint<64> off_size,
                            uint<8> checksum_dblocks,
                            uint<64> heap_obj_off, uint<64> file_size,
                            string object) uint<64>:
{
    if (curr_root_rows == 0UL)
        {
            h5policy_verify_frhp_dblock(ios, profile, root_addr, start_size,
                                        off_size, checksum_dblocks,
                                        file_size, object);
            return root_addr + heap_obj_off;
        }

    var first_row_bits = h5policy_floor_log2(start_size)
                         + h5policy_floor_log2(width);
    var max_direct_rows = h5policy_floor_log2(max_direct_size)
                          - h5policy_floor_log2(start_size) + 2UL;
    var prefix_size = 5UL + (global_sizeof_offsets as uint<64>) + off_size;
    var entry_size = global_sizeof_offsets as uint<64>;
    var cur_addr = root_addr;
    var cur_nrows = curr_root_rows;
    var cur_block_off = 0UL;
    var guard = 0UL;

    /* At each level, convert a logical heap object offset into the row/column
       of the doubling table.  The 64-iteration guard is wider than any valid
       64-bit heap geometry and prevents malformed parent pointers from turning
       this into an unbounded descent.  */
    while (guard < 64UL)
        {
            guard = guard + 1UL;
            if (!h5policy_verify_frhp_iblock(ios, profile, cur_addr, cur_nrows,
                                             width, start_size, max_direct_size,
                                             off_size, 0UL, file_size, object))
                return 0xffffffffffffffffUL;
            var local_off = heap_obj_off - cur_block_off;
            var row = 0UL;
            var col = 0UL;
            var row_block_size = start_size;
            var row_block_off = 0UL;

            if (local_off < start_size * width)
                {
                    row = 0UL;
                    col = local_off / start_size;
                }
            else
                {
                    var high_bit = h5policy_floor_log2(local_off);
                    var off_mask = 1UL <<. high_bit;
                    row = (high_bit - first_row_bits) + 1UL;
                    row_block_size = start_size <<. (row - 1UL);
                    row_block_off = off_mask;
                    col = (local_off - off_mask) / row_block_size;
                }

            if (row >= cur_nrows || col >= width)
                return 0xffffffffffffffffUL;

            var entry_off = cur_addr + prefix_size
                            + ((row * width + col) * entry_size);
            if (entry_off > file_size || entry_size > file_size - entry_off)
                return 0xffffffffffffffffUL;

            var addr_raw = h5policy_msg_bytes(ios, profile, entry_off#B, entry_size);
            if (h5policy_msg_addr_is_undef(addr_raw))
                return 0xffffffffffffffffUL;

            var child_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(addr_raw));
            var child_block_off = cur_block_off + row_block_off
                                  + (col * row_block_size);

            if (row < max_direct_rows)
                {
                    /* A direct child contains the target object bytes.  Verify
                       the block before translating the heap-relative offset to
                       a file offset.  */
                    h5policy_verify_frhp_dblock(ios, profile, child_addr,
                                                row_block_size, off_size,
                                                checksum_dblocks, file_size,
                                                object);
                    return child_addr + (heap_obj_off - child_block_off);
                }

            cur_addr = child_addr;
            cur_nrows = row - h5policy_floor_log2(width);
            cur_block_off = child_block_off;
        }

    return 0xffffffffffffffffUL;
}

/* Minimum bytes for the "records in child node" field of a v2 B-tree child
   pointer (mirrors H5B2's fixed-point sizing).  */
fun h5policy_bt2_nrec_bytes = (uint<64> node_sz, uint<64> rec_sz) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    var bytes = 1UL;
    var prev = 0UL;
    while (bytes != prev)
        {
            prev = bytes;
            var ptr_sz = o + bytes;
            if (node_sz < 10UL + ptr_sz || rec_sz + ptr_sz == 0UL)
                return bytes;
            var max_nrec = (node_sz - 10UL - ptr_sz) / (rec_sz + ptr_sz);
            bytes = 1UL;
            var thresh = 256UL;
            while (max_nrec >= thresh)
                {
                    bytes = bytes + 1UL;
                    thresh = thresh * 256UL;
                }
        }
    return bytes;
}

/* The name and creation-order indexes must describe exactly the same heap
   objects.  Record managed-ID identities while walking the name tree, then
   consume them once from the secondary tree. */
var h5policy_dense_name_heap_offsets = uint<64>[]();
var h5policy_dense_name_heap_lengths = uint<64>[]();
var h5policy_dense_name_corders = uint<64>[]();
var h5policy_dense_name_matched = uint<8>[]();
var h5policy_dense_name_nonmanaged_reported = 0;

/* The creation-order walker is the ONE piece of this file that dense
   ATTRIBUTE indexes also run: h5_dense_attrs.pk calls
   h5policy_walk_dense_corder_btree with record_type 9, h5policy_walk_dense_links
   with record_type 6.  Both used to emit a bare "dense creation-order ..."
   message, so every corder finding on an attribute index was catalogued against
   dense_index -- the wrong family, and h5cve verify then picked the dense-link
   canary for a defect whose fixture is valid-dense_attribute.h5.

   Same fix as h5policy_validate_v2_btree_geometry's `role` (see h5_btree2.pk):
   name the role in the message, since that is the only per-occurrence
   discriminator registry/findings.yml can resolve `contexts` against.  The
   prefixes must literally contain "dense attribute" / "dense link" -- several
   codes route those two as broad rules and rely on the substring.

   This is a global rather than a parameter because the five functions that emit
   these messages include two (h5policy_match_dense_corder_heap_id,
   h5policy_finish_dense_corder_matches) that already work off the module's
   corder globals and take no record_type.  h5policy_walk_dense_corder_btree is
   the sole entry point and sets this before its first emit.  The "" initializer
   is the not-in-a-walk placeholder and is never emitted; tools/message_routing.py
   drops it when enumerating this global's values.  */
var h5policy_dense_corder_role = "";

fun h5policy_reset_dense_name_index = void:
{
    h5policy_dense_name_heap_offsets = uint<64>[]();
    h5policy_dense_name_heap_lengths = uint<64>[]();
    h5policy_dense_name_corders = uint<64>[]();
    h5policy_dense_name_matched = uint<8>[]();
    h5policy_dense_name_nonmanaged_reported = 0;
}

fun h5policy_record_dense_name_heap_id = (uint<64> heap_off,
                                           uint<64> heap_len,
                                           uint<64> corder,
                                           off64 loc,
                                           string object) void:
{
    var i = 0UL;
    while (i < h5policy_dense_name_heap_offsets'length as uint<64>)
        {
            h5policy_walk_tick(1UL);
            if (h5policy_dense_name_heap_offsets[i] == heap_off
                && h5policy_dense_name_heap_lengths[i] == heap_len)
                {
                    h5policy_emit_error("H5_CORRUPT_DENSE_NAME_INDEX_DUPLICATE_ID",
                                        "corrupt", loc, object,
                                        "dense name index references one heap object more than once");
                    return;
                }
            i = i + 1UL;
        }
    h5policy_dense_name_heap_offsets += [heap_off];
    h5policy_dense_name_heap_lengths += [heap_len];
    h5policy_dense_name_corders += [corder];
    h5policy_dense_name_matched += [0UB];
}

fun h5policy_match_dense_corder_heap_id = (uint<64> heap_off,
                                            uint<64> heap_len,
                                            uint<64> corder,
                                            off64 loc,
                                            string object) void:
{
    var i = 0UL;
    while (i < h5policy_dense_name_heap_offsets'length as uint<64>)
        {
            h5policy_walk_tick(1UL);
            if (h5policy_dense_name_heap_offsets[i] == heap_off
                && h5policy_dense_name_heap_lengths[i] == heap_len)
                {
                    if (h5policy_dense_name_matched[i] != 0UB)
                        h5policy_emit_error("H5_CORRUPT_DENSE_CORDER_INDEX_DUPLICATE_ID",
                                            "corrupt", loc, object,
                                            h5policy_dense_corder_role + " index references one heap object more than once");
                    else
                        h5policy_dense_name_matched[i] = 1UB;
                    if (h5policy_dense_name_corders[i] != corder)
                        h5policy_emit_error("H5_CORRUPT_DENSE_CORDER_MISMATCH",
                                            "corrupt", loc, object,
                                            h5policy_dense_corder_role + " key disagrees with the name-indexed record");
                    return;
                }
            i = i + 1UL;
        }
    h5policy_emit_error("H5_CORRUPT_DENSE_CORDER_INDEX_UNKNOWN_ID", "corrupt",
                        loc, object,
                        h5policy_dense_corder_role + " index references a heap object absent from the name index");
}

fun h5policy_finish_dense_corder_matches = (off64 loc, string object) void:
{
    var i = 0UL;
    while (i < h5policy_dense_name_matched'length as uint<64>)
        {
            h5policy_walk_tick(1UL);
            if (h5policy_dense_name_matched[i] == 0UB)
                {
                    h5policy_emit_error("H5_CORRUPT_DENSE_CORDER_INDEX_MISSING_ID",
                                        "corrupt", loc, object,
                                        h5policy_dense_corder_role + " index omits an object present in the name index");
                    return;
                }
            i = i + 1UL;
        }
}

/* Dense link B-tree records carry a fractal-heap ID.  Managed IDs are decoded
   and recorded for cross-index consistency; other classes are an explicit
   coverage refusal rather than a silent skip. */
/* Process one v2 B-tree leaf of dense-link (type-5) records: resolve each
   fractal-heap object and validate/enqueue it as a link message.  */
/* Process nrec dense-link (type-5) records starting at rec_base (node prefix +
   6): resolve each heap object and validate/enqueue it as a link message.
   Used for both leaf and internal nodes -- in a v2 B-tree every node stores
   records, so internal-node records must be processed too, not just leaves.  */
fun h5policy_dense_link_records = (int ios, H5PolicyProfile profile,
                                   uint<64> rec_base, uint<64> nrec, uint<64> record_size,
                                   uint<64> fheap_root, uint<64> curr_root_rows,
                                   uint<64> start_size, uint<64> max_direct_size,
                                   uint<64> table_width, uint<64> off_size,
                                   uint<8> checksum_dblocks,
                                   uint<64> len_size, uint<64> file_size,
                                   string object) void:
{
    var i = 0UL;
    while (i < nrec)
        {
            /* type-5 record: name_hash(4) + heap id */
            var id_off = rec_base + (i * record_size) + 4UL;
            var id_flags = h5policy_msg_u64_at(ios, profile, id_off#B, 1UL);
            if (((id_flags .>> 4) & 3UL) == 0UL)
                {
                    /* Managed ID form: flags byte, heap object offset, heap
                       object length.  The offset is resolved through the
                       fractal heap geometry before treating the bytes as a link
                       message payload.  */
                    var heap_obj_off = h5policy_msg_u64_at(ios, profile,
                                                           id_off#B + 1#B, off_size);
                    var heap_obj_len = h5policy_msg_u64_at(ios, profile,
                                                           id_off#B + (1UL + off_size)#B,
                                                           len_size);
                    if (heap_obj_len == 0UL)
                        h5policy_emit_error("H5_CORRUPT_FRACTAL_HEAP_ID", "corrupt",
                                            id_off#B, object,
                                            "dense link name index has a zero-length heap object ID");
                    else
                        {
                            var obj_off = h5policy_frhp_locate(ios, profile,
                                                               fheap_root, curr_root_rows,
                                                               start_size, max_direct_size,
                                                               table_width, off_size,
                                                               checksum_dblocks,
                                                               heap_obj_off, file_size,
                                                               object);
                            var link_corder = 0xffffffffffffffffUL;
                            if (obj_off != 0xffffffffffffffffUL
                                && obj_off < file_size
                                && heap_obj_len <= file_size - obj_off)
                                {
                                    if (heap_obj_len >= 2UL)
                                        {
                                            var link_flags = h5policy_msg_u64_at(
                                                ios, profile, obj_off#B + 1#B, 1UL);
                                            var link_cur = 2UL;
                                            if ((link_flags & 8UL) != 0UL)
                                                link_cur = link_cur + 1UL;
                                            if ((link_flags & 4UL) != 0UL
                                                && h5policy_payload_range_ok(
                                                    heap_obj_len, link_cur, 8UL,
                                                    "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                                    obj_off#B + link_cur#B, object,
                                                    "dense link creation order overruns the link message"))
                                                link_corder = h5policy_msg_u64_at(
                                                    ios, profile,
                                                    obj_off#B + link_cur#B, 8UL);
                                        }
                                    h5policy_validate_link_payload(
                                        ios, profile, obj_off#B, heap_obj_len,
                                        object, "dense-index");
                                }
                            else
                                h5policy_emit_error("H5_CORRUPT_FRACTAL_HEAP_ID",
                                                    "corrupt", id_off#B, object,
                                                    "dense link name-index heap ID cannot be resolved in file bounds");
                            h5policy_record_dense_name_heap_id(
                                heap_obj_off, heap_obj_len, link_corder,
                                id_off#B, object);
                        }
                }
            else if (!h5policy_dense_name_nonmanaged_reported)
                {
                    h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                                        "unsupported", id_off#B, object,
                                        "dense link name index uses a non-managed fractal-heap ID");
                    h5policy_dense_name_nonmanaged_reported = 1;
                }
            i = i + 1UL;
        }
}

/* Validate one dense-link v2 B-tree leaf and process its records.  Leaf nodes
   have a fixed 6-byte prefix, n records, and a trailing checksum.  */
fun h5policy_dense_leaf_links = (int ios, H5PolicyProfile profile,
                                 uint<64> leaf_addr, uint<64> nrec,
                                 uint<64> node_size, uint<64> record_size,
                                 uint<64> fheap_root, uint<64> curr_root_rows,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> table_width, uint<64> off_size,
                                 uint<8> checksum_dblocks,
                                 uint<64> len_size, uint<64> file_size,
                                 string object) void:
{
    var recs = h5policy_checked_mul_u64(nrec, record_size,
                                        0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        leaf_addr#B, object,
                                        "dense link v2 B-tree leaf size overflow");
    var leaf_body = h5policy_checked_add_u64(recs, 4UL,
                                             0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                             leaf_addr#B, object,
                                             "dense link v2 B-tree leaf size overflow");
    var leaf_need = h5policy_checked_add_u64(6UL, leaf_body,
                                             0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                             leaf_addr#B, object,
                                             "dense link v2 B-tree leaf size overflow");
    /* The record COUNT must fit the declared node, checked before leaf_need is
       used for anything else: leaf_need is derived from nrec, so an unchecked
       nrec makes every downstream conclusion about this node untrustworthy.
       libhdf5 allocates exactly node_size bytes for the node image and then
       locates the trailing checksum at 6 + nrec*record_size -- so an nrec past
       capacity reads off the end of that allocation (heap-buffer-overflow in
       H5F_get_checksums <- H5B2__cache_leaf_verify_chksum, confirmed under ASAN
       on GHSA-hx9j-mp99-2p98/63).  h5_btree2.pk's shared engine and the
       creation-order walker already check this; the two hand-written name-index
       leaf readers did not, which is exactly the pair that reproduced. */
    if (leaf_need > node_size)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_SIZE", "corrupt",
                                leaf_addr#B, object,
                                "dense link v2 B-tree used node bytes exceed its declared node size");
            return;
        }
    if (!h5policy_checked_addr_range(leaf_addr, leaf_need, file_size,
                                     "dense link v2 B-tree leaf outside file",
                                     leaf_addr#B, object))
        return;
    if (h5policy_msg_bytes(ios, profile, leaf_addr#B, 4UL) != H5_FORMAT_BTLF_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                leaf_addr#B, object,
                                "dense link v2 B-tree leaf signature mismatch");
            return;
        }
    h5policy_mark_reached(leaf_addr, "BTLF");
    var leaf_version = h5policy_msg_u64_at(ios, profile, leaf_addr#B + 4#B, 1UL);
    var leaf_type = h5policy_msg_u64_at(ios, profile, leaf_addr#B + 5#B, 1UL);
    if (leaf_version != 0UL || leaf_type != 5UL)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_HEADER",
                                "corrupt", leaf_addr#B, object,
                                "dense link v2 B-tree leaf version or record type is invalid");
            return;
        }
    h5policy_dense_verify_trailing_checksum(ios, profile, leaf_addr, leaf_need,
                                            file_size, object,
                                            "dense link v2 B-tree leaf");

    h5policy_dense_link_records(ios, profile, leaf_addr + 6UL, nrec, record_size,
                                fheap_root, curr_root_rows, start_size, max_direct_size,
                                table_width, off_size, checksum_dblocks,
                                len_size, file_size, object);
}

/* Enumerate dense-link records from every node of the name-indexed v2 B-tree,
   resolve each fractal-heap object, and validate/enqueue it as a link message.
   Recursive geometry is shared with the creation-order walker below. */
/* v2 B-tree internal child pointers include a variable-width count for records
   in the child and, for deeper trees, records in the whole child subtree.  This
   helper mirrors the H5B2 cumulative maximum recurrence to determine that
   second width from node geometry and tree level.  */
/* Bytes for the "records in child subtree" field of a v2 B-tree child pointer
   at a node whose children are height-`level` subtrees (level >= 1).  Ports the
   spec's cumulative-max recurrence.  */
fun h5policy_bt2_subtree_bytes = (uint<64> node_sz, uint<64> rec_sz, uint<64> level) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    var u64_max = 0xffffffffffffffffUL;
    if (level == 0UL || rec_sz == 0UL || node_sz < 10UL)
        return 0UL;
    var nrec_bytes = h5policy_bt2_nrec_bytes(node_sz, rec_sz);
    var cum_max = (node_sz - 10UL) / rec_sz;         /* cum_max[0]: leaf capacity */
    var subtree_bytes = 0UL;
    var lv = 1UL;
    while (lv <= level)
        {
            var ptr_sz = o + nrec_bytes + subtree_bytes;
            if (node_sz < 10UL + ptr_sz || rec_sz + ptr_sz == 0UL)
                return subtree_bytes;
            var max_int = (node_sz - 10UL - ptr_sz) / (rec_sz + ptr_sz);
            if (max_int != 0UL
                && cum_max > (u64_max - max_int) / (max_int + 1UL))
                return 8UL;
            cum_max = ((max_int + 1UL) * cum_max) + max_int;
            subtree_bytes = 1UL;
            var thresh = 256UL;
            while (cum_max >= thresh)
                {
                    if (subtree_bytes >= 8UL
                        || thresh > (u64_max / 256UL))
                        return 8UL;
                    subtree_bytes = subtree_bytes + 1UL;
                    thresh = thresh * 256UL;
                }
            lv = lv + 1UL;
        }
    return subtree_bytes;
}

/* Creation-order indexes are independent v2 B-trees, not alternate views of
   the already-validated name tree.  Keep a per-index key set so duplicate
   creation orders are rejected even when they occur in different nodes. */
var h5policy_dense_corder_values = uint<64>[]();
var h5policy_dense_corder_nonmanaged_reported = 0;

fun h5policy_validate_dense_attr_record_flags = (uint<64> flags, off64 loc,
                                                  string object) void:
{
    if ((flags & 0x02UL) != 0UL && (flags & 0x04UL) != 0UL)
        h5policy_emit_error("H5_CORRUPT_MESSAGE_FLAG_COMBINATION", "corrupt",
                            loc, object,
                            "dense attribute record is both shared and marked do-not-share");
    if ((flags & 0x20UL) != 0UL && (flags & 0x08UL) != 0UL)
        h5policy_emit_error("H5_CORRUPT_MESSAGE_FLAG_COMBINATION", "corrupt",
                            loc, object,
                            "dense attribute record has incompatible unknown-message flags");
    if ((flags & 0x20UL) != 0UL && (flags & 0x10UL) == 0UL)
        h5policy_emit_error("H5_CORRUPT_MESSAGE_FLAG_COMBINATION", "corrupt",
                            loc, object,
                            "dense attribute record was-unknown flag requires mark-if-unknown");
}

/* Validate the records held directly by one creation-order node.  Type 6 is
   creation-ordered links (u64 key + 7-byte heap ID); type 9 is creation-ordered
   attributes (8-byte heap ID + flags + u32 key).  Resolving every managed ID
   proves that the secondary index cannot hide an out-of-file heap reference. */
fun h5policy_dense_corder_records = (int ios, H5PolicyProfile profile,
                                      uint<64> rec_base, uint<64> nrec,
                                      uint<64> record_size, uint<64> record_type,
                                      uint<8> has_lower, uint<64> lower,
                                      uint<8> has_upper, uint<64> upper,
                                      uint<64> fheap_root, uint<64> curr_root_rows,
                                      uint<64> start_size, uint<64> max_direct_size,
                                      uint<64> table_width, uint<64> off_size,
                                      uint<8> checksum_dblocks,
                                      uint<64> len_size, uint<64> file_size,
                                      string object) void:
{
    var id_capacity = record_type == 6UL ? 7UL : 8UL;
    if (1UL + off_size + len_size > id_capacity)
        {
            h5policy_emit_error("H5_CORRUPT_FRACTAL_HEAP_ID_WIDTH", "corrupt",
                                rec_base#B, object,
                                h5policy_dense_corder_role + " record cannot contain the heap ID widths declared by its heap");
            return;
        }

    var have_prev = 0;
    var prev = 0UL;
    var i = 0UL;
    while (i < nrec)
        {
            var rec_off = rec_base + (i * record_size);
            var id_off = record_type == 6UL ? rec_off + 8UL : rec_off;
            var corder_off = record_type == 6UL ? rec_off : rec_off + 9UL;
            var corder_size = record_type == 6UL ? 8UL : 4UL;
            var corder = h5policy_msg_u64_at(ios, profile, corder_off#B,
                                             corder_size);

            if (have_prev && corder <= prev)
                h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_ORDER", "corrupt",
                                    corder_off#B, object,
                                    h5policy_dense_corder_role + " B-tree node records are not strictly ordered");
            if ((has_lower != 0UB && corder <= lower)
                || (has_upper != 0UB && corder >= upper))
                h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_ORDER", "corrupt",
                                    corder_off#B, object,
                                    h5policy_dense_corder_role + " B-tree record is outside its ancestor key bounds");
            prev = corder;
            have_prev = 1;

            if (h5policy_seen_u64(h5policy_dense_corder_values, corder))
                h5policy_emit_error("H5_CORRUPT_V2_BTREE_DUPLICATE_KEY", "corrupt",
                                    corder_off#B, object,
                                    h5policy_dense_corder_role + " B-tree contains a duplicate key");
            else
                h5policy_dense_corder_values += [corder];

            if (record_type == 9UL)
                h5policy_validate_dense_attr_record_flags(
                    h5policy_msg_u64_at(ios, profile, (rec_off + 8UL)#B, 1UL),
                    (rec_off + 8UL)#B, object);

            var id_flags = h5policy_msg_u64_at(ios, profile, id_off#B, 1UL);
            if (((id_flags .>> 4) & 3UL) != 0UL)
                {
                    if (!h5policy_dense_corder_nonmanaged_reported)
                        {
                            h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                                                "unsupported", id_off#B, object,
                                                h5policy_dense_corder_role + " index uses a non-managed fractal-heap ID");
                            h5policy_dense_corder_nonmanaged_reported = 1;
                        }
                }
            else
                {
                    var heap_obj_off = h5policy_msg_u64_at(
                        ios, profile, id_off#B + 1#B, off_size);
                    var heap_obj_len = h5policy_msg_u64_at(
                        ios, profile, id_off#B + (1UL + off_size)#B, len_size);
                    if (heap_obj_len == 0UL)
                        h5policy_emit_error("H5_CORRUPT_FRACTAL_HEAP_ID", "corrupt",
                                            id_off#B, object,
                                            h5policy_dense_corder_role + " index has a zero-length heap object ID");
                    else
                        {
                            h5policy_match_dense_corder_heap_id(
                                heap_obj_off, heap_obj_len, corder,
                                id_off#B, object);
                            var obj_off = h5policy_frhp_locate(
                                ios, profile, fheap_root, curr_root_rows,
                                start_size, max_direct_size, table_width,
                                off_size, checksum_dblocks, heap_obj_off,
                                file_size, object);
                            if (obj_off == 0xffffffffffffffffUL)
                                h5policy_emit_error("H5_CORRUPT_FRACTAL_HEAP_ID",
                                                    "corrupt", id_off#B, object,
                                                    h5policy_dense_corder_role + " heap ID cannot be resolved");
                            else
                                {
                                    var object_ok = h5policy_checked_addr_range(
                                        obj_off, heap_obj_len, file_size,
                                        h5policy_dense_corder_role + " heap object outside file",
                                        id_off#B, object);
                                }
                        }
                }
            i = i + 1UL;
        }
}

/* Recursively validate every node of a type-6 or type-9 B-tree.  The returned
   count includes records in this node and all descendants, allowing both child
   subtree counters and the header's total-record count to be checked. */
fun h5policy_dense_corder_node = (int ios, H5PolicyProfile profile,
                                   uint<64> node_addr, uint<64> node_depth,
                                   uint<64> nrec, uint<64> node_size,
                                   uint<64> record_size, uint<64> record_type,
                                   uint<8> has_lower, uint<64> lower,
                                   uint<8> has_upper, uint<64> upper,
                                   uint<64> fheap_root, uint<64> curr_root_rows,
                                   uint<64> start_size, uint<64> max_direct_size,
                                   uint<64> table_width, uint<64> off_size,
                                   uint<8> checksum_dblocks,
                                   uint<64> len_size, uint<64> file_size,
                                   string object) uint<64>:
{
    if (!h5policy_mark_visited_btree(node_addr))
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_CYCLE", "corrupt",
                                node_addr#B, object,
                                h5policy_dense_corder_role + " B-tree node is referenced more than once");
            return 0xffffffffffffffffUL;
        }
    if (node_depth > profile.resources.max_btree_depth)
        {
            h5policy_emit_error("H5_RESOURCE_BTREE_DEPTH", "resource",
                                node_addr#B, object,
                                h5policy_dense_corder_role + " v2 B-tree depth exceeds the selected profile limit");
            return 0xffffffffffffffffUL;
        }

    var o = global_sizeof_offsets as uint<64>;
    var nrec_bytes = h5policy_bt2_nrec_bytes(node_size, record_size);
    var sub_bytes = node_depth > 1UL
                    ? h5policy_bt2_subtree_bytes(node_size, record_size,
                                                 node_depth - 1UL)
                    : 0UL;
    var ptr_size = node_depth == 0UL ? 0UL : o + nrec_bytes + sub_bytes;
    var recs = h5policy_checked_mul_u64(
        nrec, record_size, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        h5policy_dense_corder_role + " v2 B-tree node size overflow");
    var ptrs = node_depth == 0UL ? 0UL : h5policy_checked_mul_u64(
        nrec + 1UL, ptr_size, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        h5policy_dense_corder_role + " v2 B-tree node size overflow");
    var node_need = h5policy_checked_add_u64(
        10UL, recs, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        h5policy_dense_corder_role + " v2 B-tree node size overflow");
    node_need = h5policy_checked_add_u64(
        node_need, ptrs, 0xffffffffffffffffUL,
        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt", node_addr#B, object,
        h5policy_dense_corder_role + " v2 B-tree node size overflow");
    if (node_need > node_size)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_SIZE", "corrupt",
                                node_addr#B, object,
                                h5policy_dense_corder_role + " v2 B-tree used node bytes exceed its declared node size");
            return 0xffffffffffffffffUL;
        }
    if (!h5policy_checked_addr_range(
            node_addr, node_need, file_size,
            h5policy_dense_corder_role + " v2 B-tree node outside file",
            node_addr#B, object))
        return 0xffffffffffffffffUL;

    var expected_signature = node_depth == 0UL
                             ? H5_FORMAT_BTLF_SIGNATURE
                             : H5_FORMAT_BTIN_SIGNATURE;
    if (h5policy_msg_bytes(ios, profile, node_addr#B, 4UL)
        != expected_signature)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                node_addr#B, object,
                                h5policy_dense_corder_role + " v2 B-tree node signature mismatch");
            return 0xffffffffffffffffUL;
        }
    h5policy_mark_reached(node_addr, node_depth == 0UL ? "BTLF" : "BTIN");
    var version = h5policy_msg_u64_at(ios, profile, node_addr#B + 4#B, 1UL);
    var stored_type = h5policy_msg_u64_at(ios, profile,
                                          node_addr#B + 5#B, 1UL);
    if (version != 0UL || stored_type != record_type)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_HEADER", "corrupt",
                                node_addr#B, object,
                                h5policy_dense_corder_role + " v2 B-tree node version or record type is invalid");
            return 0xffffffffffffffffUL;
        }
    h5policy_dense_verify_trailing_checksum(
        ios, profile, node_addr, node_need, file_size, object,
        h5policy_dense_corder_role + " v2 B-tree node");
    h5policy_dense_corder_records(
        ios, profile, node_addr + 6UL, nrec, record_size, record_type,
        has_lower, lower, has_upper, upper,
        fheap_root, curr_root_rows, start_size, max_direct_size,
        table_width, off_size, checksum_dblocks, len_size, file_size, object);

    var total = nrec;
    if (node_depth == 0UL)
        return total;

    var ptr_base = node_addr + 6UL + recs;
    var valid_total = 1;
    var j = 0UL;
    while (j < nrec + 1UL)
        {
            var ptr_off = ptr_base + (j * ptr_size);
            var child_raw = h5policy_msg_bytes(ios, profile, ptr_off#B, o);
            var child_nrec = h5policy_msg_u64_at(ios, profile,
                                                 ptr_off#B + o#B,
                                                 nrec_bytes);
            if (h5policy_msg_addr_is_undef(child_raw) || child_nrec == 0UL)
                {
                    h5policy_emit_error("H5_CORRUPT_V2_BTREE_CHILD_POINTER",
                                        "corrupt", ptr_off#B, object,
                                        h5policy_dense_corder_role + " internal node has an empty child pointer");
                    valid_total = 0;
                }
            else
                {
                    var child_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(child_raw));
                    if (child_addr >= file_size)
                        {
                            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                                "corrupt", ptr_off#B, object,
                                                h5policy_dense_corder_role + " v2 B-tree child address outside file");
                            valid_total = 0;
                        }
                    else
                        {
                            var child_has_lower = has_lower;
                            var child_lower = lower;
                            var child_has_upper = has_upper;
                            var child_upper = upper;
                            var key_rel = record_type == 6UL ? 0UL : 9UL;
                            var key_size = record_type == 6UL ? 8UL : 4UL;
                            if (j > 0UL)
                                {
                                    child_has_lower = 1UB;
                                    child_lower = h5policy_msg_u64_at(
                                        ios, profile,
                                        (node_addr + 6UL
                                         + ((j - 1UL) * record_size)
                                         + key_rel)#B,
                                        key_size);
                                }
                            if (j < nrec)
                                {
                                    child_has_upper = 1UB;
                                    child_upper = h5policy_msg_u64_at(
                                        ios, profile,
                                        (node_addr + 6UL
                                         + (j * record_size) + key_rel)#B,
                                        key_size);
                                }
                            var child_total = h5policy_dense_corder_node(
                                ios, profile, child_addr, node_depth - 1UL,
                                child_nrec, node_size, record_size, record_type,
                                child_has_lower, child_lower,
                                child_has_upper, child_upper,
                                fheap_root, curr_root_rows, start_size,
                                max_direct_size, table_width, off_size,
                                checksum_dblocks, len_size, file_size, object);
                            if (child_total == 0xffffffffffffffffUL)
                                valid_total = 0;
                            else
                                {
                                    if (sub_bytes != 0UL)
                                        {
                                            var declared_total = h5policy_msg_u64_at(
                                                ios, profile,
                                                ptr_off#B + (o + nrec_bytes)#B,
                                                sub_bytes);
                                            if (declared_total != child_total)
                                                h5policy_emit_error(
                                                    "H5_CORRUPT_V2_BTREE_SUBTREE_COUNT",
                                                    "corrupt", ptr_off#B, object,
                                                    h5policy_dense_corder_role + " child subtree count is inconsistent");
                                        }
                                    if (child_total > 0xffffffffffffffffUL - total)
                                        valid_total = 0;
                                    else
                                        total = total + child_total;
                                }
                        }
                }
            j = j + 1UL;
        }
    return valid_total ? total : 0xffffffffffffffffUL;
}

/* Validate the independent creation-order B-tree header and its entire node
   graph, then compare its cardinality with the name index for the same heap. */
fun h5policy_walk_dense_corder_btree = (
    int ios, H5PolicyProfile profile, uint<64> btree_addr,
    uint<64> record_type, uint<64> expected_total,
    uint<64> fheap_root, uint<64> curr_root_rows,
    uint<64> start_size, uint<64> max_direct_size,
    uint<64> table_width, uint<64> off_size,
    uint<8> checksum_dblocks, uint<64> len_size,
    uint<64> file_size, off64 loc, string object) void:
{
    /* Sole entry point for the corder subsystem -- name the role before any
       emit, so all five emitting functions agree on it. */
    h5policy_dense_corder_role = record_type == 6UL
        ? "dense link creation-order"
        : "dense attribute creation-order";
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var hdr_size = 22UL + o + el;
    if (!h5policy_checked_addr_range(
            btree_addr, hdr_size, file_size,
            h5policy_dense_corder_role + " v2 B-tree header outside file", loc, object))
        return;
    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL)
        != H5_FORMAT_BTHD_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, object,
                                h5policy_dense_corder_role + " v2 B-tree header signature mismatch");
            return;
        }
    h5policy_mark_reached(btree_addr, "BTHD");
    var version = h5policy_msg_u64_at(ios, profile, btree_addr#B + 4#B, 1UL);
    var stored_type = h5policy_msg_u64_at(ios, profile,
                                          btree_addr#B + 5#B, 1UL);
    if (version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_V2_BTREE_VERSION",
                                "corrupt", btree_addr#B, object,
                                h5policy_dense_corder_role + " v2 B-tree header has an unsupported version");
            return;
        }
    if (stored_type != record_type)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_TYPE", "corrupt",
                                btree_addr#B + 5#B, object,
                                h5policy_dense_corder_role + " B-tree has the wrong record type");
            return;
        }
    h5policy_dense_verify_trailing_checksum(
        ios, profile, btree_addr, hdr_size, file_size, object,
        h5policy_dense_corder_role + " v2 B-tree header");

    var node_size = h5policy_msg_u64_at(ios, profile,
                                         btree_addr#B + 6#B, 4UL);
    var record_size = h5policy_msg_u64_at(ios, profile,
                                           btree_addr#B + 10#B, 2UL);
    var expected_record_size = record_type == 6UL ? 15UL : 13UL;
    if (!h5policy_validate_v2_btree_geometry(node_size, record_size,
                                              btree_addr#B, object,
                                              h5policy_dense_corder_role))
        return;
    if (record_size != expected_record_size)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_LAYOUT", "corrupt",
                                btree_addr#B + 10#B, object,
                                h5policy_dense_corder_role + " B-tree record size is invalid");
            return;
        }

    var depth = h5policy_msg_u64_at(ios, profile,
                                     btree_addr#B + 12#B, 2UL);
    var root_raw = h5policy_msg_bytes(ios, profile,
                                      btree_addr#B + 16#B, o);
    var nroot = h5policy_msg_u64_at(ios, profile,
                                    btree_addr#B + (16UL + o)#B, 2UL);
    var total_nrec = h5policy_msg_u64_at(ios, profile,
                                         btree_addr#B + (18UL + o)#B, el);
    if (total_nrec != expected_total)
        h5policy_emit_error("H5_CORRUPT_DENSE_INDEX_COUNT_MISMATCH", "corrupt",
                            btree_addr#B + (18UL + o)#B, object,
                            "dense name and creation-order indexes contain different record counts");

    if (h5policy_msg_addr_is_undef(root_raw))
        {
            if (nroot != 0UL || total_nrec != 0UL)
                h5policy_emit_error("H5_CORRUPT_V2_BTREE_ROOT", "corrupt",
                                    btree_addr#B + 16#B, object,
                                    h5policy_dense_corder_role + " B-tree has records but no root");
            return;
        }
    if (nroot == 0UL || total_nrec == 0UL || total_nrec < nroot)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_ROOT", "corrupt",
                                btree_addr#B + 16#B, object,
                                h5policy_dense_corder_role + " B-tree root counts are inconsistent");
            return;
        }

    var root_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(root_raw));
    if (root_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                btree_addr#B + 16#B, object,
                                h5policy_dense_corder_role + " v2 B-tree root address outside file");
            return;
        }
    h5policy_dense_corder_values = uint<64>[]();
    h5policy_dense_corder_nonmanaged_reported = 0;
    var walked_total = h5policy_dense_corder_node(
        ios, profile, root_addr, depth, nroot, node_size, record_size,
        record_type, 0UB, 0UL, 0UB, 0UL,
        fheap_root, curr_root_rows, start_size, max_direct_size,
        table_width, off_size, checksum_dblocks, len_size, file_size, object);
    h5policy_finish_dense_corder_matches(btree_addr#B, object);
    if (walked_total != 0xffffffffffffffffUL && walked_total != total_nrec)
        h5policy_emit_error("H5_CORRUPT_V2_BTREE_TOTAL_COUNT", "corrupt",
                            btree_addr#B + (18UL + o)#B, object,
                            h5policy_dense_corder_role + " B-tree total record count is inconsistent with its node graph");
}

/* Recursively descend a dense-link name v2 B-tree node.  A node at depth 0 is a
   leaf (processed directly); a node at depth D is internal, and its child
   pointers are addr + records-in-child (+ records-in-subtree when D > 1).
   Bounded by the tree depth itself and max_btree_depth.  */
fun h5policy_dense_links_node = (int ios, H5PolicyProfile profile,
                                 uint<64> node_addr, uint<64> node_depth, uint<64> nrec,
                                 uint<64> node_size, uint<64> record_size,
                                 uint<64> fheap_root, uint<64> curr_root_rows,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> table_width, uint<64> off_size,
                                 uint<8> checksum_dblocks,
                                 uint<64> len_size, uint<64> file_size,
                                 string object) void:
{
    /* Every other B-tree walker dedups node addresses; this one must too.
       Without it, bit-flipped child pointers that make several parents share a
       child turn the tree into a DAG, and the descent re-processes shared
       subtrees -- exponential work (~capacity^depth) that a profile with no
       budget (forensic) never stops.  A valid tree never shares a node, so this
       skips nothing legitimate.  */
    if (!h5policy_mark_visited_btree(node_addr))
        return;

    if (node_depth == 0UL)
        {
            h5policy_dense_leaf_links(ios, profile, node_addr, nrec, node_size, record_size,
                                      fheap_root, curr_root_rows, start_size,
                                      max_direct_size, table_width, off_size,
                                      checksum_dblocks, len_size, file_size,
                                      object);
            return;
        }

    if (node_depth > profile.resources.max_btree_depth)
        {
            h5policy_emit_error("H5_RESOURCE_BTREE_DEPTH", "resource",
                                node_addr#B, object,
                                "dense link v2 B-tree depth exceeds the selected profile limit");
            return;
        }

    var o = global_sizeof_offsets as uint<64>;
    var nrec_bytes = h5policy_bt2_nrec_bytes(node_size, record_size);
    var sub_bytes = node_depth > 1UL
                    ? h5policy_bt2_subtree_bytes(node_size, record_size, node_depth - 1UL)
                    : 0UL;
    var ptr_size = o + nrec_bytes + sub_bytes;
    var recs = h5policy_checked_mul_u64(nrec, record_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        node_addr#B, object,
                                        "dense link v2 B-tree node size overflow");
    var ptrs = h5policy_checked_mul_u64(nrec + 1UL, ptr_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        node_addr#B, object,
                                        "dense link v2 B-tree node size overflow");
    var node_need = h5policy_checked_add_u64(6UL, recs,
                                             0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW",
                                             "corrupt", node_addr#B, object,
                                             "dense link v2 B-tree node size overflow");
    var ptrs_and_checksum = h5policy_checked_add_u64(ptrs, 4UL,
                                                     0xffffffffffffffffUL,
                                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                                     "corrupt", node_addr#B, object,
                                                     "dense link v2 B-tree node size overflow");
    node_need = h5policy_checked_add_u64(node_need, ptrs_and_checksum,
                                         0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW",
                                         "corrupt", node_addr#B, object,
                                         "dense link v2 B-tree node size overflow");
    /* Internal nodes need the same capacity check as leaves: libhdf5 places the
       trailing checksum after the records AND the child pointers, so an
       over-capacity nrec overflows the node_size allocation in
       H5B2__cache_int_verify_chksum exactly as it does the leaf variant. */
    if (node_need > node_size)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_SIZE", "corrupt",
                                node_addr#B, object,
                                "dense link v2 B-tree used node bytes exceed its declared node size");
            return;
        }
    if (!h5policy_checked_addr_range(node_addr, node_need, file_size,
                                     "dense link v2 B-tree internal node outside file",
                                     node_addr#B, object))
        return;
    if (h5policy_msg_bytes(ios, profile, node_addr#B, 4UL) != H5_FORMAT_BTIN_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", node_addr#B, object,
                                "dense link v2 B-tree internal node signature mismatch");
            return;
        }
    h5policy_mark_reached(node_addr, "BTIN");
    var node_version = h5policy_msg_u64_at(ios, profile, node_addr#B + 4#B, 1UL);
    var node_type = h5policy_msg_u64_at(ios, profile, node_addr#B + 5#B, 1UL);
    if (node_version != 0UL || node_type != 5UL)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_NODE_HEADER",
                                "corrupt", node_addr#B, object,
                                "dense link v2 B-tree internal node version or record type is invalid");
            return;
        }
    h5policy_dense_verify_trailing_checksum(ios, profile, node_addr, node_need,
                                            file_size, object,
                                            "dense link v2 B-tree internal node");

    /* The internal node's own records are real link records too. */
    h5policy_dense_link_records(ios, profile, node_addr + 6UL, nrec, record_size,
                                fheap_root, curr_root_rows, start_size, max_direct_size,
                                table_width, off_size, checksum_dblocks,
                                len_size, file_size, object);

    var ptr_base = node_addr + 6UL + recs;
    var j = 0UL;
    while (j < nrec + 1UL)
        {
            /* Child pointers follow all records.  Each pointer starts with the
               child address, then the variable-width child-record counters
               whose sizes were computed above.  */
            var ptr_off = ptr_base + (j * ptr_size);
            var child_raw = h5policy_msg_bytes(ios, profile, ptr_off#B, o);
            var child_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(child_raw));
            var child_nrec = h5policy_msg_u64_at(ios, profile, ptr_off#B + o#B, nrec_bytes);
            if (!h5policy_msg_addr_is_undef(child_raw))
                {
                    if (child_addr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                            "corrupt", ptr_off#B, object,
                                            "dense link v2 B-tree child address outside file");
                    else
                        h5policy_dense_links_node(ios, profile, child_addr,
                                                  node_depth - 1UL,
                                                  child_nrec, node_size,
                                                  record_size, fheap_root,
                                                  curr_root_rows, start_size,
                                                  max_direct_size, table_width,
                                                  off_size, checksum_dblocks,
                                                  len_size, file_size, object);
                }
            j = j + 1UL;
        }
}

/* Entry point for dense link storage.  It validates the fractal heap header,
   derives heap-ID widths, validates the name-indexed v2 B-tree header, then
   descends the B-tree records to recover link-message payloads from the heap.
   Unsupported filtered heaps or unexpected record types return 0 so the link
   info validator can emit a coverage-gap finding.  */
fun h5policy_walk_dense_links = (int ios, H5PolicyProfile profile,
                                 uint<64> fheap_addr, uint<64> btree_addr,
                                 uint<64> corder_btree_addr,
                                 off64 loc, string object) int:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);

    /* ---- fractal heap header ---- */
    if (!h5policy_checked_addr_range(fheap_addr, 10UL, file_size,
                                     "fractal heap header outside file", loc, object))
        return 1;
    if (h5policy_msg_bytes(ios, profile, fheap_addr#B, 4UL) != H5_FORMAT_FRHP_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                fheap_addr#B, object,
                                "fractal heap header signature mismatch");
            return 1;
        }
    h5policy_mark_reached(fheap_addr, "FRHP");
    var frhp_version = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 4#B, 1UL);
    if (frhp_version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FRACTAL_HEAP_VERSION",
                                "corrupt", fheap_addr#B, object,
                                "fractal heap header has an unsupported version");
            return 1;
        }

    var filter_len = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 7#B, 2UL);
    var flags = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 9#B, 1UL);
    var frhp_size = h5policy_frhp_header_size(filter_len, fheap_addr#B, object);
    if (!h5policy_dense_verify_trailing_checksum(ios, profile, fheap_addr,
                                                 frhp_size, file_size, object,
                                                 "fractal heap header"))
        return 0;
    if (filter_len != 0UL)
        {
            var pipeline_ok = h5policy_validate_filter_pipeline_payload(
                ios, profile, h5policy_frhp_filter_pipeline_off(fheap_addr),
                filter_len, object, 0, "dense link filtered heap");
            if (!pipeline_ok)
                return 1;               /* corrupt metadata was fully handled */
            /* A filtered managed heap must checksum its direct blocks.  libhdf5
               only allocates the decompressed direct-block buffer on the
               checksum-verify path (H5HF__cache_dblock_verify_chksum); with the
               flag clear that path is skipped, and H5HF__cache_dblock_deserialize
               then memcpy()s the reverse-filtered bytes into a never-allocated
               (NULL) block.  Dense link heaps are always written with this flag
               set, so a clear flag is malformed, not merely unsupported.  */
            if ((flags & 2UL) == 0UL)
                {
                    h5policy_emit_error("H5_CORRUPT_FILTERED_HEAP_NO_DBLOCK_CHECKSUM",
                                        "corrupt", fheap_addr#B, object,
                                        "filtered dense link heap disables direct-block checksums; libhdf5 dereferences an unallocated direct block");
                    return 1;
                }
            /* Known blind spot (see h5policy/README.md): the link records live
               in a filter-compressed direct block, so a fault that only shows
               up after decoding -- e.g. a decoded block whose size mismatches
               the heap's declared block size -- is invisible here and can crash
               some libhdf5 versions during dense iteration.  The coverage gap
               is a refusal, not an accept; a metadata-only oracle cannot do
               better without reversing the pipeline.  */
            return 0;                   /* valid filtered traversal is unsupported */
        }
    var checksum_dblocks = ((flags & 2UL) != 0UL) as uint<8>;

    /* The doubling table parameters below are trusted only after the heap
       header checksum succeeds.  They define how heap object offsets map to
       direct and indirect blocks during h5policy_frhp_locate.  */
    var max_man_size = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 10#B, 4UL);
    var dtable = 14UL + (10UL * el) + (2UL * o);
    var table_width = h5policy_msg_u64_at(ios, profile, fheap_addr#B + dtable#B, 2UL);
    var start_size = h5policy_msg_u64_at(ios, profile,
                                         fheap_addr#B + (dtable + 2UL)#B, el);
    var max_direct_size = h5policy_msg_u64_at(ios, profile,
                                              fheap_addr#B + (dtable + 2UL + el)#B, el);
    var max_heap_bits = h5policy_msg_u64_at(ios, profile,
                                            fheap_addr#B + (dtable + 2UL + (2UL * el))#B, 2UL);
    var root_raw = h5policy_msg_bytes(ios, profile,
                                      fheap_addr#B + (dtable + 6UL + (2UL * el))#B, o);
    var root_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(root_raw));
    var curr_root_rows = h5policy_msg_u64_at(ios, profile,
                                             fheap_addr#B + (dtable + 6UL + (2UL * el) + o)#B, 2UL);

    /* Fractal heap IDs pack a heap-object offset and object length using widths
       derived from header limits.  Clamp length width to offset width to match
       the managed-ID layout used by dense link and attribute records.  */
    var off_size = h5policy_bytes_for_bits(max_heap_bits);
    var len_size = h5policy_bytes_for_limit(max_man_size);
    if (len_size > off_size)
        len_size = off_size;
    if (h5policy_msg_addr_is_undef(root_raw) || start_size == 0UL || table_width == 0UL)
        return 0;
    if (1UL + off_size + len_size > 7UL)
        {
            h5policy_emit_error("H5_CORRUPT_FRACTAL_HEAP_ID_WIDTH", "corrupt",
                                fheap_addr#B, object,
                                "dense link heap ID widths exceed the seven-byte record field");
            return 1;
        }

    /* ---- name-indexed v2 B-tree ---- */
    var bt_hdr = 22UL + o + el;
    if (!h5policy_checked_addr_range(btree_addr, bt_hdr, file_size,
                                     "dense link v2 B-tree header outside file", loc, object))
        return 1;
    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL) != H5_FORMAT_BTHD_SIGNATURE)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, object,
                                "dense link v2 B-tree header signature mismatch");
            return 1;
        }
    h5policy_mark_reached(btree_addr, "BTHD");
    var bt_version = h5policy_msg_u64_at(ios, profile, btree_addr#B + 4#B, 1UL);
    if (bt_version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_V2_BTREE_VERSION",
                                "corrupt", btree_addr#B, object,
                                "dense link v2 B-tree header has an unsupported version");
            return 1;
        }
    h5policy_dense_verify_trailing_checksum(ios, profile, btree_addr, bt_hdr,
                                            file_size, object,
                                            "dense link v2 B-tree header");

    var record_type = h5policy_msg_u64_at(ios, profile, btree_addr#B + 5#B, 1UL);
    var node_size = h5policy_msg_u64_at(ios, profile, btree_addr#B + 6#B, 4UL);
    var record_size = h5policy_msg_u64_at(ios, profile, btree_addr#B + 10#B, 2UL);
    var depth = h5policy_msg_u64_at(ios, profile, btree_addr#B + 12#B, 2UL);
    var bt_root_raw = h5policy_msg_bytes(ios, profile, btree_addr#B + 16#B, o);
    var bt_root = hdf5_addr_to_file_u64(bytes_to_u64_le(bt_root_raw));
    var num_root = h5policy_msg_u64_at(ios, profile, btree_addr#B + (16UL + o)#B, 2UL);

    if (!h5policy_validate_v2_btree_geometry(node_size, record_size,
                                              btree_addr#B, object,
                                              "dense link"))
        return 1;

    if (record_type != 5UL || h5policy_msg_addr_is_undef(bt_root_raw))
        return 0;
    if (record_size != 11UL)
        {
            h5policy_emit_error("H5_CORRUPT_V2_BTREE_RECORD_LAYOUT", "corrupt",
                                btree_addr#B + 10#B, object,
                                "dense link name-index record size is invalid");
            return 1;
        }

    var name_total = h5policy_msg_u64_at(ios, profile,
                                         btree_addr#B + (18UL + o)#B, el);
    h5policy_reset_dense_name_index;
    if (bt_root >= file_size)
        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                            btree_addr#B + 16#B, object,
                            "dense link v2 B-tree root address outside file");
    else
        h5policy_dense_links_node(ios, profile, bt_root, depth, num_root,
                                  node_size, record_size, root_addr,
                                  curr_root_rows, start_size, max_direct_size,
                                  table_width, off_size, checksum_dblocks,
                                  len_size, file_size, object);

    if (corder_btree_addr != 0xffffffffffffffffUL)
        h5policy_walk_dense_corder_btree(
            ios, profile, corder_btree_addr, 6UL, name_total,
            root_addr, curr_root_rows, start_size, max_direct_size,
            table_width, off_size, checksum_dblocks, len_size,
            file_size, loc, object);
    return 1;
}

/* Link-info messages are the switch from compact link messages to dense link
   storage.  h5policy validates the address fields and tries the dense walker;
   if the storage layout is outside the supported subset, the file is marked as
   an unsupported coverage gap instead of silently accepting unseen links.  */
fun h5policy_validate_linfo_payload = (int ios,
                                       H5PolicyProfile profile,
                                       offset<uint<64>,B> payload_off,
                                       uint<64> msg_size,
                                       string object) void:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                   "H5_CORRUPT_LINK_INFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "link-info message is too small"))
        return;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
    var flags = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var cur = 2UL;

    /* Link-info flags optionally include maximum creation order and a second,
       independently validated creation-order index address. */
    if (version != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_LINK_INFO_VERSION",
                                "corrupt", payload_off, object,
                                "unsupported link-info message version");
            return;
        }

    if ((flags & ~3UL) != 0UL)
        h5policy_emit_error("H5_CORRUPT_LINK_INFO_FLAGS",
                            "corrupt", payload_off + 1#B, object,
                            "link-info message has invalid flag bits");
    if ((flags & 2UL) != 0UL && (flags & 1UL) == 0UL)
        h5policy_emit_error("H5_CORRUPT_LINK_INFO_FLAGS",
                            "corrupt", payload_off + 1#B, object,
                            "link-info creation-order index requires creation-order tracking");

    if ((flags & 1UL) != 0UL)
        {
            if (!h5policy_payload_range_ok(msg_size, cur, 8UL,
                                           "H5_CORRUPT_LINK_INFO_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           "link-info max creation order is missing"))
                return;

            var max_corder = h5policy_msg_u64_at(ios, profile,
                                                 payload_off + cur#B, 8UL);
            if ((max_corder & 0x8000000000000000UL) != 0UL)
                h5policy_emit_error("H5_CORRUPT_LINK_INFO_NEGATIVE_MAX_CORDER",
                                    "corrupt", payload_off + cur#B, object,
                                    "link-info max creation order is negative");

            cur = cur + 8UL;
        }

    var min_size = cur + (2UL * (global_sizeof_offsets as uint<64>));
    if ((flags & 2UL) != 0UL)
        min_size = min_size + (global_sizeof_offsets as uint<64>);

    /* Dense link storage needs a paired fractal heap/name index and, when the
       indexed flag is set, a third address for the creation-order B-tree. */
    if (!h5policy_payload_range_ok(msg_size, 0UL, min_size,
                                   "H5_CORRUPT_LINK_INFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "link-info addresses overrun the message"))
        return;

    var fheap_raw = h5policy_msg_bytes(ios, profile,
                                       payload_off + cur#B,
                                       global_sizeof_offsets as uint<64>);
    var fheap_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(fheap_raw));
    cur = cur + (global_sizeof_offsets as uint<64>);

    var name_btree_raw = h5policy_msg_bytes(ios, profile,
                                            payload_off + cur#B,
                                            global_sizeof_offsets as uint<64>);
    var name_btree_addr = hdf5_addr_to_file_u64(bytes_to_u64_le(name_btree_raw));
    cur = cur + (global_sizeof_offsets as uint<64>);

    var corder_btree_addr = 0xffffffffffffffffUL;
    var corder_is_undef = 1;
    if ((flags & 2UL) != 0UL)
        {
            var corder_btree_raw = h5policy_msg_bytes(
                ios, profile, payload_off + cur#B,
                global_sizeof_offsets as uint<64>);
            corder_is_undef = h5policy_msg_addr_is_undef(corder_btree_raw);
            if (!corder_is_undef)
                corder_btree_addr = hdf5_addr_to_file_u64(
                    bytes_to_u64_le(corder_btree_raw));
            cur = cur + (global_sizeof_offsets as uint<64>);
        }

    /* Version-1 object headers include alignment padding in the advertised
       message size; version-2 messages must end at the address fields. */
    if (!h5policy_message_size_matches(msg_size, cur))
        h5policy_emit_error("H5_CORRUPT_LINK_INFO_TRAILING_BYTES",
                            "corrupt", payload_off + cur#B, object,
                            "link-info message has trailing bytes");

    var fheap_is_undef = h5policy_msg_addr_is_undef(fheap_raw);
    var name_is_undef = h5policy_msg_addr_is_undef(name_btree_raw);
    if (fheap_is_undef != name_is_undef)
        {
            h5policy_emit_error("H5_CORRUPT_LINK_INFO_ADDRESS_PAIR", "corrupt",
                                payload_off, object,
                                "link-info fractal-heap and name-index addresses are not both defined or both undefined");
            return;
        }
    if ((flags & 2UL) != 0UL && !fheap_is_undef && corder_is_undef)
        {
            h5policy_emit_error("H5_CORRUPT_LINK_INFO_CORDER_ADDRESS", "corrupt",
                                payload_off, object,
                                "dense link-info message has an undefined creation-order index address");
            return;
        }
    if (fheap_is_undef)
        {
            if ((flags & 2UL) != 0UL && !corder_is_undef)
                h5policy_emit_error("H5_CORRUPT_LINK_INFO_CORDER_ADDRESS", "corrupt",
                                    payload_off, object,
                                    "link-info creation-order index is defined without dense storage");
            return;
        }

    var handled = 0;
    if (!fheap_is_undef && !name_is_undef)
        /* The dense walker returns 0 for unsupported-but-recognized layouts
           such as filtered heaps.  That lets this wrapper emit one clean
           coverage finding at the link-info message.  */
        handled = h5policy_walk_dense_links(ios, profile, fheap_addr,
                                            name_btree_addr, corder_btree_addr,
                                            payload_off, object);

    if (!handled)
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                            "unsupported", payload_off, object,
                            "dense link storage uses an unsupported fractal-heap/B-tree layout");
}

/* ---- Old-style group traversal (symbol table -> v1 B-tree -> SNOD -> heap) --
   A pre-1.8 group stores its members through a symbol-table message giving a
   v1 B-tree (node type 0) and a local heap.  The B-tree indexes symbol-table
   nodes (SNOD); each entry names a child (via a heap offset) and points to its
   object header.  Everything below is decoded from raw bytes with bounds
   checks, a visited set (cycle/shared-node guard), the max_btree_depth budget,
   and metadata accounting -- and it enqueues the child object headers into the
   same bounded BFS the link-message path uses.  */
var H5POLICY_MAX_HEAP_NAME = 1024UL;

/* Data-segment size of the local heap currently being walked; a link-name
   offset must fall inside it.  Set by h5policy_local_heap_data_addr (the whole
   group walk for one heap runs synchronously, so a global is sufficient).  */
var h5policy_heap_data_seg_size = 0UL;

/* h5_walk.pk - Bounded object-header walking and message checks.  */

type H5WalkContext = struct
{
    uint<64> metadata_seen;
    uint<64> object_count;
    uint<64> attribute_count;
    uint<64> object_header_chunk_count;
    uint<64> btree_depth;
    uint<64> link_depth;
    uint<64> dtype_depth;
    uint<64> max_rank_seen;
    uint<64> dataset_element_count;
    uint<64> datatype_size;
    uint<64> logical_dataset_bytes;
    uint<64> max_logical_dataset_bytes_seen;
    uint<64> chunk_index_count;
    uint<8> has_dataspace;
    uint<8> has_datatype;
};

var h5policy_visited_ohdrs = uint<64>[]();
var h5policy_visited_conts = uint<64>[]();
var h5policy_visited_btrees = uint<64>[]();

var h5policy_pending_ohdrs = uint<64>[]();
var h5policy_pending_depths = uint<64>[]();
var h5policy_pending_paths = string[]();
var h5policy_pending_index = 0UL;

var h5policy_current_object_depth = 0UL;
var h5policy_dense_handled = 0;

fun h5policy_reset_traversal_state = void:
{
    h5policy_visited_ohdrs = uint<64>[]();
    h5policy_visited_conts = uint<64>[]();
    h5policy_visited_btrees = uint<64>[]();
    h5policy_pending_ohdrs = uint<64>[]();
    h5policy_pending_depths = uint<64>[]();
    h5policy_pending_paths = string[]();
    h5policy_pending_index = 0UL;
    h5policy_current_object_depth = 0UL;
}

fun h5policy_seen_u64 = (uint<64>[] values, uint<64> value) int:
{
    var i = 0UL;

    while (i < values'length)
        {
            if (values[i] == value)
                return 1;
            i = i + 1UL;
        }

    return 0;
}

fun h5policy_mark_visited_ohdr = (uint<64> addr) int:
{
    if (h5policy_seen_u64(h5policy_visited_ohdrs, addr))
        return 0;

    h5policy_visited_ohdrs += [addr];
    return 1;
}

fun h5policy_mark_visited_cont = (uint<64> addr) int:
{
    if (h5policy_seen_u64(h5policy_visited_conts, addr))
        return 0;

    h5policy_visited_conts += [addr];
    return 1;
}

fun h5policy_mark_visited_btree = (uint<64> addr) int:
{
    if (h5policy_seen_u64(h5policy_visited_btrees, addr))
        return 0;

    h5policy_visited_btrees += [addr];
    return 1;
}

fun h5policy_join_path = (string parent, string name) string:
{
    if (parent == "/")
        return "/" + name;
    return parent + "/" + name;
}

fun h5policy_enqueue_ohdr = (H5PolicyLimits profile,
                             uint<64> addr,
                             uint<64> depth,
                             string path,
                             off64 loc,
                             string object) void:
{
    if (depth > profile.max_link_traversal_depth)
        {
            h5policy_emit_error("H5_CORRUPT_LINK_TRAVERSAL_DEPTH_EXCEEDED",
                                "corrupt", loc, object,
                                "link traversal depth exceeds the selected profile limit");
            return;
        }

    if (h5policy_seen_u64(h5policy_visited_ohdrs, addr)
        || h5policy_seen_u64(h5policy_pending_ohdrs, addr))
        return;

    h5policy_pending_ohdrs += [addr];
    h5policy_pending_depths += [depth];
    h5policy_pending_paths += [path];
}

fun h5policy_new_walk_context = H5WalkContext:
{
    return H5WalkContext
    {
        metadata_seen = 0UL,
        object_count = 0UL,
        attribute_count = 0UL,
        object_header_chunk_count = 0UL,
        btree_depth = 0UL,
        link_depth = 0UL,
        dtype_depth = 0UL,
        max_rank_seen = 0UL,
        dataset_element_count = 0UL,
        datatype_size = 0UL,
        logical_dataset_bytes = 0UL,
        max_logical_dataset_bytes_seen = 0UL,
        chunk_index_count = 0UL,
        has_dataspace = 0UB,
        has_datatype = 0UB
    };
}

fun h5policy_count_object = (H5WalkContext ctx,
                             H5PolicyLimits profile,
                             off64 loc,
                             string object) H5WalkContext:
{
    var next = h5policy_checked_add_u64(ctx.object_count, 1UL,
                                        profile.max_object_count,
                                        "H5_RESOURCE_OBJECT_COUNT",
                                        "resource",
                                        loc, object,
                                        "object count budget exceeded");
    ctx.object_count = next;
    return ctx;
}

fun h5policy_account_metadata = (H5WalkContext ctx,
                                 H5PolicyLimits profile,
                                 uint<64> bytes,
                                 off64 loc,
                                 string object) H5WalkContext:
{
    var next = h5policy_checked_add_u64(ctx.metadata_seen, bytes,
                                        profile.max_metadata_bytes,
                                        "H5_RESOURCE_METADATA_BYTES",
                                        "resource",
                                        loc, object,
                                        "metadata byte budget exceeded");
    ctx.metadata_seen = next;
    return ctx;
}

fun h5policy_count_root_object = (H5WalkContext ctx,
                                  H5PolicyLimits profile,
                                  off64 loc) H5WalkContext:
{
    return h5policy_count_object(ctx, profile, loc, "/");
}

fun h5policy_map_msg_prefix = (int ios, H5PolicyLimits profile,
                               offset<uint<64>,B> off) msg_prefix:
{
    if (h5policy_nonstrict != 0)
        return msg_prefix @! ios : off;
    return msg_prefix @ ios : off;
}

fun h5policy_map_cont = (int ios, H5PolicyLimits profile,
                         offset<uint<64>,B> off) H5O_msg_cont:
{
    if (h5policy_nonstrict != 0)
        return H5O_msg_cont @! ios : off;
    return H5O_msg_cont @ ios : off;
}

fun h5policy_msg_bytes = (int ios, H5PolicyLimits profile,
                          offset<uint<64>,B> off,
                          uint<64> size) byte[]:
{
    if (h5policy_nonstrict != 0)
        return byte[size] @! ios : off;
    return byte[size] @ ios : off;
}

fun h5policy_msg_u64_at = (int ios, H5PolicyLimits profile,
                           offset<uint<64>,B> off,
                           uint<64> size) uint<64>:
{
    return bytes_to_u64_le(h5policy_msg_bytes(ios, profile, off, size));
}

fun h5policy_payload_range_ok = (uint<64> msg_size,
                                 uint<64> rel,
                                 uint<64> size,
                                 string code,
                                 off64 loc,
                                 string object,
                                 string message) int:
{
    if (rel > msg_size || size > msg_size - rel)
        {
            h5policy_emit_error(code, "corrupt", loc, object, message);
            return 0;
        }

    return 1;
}

fun h5policy_msg_addr_is_undef = (byte[] raw) int:
{
    var n = 0UL;

    while (n < raw'length)
        {
            if (raw[n] != 0xffUB) return 0;
            n = n + 1UL;
        }

    return 1;
}

fun h5policy_string_from_payload = (int ios, H5PolicyLimits profile,
                                    offset<uint<64>,B> off,
                                    uint<64> size) string:
{
    var name = "";
    var i = 0UL;

    while (i < size)
        {
            var b = h5policy_msg_u64_at(ios, profile, off + i#B, 1UL) as uint<8>;
            if (b == 0UB)
                return name;
            name = name + ((b as char) as string);
            i = i + 1UL;
        }

    return name;
}

fun h5policy_core_filter = (uint<64> filter_id) int:
{
    return filter_id >= 1UL && filter_id <= 6UL;
}

fun h5policy_note_btree_addr = (H5PolicyLimits profile,
                                uint<64> addr,
                                off64 loc,
                                string object,
                                string message) void:
{
    if (addr == 0UL || addr == 0xffffffffffffffffUL)
        return;

    if (h5policy_mark_visited_btree(addr))
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                            "unsupported", loc, object, message);
}

fun h5policy_note_chunk_index_addr = (H5WalkContext ctx,
                                      H5PolicyLimits profile,
                                      uint<64> addr,
                                      off64 loc,
                                      string object) H5WalkContext:
{
    if (addr == 0UL || addr == 0xffffffffffffffffUL)
        return ctx;

    ctx.chunk_index_count =
        h5policy_checked_add_u64(ctx.chunk_index_count, 1UL,
                                 profile.max_chunk_count,
                                 "H5_RESOURCE_CHUNK_COUNT",
                                 "resource",
                                 loc, object,
                                 "chunk index budget exceeded");

    h5policy_note_btree_addr(profile, addr, loc, object,
                             "chunk index traversal is bounded but not decoded yet");
    return ctx;
}

fun h5policy_update_logical_dataset_size = (H5WalkContext ctx,
                                            H5PolicyLimits profile,
                                            off64 loc,
                                            string object) H5WalkContext:
{
    if (ctx.has_dataspace != 0UB && ctx.has_datatype != 0UB)
        {
            ctx.logical_dataset_bytes =
                h5policy_checked_mul_u64(ctx.dataset_element_count,
                                         ctx.datatype_size,
                                         profile.max_logical_dataset_bytes,
                                         "H5_RESOURCE_LOGICAL_DATASET_BYTES",
                                         "resource",
                                         loc, object,
                                         "logical dataset byte budget exceeded");
            if (ctx.logical_dataset_bytes > ctx.max_logical_dataset_bytes_seen)
                ctx.max_logical_dataset_bytes_seen = ctx.logical_dataset_bytes;
        }

    return ctx;
}

fun h5policy_validate_dataspace_payload = (int ios,
                                           H5PolicyLimits profile,
                                           H5WalkContext ctx,
                                           offset<uint<64>,B> payload_off,
                                           uint<64> msg_size,
                                           string object) H5WalkContext:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 1UL,
                                   "H5_CORRUPT_DATASPACE_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "dataspace message is too small"))
        return ctx;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL) as uint<8>;
    var ndims = 0UL;
    var dim_rel = 0UL;
    var element_count = 1UL;

    if (version == 1UB)
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 8UL,
                                           "H5_CORRUPT_DATASPACE_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "dataspace v1 message is too small"))
                return ctx;

            ndims = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
            dim_rel = 8UL;
        }
    else if (version == 2UB)
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 4UL,
                                           "H5_CORRUPT_DATASPACE_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "dataspace v2 message is too small"))
                return ctx;

            ndims = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
            var space_type = h5policy_msg_u64_at(ios, profile,
                                                 payload_off + 3#B, 1UL);
            if (space_type > 2UL)
                h5policy_emit_error("H5_CORRUPT_DATASPACE_INVALID_CLASS",
                                    "corrupt", payload_off, object,
                                    "dataspace v2 has an invalid space type");

            if (space_type == 0UL)
                ndims = 0UL;
            if (space_type == 2UL)
                element_count = 0UL;

            dim_rel = 4UL;
        }
    else
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_DATASPACE_VERSION",
                                "corrupt", payload_off, object,
                                "unsupported dataspace message version");
            return ctx;
        }

    if (ndims > ctx.max_rank_seen)
        ctx.max_rank_seen = ndims;

    if (ndims > profile.max_rank)
        h5policy_emit_error("H5_RESOURCE_DATASPACE_RANK",
                            "resource", payload_off, object,
                            "dataspace rank exceeds the selected profile limit");

    var dims_bytes = h5policy_checked_mul_u64(ndims,
                                             global_sizeof_lengths as uint<64>,
                                             0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW",
                                             "corrupt",
                                             payload_off, object,
                                             "dataspace dimension byte count overflow");
    if (!h5policy_payload_range_ok(msg_size, dim_rel, dims_bytes,
                                   "H5_CORRUPT_DATASPACE_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "dataspace dimensions overrun the message"))
        return ctx;

    if (element_count != 0UL)
        {
            var i = 0UL;
            while (i < ndims)
                {
                    var dim = h5policy_msg_u64_at(ios, profile,
                                                  payload_off
                                                  + (dim_rel
                                                     + i * (global_sizeof_lengths as uint<64>))#B,
                                                  global_sizeof_lengths as uint<64>);
                    element_count =
                        h5policy_checked_mul_u64(element_count, dim,
                                                 profile.max_logical_dataset_bytes,
                                                 "H5_RESOURCE_LOGICAL_DATASET_BYTES",
                                                 "resource",
                                                 payload_off, object,
                                                 "dataspace element count exceeds the selected profile limit");
                    i = i + 1UL;
                }
        }

    ctx.has_dataspace = 1UB;
    ctx.dataset_element_count = element_count;
    return h5policy_update_logical_dataset_size(ctx, profile,
                                                payload_off, object);
}

fun h5policy_round_up_8 = (uint<64> n) uint<64>:
{
    var r = n % 8UL;
    if (r == 0UL)
        return n;
    return n + (8UL - r);
}

/* Width of the "byte offset of member" field in a version-3 compound, keyed
   to the compound's own element size (mirrors the on-disk encoding).  */
fun h5policy_v3_memb_off_size = (uint<64> elm_size) uint<64>:
{
    if (elm_size < 256UL) return 1UL;
    if (elm_size < 65536UL) return 2UL;
    if (elm_size < 4294967296UL) return 4UL;
    return 8UL;
}

/* NUL-terminated name length, but never scanning past the datatype blob.
   Returns max if no terminator is found in the window (the caller then fails
   the room check rather than reading unbounded attacker-controlled bytes).  */
fun h5policy_dtype_name_len = (int ios, H5PolicyLimits profile,
                               offset<uint<64>,B> off, uint<64> max) uint<64>:
{
    var i = 0UL;

    while (i < max)
        {
            var b = h5policy_msg_u64_at(ios, profile, off + i#B, 1UL) as uint<8>;
            if (b == 0UB)
                return i;
            i = i + 1UL;
        }

    return max;
}

fun h5policy_dtype_room = (uint<64> need, uint<64> avail, uint<64> used,
                           off64 loc, string object) int:
{
    if (need > avail - used)
        {
            h5policy_emit_error("H5_CORRUPT_DATATYPE_MESSAGE_TOO_SMALL",
                                "corrupt", loc, object,
                                "datatype properties overrun the blob");
            return 0;
        }

    return 1;
}

/* Bounded, depth-guarded recursive datatype validator.  Returns the total
   consumed size (8-byte header + properties) of the blob at blob_off, or 0 on
   a hard error (after emitting a finding).  `avail` is the number of bytes the
   blob may occupy; every field read and every recursion stays inside it, and
   nesting is capped by profile.max_datatype_recursion_depth so a maliciously
   deep type cannot exhaust the stack (the audit's top datatype CVE class).  */
fun h5policy_dtype_check = (int ios, H5PolicyLimits profile,
                            offset<uint<64>,B> blob_off,
                            uint<64> avail, string object,
                            uint<64> depth) uint<64>:
{
    if (depth > profile.max_datatype_recursion_depth)
        {
            h5policy_emit_error("H5_CORRUPT_DATATYPE_RECURSION_LIMIT",
                                "corrupt", blob_off, object,
                                "datatype nesting exceeds the selected profile limit");
            return 0UL;
        }

    if (avail < 8UL)
        {
            h5policy_emit_error("H5_CORRUPT_DATATYPE_MESSAGE_TOO_SMALL",
                                "corrupt", blob_off, object,
                                "datatype blob is too small for its header");
            return 0UL;
        }

    var flags = h5policy_msg_u64_at(ios, profile, blob_off, 4UL);
    var elm_size = h5policy_msg_u64_at(ios, profile, blob_off + 4#B, 4UL);
    var version = (flags .>> 4) & 0xfUL;
    var ctype = flags & 0xfUL;
    var used = 8UL;

    /* Versions 1-4 are all in the wild; HDF5 1.14 with the latest libver
       writes version-4 compound/enum/array types.  Versions 3 and 4 share the
       "modern" member encoding (variable-width offsets, unpadded names).  */
    if (version == 0UL || version > 4UL)
        h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_DATATYPE_VERSION",
                            "corrupt", blob_off, object,
                            "unsupported datatype message version");

    if (ctype > 10UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNKNOWN_DATATYPE_CLASS",
                                "corrupt", blob_off, object,
                                "unknown datatype class");
            return 0UL;
        }

    if (elm_size == 0UL)
        h5policy_emit_error("H5_CORRUPT_DATATYPE_ZERO_SIZE",
                            "corrupt", blob_off, object,
                            "datatype storage size is zero");

    /* Non-recursive classes have fixed-size property blocks. */
    var simple = 1;
    var props = 0UL;
    if (ctype == 0UL || ctype == 4UL)
        props = 4UL;                             /* fixed-point / bit field */
    else if (ctype == 1UL)
        props = 12UL;                            /* floating-point */
    else if (ctype == 2UL)
        props = 2UL;                             /* time */
    else if (ctype == 3UL || ctype == 7UL)
        props = 0UL;                             /* string / reference */
    else if (ctype == 5UL)
        props = (flags .>> 8) & 0xffUL;          /* opaque tag */
    else
        simple = 0;

    if (simple)
        {
            if (!h5policy_dtype_room(props, avail, used, blob_off, object))
                return 0UL;

            /* Numeric types (fixed-point, floating-point, bit field) begin their
               properties with bit offset then bit precision.  Reject a size that
               vastly exceeds the precision -- an "unusually large number of
               unused bits", which libhdf5 treats as a corrupt/crafted file
               (H5T_is_numeric_with_unusual_unused_bits).  */
            if (ctype == 0UL || ctype == 1UL || ctype == 4UL)
                {
                    var bit_offset = h5policy_msg_u64_at(ios, profile,
                                                         blob_off + 8#B, 2UL);
                    var bit_prec = h5policy_msg_u64_at(ios, profile,
                                                       blob_off + 10#B, 2UL);
                    if (elm_size > 1UL && bit_prec < (elm_size * 8UL)
                        && (elm_size * 8UL) > (2UL * (bit_prec + bit_offset)))
                        h5policy_emit_error("H5_CORRUPT_DATATYPE_UNUSED_BITS",
                                            "corrupt", blob_off, object,
                                            "numeric datatype has an unusually large number of unused bits");
                }

            return used + props;
        }

    /* ---- class 9: Variable-Length (single inline base type) ---- */
    if (ctype == 9UL)
        {
            var child = h5policy_dtype_check(ios, profile, blob_off + used#B,
                                             avail - used, object, depth + 1UL);
            if (child == 0UL)
                return 0UL;
            return used + child;
        }

    /* ---- class 10: Array (rank + dims [+ v2 reserved/perm] + base type) ---- */
    if (ctype == 10UL)
        {
            if (!h5policy_dtype_room(1UL, avail, used, blob_off, object))
                return 0UL;
            var rank = h5policy_msg_u64_at(ios, profile, blob_off + used#B, 1UL);
            used = used + 1UL;

            if (version == 2UL)
                {
                    if (!h5policy_dtype_room(3UL, avail, used, blob_off, object))
                        return 0UL;
                    used = used + 3UL;           /* reserved */
                }

            var dims = h5policy_checked_mul_u64(rank, 4UL, 0xffffffffffffffffUL,
                                                "H5_CORRUPT_LENGTH_OVERFLOW",
                                                "corrupt", blob_off, object,
                                                "array dimension byte count overflow");
            if (!h5policy_dtype_room(dims, avail, used, blob_off, object))
                return 0UL;
            used = used + dims;

            if (version == 2UL)
                {
                    if (!h5policy_dtype_room(dims, avail, used, blob_off, object))
                        return 0UL;
                    used = used + dims;          /* permutation indices */
                }

            var child = h5policy_dtype_check(ios, profile, blob_off + used#B,
                                             avail - used, object, depth + 1UL);
            if (child == 0UL)
                return 0UL;
            return used + child;
        }

    /* ---- class 8: Enum (base type, then member names and values) ---- */
    if (ctype == 8UL)
        {
            var num = (flags .>> 8) & 0xffffUL;

            if (!h5policy_dtype_room(8UL, avail, used, blob_off, object))
                return 0UL;
            var base_elm = h5policy_msg_u64_at(ios, profile,
                                               blob_off + used#B + 4#B, 4UL);
            var child = h5policy_dtype_check(ios, profile, blob_off + used#B,
                                             avail - used, object, depth + 1UL);
            if (child == 0UL)
                return 0UL;
            used = used + child;

            var m = 0UL;
            while (m < num)
                {
                    var nlen = h5policy_dtype_name_len(ios, profile,
                                                       blob_off + used#B,
                                                       avail - used);
                    var adv = version >= 3UL
                              ? (nlen + 1UL)
                              : h5policy_round_up_8(nlen + 1UL);
                    if (!h5policy_dtype_room(adv, avail, used, blob_off, object))
                        return 0UL;
                    used = used + adv;
                    m = m + 1UL;
                }

            var vals = h5policy_checked_mul_u64(num, base_elm,
                                                0xffffffffffffffffUL,
                                                "H5_CORRUPT_LENGTH_OVERFLOW",
                                                "corrupt", blob_off, object,
                                                "enum value byte count overflow");
            if (!h5policy_dtype_room(vals, avail, used, blob_off, object))
                return 0UL;
            used = used + vals;
            return used;
        }

    /* ---- class 6: Compound (per-member name, offset, and nested type) ---- */
    if (ctype == 6UL)
        {
            var num = (flags .>> 8) & 0xffffUL;
            var m = 0UL;

            if (num == 0UL)
                h5policy_emit_error("H5_CORRUPT_DATATYPE_ZERO_MEMBERS",
                                    "corrupt", blob_off, object,
                                    "compound datatype has zero members");

            while (m < num)
                {
                    var nlen = h5policy_dtype_name_len(ios, profile,
                                                       blob_off + used#B,
                                                       avail - used);
                    var adv = (version == 1UL || version == 2UL)
                              ? h5policy_round_up_8(nlen + 1UL)
                              : (nlen + 1UL);
                    if (!h5policy_dtype_room(adv, avail, used, blob_off, object))
                        return 0UL;
                    used = used + adv;

                    var off_w = version >= 3UL
                                ? h5policy_v3_memb_off_size(elm_size)
                                : 4UL;
                    if (!h5policy_dtype_room(off_w, avail, used, blob_off, object))
                        return 0UL;
                    used = used + off_w;

                    if (version == 1UL)
                        {
                            /* ndim(1) + res(3) + perm(4) + res(4) + dims(16) */
                            if (!h5policy_dtype_room(28UL, avail, used,
                                                     blob_off, object))
                                return 0UL;
                            used = used + 28UL;
                        }

                    var child = h5policy_dtype_check(ios, profile,
                                                     blob_off + used#B,
                                                     avail - used, object,
                                                     depth + 1UL);
                    if (child == 0UL)
                        return 0UL;
                    used = used + child;
                    m = m + 1UL;
                }

            return used;
        }

    return used;
}

fun h5policy_validate_dtype_payload = (int ios,
                                       H5PolicyLimits profile,
                                       H5WalkContext ctx,
                                       offset<uint<64>,B> payload_off,
                                       uint<64> msg_size,
                                       string object) H5WalkContext:
{
    var consumed = h5policy_dtype_check(ios, profile, payload_off,
                                        msg_size, object, 0UL);
    if (consumed == 0UL)
        return ctx;

    var elm_size = h5policy_msg_u64_at(ios, profile, payload_off + 4#B, 4UL);

    if (profile.max_single_allocation_bytes != 0UL
        && elm_size > profile.max_single_allocation_bytes)
        h5policy_emit_error("H5_RESOURCE_SINGLE_ALLOCATION_BYTES",
                            "resource", payload_off, object,
                            "datatype storage size exceeds the selected profile limit");

    ctx.has_datatype = 1UB;
    ctx.datatype_size = elm_size;
    return h5policy_update_logical_dataset_size(ctx, profile,
                                                payload_off, object);
}

var H5POLICY_TREE_SIG = [0x54UB, 0x52UB, 0x45UB, 0x45UB];   /* "TREE" */

/* Walk a v1 (type-1, raw-data-chunk) B-tree chunk index: count chunks against
   max_chunk_count, verify each chunk's address+size lies in the file, and bound
   recursion by max_btree_depth and a visited set.  `ndims` is the chunk
   dimensionality from the layout message (dataset rank + 1); a type-1 key is
   chunk_size(4) + filter_mask(4) + ndims 8-byte offsets.  This validates the
   index structure under budget; it does not read chunk contents.  */
fun h5policy_walk_chunk_btree = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                 uint<64> btree_addr, uint<64> ndims,
                                 string object, uint<64> btree_depth) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var file_size = h5policy_ceiling(ios);

    if (btree_depth > profile.max_btree_depth)
        {
            h5policy_emit_error("H5_CORRUPT_BTREE_DEPTH_EXCEEDED", "corrupt",
                                btree_addr#B, object,
                                "chunk B-tree depth exceeds the selected profile limit");
            return ctx;
        }

    if (!h5policy_mark_visited_btree(btree_addr))
        return ctx;

    var hdr = 8UL + (2UL * o);
    if (!h5policy_checked_addr_range(btree_addr, hdr, file_size,
                                     "chunk B-tree node outside file",
                                     btree_addr#B, object))
        return ctx;

    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL) != H5POLICY_TREE_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, object,
                                "chunk B-tree signature mismatch");
            return ctx;
        }

    var node_type = h5policy_msg_u64_at(ios, profile, btree_addr#B + 4#B, 1UL);
    if (node_type != 1UL)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, object,
                                "expected a raw-data-chunk (type 1) v1 B-tree node");
            return ctx;
        }

    var node_level = h5policy_msg_u64_at(ios, profile, btree_addr#B + 5#B, 1UL);
    var entries_used = h5policy_msg_u64_at(ios, profile, btree_addr#B + 6#B, 2UL);
    var offs_bytes = h5policy_checked_mul_u64(ndims, 8UL, 0xffffffffffffffffUL,
                                              "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                              btree_addr#B, object,
                                              "chunk B-tree key size overflow");
    var key_size = h5policy_checked_add_u64(8UL, offs_bytes, 0xffffffffffffffffUL,
                                            "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                            btree_addr#B, object,
                                            "chunk B-tree key size overflow");
    var pair = key_size + o;
    var body = h5policy_checked_mul_u64(entries_used, pair, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        btree_addr#B, object,
                                        "chunk B-tree node size overflow");
    body = h5policy_checked_add_u64(body, key_size, 0xffffffffffffffffUL,
                                    "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                    btree_addr#B, object,
                                    "chunk B-tree node size overflow");
    var total = h5policy_checked_add_u64(hdr, body, 0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                         btree_addr#B, object,
                                         "chunk B-tree node size overflow");
    if (!h5policy_checked_addr_range(btree_addr, total, file_size,
                                     "chunk B-tree node body outside file",
                                     btree_addr#B, object))
        return ctx;

    ctx = h5policy_account_metadata(ctx, profile, total, btree_addr#B, object);

    var i = 0UL;
    while (i < entries_used)
        {
            /* Bounded traversal: stop once the chunk budget is reached. */
            if (profile.max_chunk_count != 0xffffffffffffffffUL
                && ctx.chunk_index_count >= profile.max_chunk_count)
                return ctx;

            var key_off = btree_addr + hdr + (i * pair);
            var child_raw = h5policy_msg_bytes(ios, profile,
                                               (key_off + key_size)#B, o);
            var child_addr = bytes_to_u64_le(child_raw);

            if (node_level > 0UL)
                {
                    if (!h5policy_msg_addr_is_undef(child_raw))
                        ctx = h5policy_walk_chunk_btree(ios, profile, ctx,
                                                        child_addr, ndims,
                                                        object, btree_depth + 1UL);
                }
            else
                {
                    /* Leaf: child pointer is the raw data chunk; key = its size. */
                    var chunk_size = h5policy_msg_u64_at(ios, profile, key_off#B, 4UL);
                    ctx.chunk_index_count =
                        h5policy_checked_add_u64(ctx.chunk_index_count, 1UL,
                                                 profile.max_chunk_count,
                                                 "H5_RESOURCE_CHUNK_COUNT", "resource",
                                                 btree_addr#B, object,
                                                 "chunk count exceeds the selected profile limit");
                    if (!h5policy_msg_addr_is_undef(child_raw))
                        {
                            var ok = h5policy_checked_addr_range(child_addr, chunk_size,
                                                                 file_size,
                                                                 "chunk data outside file",
                                                                 key_off#B, object);
                        }
                }
            i = i + 1UL;
        }

    return ctx;
}

var H5POLICY_BTHD_SIG = [0x42UB, 0x54UB, 0x48UB, 0x44UB];   /* "BTHD" */
var H5POLICY_BTLF_SIG = [0x42UB, 0x54UB, 0x4cUB, 0x46UB];   /* "BTLF" */
var H5POLICY_BTIN_SIG = [0x42UB, 0x54UB, 0x49UB, 0x4eUB];   /* "BTIN" */

/* Validate a version-2 B-tree chunk index (v4 layout index type 5).  The
   checksummed header gives the total record count (= chunk count) directly, so
   we enforce it against max_chunk_count without walking, validate the header
   and root node, and -- when the root is a leaf -- bounds-check each chunk
   address.  Deep trees are validated at the root under the count budget (the
   audit's "validate the index root under a budget"); the variable-width
   internal-node child pointers are not decoded.  */
fun h5policy_walk_v2_btree_chunks = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                     uint<64> hdr_addr, off64 loc,
                                     string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    var hdr_size = 22UL + o + el;

    if (!h5policy_checked_addr_range(hdr_addr, hdr_size, file_size,
                                     "v2 B-tree header outside file", loc, object))
        return ctx;

    if (h5policy_msg_bytes(ios, profile, hdr_addr#B, 4UL) != H5POLICY_BTHD_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree header signature mismatch");
            return ctx;
        }

    var hdr_body = h5policy_msg_bytes(ios, profile, hdr_addr#B, hdr_size - 4UL);
    var hdr_stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                       hdr_addr#B + (hdr_size - 4UL)#B,
                                                       4UL));
    if (lookup3_hashlittle(hdr_body, 0) != hdr_stored)
        h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt",
                            hdr_addr#B, object,
                            "v2 B-tree header checksum mismatch");

    var record_type = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 5#B, 1UL);
    var record_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 10#B, 2UL);
    var depth = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 12#B, 2UL);
    var root_raw = h5policy_msg_bytes(ios, profile, hdr_addr#B + 16#B, o);
    var root_addr = bytes_to_u64_le(root_raw);
    var num_root = h5policy_msg_u64_at(ios, profile, hdr_addr#B + (16UL + o)#B, 2UL);
    var total_nrec = h5policy_msg_u64_at(ios, profile, hdr_addr#B + (18UL + o)#B, el);

    if (record_type != 10UL && record_type != 11UL)
        {
            h5policy_emit_error("H5_CORRUPT_UNKNOWN_CHUNK_INDEX_TYPE", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree chunk index has an unexpected record type");
            return ctx;
        }

    /* Total record count == chunk count: enforce the resource budget. */
    ctx.chunk_index_count =
        h5policy_checked_add_u64(ctx.chunk_index_count, total_nrec,
                                 profile.max_chunk_count,
                                 "H5_RESOURCE_CHUNK_COUNT", "resource",
                                 hdr_addr#B, object,
                                 "chunk count exceeds the selected profile limit");

    ctx = h5policy_account_metadata(ctx, profile, hdr_size, hdr_addr#B, object);

    if (h5policy_msg_addr_is_undef(root_raw))
        return ctx;
    if (root_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                hdr_addr#B, object,
                                "v2 B-tree root node outside file");
            return ctx;
        }

    if (depth == 0UL)
        {
            var recs_bytes = h5policy_checked_mul_u64(num_root, record_size,
                                                      0xffffffffffffffffUL,
                                                      "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                      root_addr#B, object,
                                                      "v2 B-tree leaf size overflow");
            var need = h5policy_checked_add_u64(6UL, recs_bytes, 0xffffffffffffffffUL,
                                                "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                root_addr#B, object,
                                                "v2 B-tree leaf size overflow");
            if (!h5policy_checked_addr_range(root_addr, need, file_size,
                                             "v2 B-tree leaf outside file",
                                             root_addr#B, object))
                return ctx;
            if (h5policy_msg_bytes(ios, profile, root_addr#B, 4UL) != H5POLICY_BTLF_SIG)
                {
                    h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                        root_addr#B, object,
                                        "v2 B-tree leaf signature mismatch");
                    return ctx;
                }
            var i = 0UL;
            while (i < num_root)
                {
                    var rec_off = root_addr + 6UL + (i * record_size);
                    var caddr_raw = h5policy_msg_bytes(ios, profile, rec_off#B, o);
                    var caddr = bytes_to_u64_le(caddr_raw);
                    if (!h5policy_msg_addr_is_undef(caddr_raw) && caddr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                            rec_off#B, object,
                                            "chunk data address outside file");
                    i = i + 1UL;
                }
        }
    else if (h5policy_msg_bytes(ios, profile, root_addr#B, 4UL) != H5POLICY_BTIN_SIG)
        h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                            root_addr#B, object,
                            "v2 B-tree internal node signature mismatch");

    return ctx;
}

var H5POLICY_FAHD_SIG = [0x46UB, 0x41UB, 0x48UB, 0x44UB];   /* "FAHD" */
var H5POLICY_FADB_SIG = [0x46UB, 0x41UB, 0x44UB, 0x42UB];   /* "FADB" */

/* Validate a fixed-array chunk index (v4 layout index type 3), used by chunked
   datasets with fixed dimensions.  The checksummed header gives the element
   count (= chunk count) and data-block address; the data block holds one
   element per chunk whose leading offset-sized field is the chunk address.
   Paged data blocks (very large arrays) fall back to a coverage gap.  */
fun h5policy_walk_fixed_array_chunks = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                        uint<64> hdr_addr, off64 loc,
                                        string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    var hdr_size = 12UL + el + o;

    if (!h5policy_checked_addr_range(hdr_addr, hdr_size, file_size,
                                     "fixed array header outside file", loc, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, hdr_addr#B, 4UL) != H5POLICY_FAHD_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", hdr_addr#B, object,
                                "fixed array header signature mismatch");
            return ctx;
        }

    var hdr_body = h5policy_msg_bytes(ios, profile, hdr_addr#B, hdr_size - 4UL);
    var hdr_stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                       hdr_addr#B + (hdr_size - 4UL)#B, 4UL));
    if (lookup3_hashlittle(hdr_body, 0) != hdr_stored)
        h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt", hdr_addr#B, object,
                            "fixed array header checksum mismatch");

    var raw_elmt_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 6#B, 1UL);
    var page_bits = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 7#B, 1UL);
    var nelmts = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 8#B, el);
    var dblk_raw = h5policy_msg_bytes(ios, profile, hdr_addr#B + (8UL + el)#B, o);
    var dblk_addr = bytes_to_u64_le(dblk_raw);

    ctx.chunk_index_count =
        h5policy_checked_add_u64(ctx.chunk_index_count, nelmts,
                                 profile.max_chunk_count,
                                 "H5_RESOURCE_CHUNK_COUNT", "resource",
                                 hdr_addr#B, object,
                                 "chunk count exceeds the selected profile limit");
    ctx = h5policy_account_metadata(ctx, profile, hdr_size, hdr_addr#B, object);

    if (h5policy_msg_addr_is_undef(dblk_raw))
        return ctx;
    if (dblk_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", hdr_addr#B, object,
                                "fixed array data block outside file");
            return ctx;
        }

    var is_paged = page_bits > 0UL && page_bits < 48UL
                   && nelmts > (1UL <<. page_bits);

    if (!is_paged)
        {
            /* Elements stored inline in a single data block. */
            var db_prefix = 6UL + o;
            var elems = h5policy_checked_mul_u64(nelmts, raw_elmt_size, 0xffffffffffffffffUL,
                                                 "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                 dblk_addr#B, object,
                                                 "fixed array data block size overflow");
            var db_need = h5policy_checked_add_u64(db_prefix + 4UL, elems, 0xffffffffffffffffUL,
                                                   "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                   dblk_addr#B, object,
                                                   "fixed array data block size overflow");
            if (!h5policy_checked_addr_range(dblk_addr, db_need, file_size,
                                             "fixed array data block body outside file",
                                             dblk_addr#B, object))
                return ctx;
            if (h5policy_msg_bytes(ios, profile, dblk_addr#B, 4UL) != H5POLICY_FADB_SIG)
                {
                    h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", dblk_addr#B, object,
                                        "fixed array data block signature mismatch");
                    return ctx;
                }

            var i = 0UL;
            while (i < nelmts)
                {
                    var elem_off = dblk_addr + db_prefix + (i * raw_elmt_size);
                    var caddr_raw = h5policy_msg_bytes(ios, profile, elem_off#B, o);
                    var caddr = bytes_to_u64_le(caddr_raw);
                    if (!h5policy_msg_addr_is_undef(caddr_raw) && caddr >= file_size)
                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", elem_off#B, object,
                                            "chunk data address outside file");
                    i = i + 1UL;
                }

            return ctx;
        }

    /* Paged data block: prefix (+page-init bitmap +prefix checksum) followed by
       one page per group of dblk_page_nelmts elements (last page shorter), each
       with its own checksum.  Only pages flagged initialized carry chunks.  */
    var page_nelmts = 1UL <<. page_bits;
    var npages = (nelmts + page_nelmts - 1UL) / page_nelmts;
    var last_page_nelmts = nelmts - ((npages - 1UL) * page_nelmts);
    var page_init_size = (npages + 7UL) / 8UL;
    var db_prefix = 6UL + o + page_init_size + 4UL;
    var full_page_bytes =
        h5policy_checked_add_u64(h5policy_checked_mul_u64(page_nelmts, raw_elmt_size,
                                                          0xffffffffffffffffUL,
                                                          "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                                          dblk_addr#B, object,
                                                          "fixed array page size overflow"),
                                 4UL, 0xffffffffffffffffUL,
                                 "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                 dblk_addr#B, object, "fixed array page size overflow");
    var all_pages = h5policy_checked_mul_u64(npages, full_page_bytes, 0xffffffffffffffffUL,
                                             "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                             dblk_addr#B, object,
                                             "fixed array data block size overflow");
    if (!h5policy_checked_addr_range(dblk_addr, db_prefix + all_pages, file_size,
                                     "fixed array paged data block outside file",
                                     dblk_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, dblk_addr#B, 4UL) != H5POLICY_FADB_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", dblk_addr#B, object,
                                "fixed array data block signature mismatch");
            return ctx;
        }

    var p = 0UL;
    while (p < npages)
        {
            var page_start = dblk_addr + db_prefix + (p * full_page_bytes);
            var pn = (p == npages - 1UL) ? last_page_nelmts : page_nelmts;
            var bmap = h5policy_msg_u64_at(ios, profile,
                                           dblk_addr#B + (6UL + o + (p / 8UL))#B, 1UL);
            if (((bmap .>> (p % 8UL)) & 1UL) != 0UL)   /* page initialized */
                {
                    var j = 0UL;
                    while (j < pn)
                        {
                            var elem_off = page_start + (j * raw_elmt_size);
                            var caddr_raw = h5policy_msg_bytes(ios, profile, elem_off#B, o);
                            var caddr = bytes_to_u64_le(caddr_raw);
                            if (!h5policy_msg_addr_is_undef(caddr_raw) && caddr >= file_size)
                                h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                                    elem_off#B, object,
                                                    "chunk data address outside file");
                            j = j + 1UL;
                        }
                }
            p = p + 1UL;
        }

    return ctx;
}

var H5POLICY_EAHD_SIG = [0x45UB, 0x41UB, 0x48UB, 0x44UB];   /* "EAHD" */
var H5POLICY_EAIB_SIG = [0x45UB, 0x41UB, 0x49UB, 0x42UB];   /* "EAIB" */

/* Validate an extensible-array chunk index (v4 layout index type 4), used by
   chunked datasets with one unlimited dimension.  The checksummed header gives
   the element count (= chunk count) and index-block address.  The index block
   stores the first `idx_blk_elmts` chunk addresses inline (validated here);
   deeper data/secondary blocks are counted via the header under budget rather
   than fully walked ("validate the index root under a budget").  */
fun h5policy_walk_ext_array_chunks = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                      uint<64> hdr_addr, off64 loc,
                                      string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    var hdr_size = 16UL + (6UL * el) + o;

    if (!h5policy_checked_addr_range(hdr_addr, hdr_size, file_size,
                                     "extensible array header outside file", loc, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, hdr_addr#B, 4UL) != H5POLICY_EAHD_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", hdr_addr#B, object,
                                "extensible array header signature mismatch");
            return ctx;
        }

    var hdr_body = h5policy_msg_bytes(ios, profile, hdr_addr#B, hdr_size - 4UL);
    var hdr_stored = lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                       hdr_addr#B + (hdr_size - 4UL)#B, 4UL));
    if (lookup3_hashlittle(hdr_body, 0) != hdr_stored)
        h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM", "corrupt", hdr_addr#B, object,
                            "extensible array header checksum mismatch");

    var raw_elmt_size = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 6#B, 1UL);
    var idx_blk_elmts = h5policy_msg_u64_at(ios, profile, hdr_addr#B + 8#B, 1UL);
    var nelmts = h5policy_msg_u64_at(ios, profile, hdr_addr#B + (12UL + (5UL * el))#B, el);
    var idx_raw = h5policy_msg_bytes(ios, profile, hdr_addr#B + (12UL + (6UL * el))#B, o);
    var idx_blk_addr = bytes_to_u64_le(idx_raw);

    ctx.chunk_index_count =
        h5policy_checked_add_u64(ctx.chunk_index_count, nelmts,
                                 profile.max_chunk_count,
                                 "H5_RESOURCE_CHUNK_COUNT", "resource",
                                 hdr_addr#B, object,
                                 "chunk count exceeds the selected profile limit");
    ctx = h5policy_account_metadata(ctx, profile, hdr_size, hdr_addr#B, object);

    if (h5policy_msg_addr_is_undef(idx_raw))
        return ctx;
    if (idx_blk_addr >= file_size)
        {
            h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", hdr_addr#B, object,
                                "extensible array index block outside file");
            return ctx;
        }

    var ib_prefix = 6UL + o;
    var inline = h5policy_checked_mul_u64(idx_blk_elmts, raw_elmt_size, 0xffffffffffffffffUL,
                                          "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                          idx_blk_addr#B, object,
                                          "extensible array index block size overflow");
    if (!h5policy_checked_addr_range(idx_blk_addr, ib_prefix + inline, file_size,
                                     "extensible array index block body outside file",
                                     idx_blk_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, idx_blk_addr#B, 4UL) != H5POLICY_EAIB_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", idx_blk_addr#B, object,
                                "extensible array index block signature mismatch");
            return ctx;
        }

    var i = 0UL;
    while (i < idx_blk_elmts)
        {
            var elem_off = idx_blk_addr + ib_prefix + (i * raw_elmt_size);
            var caddr_raw = h5policy_msg_bytes(ios, profile, elem_off#B, o);
            var caddr = bytes_to_u64_le(caddr_raw);
            if (!h5policy_msg_addr_is_undef(caddr_raw) && caddr >= file_size)
                h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt", elem_off#B, object,
                                    "chunk data address outside file");
            i = i + 1UL;
        }

    return ctx;
}

fun h5policy_validate_layout_payload = (int ios,
                                        H5PolicyLimits profile,
                                        H5WalkContext ctx,
                                        offset<uint<64>,B> payload_off,
                                        uint<64> msg_size,
                                        string object) H5WalkContext:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 1UL,
                                   "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "layout message is too small"))
        return ctx;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
    var layout_class = 0UL;
    var file_size = h5policy_ceiling(ios);

    if (version == 1UL || version == 2UL)
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 8UL,
                                           "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "layout v1/v2 message is too small"))
                return ctx;

            var ndims = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
            layout_class = h5policy_msg_u64_at(ios, profile, payload_off + 2#B, 1UL);
            if (layout_class == CHUNKED as uint<64>)
                {
                    var idx_addr = h5policy_msg_u64_at(ios, profile,
                                                       payload_off + 8#B,
                                                       global_sizeof_offsets as uint<64>);
                    if (idx_addr != 0UL && idx_addr != 0xffffffffffffffffUL)
                        ctx = h5policy_walk_chunk_btree(ios, profile, ctx,
                                                        idx_addr, ndims,
                                                        object, 0UL);
                    var dims_rel = 8UL + (global_sizeof_offsets as uint<64>);
                    var dims_bytes = h5policy_checked_mul_u64(ndims, 4UL,
                                                             0xffffffffffffffffUL,
                                                             "H5_CORRUPT_LENGTH_OVERFLOW",
                                                             "corrupt",
                                                             payload_off, object,
                                                             "chunk dimension byte count overflow");
                    if (h5policy_payload_range_ok(msg_size, dims_rel, dims_bytes,
                                                  "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                  payload_off, object,
                                                  "chunk dimensions overrun the layout message"))
                        {
                            var i = 0UL;
                            while (i < ndims)
                                {
                                    var dim = h5policy_msg_u64_at(ios, profile,
                                                                  payload_off
                                                                  + (dims_rel + i * 4UL)#B,
                                                                  4UL);
                                    if (dim == 0UL)
                                        h5policy_emit_error("H5_CORRUPT_ZERO_CHUNK_DIMENSION",
                                                            "corrupt",
                                                            payload_off, object,
                                                            "chunk dimension is zero");
                                    i = i + 1UL;
                                }
                        }
                }
        }
    else if (version == 3UL)
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                           "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "layout v3 message is too small"))
                return ctx;

            layout_class = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
            if (layout_class == CONTIG as uint<64>)
                {
                    var min_size = 2UL + (global_sizeof_offsets as uint<64>)
                                   + (global_sizeof_lengths as uint<64>);
                    if (h5policy_payload_range_ok(msg_size, 0UL, min_size,
                                                  "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                  payload_off, object,
                                                  "contiguous layout message is too small"))
                        {
                            var data_addr_raw =
                                h5policy_msg_bytes(ios, profile, payload_off + 2#B,
                                                   global_sizeof_offsets as uint<64>);
                            var data_addr = bytes_to_u64_le(data_addr_raw);
                            var data_size = h5policy_msg_u64_at(ios, profile,
                                                                payload_off
                                                                + (2UL
                                                                   + (global_sizeof_offsets as uint<64>))#B,
                                                                global_sizeof_lengths as uint<64>);
                            if (!h5policy_msg_addr_is_undef(data_addr_raw))
                                {
                                    var ok = h5policy_checked_addr_range(data_addr,
                                                                         data_size,
                                                                         file_size,
                                                                         "contiguous data range outside file",
                                                                         payload_off,
                                                                         object);
                                }
                        }
                }
            else if (layout_class == CHUNKED as uint<64>)
                {
                    if (h5policy_payload_range_ok(msg_size, 0UL,
                                                  3UL + (global_sizeof_offsets as uint<64>),
                                                  "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                  payload_off, object,
                                                  "chunked layout message is too small"))
                        {
                            var ndims3 = h5policy_msg_u64_at(ios, profile,
                                                             payload_off + 2#B, 1UL);
                            var idx_addr3 = h5policy_msg_u64_at(ios, profile,
                                                                payload_off + 3#B,
                                                                global_sizeof_offsets as uint<64>);
                            if (idx_addr3 != 0UL && idx_addr3 != 0xffffffffffffffffUL)
                                ctx = h5policy_walk_chunk_btree(ios, profile, ctx,
                                                                idx_addr3, ndims3,
                                                                object, 0UL);
                            var dims_rel3 = 3UL + (global_sizeof_offsets as uint<64>);
                            var dims_bytes3 = h5policy_checked_mul_u64(ndims3,
                                                                      4UL,
                                                                      0xffffffffffffffffUL,
                                                                      "H5_CORRUPT_LENGTH_OVERFLOW",
                                                                      "corrupt",
                                                                      payload_off, object,
                                                                      "chunk dimension byte count overflow");
                            if (h5policy_payload_range_ok(msg_size, dims_rel3,
                                                          dims_bytes3,
                                                          "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                          payload_off, object,
                                                          "chunk dimensions overrun the layout message"))
                                {
                                    var j = 0UL;
                                    while (j < ndims3)
                                        {
                                            var dim3 = h5policy_msg_u64_at(ios, profile,
                                                                          payload_off
                                                                          + (dims_rel3 + j * 4UL)#B,
                                                                          4UL);
                                            if (dim3 == 0UL)
                                                h5policy_emit_error("H5_CORRUPT_ZERO_CHUNK_DIMENSION",
                                                                    "corrupt",
                                                                    payload_off, object,
                                                                    "chunk dimension is zero");
                                            j = j + 1UL;
                                        }
                                }
                        }
                }
        }
    else if (version == 4UL)
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                           "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "layout v4 message is too small"))
                return ctx;

            layout_class = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
            if (layout_class == VIRTUAL as uint<64>)
                {
                    h5policy_note_vds;
                    if (profile.allow_vds == 0UB)
                        h5policy_emit_error("H5_POLICY_VDS", "policy",
                                            payload_off, object,
                                            "virtual dataset layout encountered; profile denies VDS");
                }

            if (layout_class == CHUNKED as uint<64>
                && h5policy_payload_range_ok(msg_size, 0UL, 5UL,
                                             "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                             payload_off, object,
                                             "chunked v4 layout message is too small"))
                {
                    var ndims4 = h5policy_msg_u64_at(ios, profile,
                                                     payload_off + 3#B, 1UL);
                    var enc = h5policy_msg_u64_at(ios, profile,
                                                  payload_off + 4#B, 1UL);
                    var dims_rel4 = 5UL;
                    var dims_bytes4 = h5policy_checked_mul_u64(ndims4, enc,
                                                               0xffffffffffffffffUL,
                                                               "H5_CORRUPT_LENGTH_OVERFLOW",
                                                               "corrupt",
                                                               payload_off, object,
                                                               "chunk dimension byte count overflow");
                    var idx_type_rel = dims_rel4 + dims_bytes4;
                    var chunk_elem_count = 1UL;
                    if (h5policy_payload_range_ok(msg_size, dims_rel4,
                                                  dims_bytes4,
                                                  "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                  payload_off, object,
                                                  "chunk dimensions overrun the layout message"))
                        {
                            var k = 0UL;
                            while (k < ndims4)
                                {
                                    var dim4 = h5policy_msg_u64_at(ios, profile,
                                                                  payload_off
                                                                  + (dims_rel4 + k * enc)#B,
                                                                  enc);
                                    if (dim4 == 0UL)
                                        h5policy_emit_error("H5_CORRUPT_ZERO_CHUNK_DIMENSION",
                                                            "corrupt",
                                                            payload_off, object,
                                                            "chunk dimension is zero");
                                    else
                                        chunk_elem_count =
                                            h5policy_checked_mul_u64(chunk_elem_count, dim4,
                                                                     0xffffffffffffffffUL,
                                                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                                                     "corrupt", payload_off, object,
                                                                     "chunk element count overflow");
                                    k = k + 1UL;
                                }
                        }
                    if (h5policy_payload_range_ok(msg_size, idx_type_rel, 1UL,
                                                  "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                  payload_off, object,
                                                  "chunk index type overruns the layout message"))
                        {
                            var idx_type = h5policy_msg_u64_at(ios, profile,
                                                               payload_off + idx_type_rel#B,
                                                               1UL);
                            var idx_info_len = 0UL;
                            if (idx_type == 1UL)
                                idx_info_len = 0UL;
                            else if (idx_type == 2UL)
                                idx_info_len = 0UL;
                            else if (idx_type == 3UL)
                                idx_info_len = 1UL;
                            else if (idx_type == 4UL)
                                idx_info_len = 5UL;
                            else if (idx_type == 5UL)
                                idx_info_len = 6UL;
                            else
                                h5policy_emit_error("H5_CORRUPT_UNKNOWN_CHUNK_INDEX_TYPE",
                                                    "corrupt", payload_off, object,
                                                    "unknown chunk index type");

                            var idx_addr_rel = idx_type_rel + 1UL + idx_info_len;
                            if (h5policy_payload_range_ok(msg_size, idx_addr_rel,
                                                          global_sizeof_offsets as uint<64>,
                                                          "H5_CORRUPT_LAYOUT_MESSAGE_TOO_SMALL",
                                                          payload_off, object,
                                                          "chunk index address overruns the layout message"))
                                {
                                    var idx_addr4 = h5policy_msg_u64_at(ios, profile,
                                                                        payload_off + idx_addr_rel#B,
                                                                        global_sizeof_offsets as uint<64>);
                                    if (idx_type == 5UL
                                        && idx_addr4 != 0UL
                                        && idx_addr4 != 0xffffffffffffffffUL)
                                        ctx = h5policy_walk_v2_btree_chunks(ios, profile, ctx,
                                                                            idx_addr4,
                                                                            payload_off + idx_addr_rel#B,
                                                                            object);
                                    else if (idx_type == 3UL
                                             && idx_addr4 != 0UL
                                             && idx_addr4 != 0xffffffffffffffffUL)
                                        ctx = h5policy_walk_fixed_array_chunks(ios, profile, ctx,
                                                                               idx_addr4,
                                                                               payload_off + idx_addr_rel#B,
                                                                               object);
                                    else if (idx_type == 4UL
                                             && idx_addr4 != 0UL
                                             && idx_addr4 != 0xffffffffffffffffUL)
                                        ctx = h5policy_walk_ext_array_chunks(ios, profile, ctx,
                                                                             idx_addr4,
                                                                             payload_off + idx_addr_rel#B,
                                                                             object);
                                    else if (idx_type == 2UL)
                                        {
                                            /* Implicit: chunks stored contiguously from a base
                                               address, no index structure.  Estimate the chunk
                                               count from the dataspace and chunk element counts. */
                                            if (idx_addr4 != 0UL
                                                && idx_addr4 != 0xffffffffffffffffUL)
                                                {
                                                    var nch = 1UL;
                                                    if (ctx.has_dataspace != 0UB
                                                        && chunk_elem_count != 0UL)
                                                        nch = (ctx.dataset_element_count
                                                               + chunk_elem_count - 1UL)
                                                              / chunk_elem_count;
                                                    ctx.chunk_index_count =
                                                        h5policy_checked_add_u64(ctx.chunk_index_count, nch,
                                                                                 profile.max_chunk_count,
                                                                                 "H5_RESOURCE_CHUNK_COUNT", "resource",
                                                                                 payload_off + idx_addr_rel#B, object,
                                                                                 "chunk count exceeds the selected profile limit");
                                                    if (idx_addr4 >= (h5policy_ceiling(ios)))
                                                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                                                            payload_off + idx_addr_rel#B, object,
                                                                            "implicit chunk base address outside file");
                                                }
                                        }
                                    else if (idx_type == 1UL)
                                        {
                                            /* Single Chunk: the address field is
                                               the one chunk's data address.  */
                                            if (idx_addr4 != 0UL
                                                && idx_addr4 != 0xffffffffffffffffUL)
                                                {
                                                    ctx.chunk_index_count =
                                                        h5policy_checked_add_u64(ctx.chunk_index_count, 1UL,
                                                                                 profile.max_chunk_count,
                                                                                 "H5_RESOURCE_CHUNK_COUNT", "resource",
                                                                                 payload_off + idx_addr_rel#B, object,
                                                                                 "chunk count exceeds the selected profile limit");
                                                    if (idx_addr4 >= (h5policy_ceiling(ios)))
                                                        h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE", "corrupt",
                                                                            payload_off + idx_addr_rel#B, object,
                                                                            "single-chunk data address outside file");
                                                }
                                        }
                                    else
                                        ctx = h5policy_note_chunk_index_addr(ctx, profile,
                                                                             idx_addr4,
                                                                             payload_off + idx_addr_rel#B,
                                                                             object);
                                }
                        }
                }
        }
    else
        h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_LAYOUT_VERSION",
                            "corrupt", payload_off, object,
                            "unsupported layout message version");

    if (layout_class > VIRTUAL as uint<64>)
        h5policy_emit_error("H5_CORRUPT_UNKNOWN_LAYOUT_CLASS",
                            "corrupt", payload_off, object,
                            "unknown data layout class");

    return ctx;
}

fun h5policy_validate_filter_pipeline_payload = (int ios,
                                                 H5PolicyLimits profile,
                                                 offset<uint<64>,B> payload_off,
                                                 uint<64> msg_size,
                                                 string object) void:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                   "H5_CORRUPT_FILTER_PIPELINE_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "filter pipeline message is too small"))
        return;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
    var nfilters = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var cur = 0UL;

    if (nfilters > profile.max_filter_count)
        h5policy_emit_error("H5_RESOURCE_FILTER_COUNT", "resource",
                            payload_off, object,
                            "filter count exceeds the selected profile limit");

    if (version == 1UL)
        cur = 8UL;
    else if (version == 2UL)
        cur = 2UL;
    else
        {
            h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FILTER_PIPELINE_VERSION",
                                "corrupt", payload_off, object,
                                "unsupported filter pipeline version");
            return;
        }

    var idx = 0UL;
    while (idx < nfilters)
        {
            var desc_header = version == 1UL ? 8UL : 6UL;

            if (!h5policy_payload_range_ok(msg_size, cur, desc_header,
                                           "H5_CORRUPT_FILTER_PIPELINE_OVERRUNS_MESSAGE",
                                           payload_off + cur#B, object,
                                           "filter descriptor overruns the pipeline message"))
                return;

            var filter_id = h5policy_msg_u64_at(ios, profile,
                                                payload_off + cur#B, 2UL);
            var name_len = 0UL;
            var cd_nelmts = 0UL;

            if (version == 1UL)
                {
                    name_len = h5policy_msg_u64_at(ios, profile,
                                                   payload_off + (cur + 2UL)#B,
                                                   2UL);
                    cd_nelmts = h5policy_msg_u64_at(ios, profile,
                                                    payload_off + (cur + 6UL)#B,
                                                    2UL);
                }
            else
                cd_nelmts = h5policy_msg_u64_at(ios, profile,
                                                payload_off + (cur + 4UL)#B,
                                                2UL);

            if (!h5policy_core_filter(filter_id))
                {
                    h5policy_note_dynamic_filter(filter_id);
                    if (profile.allow_dynamic_filters == 0UB)
                        h5policy_emit_error("H5_POLICY_DYNAMIC_FILTER", "policy",
                                            payload_off + cur#B, object,
                                            "non-core filter required; profile disables dynamic filters");
                }

            var cd_bytes = h5policy_checked_mul_u64(cd_nelmts, 4UL,
                                                    0xffffffffffffffffUL,
                                                    "H5_CORRUPT_LENGTH_OVERFLOW",
                                                    "corrupt",
                                                    payload_off + cur#B,
                                                    object,
                                                    "filter client-data byte count overflow");
            var desc_size = h5policy_checked_add_u64(desc_header, name_len,
                                                     0xffffffffffffffffUL,
                                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                                     "corrupt",
                                                     payload_off + cur#B,
                                                     object,
                                                     "filter descriptor size overflow");
            desc_size = h5policy_checked_add_u64(desc_size, cd_bytes,
                                                 0xffffffffffffffffUL,
                                                 "H5_CORRUPT_LENGTH_OVERFLOW",
                                                 "corrupt",
                                                 payload_off + cur#B,
                                                 object,
                                                 "filter descriptor size overflow");
            if (version == 1UL && (cd_nelmts % 2UL) != 0UL)
                desc_size = h5policy_checked_add_u64(desc_size, 4UL,
                                                     0xffffffffffffffffUL,
                                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                                     "corrupt",
                                                     payload_off + cur#B,
                                                     object,
                                                     "filter descriptor padding overflow");

            if (!h5policy_payload_range_ok(msg_size, cur, desc_size,
                                           "H5_CORRUPT_FILTER_PIPELINE_OVERRUNS_MESSAGE",
                                           payload_off + cur#B, object,
                                           "filter descriptor overruns the pipeline message"))
                return;

            cur = cur + desc_size;
            idx = idx + 1UL;
        }
}

fun h5policy_validate_link_payload = (int ios,
                                      H5PolicyLimits profile,
                                      offset<uint<64>,B> payload_off,
                                      uint<64> msg_size,
                                      string object) void:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                   "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "link message is too small"))
        return;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
    var flags = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var cur = 2UL;
    var link_type = 0UL;

    if (version != 1UL)
        h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_LINK_VERSION",
                            "corrupt", payload_off, object,
                            "unsupported link message version");

    if ((flags & 8UL) != 0UL)
        {
            if (!h5policy_payload_range_ok(msg_size, cur, 1UL,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           "link type byte is missing"))
                return;
            link_type = h5policy_msg_u64_at(ios, profile,
                                            payload_off + cur#B, 1UL);
            cur = cur + 1UL;
        }

    if ((flags & 4UL) != 0UL)
        cur = cur + 8UL;
    if ((flags & 16UL) != 0UL)
        cur = cur + 1UL;

    var len_width = 1UL <<. (flags & 3UL);
    if (!h5policy_payload_range_ok(msg_size, cur, len_width,
                                   "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                   payload_off + cur#B, object,
                                   "link name length field is missing"))
        return;

    var name_len = h5policy_msg_u64_at(ios, profile,
                                       payload_off + cur#B, len_width);
    cur = cur + len_width;
    var name_off = payload_off + cur#B;

    if (name_len == 0UL)
        h5policy_emit_error("H5_CORRUPT_LINK_NAME_EMPTY",
                            "corrupt", payload_off + cur#B, object,
                            "link name is empty");

    if (!h5policy_payload_range_ok(msg_size, cur, name_len,
                                   "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                   payload_off + cur#B, object,
                                   "link name overruns the link message"))
        return;

    cur = cur + name_len;
    var link_name = h5policy_string_from_payload(ios, profile,
                                                 name_off, name_len);
    if (link_name == "")
        link_name = "<unnamed>";

    if (link_type == 0UL)
        {
            if (!h5policy_payload_range_ok(msg_size, cur,
                                           global_sizeof_offsets as uint<64>,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           "hard link target address is missing"))
                return;

            var target_raw = h5policy_msg_bytes(ios, profile,
                                                payload_off + cur#B,
                                                global_sizeof_offsets as uint<64>);
            var target = bytes_to_u64_le(target_raw);
            if (!h5policy_msg_addr_is_undef(target_raw))
                {
                    var ok = h5policy_checked_addr_range(target, 1UL,
                                                         h5policy_ceiling(ios),
                                                         "hard link target address outside file",
                                                         payload_off + cur#B,
                                                         object);
                    if (ok)
                        h5policy_enqueue_ohdr(profile, target,
                                              h5policy_current_object_depth + 1UL,
                                              h5policy_join_path(object, link_name),
                                              payload_off + cur#B,
                                              object);
                }
        }
    else if (link_type == 1UL)
        {
            if (!h5policy_payload_range_ok(msg_size, cur, 2UL,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           "soft link length is missing"))
                return;
            var soft_len = h5policy_msg_u64_at(ios, profile,
                                               payload_off + cur#B, 2UL);
            if (!h5policy_payload_range_ok(msg_size, cur + 2UL, soft_len,
                                           "H5_CORRUPT_LINK_MESSAGE_TOO_SMALL",
                                           payload_off + cur#B, object,
                                           "soft link target overruns the link message"))
                return;
        }
    else if (link_type == 64UL)
        {
            h5policy_note_external_link;
            if (profile.allow_external_links == 0UB)
                h5policy_emit_error("H5_POLICY_EXTERNAL_LINK", "policy",
                                    payload_off, object,
                                    "external link encountered; profile denies external references");
        }
    else
        {
            h5policy_emit_error("H5_POLICY_USER_DEFINED_LINK", "policy",
                                payload_off, object,
                                "user-defined link encountered; profile denies user-defined links");
        }
}

var H5POLICY_FRHP_SIG = [0x46UB, 0x52UB, 0x48UB, 0x50UB];   /* "FRHP" */

fun h5policy_bytes_for_bits = (uint<64> nbits) uint<64>:
{
    return (nbits + 7UL) / 8UL;
}

fun h5policy_bytes_for_limit = (uint<64> limit) uint<64>:
{
    var nbytes = 1UL;
    var max = 0xffUL;
    while (nbytes < 8UL && limit > max)
        {
            nbytes = nbytes + 1UL;
            max = (max <<. 8UL) | 0xffUL;
        }
    return nbytes;
}

fun h5policy_floor_log2 = (uint<64> value) uint<64>:
{
    var v = value;
    var n = 0UL;
    while ((v .>> 1UL) > 0UL)
        {
            v = v .>> 1UL;
            n = n + 1UL;
        }
    return n;
}

/* File offset of a fractal-heap managed object, from its heap offset.  Mirrors
   H5HF__man_dblock_locate (and the single-root-direct-block shortcut).  Returns
   the undef sentinel when the lookup escapes the block geometry (corruption or
   a heap id from another heap).  Bounded by a fixed descent guard.  */
fun h5policy_frhp_locate = (int ios, H5PolicyLimits profile,
                            uint<64> root_addr, uint<64> curr_root_rows,
                            uint<64> start_size, uint<64> max_direct_size,
                            uint<64> width, uint<64> off_size,
                            uint<64> heap_obj_off, uint<64> file_size) uint<64>:
{
    if (curr_root_rows == 0UL)
        return root_addr + heap_obj_off;

    var first_row_bits = h5policy_floor_log2(start_size)
                         + h5policy_floor_log2(width);
    var max_direct_rows = h5policy_floor_log2(max_direct_size)
                          - h5policy_floor_log2(start_size) + 2UL;
    var prefix_size = 5UL + (global_sizeof_offsets as uint<64>) + off_size;
    var entry_size = global_sizeof_offsets as uint<64>;
    var cur_addr = root_addr;
    var cur_nrows = curr_root_rows;
    var cur_block_off = 0UL;
    var guard = 0UL;

    while (guard < 64UL)
        {
            guard = guard + 1UL;
            var local_off = heap_obj_off - cur_block_off;
            var row = 0UL;
            var col = 0UL;
            var row_block_size = start_size;
            var row_block_off = 0UL;

            if (local_off < start_size * width)
                {
                    row = 0UL;
                    col = local_off / start_size;
                }
            else
                {
                    var high_bit = h5policy_floor_log2(local_off);
                    var off_mask = 1UL <<. high_bit;
                    row = (high_bit - first_row_bits) + 1UL;
                    row_block_size = start_size <<. (row - 1UL);
                    row_block_off = off_mask;
                    col = (local_off - off_mask) / row_block_size;
                }

            if (row >= cur_nrows || col >= width)
                return 0xffffffffffffffffUL;

            var entry_off = cur_addr + prefix_size
                            + ((row * width + col) * entry_size);
            if (entry_off > file_size || entry_size > file_size - entry_off)
                return 0xffffffffffffffffUL;

            var addr_raw = h5policy_msg_bytes(ios, profile, entry_off#B, entry_size);
            if (h5policy_msg_addr_is_undef(addr_raw))
                return 0xffffffffffffffffUL;

            var child_addr = bytes_to_u64_le(addr_raw);
            var child_block_off = cur_block_off + row_block_off
                                  + (col * row_block_size);

            if (row < max_direct_rows)
                return child_addr + (heap_obj_off - child_block_off);

            cur_addr = child_addr;
            cur_nrows = row - h5policy_floor_log2(width);
            cur_block_off = child_block_off;
        }

    return 0xffffffffffffffffUL;
}

/* Minimum bytes for the "records in child node" field of a v2 B-tree child
   pointer (mirrors H5B2's fixed-point sizing).  */
fun h5policy_bt2_nrec_bytes = (uint<64> node_sz, uint<64> rec_sz) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    var bytes = 1UL;
    var prev = 0UL;
    while (bytes != prev)
        {
            prev = bytes;
            var ptr_sz = o + bytes;
            if (node_sz < 10UL + ptr_sz || rec_sz + ptr_sz == 0UL)
                return bytes;
            var max_nrec = (node_sz - 10UL - ptr_sz) / (rec_sz + ptr_sz);
            bytes = 1UL;
            var thresh = 256UL;
            while (max_nrec >= thresh)
                {
                    bytes = bytes + 1UL;
                    thresh = thresh * 256UL;
                }
        }
    return bytes;
}

/* Process one v2 B-tree leaf of dense-link (type-5) records: resolve each
   fractal-heap object and validate/enqueue it as a link message.  */
/* Process nrec dense-link (type-5) records starting at rec_base (node prefix +
   6): resolve each heap object and validate/enqueue it as a link message.
   Used for both leaf and internal nodes -- in a v2 B-tree every node stores
   records, so internal-node records must be processed too, not just leaves.  */
fun h5policy_dense_link_records = (int ios, H5PolicyLimits profile,
                                   uint<64> rec_base, uint<64> nrec, uint<64> record_size,
                                   uint<64> fheap_root, uint<64> curr_root_rows,
                                   uint<64> start_size, uint<64> max_direct_size,
                                   uint<64> table_width, uint<64> off_size,
                                   uint<64> len_size, uint<64> file_size,
                                   string object) void:
{
    var i = 0UL;
    while (i < nrec)
        {
            /* type-5 record: name_hash(4) + heap id */
            var id_off = rec_base + (i * record_size) + 4UL;
            var id_flags = h5policy_msg_u64_at(ios, profile, id_off#B, 1UL);
            if (((id_flags .>> 4) & 3UL) == 0UL)
                {
                    var heap_obj_off = h5policy_msg_u64_at(ios, profile,
                                                           id_off#B + 1#B, off_size);
                    var heap_obj_len = h5policy_msg_u64_at(ios, profile,
                                                           id_off#B + (1UL + off_size)#B,
                                                           len_size);
                    if (heap_obj_len != 0UL)
                        {
                            var obj_off = h5policy_frhp_locate(ios, profile,
                                                               fheap_root, curr_root_rows,
                                                               start_size, max_direct_size,
                                                               table_width, off_size,
                                                               heap_obj_off, file_size);
                            if (obj_off != 0xffffffffffffffffUL
                                && obj_off < file_size
                                && heap_obj_len <= file_size - obj_off)
                                h5policy_validate_link_payload(ios, profile,
                                                               obj_off#B, heap_obj_len,
                                                               object);
                        }
                }
            i = i + 1UL;
        }
}

fun h5policy_dense_leaf_links = (int ios, H5PolicyLimits profile,
                                 uint<64> leaf_addr, uint<64> nrec, uint<64> record_size,
                                 uint<64> fheap_root, uint<64> curr_root_rows,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> table_width, uint<64> off_size,
                                 uint<64> len_size, uint<64> file_size,
                                 string object) void:
{
    var leaf_need = 6UL + (nrec * record_size);
    if (!h5policy_checked_addr_range(leaf_addr, leaf_need, file_size,
                                     "dense link v2 B-tree leaf outside file",
                                     leaf_addr#B, object))
        return;
    if (h5policy_msg_bytes(ios, profile, leaf_addr#B, 4UL) != H5POLICY_BTLF_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                leaf_addr#B, object,
                                "dense link v2 B-tree leaf signature mismatch");
            return;
        }

    h5policy_dense_link_records(ios, profile, leaf_addr + 6UL, nrec, record_size,
                                fheap_root, curr_root_rows, start_size, max_direct_size,
                                table_width, off_size, len_size, file_size, object);
}

/* Enumerate dense-link records from the name-indexed v2 B-tree (root leaf, or a
   depth-1 root internal node's leaves), resolve each fractal-heap object, and
   validate/enqueue it as a link message.  Returns 1 when handled; 0 when the
   structure is outside the supported subset (filtered heap, v2 B-tree depth>1,
   non-managed ids), so the caller falls back to a coverage gap.  */
/* Bytes for the "records in child subtree" field of a v2 B-tree child pointer
   at a node whose children are height-`level` subtrees (level >= 1).  Ports the
   spec's cumulative-max recurrence.  */
fun h5policy_bt2_subtree_bytes = (uint<64> node_sz, uint<64> rec_sz, uint<64> level) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    if (level == 0UL || rec_sz == 0UL || node_sz < 10UL)
        return 0UL;
    var nrec_bytes = h5policy_bt2_nrec_bytes(node_sz, rec_sz);
    var cum_max = (node_sz - 10UL) / rec_sz;         /* cum_max[0]: leaf capacity */
    var subtree_bytes = 0UL;
    var lv = 1UL;
    while (lv <= level)
        {
            var ptr_sz = o + nrec_bytes + subtree_bytes;
            if (node_sz < 10UL + ptr_sz || rec_sz + ptr_sz == 0UL)
                return subtree_bytes;
            var max_int = (node_sz - 10UL - ptr_sz) / (rec_sz + ptr_sz);
            cum_max = ((max_int + 1UL) * cum_max) + max_int;
            subtree_bytes = 1UL;
            var thresh = 256UL;
            while (cum_max >= thresh)
                {
                    subtree_bytes = subtree_bytes + 1UL;
                    thresh = thresh * 256UL;
                }
            lv = lv + 1UL;
        }
    return subtree_bytes;
}

/* Recursively descend a dense-link name v2 B-tree node.  A node at depth 0 is a
   leaf (processed directly); a node at depth D is internal, and its child
   pointers are addr + records-in-child (+ records-in-subtree when D > 1).
   Bounded by the tree depth itself and max_btree_depth.  */
fun h5policy_dense_links_node = (int ios, H5PolicyLimits profile,
                                 uint<64> node_addr, uint<64> node_depth, uint<64> nrec,
                                 uint<64> node_size, uint<64> record_size,
                                 uint<64> fheap_root, uint<64> curr_root_rows,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> table_width, uint<64> off_size,
                                 uint<64> len_size, uint<64> file_size,
                                 string object) void:
{
    if (node_depth == 0UL)
        {
            h5policy_dense_leaf_links(ios, profile, node_addr, nrec, record_size,
                                      fheap_root, curr_root_rows, start_size,
                                      max_direct_size, table_width, off_size,
                                      len_size, file_size, object);
            return;
        }

    if (node_depth > profile.max_btree_depth)
        {
            h5policy_emit_error("H5_CORRUPT_BTREE_DEPTH_EXCEEDED", "corrupt",
                                node_addr#B, object,
                                "dense link v2 B-tree depth exceeds the selected profile limit");
            return;
        }

    var o = global_sizeof_offsets as uint<64>;
    var nrec_bytes = h5policy_bt2_nrec_bytes(node_size, record_size);
    var sub_bytes = node_depth > 1UL
                    ? h5policy_bt2_subtree_bytes(node_size, record_size, node_depth - 1UL)
                    : 0UL;
    var ptr_size = o + nrec_bytes + sub_bytes;
    var recs = h5policy_checked_mul_u64(nrec, record_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        node_addr#B, object,
                                        "dense link v2 B-tree node size overflow");
    var ptrs = h5policy_checked_mul_u64(nrec + 1UL, ptr_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        node_addr#B, object,
                                        "dense link v2 B-tree node size overflow");
    if (!h5policy_checked_addr_range(node_addr, 6UL + recs + ptrs, file_size,
                                     "dense link v2 B-tree internal node outside file",
                                     node_addr#B, object))
        return;
    if (h5policy_msg_bytes(ios, profile, node_addr#B, 4UL) != H5POLICY_BTIN_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", node_addr#B, object,
                                "dense link v2 B-tree internal node signature mismatch");
            return;
        }

    /* The internal node's own records are real link records too. */
    h5policy_dense_link_records(ios, profile, node_addr + 6UL, nrec, record_size,
                                fheap_root, curr_root_rows, start_size, max_direct_size,
                                table_width, off_size, len_size, file_size, object);

    var ptr_base = node_addr + 6UL + recs;
    var j = 0UL;
    while (j < nrec + 1UL)
        {
            var ptr_off = ptr_base + (j * ptr_size);
            var child_raw = h5policy_msg_bytes(ios, profile, ptr_off#B, o);
            var child_addr = bytes_to_u64_le(child_raw);
            var child_nrec = h5policy_msg_u64_at(ios, profile, ptr_off#B + o#B, nrec_bytes);
            if (!h5policy_msg_addr_is_undef(child_raw))
                h5policy_dense_links_node(ios, profile, child_addr, node_depth - 1UL,
                                          child_nrec, node_size, record_size, fheap_root,
                                          curr_root_rows, start_size, max_direct_size,
                                          table_width, off_size, len_size, file_size, object);
            j = j + 1UL;
        }
}

fun h5policy_walk_dense_links = (int ios, H5PolicyLimits profile,
                                 uint<64> fheap_addr, uint<64> btree_addr,
                                 off64 loc, string object) int:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);

    /* ---- fractal heap header ---- */
    var frhp_min = 14UL + (2UL * o) + (10UL * el) + 8UL + (2UL * el) + o + 2UL;
    if (!h5policy_checked_addr_range(fheap_addr, frhp_min, file_size,
                                     "fractal heap header outside file", loc, object))
        return 0;
    if (h5policy_msg_bytes(ios, profile, fheap_addr#B, 4UL) != H5POLICY_FRHP_SIG)
        return 0;

    var filter_len = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 7#B, 2UL);
    if (filter_len != 0UL)
        return 0;                       /* filtered heap: not supported here */

    var max_man_size = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 10#B, 4UL);
    var dtable = 14UL + (10UL * el) + (2UL * o);
    var table_width = h5policy_msg_u64_at(ios, profile, fheap_addr#B + dtable#B, 2UL);
    var start_size = h5policy_msg_u64_at(ios, profile,
                                         fheap_addr#B + (dtable + 2UL)#B, el);
    var max_direct_size = h5policy_msg_u64_at(ios, profile,
                                              fheap_addr#B + (dtable + 2UL + el)#B, el);
    var max_heap_bits = h5policy_msg_u64_at(ios, profile,
                                            fheap_addr#B + (dtable + 2UL + (2UL * el))#B, 2UL);
    var root_raw = h5policy_msg_bytes(ios, profile,
                                      fheap_addr#B + (dtable + 6UL + (2UL * el))#B, o);
    var root_addr = bytes_to_u64_le(root_raw);
    var curr_root_rows = h5policy_msg_u64_at(ios, profile,
                                             fheap_addr#B + (dtable + 6UL + (2UL * el) + o)#B, 2UL);

    var off_size = h5policy_bytes_for_bits(max_heap_bits);
    var len_size = h5policy_bytes_for_limit(max_man_size);
    if (len_size > off_size)
        len_size = off_size;
    if (h5policy_msg_addr_is_undef(root_raw) || start_size == 0UL || table_width == 0UL)
        return 0;

    /* ---- name-indexed v2 B-tree (root leaf only) ---- */
    var bt_hdr = 22UL + o + el;
    if (!h5policy_checked_addr_range(btree_addr, bt_hdr, file_size,
                                     "dense link v2 B-tree header outside file", loc, object))
        return 0;
    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL) != H5POLICY_BTHD_SIG)
        return 0;

    var record_type = h5policy_msg_u64_at(ios, profile, btree_addr#B + 5#B, 1UL);
    var node_size = h5policy_msg_u64_at(ios, profile, btree_addr#B + 6#B, 4UL);
    var record_size = h5policy_msg_u64_at(ios, profile, btree_addr#B + 10#B, 2UL);
    var depth = h5policy_msg_u64_at(ios, profile, btree_addr#B + 12#B, 2UL);
    var bt_root_raw = h5policy_msg_bytes(ios, profile, btree_addr#B + 16#B, o);
    var bt_root = bytes_to_u64_le(bt_root_raw);
    var num_root = h5policy_msg_u64_at(ios, profile, btree_addr#B + (16UL + o)#B, 2UL);

    if (record_type != 5UL || h5policy_msg_addr_is_undef(bt_root_raw))
        return 0;

    h5policy_dense_links_node(ios, profile, bt_root, depth, num_root, node_size,
                              record_size, root_addr, curr_root_rows, start_size,
                              max_direct_size, table_width, off_size, len_size,
                              file_size, object);
    return 1;
}

fun h5policy_validate_linfo_payload = (int ios,
                                       H5PolicyLimits profile,
                                       offset<uint<64>,B> payload_off,
                                       uint<64> msg_size,
                                       string object) void:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                   "H5_CORRUPT_LINK_INFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "link-info message is too small"))
        return;

    var flags = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var cur = 2UL;

    if ((flags & 1UL) != 0UL)
        cur = cur + 8UL;

    var min_size = cur + (2UL * (global_sizeof_offsets as uint<64>));
    if ((flags & 2UL) != 0UL)
        min_size = min_size + (global_sizeof_offsets as uint<64>);

    if (!h5policy_payload_range_ok(msg_size, 0UL, min_size,
                                   "H5_CORRUPT_LINK_INFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "link-info addresses overrun the message"))
        return;

    var fheap_raw = h5policy_msg_bytes(ios, profile,
                                       payload_off + cur#B,
                                       global_sizeof_offsets as uint<64>);
    var fheap_addr = bytes_to_u64_le(fheap_raw);
    cur = cur + (global_sizeof_offsets as uint<64>);

    var name_btree_raw = h5policy_msg_bytes(ios, profile,
                                            payload_off + cur#B,
                                            global_sizeof_offsets as uint<64>);
    var name_btree_addr = bytes_to_u64_le(name_btree_raw);
    cur = cur + (global_sizeof_offsets as uint<64>);

    var handled = 0;
    if (!h5policy_msg_addr_is_undef(fheap_raw)
        && !h5policy_msg_addr_is_undef(name_btree_raw))
        handled = h5policy_walk_dense_links(ios, profile, fheap_addr,
                                            name_btree_addr, payload_off, object);

    if (!handled && !h5policy_msg_addr_is_undef(fheap_raw))
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                            "unsupported", payload_off, object,
                            "dense link storage uses an unsupported fractal-heap/B-tree layout");
}

/* ---- Old-style group traversal (symbol table -> v1 B-tree -> SNOD -> heap) --
   A pre-1.8 group stores its members through a symbol-table message giving a
   v1 B-tree (node type 0) and a local heap.  The B-tree indexes symbol-table
   nodes (SNOD); each entry names a child (via a heap offset) and points to its
   object header.  Everything below is decoded from raw bytes with bounds
   checks, a visited set (cycle/shared-node guard), the max_btree_depth budget,
   and metadata accounting -- and it enqueues the child object headers into the
   same bounded BFS the link-message path uses.  */
var H5POLICY_HEAP_SIG = [0x48UB, 0x45UB, 0x41UB, 0x50UB];   /* "HEAP" */
var H5POLICY_SNOD_SIG = [0x53UB, 0x4eUB, 0x4fUB, 0x44UB];   /* "SNOD" */
var H5POLICY_MAX_HEAP_NAME = 1024UL;   /* H5POLICY_TREE_SIG defined earlier */

/* Data-segment size of the local heap currently being walked; a link-name
   offset must fall inside it.  Set by h5policy_local_heap_data_addr (the whole
   group walk for one heap runs synchronously, so a global is sufficient).  */
var h5policy_heap_data_seg_size = 0UL;

/* Bounded, NUL-terminated link name from the local heap data segment. */
fun h5policy_heap_name = (int ios, H5PolicyLimits profile,
                          uint<64> data_seg_addr, uint<64> name_off,
                          uint<64> file_size) string:
{
    if (data_seg_addr == 0xffffffffffffffffUL
        || name_off > file_size || data_seg_addr > file_size - name_off)
        return "";

    var abs = data_seg_addr + name_off;
    if (abs >= file_size)
        return "";

    var avail = file_size - abs;
    var cap = avail < H5POLICY_MAX_HEAP_NAME ? avail : H5POLICY_MAX_HEAP_NAME;
    return h5policy_string_from_payload(ios, profile, abs#B, cap);
}

/* Validate a local heap header and return its data-segment address (or the
   undef sentinel on error, after emitting).  */
fun h5policy_local_heap_data_addr = (int ios, H5PolicyLimits profile,
                                     uint<64> heap_addr, uint<64> file_size,
                                     off64 loc, string object) uint<64>:
{
    var o = global_sizeof_offsets as uint<64>;
    var l = global_sizeof_lengths as uint<64>;
    var hdr_size = 8UL + (2UL * l) + o;

    if (!h5policy_checked_addr_range(heap_addr, hdr_size, file_size,
                                     "local heap header outside file",
                                     loc, object))
        return 0xffffffffffffffffUL;

    if (h5policy_msg_bytes(ios, profile, heap_addr#B, 4UL) != H5POLICY_HEAP_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                heap_addr#B, object,
                                "local heap signature mismatch");
            return 0xffffffffffffffffUL;
        }

    /* Data segment size (bounds link-name offsets) is the first length field. */
    h5policy_heap_data_seg_size = h5policy_msg_u64_at(ios, profile,
                                                      heap_addr#B + 8#B, l);
    var data_seg_addr = h5policy_msg_u64_at(ios, profile,
                                            heap_addr#B + (8UL + (2UL * l))#B, o);

    /* The data segment stores the link names; libhdf5 requires it to lie within
       the file and rejects a local heap whose declared segment runs past the
       EOA.  Without this an inflated data-segment size is silently accepted.  */
    var seg_ok = h5policy_checked_addr_range(data_seg_addr,
                                             h5policy_heap_data_seg_size, file_size,
                                             "local heap data segment outside file",
                                             loc, object);
    return data_seg_addr;
}

/* One symbol-table node: enqueue each non-symbolic entry's child header. */
fun h5policy_walk_snod = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                          uint<64> snod_addr, uint<64> data_seg_addr,
                          string parent_path, uint<64> obj_depth) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var file_size = h5policy_ceiling(ios);

    if (!h5policy_mark_visited_btree(snod_addr))
        return ctx;

    if (!h5policy_checked_addr_range(snod_addr, 8UL, file_size,
                                     "symbol table node outside file",
                                     snod_addr#B, parent_path))
        return ctx;

    if (h5policy_msg_bytes(ios, profile, snod_addr#B, 4UL) != H5POLICY_SNOD_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                snod_addr#B, parent_path,
                                "symbol table node signature mismatch");
            return ctx;
        }

    var num = h5policy_msg_u64_at(ios, profile, snod_addr#B + 6#B, 2UL);
    var ent_size = (2UL * o) + 24UL;
    var body = h5policy_checked_mul_u64(num, ent_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        snod_addr#B, parent_path,
                                        "symbol table node size overflow");
    var total = h5policy_checked_add_u64(8UL, body, 0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                         snod_addr#B, parent_path,
                                         "symbol table node size overflow");
    if (!h5policy_checked_addr_range(snod_addr, total, file_size,
                                     "symbol table node entries outside file",
                                     snod_addr#B, parent_path))
        return ctx;

    ctx = h5policy_account_metadata(ctx, profile, total, snod_addr#B, parent_path);

    var i = 0UL;
    while (i < num)
        {
            var eoff = snod_addr + 8UL + (i * ent_size);
            var cache_type = h5policy_msg_u64_at(ios, profile,
                                                 eoff#B + (2UL * o)#B, 4UL);
            /* Valid cache types are 0 (none), 1 (cached group B-tree/heap) and
               2 (symbolic link).  libhdf5 rejects anything else with "unknown
               symbol table entry cache type".  */
            if (cache_type > 2UL)
                h5policy_emit_error("H5_CORRUPT_SYMBOL_TABLE_CACHE_TYPE",
                                    "corrupt", eoff#B, parent_path,
                                    "symbol table entry has an unknown cache type");
            if (cache_type != 2UL)   /* 2 = symbolic (soft) link: no object header */
                {
                    var name_off = h5policy_msg_u64_at(ios, profile, eoff#B, o);
                    var ohdr_raw = h5policy_msg_bytes(ios, profile, eoff#B + o#B, o);
                    var ohdr_addr = bytes_to_u64_le(ohdr_raw);

                    if (name_off >= h5policy_heap_data_seg_size)
                        h5policy_emit_error("H5_CORRUPT_HEAP_OFFSET_OUT_OF_BOUNDS",
                                            "corrupt", eoff#B, parent_path,
                                            "link name offset is beyond the local heap data segment");

                    if (!h5policy_msg_addr_is_undef(ohdr_raw))
                        {
                            if (ohdr_addr < file_size)
                                {
                                    var name = h5policy_heap_name(ios, profile,
                                                                  data_seg_addr,
                                                                  name_off, file_size);
                                    if (name == "")
                                        name = "<anon>";
                                    h5policy_enqueue_ohdr(profile, ohdr_addr,
                                                          obj_depth + 1UL,
                                                          h5policy_join_path(parent_path, name),
                                                          eoff#B, parent_path);
                                }
                            else
                                h5policy_emit_error("H5_CORRUPT_OFFSET_OUT_OF_FILE",
                                                    "corrupt", eoff#B, parent_path,
                                                    "symbol table entry object header address outside file");
                        }
                }
            i = i + 1UL;
        }

    return ctx;
}

/* Recurse the group v1 B-tree (node type 0); leaves reference SNODs. */
fun h5policy_walk_group_btree = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                 uint<64> btree_addr, uint<64> data_seg_addr,
                                 string parent_path, uint<64> obj_depth,
                                 uint<64> btree_depth) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var l = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);

    if (btree_depth > profile.max_btree_depth)
        {
            h5policy_emit_error("H5_CORRUPT_BTREE_DEPTH_EXCEEDED", "corrupt",
                                btree_addr#B, parent_path,
                                "group B-tree depth exceeds the selected profile limit");
            return ctx;
        }

    if (!h5policy_mark_visited_btree(btree_addr))
        return ctx;

    var hdr = 8UL + (2UL * o);
    if (!h5policy_checked_addr_range(btree_addr, hdr, file_size,
                                     "group B-tree node outside file",
                                     btree_addr#B, parent_path))
        return ctx;

    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL) != H5POLICY_TREE_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, parent_path,
                                "group B-tree signature mismatch");
            return ctx;
        }

    var node_type = h5policy_msg_u64_at(ios, profile, btree_addr#B + 4#B, 1UL);
    if (node_type != 0UL)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                btree_addr#B, parent_path,
                                "expected a group (type 0) v1 B-tree node");
            return ctx;
        }

    var node_level = h5policy_msg_u64_at(ios, profile, btree_addr#B + 5#B, 1UL);
    var entries_used = h5policy_msg_u64_at(ios, profile, btree_addr#B + 6#B, 2UL);
    var pair = l + o;
    var body = h5policy_checked_mul_u64(entries_used, pair, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        btree_addr#B, parent_path,
                                        "group B-tree node size overflow");
    body = h5policy_checked_add_u64(body, l, 0xffffffffffffffffUL,
                                    "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                    btree_addr#B, parent_path,
                                    "group B-tree node size overflow");
    var total = h5policy_checked_add_u64(hdr, body, 0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                         btree_addr#B, parent_path,
                                         "group B-tree node size overflow");
    if (!h5policy_checked_addr_range(btree_addr, total, file_size,
                                     "group B-tree node body outside file",
                                     btree_addr#B, parent_path))
        return ctx;

    ctx = h5policy_account_metadata(ctx, profile, total, btree_addr#B, parent_path);

    var i = 0UL;
    while (i < entries_used)
        {
            /* pair i = key(l) then child(o); child follows the key. */
            var child_off = btree_addr + hdr + (i * pair) + l;
            var child_raw = h5policy_msg_bytes(ios, profile, child_off#B, o);
            var child_addr = bytes_to_u64_le(child_raw);

            if (!h5policy_msg_addr_is_undef(child_raw))
                {
                    if (node_level > 0UL)
                        ctx = h5policy_walk_group_btree(ios, profile, ctx,
                                                        child_addr, data_seg_addr,
                                                        parent_path, obj_depth,
                                                        btree_depth + 1UL);
                    else
                        ctx = h5policy_walk_snod(ios, profile, ctx,
                                                 child_addr, data_seg_addr,
                                                 parent_path, obj_depth);
                }
            i = i + 1UL;
        }

    return ctx;
}

fun h5policy_validate_stab_payload = (int ios,
                                      H5PolicyLimits profile,
                                      H5WalkContext ctx,
                                      offset<uint<64>,B> payload_off,
                                      uint<64> msg_size,
                                      string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL * o,
                                   "H5_CORRUPT_SYMBOL_TABLE_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "symbol-table message is too small"))
        return ctx;

    var btree_raw = h5policy_msg_bytes(ios, profile, payload_off, o);
    var heap_raw = h5policy_msg_bytes(ios, profile, payload_off + o#B, o);
    var btree_addr = bytes_to_u64_le(btree_raw);
    var heap_addr = bytes_to_u64_le(heap_raw);

    if (h5policy_msg_addr_is_undef(btree_raw) || h5policy_msg_addr_is_undef(heap_raw))
        return ctx;

    var file_size = h5policy_ceiling(ios);
    var data_seg_addr = h5policy_local_heap_data_addr(ios, profile, heap_addr,
                                                      file_size, payload_off, object);
    return h5policy_walk_group_btree(ios, profile, ctx, btree_addr, data_seg_addr,
                                     object, h5policy_current_object_depth, 0UL);
}

fun h5policy_validate_fill_payload = (int ios,
                                      H5PolicyLimits profile,
                                      offset<uint<64>,B> payload_off,
                                      uint<64> msg_size,
                                      string object,
                                      int old_fill) void:
{
    var fill_size = 0UL;

    if (old_fill)
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 4UL,
                                           "H5_CORRUPT_FILL_VALUE_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "old fill-value message is too small"))
                return;
            fill_size = h5policy_msg_u64_at(ios, profile, payload_off, 4UL);
            if (!h5policy_payload_range_ok(msg_size, 4UL, fill_size,
                                           "H5_CORRUPT_FILL_VALUE_OVERRUNS_MESSAGE",
                                           payload_off, object,
                                           "old fill value overruns the message"))
                return;
        }
    else
        {
            if (!h5policy_payload_range_ok(msg_size, 0UL, 1UL,
                                           "H5_CORRUPT_FILL_VALUE_MESSAGE_TOO_SMALL",
                                           payload_off, object,
                                           "fill-value message is too small"))
                return;

            var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
            if (version == 1UL || version == 2UL)
                {
                    if (!h5policy_payload_range_ok(msg_size, 0UL, 4UL,
                                                   "H5_CORRUPT_FILL_VALUE_MESSAGE_TOO_SMALL",
                                                   payload_off, object,
                                                   "fill-value v1/v2 message is too small"))
                        return;
                    var defined = h5policy_msg_u64_at(ios, profile,
                                                      payload_off + 3#B, 1UL);
                    if (defined != 0UL)
                        {
                            if (!h5policy_payload_range_ok(msg_size, 4UL, 4UL,
                                                           "H5_CORRUPT_FILL_VALUE_MESSAGE_TOO_SMALL",
                                                           payload_off, object,
                                                           "fill-value size field is missing"))
                                return;
                            fill_size = h5policy_msg_u64_at(ios, profile,
                                                            payload_off + 4#B,
                                                            4UL);
                            if (!h5policy_payload_range_ok(msg_size, 8UL,
                                                           fill_size,
                                                           "H5_CORRUPT_FILL_VALUE_OVERRUNS_MESSAGE",
                                                           payload_off, object,
                                                           "fill value overruns the message"))
                                return;
                        }
                }
            else if (version == 3UL)
                {
                    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                                   "H5_CORRUPT_FILL_VALUE_MESSAGE_TOO_SMALL",
                                                   payload_off, object,
                                                   "fill-value v3 message is too small"))
                        return;
                    var flags = h5policy_msg_u64_at(ios, profile,
                                                    payload_off + 1#B, 1UL);
                    if ((flags & 0x20UL) != 0UL)
                        {
                            if (!h5policy_payload_range_ok(msg_size, 2UL, 4UL,
                                                           "H5_CORRUPT_FILL_VALUE_MESSAGE_TOO_SMALL",
                                                           payload_off, object,
                                                           "fill-value size field is missing"))
                                return;
                            fill_size = h5policy_msg_u64_at(ios, profile,
                                                            payload_off + 2#B,
                                                            4UL);
                            if (!h5policy_payload_range_ok(msg_size, 6UL,
                                                           fill_size,
                                                           "H5_CORRUPT_FILL_VALUE_OVERRUNS_MESSAGE",
                                                           payload_off, object,
                                                           "fill value overruns the message"))
                                return;
                        }
                }
            else
                h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_FILL_VALUE_VERSION",
                                    "corrupt", payload_off, object,
                                    "unsupported fill-value message version");
        }

    if (profile.max_single_allocation_bytes != 0UL
        && fill_size > profile.max_single_allocation_bytes)
        h5policy_emit_error("H5_RESOURCE_SINGLE_ALLOCATION_BYTES",
                            "resource", payload_off, object,
                            "fill value exceeds the selected profile limit");
}

fun h5policy_validate_attribute_payload = (int ios,
                                           H5PolicyLimits profile,
                                           H5WalkContext ctx,
                                           offset<uint<64>,B> payload_off,
                                           uint<64> msg_size,
                                           string object) H5WalkContext:
{
    if (!h5policy_payload_range_ok(msg_size, 0UL, 8UL,
                                   "H5_CORRUPT_ATTRIBUTE_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "attribute message is too small"))
        return ctx;

    var version = h5policy_msg_u64_at(ios, profile, payload_off, 1UL);
    var flags = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var name_size = h5policy_msg_u64_at(ios, profile, payload_off + 2#B, 2UL);
    var dtype_size = h5policy_msg_u64_at(ios, profile, payload_off + 4#B, 2UL);
    var dspace_size = h5policy_msg_u64_at(ios, profile, payload_off + 6#B, 2UL);
    var cur = 8UL;

    if (version == 3UL)
        cur = cur + 1UL;
    else if (version == 0UL || version > 3UL)
        h5policy_emit_error("H5_CORRUPT_UNSUPPORTED_ATTRIBUTE_VERSION",
                            "corrupt", payload_off, object,
                            "unsupported attribute message version");

    ctx.attribute_count =
        h5policy_checked_add_u64(ctx.attribute_count, 1UL,
                                 profile.max_attribute_count,
                                 "H5_RESOURCE_ATTRIBUTE_COUNT",
                                 "resource",
                                 payload_off, object,
                                 "attribute count exceeds the selected profile limit");

    if (name_size == 0UL)
        h5policy_emit_error("H5_CORRUPT_ATTRIBUTE_NAME_EMPTY",
                            "corrupt", payload_off, object,
                            "attribute name is empty");

    var stored_name_size = version == 1UL ? align8(name_size) : name_size;
    var stored_dtype_size = version == 1UL ? align8(dtype_size) : dtype_size;
    var stored_dspace_size = version == 1UL ? align8(dspace_size) : dspace_size;
    var total = h5policy_checked_add_u64(cur, stored_name_size,
                                         0xffffffffffffffffUL,
                                         "H5_CORRUPT_LENGTH_OVERFLOW",
                                         "corrupt", payload_off, object,
                                         "attribute name size overflow");
    total = h5policy_checked_add_u64(total, stored_dtype_size,
                                     0xffffffffffffffffUL,
                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                     "corrupt", payload_off, object,
                                     "attribute datatype size overflow");
    total = h5policy_checked_add_u64(total, stored_dspace_size,
                                     0xffffffffffffffffUL,
                                     "H5_CORRUPT_LENGTH_OVERFLOW",
                                     "corrupt", payload_off, object,
                                     "attribute dataspace size overflow");

    if (!h5policy_payload_range_ok(msg_size, 0UL, total,
                                   "H5_CORRUPT_ATTRIBUTE_OVERRUNS_MESSAGE",
                                   payload_off, object,
                                   "attribute header/name/type/space overruns the message"))
        return ctx;

    var dtype_off = payload_off + (cur + stored_name_size)#B;
    var dspace_off = dtype_off + stored_dtype_size#B;
    var attr_ctx = h5policy_new_walk_context;

    if (version >= 2UL && (flags & 1UL) != 0UL)
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                            "unsupported", dtype_off, object,
                            "shared attribute datatype validation is not covered yet");
    else
        attr_ctx = h5policy_validate_dtype_payload(ios, profile, attr_ctx,
                                                   dtype_off, dtype_size,
                                                   object);

    if (version >= 2UL && (flags & 2UL) != 0UL)
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                            "unsupported", dspace_off, object,
                            "shared attribute dataspace validation is not covered yet");
    else
        attr_ctx = h5policy_validate_dataspace_payload(ios, profile, attr_ctx,
                                                       dspace_off, dspace_size,
                                                       object);

    var attr_data_size = msg_size - total;
    if (profile.max_single_allocation_bytes != 0UL
        && attr_data_size > profile.max_single_allocation_bytes)
        h5policy_emit_error("H5_RESOURCE_SINGLE_ALLOCATION_BYTES",
                            "resource", payload_off, object,
                            "attribute payload exceeds the selected profile limit");

    return ctx;
}

fun h5policy_validate_fsinfo_payload = (int ios,
                                        H5PolicyLimits profile,
                                        offset<uint<64>,B> payload_off,
                                        uint<64> msg_size,
                                        string object) void:
{
    var min_size = 3UL + (2UL * (global_sizeof_lengths as uint<64>))
                   + 2UL + (global_sizeof_offsets as uint<64>)
                   + (12UL * (global_sizeof_offsets as uint<64>));
    if (!h5policy_payload_range_ok(msg_size, 0UL, min_size,
                                   "H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "file-space info message is too small"))
        return;

    var page_size = h5policy_msg_u64_at(ios, profile,
                                        payload_off
                                        + (3UL + (global_sizeof_lengths as uint<64>))#B,
                                        global_sizeof_lengths as uint<64>);
    if (page_size == 0UL)
        h5policy_emit_error("H5_CORRUPT_FREE_SPACE_PAGE_SIZE",
                            "corrupt", payload_off, object,
                            "free-space page size is zero");

    h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                        "unsupported", payload_off, object,
                        "free-space manager semantic validation is a Phase 2 stub");
}

fun h5policy_validate_mdci_payload = (int ios,
                                      H5PolicyLimits profile,
                                      offset<uint<64>,B> payload_off,
                                      uint<64> msg_size,
                                      string object) void:
{
    var min_size = 1UL + (global_sizeof_offsets as uint<64>)
                   + (global_sizeof_lengths as uint<64>);
    if (!h5policy_payload_range_ok(msg_size, 0UL, min_size,
                                   "H5_CORRUPT_CACHE_IMAGE_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "metadata cache image message is too small"))
        return;

    var addr_raw = h5policy_msg_bytes(ios, profile,
                                      payload_off + 1#B,
                                      global_sizeof_offsets as uint<64>);
    var image_addr = bytes_to_u64_le(addr_raw);
    var image_size = h5policy_msg_u64_at(ios, profile,
                                         payload_off
                                         + (1UL + (global_sizeof_offsets as uint<64>))#B,
                                         global_sizeof_lengths as uint<64>);

    if (!h5policy_msg_addr_is_undef(addr_raw))
        {
            var ok = h5policy_checked_addr_range(image_addr, image_size,
                                                 h5policy_ceiling(ios),
                                                 "metadata cache image outside file",
                                                 payload_off,
                                                 object);
        }

    h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                        "unsupported", payload_off, object,
                        "metadata cache image contents are not decoded by Phase 2");
}

/* One v2 B-tree leaf of dense-attribute (type-8) records: resolve each
   fractal-heap object and validate it as an attribute message.  Type-8 records
   place the heap id at record offset 0.  */
/* Process nrec dense-attribute (type-8) records starting at rec_base; used for
   both leaf and internal nodes (internal-node records are real records too).  */
fun h5policy_dense_attr_records = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                   uint<64> rec_base, uint<64> nrec, uint<64> record_size,
                                   uint<64> fheap_root, uint<64> curr_root_rows,
                                   uint<64> start_size, uint<64> max_direct_size,
                                   uint<64> table_width, uint<64> off_size,
                                   uint<64> len_size, uint<64> file_size,
                                   string object) H5WalkContext:
{
    var i = 0UL;
    while (i < nrec)
        {
            var id_off = rec_base + (i * record_size);   /* type-8: heap id at rec+0 */
            var id_flags = h5policy_msg_u64_at(ios, profile, id_off#B, 1UL);
            if (((id_flags .>> 4) & 3UL) == 0UL)
                {
                    var heap_obj_off = h5policy_msg_u64_at(ios, profile,
                                                           id_off#B + 1#B, off_size);
                    var heap_obj_len = h5policy_msg_u64_at(ios, profile,
                                                           id_off#B + (1UL + off_size)#B,
                                                           len_size);
                    if (heap_obj_len != 0UL)
                        {
                            var obj_off = h5policy_frhp_locate(ios, profile,
                                                               fheap_root, curr_root_rows,
                                                               start_size, max_direct_size,
                                                               table_width, off_size,
                                                               heap_obj_off, file_size);
                            if (obj_off != 0xffffffffffffffffUL
                                && obj_off < file_size
                                && heap_obj_len <= file_size - obj_off)
                                ctx = h5policy_validate_attribute_payload(ios, profile, ctx,
                                                                          obj_off#B, heap_obj_len,
                                                                          object);
                        }
                }
            i = i + 1UL;
        }
    return ctx;
}

fun h5policy_dense_leaf_attrs = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                 uint<64> leaf_addr, uint<64> nrec, uint<64> record_size,
                                 uint<64> fheap_root, uint<64> curr_root_rows,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> table_width, uint<64> off_size,
                                 uint<64> len_size, uint<64> file_size,
                                 string object) H5WalkContext:
{
    var leaf_need = 6UL + (nrec * record_size);
    if (!h5policy_checked_addr_range(leaf_addr, leaf_need, file_size,
                                     "dense attribute v2 B-tree leaf outside file",
                                     leaf_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, leaf_addr#B, 4UL) != H5POLICY_BTLF_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt",
                                leaf_addr#B, object,
                                "dense attribute v2 B-tree leaf signature mismatch");
            return ctx;
        }

    ctx = h5policy_dense_attr_records(ios, profile, ctx, leaf_addr + 6UL, nrec, record_size,
                                      fheap_root, curr_root_rows, start_size, max_direct_size,
                                      table_width, off_size, len_size, file_size, object);

    return ctx;
}

/* Recursively descend a dense-attribute name v2 B-tree node (see the dense-link
   node walker for the pointer layout).  Threads ctx so attributes are counted
   and validated.  */
fun h5policy_dense_attrs_node = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                 uint<64> node_addr, uint<64> node_depth, uint<64> nrec,
                                 uint<64> node_size, uint<64> record_size,
                                 uint<64> fheap_root, uint<64> curr_root_rows,
                                 uint<64> start_size, uint<64> max_direct_size,
                                 uint<64> table_width, uint<64> off_size,
                                 uint<64> len_size, uint<64> file_size,
                                 string object) H5WalkContext:
{
    if (node_depth == 0UL)
        return h5policy_dense_leaf_attrs(ios, profile, ctx, node_addr, nrec, record_size,
                                         fheap_root, curr_root_rows, start_size,
                                         max_direct_size, table_width, off_size,
                                         len_size, file_size, object);

    if (node_depth > profile.max_btree_depth)
        {
            h5policy_emit_error("H5_CORRUPT_BTREE_DEPTH_EXCEEDED", "corrupt",
                                node_addr#B, object,
                                "dense attribute v2 B-tree depth exceeds the selected profile limit");
            return ctx;
        }

    var o = global_sizeof_offsets as uint<64>;
    var nrec_bytes = h5policy_bt2_nrec_bytes(node_size, record_size);
    var sub_bytes = node_depth > 1UL
                    ? h5policy_bt2_subtree_bytes(node_size, record_size, node_depth - 1UL)
                    : 0UL;
    var ptr_size = o + nrec_bytes + sub_bytes;
    var recs = h5policy_checked_mul_u64(nrec, record_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        node_addr#B, object,
                                        "dense attribute v2 B-tree node size overflow");
    var ptrs = h5policy_checked_mul_u64(nrec + 1UL, ptr_size, 0xffffffffffffffffUL,
                                        "H5_CORRUPT_LENGTH_OVERFLOW", "corrupt",
                                        node_addr#B, object,
                                        "dense attribute v2 B-tree node size overflow");
    if (!h5policy_checked_addr_range(node_addr, 6UL + recs + ptrs, file_size,
                                     "dense attribute v2 B-tree internal node outside file",
                                     node_addr#B, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, node_addr#B, 4UL) != H5POLICY_BTIN_SIG)
        {
            h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE", "corrupt", node_addr#B, object,
                                "dense attribute v2 B-tree internal node signature mismatch");
            return ctx;
        }

    /* The internal node's own records are real attribute records too. */
    ctx = h5policy_dense_attr_records(ios, profile, ctx, node_addr + 6UL, nrec, record_size,
                                      fheap_root, curr_root_rows, start_size, max_direct_size,
                                      table_width, off_size, len_size, file_size, object);

    var ptr_base = node_addr + 6UL + recs;
    var j = 0UL;
    while (j < nrec + 1UL)
        {
            var ptr_off = ptr_base + (j * ptr_size);
            var child_raw = h5policy_msg_bytes(ios, profile, ptr_off#B, o);
            var child_addr = bytes_to_u64_le(child_raw);
            var child_nrec = h5policy_msg_u64_at(ios, profile, ptr_off#B + o#B, nrec_bytes);
            if (!h5policy_msg_addr_is_undef(child_raw))
                ctx = h5policy_dense_attrs_node(ios, profile, ctx, child_addr, node_depth - 1UL,
                                                child_nrec, node_size, record_size, fheap_root,
                                                curr_root_rows, start_size, max_direct_size,
                                                table_width, off_size, len_size, file_size, object);
            j = j + 1UL;
        }
    return ctx;
}

/* Dense attributes: fractal heap + name-indexed v2 B-tree (type-8 records) of
   any depth.  Sets h5policy_dense_handled.  */
fun h5policy_walk_dense_attrs = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                 uint<64> fheap_addr, uint<64> btree_addr,
                                 off64 loc, string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    var el = global_sizeof_lengths as uint<64>;
    var file_size = h5policy_ceiling(ios);
    h5policy_dense_handled = 0;

    var frhp_min = 14UL + (2UL * o) + (10UL * el) + 8UL + (2UL * el) + o + 2UL;
    if (!h5policy_checked_addr_range(fheap_addr, frhp_min, file_size,
                                     "fractal heap header outside file", loc, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, fheap_addr#B, 4UL) != H5POLICY_FRHP_SIG)
        return ctx;
    if (h5policy_msg_u64_at(ios, profile, fheap_addr#B + 7#B, 2UL) != 0UL)
        return ctx;                     /* filtered heap: not supported here */

    var max_man_size = h5policy_msg_u64_at(ios, profile, fheap_addr#B + 10#B, 4UL);
    var dtable = 14UL + (10UL * el) + (2UL * o);
    var table_width = h5policy_msg_u64_at(ios, profile, fheap_addr#B + dtable#B, 2UL);
    var start_size = h5policy_msg_u64_at(ios, profile, fheap_addr#B + (dtable + 2UL)#B, el);
    var max_direct_size = h5policy_msg_u64_at(ios, profile,
                                              fheap_addr#B + (dtable + 2UL + el)#B, el);
    var max_heap_bits = h5policy_msg_u64_at(ios, profile,
                                            fheap_addr#B + (dtable + 2UL + (2UL * el))#B, 2UL);
    var root_raw = h5policy_msg_bytes(ios, profile,
                                      fheap_addr#B + (dtable + 6UL + (2UL * el))#B, o);
    var root_addr = bytes_to_u64_le(root_raw);
    var curr_root_rows = h5policy_msg_u64_at(ios, profile,
                                             fheap_addr#B + (dtable + 6UL + (2UL * el) + o)#B, 2UL);

    var off_size = h5policy_bytes_for_bits(max_heap_bits);
    var len_size = h5policy_bytes_for_limit(max_man_size);
    if (len_size > off_size)
        len_size = off_size;
    if (h5policy_msg_addr_is_undef(root_raw) || start_size == 0UL || table_width == 0UL)
        return ctx;

    var bt_hdr = 22UL + o + el;
    if (!h5policy_checked_addr_range(btree_addr, bt_hdr, file_size,
                                     "dense attribute v2 B-tree header outside file", loc, object))
        return ctx;
    if (h5policy_msg_bytes(ios, profile, btree_addr#B, 4UL) != H5POLICY_BTHD_SIG)
        return ctx;

    var record_type = h5policy_msg_u64_at(ios, profile, btree_addr#B + 5#B, 1UL);
    var node_size = h5policy_msg_u64_at(ios, profile, btree_addr#B + 6#B, 4UL);
    var record_size = h5policy_msg_u64_at(ios, profile, btree_addr#B + 10#B, 2UL);
    var depth = h5policy_msg_u64_at(ios, profile, btree_addr#B + 12#B, 2UL);
    var bt_root_raw = h5policy_msg_bytes(ios, profile, btree_addr#B + 16#B, o);
    var bt_root = bytes_to_u64_le(bt_root_raw);
    var num_root = h5policy_msg_u64_at(ios, profile, btree_addr#B + (16UL + o)#B, 2UL);

    if (record_type != 8UL || h5policy_msg_addr_is_undef(bt_root_raw))
        return ctx;

    ctx = h5policy_dense_attrs_node(ios, profile, ctx, bt_root, depth, num_root, node_size,
                                    record_size, root_addr, curr_root_rows, start_size,
                                    max_direct_size, table_width, off_size, len_size,
                                    file_size, object);
    h5policy_dense_handled = 1;
    return ctx;
}

fun h5policy_validate_ainfo_payload = (int ios, H5PolicyLimits profile, H5WalkContext ctx,
                                       offset<uint<64>,B> payload_off,
                                       uint<64> msg_size, string object) H5WalkContext:
{
    var o = global_sizeof_offsets as uint<64>;
    if (!h5policy_payload_range_ok(msg_size, 0UL, 2UL,
                                   "H5_CORRUPT_ATTRIBUTE_INFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "attribute-info message is too small"))
        return ctx;

    var flags = h5policy_msg_u64_at(ios, profile, payload_off + 1#B, 1UL);
    var cur = 2UL;
    if ((flags & 1UL) != 0UL)
        cur = cur + 2UL;                /* max creation index */

    if (!h5policy_payload_range_ok(msg_size, 0UL, cur + (2UL * o),
                                   "H5_CORRUPT_ATTRIBUTE_INFO_MESSAGE_TOO_SMALL",
                                   payload_off, object,
                                   "attribute-info addresses overrun the message"))
        return ctx;

    var fheap_raw = h5policy_msg_bytes(ios, profile, payload_off + cur#B, o);
    var fheap_addr = bytes_to_u64_le(fheap_raw);
    var btree_raw = h5policy_msg_bytes(ios, profile, payload_off + (cur + o)#B, o);
    var btree_addr = bytes_to_u64_le(btree_raw);

    if (h5policy_msg_addr_is_undef(fheap_raw) || h5policy_msg_addr_is_undef(btree_raw))
        return ctx;

    ctx = h5policy_walk_dense_attrs(ios, profile, ctx, fheap_addr, btree_addr,
                                    payload_off, object);
    if (!h5policy_dense_handled)
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP", "unsupported",
                            payload_off, object,
                            "dense attribute storage uses an unsupported fractal-heap/B-tree layout");
    return ctx;
}

fun h5policy_validate_message_payload = (int ios,
                                         H5PolicyLimits profile,
                                         H5WalkContext ctx,
                                         uint<64> m_type,
                                         offset<uint<64>,B> payload_off,
                                         uint<64> msg_size,
                                         string object) H5WalkContext:
{
    if (m_type == 0x01UL)
        return h5policy_validate_dataspace_payload(ios, profile, ctx,
                                                   payload_off, msg_size,
                                                   object);
    if (m_type == 0x02UL)
        h5policy_validate_linfo_payload(ios, profile, payload_off,
                                        msg_size, object);
    if (m_type == 0x03UL)
        return h5policy_validate_dtype_payload(ios, profile, ctx,
                                               payload_off, msg_size,
                                               object);
    if (m_type == 0x04UL)
        h5policy_validate_fill_payload(ios, profile, payload_off,
                                       msg_size, object, 1);
    else if (m_type == 0x05UL)
        h5policy_validate_fill_payload(ios, profile, payload_off,
                                       msg_size, object, 0);
    else if (m_type == 0x06UL)
        h5policy_validate_link_payload(ios, profile, payload_off,
                                       msg_size, object);
    else if (m_type == 0x08UL)
        return h5policy_validate_layout_payload(ios, profile, ctx,
                                                payload_off, msg_size,
                                                object);
    else if (m_type == 0x0bUL)
        h5policy_validate_filter_pipeline_payload(ios, profile,
                                                  payload_off, msg_size,
                                                  object);
    else if (m_type == 0x0cUL)
        return h5policy_validate_attribute_payload(ios, profile, ctx,
                                                   payload_off, msg_size,
                                                   object);
    else if (m_type == 0x0fUL)
        h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                            "unsupported", payload_off, object,
                            "shared object-header message table traversal is not covered yet");
    else if (m_type == 0x15UL)
        return h5policy_validate_ainfo_payload(ios, profile, ctx, payload_off,
                                               msg_size, object);
    else if (m_type == 0x17UL)
        h5policy_validate_fsinfo_payload(ios, profile, payload_off,
                                         msg_size, object);
    else if (m_type == 0x18UL)
        h5policy_validate_mdci_payload(ios, profile, payload_off,
                                       msg_size, object);
    else if (m_type == 0x11UL)
        return h5policy_validate_stab_payload(ios, profile, ctx, payload_off,
                                              msg_size, object);

    return ctx;
}

fun h5policy_known_message_id = (uint<64> m_type) int:
{
    if (m_type <= 0x09UL) return 1;
    if (m_type >= 0x0aUL && m_type <= 0x18UL) return 1;
    return 0;
}

fun h5policy_message_name = (uint<64> m_type) string:
{
    if (m_type == 0x00UL) return "nil";
    if (m_type == 0x01UL) return "dataspace";
    if (m_type == 0x02UL) return "link_info";
    if (m_type == 0x03UL) return "datatype";
    if (m_type == 0x04UL) return "old_fill_value";
    if (m_type == 0x05UL) return "fill_value";
    if (m_type == 0x06UL) return "link";
    if (m_type == 0x07UL) return "external_file_list";
    if (m_type == 0x08UL) return "layout";
    if (m_type == 0x09UL) return "bogus";
    if (m_type == 0x0aUL) return "group_info";
    if (m_type == 0x0bUL) return "filter_pipeline";
    if (m_type == 0x0cUL) return "attribute";
    if (m_type == 0x0dUL) return "object_name";
    if (m_type == 0x0eUL) return "old_mtime";
    if (m_type == 0x0fUL) return "shared_message_table";
    if (m_type == 0x10UL) return "object_header_continuation";
    if (m_type == 0x11UL) return "symbol_table";
    if (m_type == 0x12UL) return "mtime";
    if (m_type == 0x13UL) return "btree_k";
    if (m_type == 0x14UL) return "driver_info";
    if (m_type == 0x15UL) return "attribute_info";
    if (m_type == 0x16UL) return "reference_count";
    if (m_type == 0x17UL) return "file_space_info";
    if (m_type == 0x18UL) return "metadata_cache_image";
    return "unknown";
}

fun h5policy_validate_message_policy = (uint<64> m_type,
                                        H5PolicyLimits profile,
                                        off64 loc,
                                        string object) void:
{
    if (m_type == 0x07UL && profile.allow_external_storage == 0UB)
        {
            h5policy_note_external_storage;
            h5policy_emit_error("H5_POLICY_EXTERNAL_STORAGE", "policy",
                                loc, object,
                                "external file list message encountered; profile denies external storage");
        }
    else if (m_type == 0x07UL)
        h5policy_note_external_storage;

    if (m_type == 0x09UL && profile.allow_legacy_dangerous_messages == 0UB)
        h5policy_emit_error("H5_POLICY_LEGACY_DANGEROUS_MESSAGE", "policy",
                            loc, object,
                            "bogus-valid object header message encountered");

    if (!h5policy_known_message_id(m_type))
        {
            h5policy_note_unknown_message;
            if (profile.allow_unknown_messages == 0UB)
                h5policy_emit_error("H5_POLICY_UNKNOWN_MESSAGE", "policy",
                                    loc, object,
                                    "unknown object-header message encountered");
            else
                h5policy_emit_error("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP",
                                    "unsupported", loc, object,
                                    "unknown object-header message is not classified by this validator");
        }
}

fun h5policy_validate_msg_chunk = (int ios,
                                   H5PolicyLimits profile,
                                   H5WalkContext ctx,
                                   uint<8> version,
                                   int prefix_bytes,
                                   offset<uint<64>,B> chunk_off,
                                   uint<64> chunk_size,
                                   string object) H5WalkContext:
{
    var i = 0UL;
    var msg_count = 0UL;
    var file_size = h5policy_ceiling(ios);

    global_version = version;

    while (i < chunk_size)
        {
            /* Fewer than a message prefix remain: this is the chunk's trailing
               gap, not a message.  HDF5 object-header chunks may leave up to
               (prefix_bytes - 1) unused bytes at the end -- anything that large
               would instead hold a NIL message -- so stop parsing cleanly.  */
            if ((chunk_size - i) < (prefix_bytes as uint<64>))
                break;

            var prefix = h5policy_map_msg_prefix(ios, profile, chunk_off + i#B);
            var m_type = 0UL;
            var m_size = 0UL;
            var m_flags = 0UB;

            if (version == 1UB)
                {
                    m_type = prefix.v1_msg_prefix.msg_type as uint<64>;
                    m_size = prefix.v1_msg_prefix.msg_size as uint<64>;
                    m_flags = prefix.v1_msg_prefix.msg_flags;
                }
            else
                {
                    m_type = prefix.v2_msg_prefix.msg_type as uint<64>;
                    m_size = prefix.v2_msg_prefix.msg_size as uint<64>;
                    m_flags = prefix.v2_msg_prefix.msg_flags;
                }

            var payload_off = chunk_off + i#B + (prefix_bytes as uint<64>)#B;
            var remaining = chunk_size - i - (prefix_bytes as uint<64>);

            if (m_size > remaining)
                {
                    h5policy_emit_error("H5_CORRUPT_MESSAGE_OVERRUNS_CHUNK",
                                        "corrupt",
                                        payload_off, object,
                                        "object-header message payload overruns chunk");
                    return ctx;
                }

            h5policy_validate_message_policy(m_type, profile,
                                             chunk_off + i#B, object);

            ctx = h5policy_validate_message_payload(ios, profile, ctx,
                                                    m_type, payload_off,
                                                    m_size, object);

            if (m_type == 0x10UL)
                {
                    var cont = h5policy_map_cont(ios, profile, payload_off);
                    var cont_addr = bytes_to_u64_le(cont.addr_raw);
                    var cont_size = bytes_to_u64_le(cont.size_raw);

                    ctx.object_header_chunk_count =
                        h5policy_checked_add_u64(ctx.object_header_chunk_count,
                                                 1UL,
                                                 profile.max_object_header_chunks,
                                                 "H5_RESOURCE_OBJECT_HEADER_CHUNKS",
                                                 "resource",
                                                 payload_off, object,
                                                 "object-header continuation chunk budget exceeded");

                    if (cont_size == 0UL)
                        h5policy_emit_error("H5_CORRUPT_ZERO_CONTINUATION_CHUNK",
                                            "corrupt",
                                            payload_off, object,
                                            "object-header continuation chunk has zero size");
                    else
                        {
                            var ok = h5policy_checked_addr_range(cont_addr,
                                                                 cont_size,
                                                                 file_size,
                                                                 "object-header continuation chunk outside file",
                                                                 payload_off,
                                                                 object);
                            if (ok && cont_addr == (chunk_off/#B))
                                h5policy_emit_error("H5_CORRUPT_SELF_REFERENTIAL_CONTINUATION",
                                                    "corrupt",
                                                    payload_off, object,
                                                    "object-header continuation chunk points to its own chunk");
                            else if (ok)
                                {
                                    if (!h5policy_mark_visited_cont(cont_addr))
                                        h5policy_emit_error("H5_CORRUPT_NON_PROGRESS_LOOP",
                                                            "corrupt",
                                                            payload_off, object,
                                                            "object-header continuation chunk was already visited");
                                    else
                                        {
                                            ctx = h5policy_account_metadata(ctx, profile,
                                                                            cont_size,
                                                                            cont_addr#B,
                                                                            object);
                                            var cont_msg_off = cont_addr#B;
                                            var cont_msg_size = cont_size;

                                            if (version == 2UB)
                                                {
                                                    /* A v2 continuation chunk is an OCHK signature (4B),
                                                       the message data, then a Jenkins checksum (4B) --
                                                       so it needs at least 8 bytes, and the message region
                                                       excludes both.  */
                                                    if (cont_size < 8UL)
                                                        h5policy_emit_error("H5_CORRUPT_MESSAGE_OVERRUNS_CHUNK",
                                                                            "corrupt",
                                                                            cont_addr#B,
                                                                            object,
                                                                            "v2 continuation chunk is too small for its signature and checksum");
                                                    else
                                                        {
                                                            var sig = h5policy_msg_bytes(ios, profile,
                                                                                         cont_addr#B,
                                                                                         4UL);
                                                            if (sig != CONT_SIG)
                                                                h5policy_emit_error("H5_CORRUPT_BAD_SIGNATURE",
                                                                                    "corrupt",
                                                                                    cont_addr#B,
                                                                                    object,
                                                                                    "v2 continuation chunk signature mismatch");

                                                            var cont_chksum_bytes =
                                                                h5policy_msg_bytes(ios, profile,
                                                                                   cont_addr#B,
                                                                                   cont_size - 4UL);
                                                            var cont_stored_chksum =
                                                                lookup3_u32_le(h5policy_msg_bytes(ios, profile,
                                                                                                  cont_addr#B + (cont_size - 4UL)#B,
                                                                                                  4UL));
                                                            if (lookup3_hashlittle(cont_chksum_bytes, 0)
                                                                != cont_stored_chksum)
                                                                h5policy_emit_error("H5_CORRUPT_BAD_CHECKSUM",
                                                                                    "corrupt",
                                                                                    cont_addr#B,
                                                                                    object,
                                                                                    "v2 continuation chunk checksum mismatch");

                                                            cont_msg_off = cont_addr#B + 4#B;
                                                            cont_msg_size = cont_size - 8UL;
                                                        }
                                                }

                                            if (cont_msg_size > 0UL)
                                                ctx = h5policy_validate_msg_chunk(ios, profile, ctx,
                                                                                  version,
                                                                                  prefix_bytes,
                                                                                  cont_msg_off,
                                                                                  cont_msg_size,
                                                                                  object);
                                        }
                                }
                        }
                }

            i = i + (prefix_bytes as uint<64>) + m_size;
            msg_count = msg_count + 1UL;
        }

    return ctx;
}

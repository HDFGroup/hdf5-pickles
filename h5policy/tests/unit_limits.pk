/* ---- Run-mode defaults ----------------------------------------------- */

reset_limit_case;
LIMIT_PROFILE = H5_FORENSIC;
h5policy_apply_run_mode(LIMIT_PROFILE);
expect_limit("forensic_mode_defaults_non_strict_and_continue",
             h5policy_nonstrict == 1 && h5policy_continue == 1);

reset_limit_case;
LIMIT_PROFILE = H5_FORENSIC;
h5policy_mapping_arg = "strict";
h5policy_apply_run_mode(LIMIT_PROFILE);
expect_limit("forensic_mapping_override_preserves_continue",
             h5policy_nonstrict == 0 && h5policy_continue == 1);

reset_limit_case;
h5policy_mapping_arg = "non_strict";
h5policy_continue_arg = "yes";
h5policy_apply_run_mode(LIMIT_PROFILE);
expect_limit("strict_profile_run_mode_overrides",
             h5policy_nonstrict == 1 && h5policy_continue == 1);

if (limit_failures != 0)
    {
        printf("UNIT LIMITS: %i32d failure(s)\n", limit_failures);
        exit(1);
    }
printf("UNIT LIMITS: all passed\n");

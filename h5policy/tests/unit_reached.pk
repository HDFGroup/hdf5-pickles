 * GNU General Public License for more details.
 *
 * You should have received a copy of the GNU General Public License
 * along with this program.  If not, see <http://www.gnu.org/licenses/>.
 */

load h5_policy;

var reached_failures = 0;

fun expect_reached = (string name, int cond) void:
{
    if (cond)
        printf("PASS %s\n", name);
    else
        {
            printf("FAIL %s\n", name);
            reached_failures = reached_failures + 1;
        }
}

/* -- recording and lookup -- */

h5policy_reset_traversal_state;
h5policy_mark_reached(0x1000UL, "FAHD");
h5policy_mark_reached(0x2000UL, "HEAP");

expect_reached("mark_records_the_address",
               h5policy_was_reached(0x1000UL));
expect_reached("mark_records_the_kind",
               h5policy_reached_kind_at(0x1000UL) == "FAHD");
expect_reached("mark_keeps_kinds_with_their_addresses",
               h5policy_reached_kind_at(0x2000UL) == "HEAP");
expect_reached("unrecorded_address_reads_as_not_reached",
               !h5policy_was_reached(0x3000UL));
expect_reached("unrecorded_address_has_no_kind",
               h5policy_reached_kind_at(0x3000UL) == "");

/* Address 0 is a legitimate address here (the superblock lives there); the
   record must not treat it as a sentinel the way findings do.  */
h5policy_mark_reached(0UL, "SUPER");
expect_reached("address_zero_is_recordable",
               h5policy_was_reached(0UL)
               && h5policy_reached_kind_at(0UL) == "SUPER");

/* -- walk-budget neutrality: the property the design rests on -- */

h5policy_reset_traversal_state;
var ops_before = h5policy_walk_ops;
for (var i = 0UL; i < 500UL; i = i + 1UL)
    h5policy_mark_reached(i, "OHDR");
expect_reached("marking_does_not_consume_the_walk_budget",
               h5policy_walk_ops == ops_before);

/* The contrast that makes the point: a deduplicated set does charge, which is
   exactly why the record is append-only.  */
h5policy_reset_traversal_state;
var probe = uint<64>[]();
for (var i = 0UL; i < 50UL; i = i + 1UL)
    probe += [i];
var ops_pre_scan = h5policy_walk_ops;
var seen = h5policy_seen_u64(probe, 49UL);
expect_reached("deduplicated_membership_does_charge_the_budget",
               h5policy_walk_ops > ops_pre_scan);

/* Report-time lookup runs after the walk and must not charge either. */
h5policy_reset_traversal_state;
h5policy_mark_reached(0x4000UL, "BTHD");
var ops_pre_lookup = h5policy_walk_ops;
var kind = h5policy_reached_kind_at(0x4000UL);
expect_reached("lookup_does_not_consume_the_walk_budget",
               h5policy_walk_ops == ops_pre_lookup);

/* -- duplicates -- */

h5policy_reset_traversal_state;
h5policy_mark_reached(0x5000UL, "TREE");
h5policy_mark_reached(0x5000UL, "TREE");
expect_reached("duplicate_reads_are_recorded_not_merged",
               h5policy_reached_addrs'length == 2);
expect_reached("duplicates_still_resolve_to_the_kind",
               h5policy_reached_kind_at(0x5000UL) == "TREE");

/* -- cap -- */

h5policy_reset_traversal_state;
var saved_cap = H5POLICY_MAX_REACHED;
H5POLICY_MAX_REACHED = 3UL;
for (var i = 0UL; i < 10UL; i = i + 1UL)
    h5policy_mark_reached(0x9000UL + i, "OHDR");
expect_reached("record_stops_at_the_cap",
               h5policy_reached_addrs'length == 3);
expect_reached("cap_sets_the_truncation_flag",
               h5policy_reached_truncated == 1);
expect_reached("kinds_stay_in_step_with_addresses_at_the_cap",
               h5policy_reached_kinds'length == h5policy_reached_addrs'length);
/* Past the cap "not reached" is unsupportable: the reader needs the flag to
   tell that apart from a genuine absence.  */
expect_reached("address_past_the_cap_is_not_recorded",
               !h5policy_was_reached(0x9000UL + 9UL));
H5POLICY_MAX_REACHED = saved_cap;

/* -- reset -- */

h5policy_reset_traversal_state;
h5policy_mark_reached(0x6000UL, "SNOD");
h5policy_reset_traversal_state;
expect_reached("reset_clears_the_record",
               h5policy_reached_addrs'length == 0
               && h5policy_reached_kinds'length == 0);
expect_reached("reset_clears_the_truncation_flag",
               h5policy_reached_truncated == 0);
expect_reached("reset_makes_a_previous_address_read_as_not_reached",
               !h5policy_was_reached(0x6000UL));

if (reached_failures != 0)
    {
        printf("UNIT REACHED: %i32d failure(s)\n", reached_failures);
        exit(1);
    }
printf("UNIT REACHED: all passed\n");

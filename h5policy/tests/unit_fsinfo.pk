load h5_policy;

var fsinfo_failures = 0;

fun expect_fsinfo = (string name, int cond) void:
{
    if (cond)
        printf("PASS %s\n", name);
    else
        {
            printf("FAIL %s\n", name);
            fsinfo_failures = fsinfo_failures + 1;
        }
}

fun fsinfo_has_code = (string code) int:
{
    var i = 0UL;
    while (i < h5policy_finding_codes'length)
        {
            if (h5policy_finding_codes[i] == code)
                return 1;
            i = i + 1UL;
        }
    return 0;
}

fun run_fsinfo_blob = (byte[] blob) void:
{
    var ios = open("*unit-fsinfo*");
    byte[blob'length] @ ios : 0#B = blob;
    h5policy_reset_findings;
    var ctx = h5policy_new_walk_context;
    ctx = h5policy_validate_fsinfo_payload(ios, H5_UNTRUSTED_STRICT, ctx,
                                           0#B, blob'length, "/u");
    close(ios);
}

set_global_sizeof_offsets(4UB);
set_global_sizeof_lengths(4UB);

/* The message envelope is validated in place; the free-space managers it names
   are walked separately (exercised end-to-end by the corpus fsm_persist
   fixtures).  An envelope with no persisted, defined managers is therefore a
   clean, finding-free accept -- not a coverage gap. */
var FSINFO_V0 = [0UB, 2UB, 16UB, 0UB, 0UB, 0UB];
run_fsinfo_blob(FSINFO_V0);
expect_fsinfo("v0_without_addresses_is_structurally_valid",
              h5policy_finding_codes'length == 0);

/* Undefined address slots are libhdf5's representation of unused free-space
   managers and are skipped without a walk. */
var FSINFO_V0_PERSIST =
    [0UB, 1UB, 16UB, 0UB, 0UB, 0UB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB];
run_fsinfo_blob(FSINFO_V0_PERSIST);
expect_fsinfo("v0_all_persist_skips_undefined_addresses",
              h5policy_finding_codes'length == 0
              && !fsinfo_has_code("H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL"));

var FSINFO_V1 =
    [1UB, 1UB, 0UB,
     16UB, 0UB, 0UB, 0UB,
     0UB, 16UB, 0UB, 0UB,
     32UB, 0UB,
     52UB, 18UB, 0UB, 0UB];
run_fsinfo_blob(FSINFO_V1);
expect_fsinfo("v1_nonpersistent_omits_addresses",
              h5policy_finding_codes'length == 0);

var FSINFO_V1_PERSIST =
    [1UB, 0UB, 1UB,
     16UB, 0UB, 0UB, 0UB,
     0UB, 16UB, 0UB, 0UB,
     32UB, 0UB,
     52UB, 18UB, 0UB, 0UB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB,
     0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB, 0xffUB];
run_fsinfo_blob(FSINFO_V1_PERSIST);
expect_fsinfo("v1_persistent_skips_undefined_addresses",
              h5policy_finding_codes'length == 0
              && !fsinfo_has_code("H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL"));

/* Each persistence form must still require its conditional address vector. */
var FSINFO_V0_TRUNCATED = [0UB, 1UB, 16UB, 0UB, 0UB, 0UB];
run_fsinfo_blob(FSINFO_V0_TRUNCATED);
expect_fsinfo("v0_all_persist_requires_six_addresses",
              fsinfo_has_code("H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL")
              && !fsinfo_has_code("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP"));

var FSINFO_V1_TRUNCATED =
    [1UB, 1UB, 1UB,
     16UB, 0UB, 0UB, 0UB,
     0UB, 16UB, 0UB, 0UB,
     32UB, 0UB,
     52UB, 18UB, 0UB, 0UB];
run_fsinfo_blob(FSINFO_V1_TRUNCATED);
expect_fsinfo("v1_persistent_requires_twelve_addresses",
              fsinfo_has_code("H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL")
              && !fsinfo_has_code("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP"));

/* Version 0 has no page-size field; version 1 retains the scalar check. */
var FSINFO_V1_ZERO_PAGE =
    [1UB, 1UB, 0UB,
     16UB, 0UB, 0UB, 0UB,
     0UB, 0UB, 0UB, 0UB,
     32UB, 0UB,
     52UB, 18UB, 0UB, 0UB];
run_fsinfo_blob(FSINFO_V1_ZERO_PAGE);
expect_fsinfo("v1_zero_page_size_is_corrupt",
              fsinfo_has_code("H5_CORRUPT_FREE_SPACE_PAGE_SIZE")
              && !fsinfo_has_code("H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL"));

run_fsinfo_blob([2UB]);
expect_fsinfo("unsupported_version_is_reported_before_layout_decode",
              fsinfo_has_code("H5_CORRUPT_UNSUPPORTED_FSINFO_VERSION")
              && !fsinfo_has_code("H5_CORRUPT_FSINFO_MESSAGE_TOO_SMALL")
              && !fsinfo_has_code("H5_UNSUPPORTED_PICKLE_COVERAGE_GAP"));

if (fsinfo_failures != 0)
    {
        printf("UNIT FSINFO: %i32d failure(s)\n", fsinfo_failures);
        exit(1);
    }
printf("UNIT FSINFO: all passed\n");

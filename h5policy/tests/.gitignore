# Generated corpus fixtures (produced by tools/h5policy-gencorpus via run.sh).
# The tracked specification is expected/*.yml; the binaries are build output.
valid/*.h5
malformed/*.h5
policy/*.h5
resource/*.h5
coverage/*.h5
integration/*.h5
# cve/ holds committed, crafted CVE seeds (built by cve/make_*.py) -- not
# generated, so they are tracked rather than ignored.
# fuzz-findings/ is ephemeral h5policy-fuzz output (mutants + sidecars),
# regenerated by a soak.  Promote anything worth keeping into a curated fixture
# (a gencorpus generator or a cve/make_*.py seed) instead of committing it.
fuzz-findings/
crash-findings/

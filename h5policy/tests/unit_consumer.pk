/* unit_consumer.pk - Contract checks for h5policy's in-process result API.  */

/* Copyright (C) 2026 The HDF Group.  */

load h5_policy;

var consumer_failures = 0;

fun expect_consumer = (string name, int cond) void:
{
    if (cond)
        printf("PASS %s\n", name);
    else
        {
            printf("FAIL %s\n", name);
            consumer_failures = consumer_failures + 1;
        }
}

h5policy_reset_findings;
h5policy_reset_reached;

expect_consumer("empty_result_has_no_findings",
                h5policy_result_finding_count == 0UL);
expect_consumer("empty_result_is_complete",
                h5policy_result_findings_complete);
expect_consumer("finding_limit_is_exposed",
                h5policy_result_finding_limit == H5POLICY_MAX_FINDINGS);
expect_consumer("empty_result_accepts",
                h5policy_result_decision == "accept"
                && h5policy_result_exit_code == H5POLICY_EXIT_ACCEPT);

h5policy_emit_warning("H5_TEST_WARNING", 0x123UL#B, "/object",
                      "consumer API test");
expect_consumer("finding_count_is_exposed",
                h5policy_result_finding_count == 1UL);
expect_consumer("finding_fields_are_exposed",
                h5policy_result_finding_severity(0UL) == "warning"
                && h5policy_result_finding_code(0UL) == "H5_TEST_WARNING"
                && h5policy_result_finding_class(0UL) == "warning"
                && h5policy_result_finding_has_location(0UL)
                && h5policy_result_finding_offset(0UL) == 0x123UL
                && h5policy_result_finding_object(0UL) == "/object"
                && h5policy_result_finding_message(0UL) == "consumer API test");
expect_consumer("finding_code_query_hits",
                h5policy_result_has_finding_code("H5_TEST_WARNING"));
expect_consumer("finding_code_query_misses",
                !h5policy_result_has_finding_code("H5_TEST_MISSING"));
expect_consumer("warning_decision_is_exposed",
                h5policy_result_decision == "accept_with_warnings"
                && h5policy_result_exit_code == H5POLICY_EXIT_WARN);

h5policy_emit_unlocated_error("H5_TEST_UNLOCATED", "internal", "metadata",
                              "no byte address");
expect_consumer("unlocated_finding_is_distinct_from_offset_zero",
                !h5policy_result_finding_has_location(1UL)
                && h5policy_result_finding_offset(1UL) == 0UL);

h5policy_reset_walk_status;
expect_consumer("walk_status_starts_explicitly_idle",
                !h5policy_result_walk_started
                && !h5policy_result_walk_completed
                && h5policy_result_walk_stop_reason == "not_started");
h5policy_walk_started = 1;
h5policy_walk_completed = 1;
h5policy_walk_stop_reason = "";
expect_consumer("walk_status_is_exposed",
                h5policy_result_walk_started
                && h5policy_result_walk_completed
                && h5policy_result_walk_stop_reason == "");

h5policy_mark_reached(0x456UL, "OHDR");
expect_consumer("reachability_query_is_exposed",
                h5policy_result_was_reached(0x456UL)
                && h5policy_result_reached_kind_at(0x456UL) == "OHDR");
expect_consumer("missing_reachability_is_exposed",
                !h5policy_result_was_reached(0x457UL)
                && h5policy_result_reached_kind_at(0x457UL) == "");
expect_consumer("complete_reachability_is_exposed",
                h5policy_result_reachability_complete);
h5policy_reached_truncated = 1;
expect_consumer("truncated_reachability_is_exposed",
                !h5policy_result_reachability_complete);

h5policy_run_options.continue_after_corruption = 0UB;
expect_consumer("stop_run_option_is_exposed",
                !h5policy_result_continue_after_corruption);
h5policy_run_options.continue_after_corruption = 1UB;
expect_consumer("continue_run_option_is_exposed",
                h5policy_result_continue_after_corruption);

h5policy_reset_findings;
h5policy_reset_reached;
h5policy_reset_walk_status;
expect_consumer("reset_is_visible_through_the_API",
                h5policy_result_finding_count == 0UL
                && h5policy_result_decision == "accept"
                && h5policy_result_reachability_complete
                && !h5policy_result_walk_started
                && !h5policy_result_walk_completed);

if (consumer_failures != 0)
    {
        printf("UNIT CONSUMER: %i32d failure(s)\n", consumer_failures);
        exit(1);
    }
printf("UNIT CONSUMER: all passed\n");
